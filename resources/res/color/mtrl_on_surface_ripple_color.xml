<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        state_pressed="true"
        color="?attr/colorOnSurface"
        alpha="@dimen/mtrl_low_ripple_pressed_alpha"/>
    <item
        state_focused="true"
        color="?attr/colorOnSurface"
        alpha="@dimen/mtrl_low_ripple_focused_alpha"/>
    <item
        color="?attr/colorOnSurface"
        alpha="@dimen/mtrl_low_ripple_hovered_alpha"
        state_hovered="true"/>
    <item
        color="?attr/colorOnSurface"
        alpha="@dimen/mtrl_low_ripple_default_alpha"/>
</selector>
