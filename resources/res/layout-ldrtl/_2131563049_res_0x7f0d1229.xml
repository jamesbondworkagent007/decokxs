<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x11"
    orientation="0"
    id="@+id/timepicker"
    layout_width="-1"
    android:layout_height="match_parent"
    minHeight="150dp">
    <com.contrarywind.view.WheelView
        id="@+id/day"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1.1"/>
    <com.contrarywind.view.WheelView
        id="@+id/month"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1.1"/>
    <com.contrarywind.view.WheelView
        id="@+id/year"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1"/>
    <com.contrarywind.view.WheelView
        id="@+id/hour"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1.1"/>
    <com.contrarywind.view.WheelView
        id="@+id/min"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1.1"/>
    <com.contrarywind.view.WheelView
        id="@+id/second"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1.1"/>
</LinearLayout>
