<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape shape="2">
            <stroke
                width="1dp"
                color="@android:color/black"/>
        </shape>
    </item>
    <item>
        <rotate
            android:fromDegrees="90"
            android:toDegrees="-90"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape shape="2">
                <stroke
                    width="1dp"
                    color="@android:color/black"/>
            </shape>
        </rotate>
    </item>
    <item>
        <shape shape="0">
            <stroke
                width="1dp"
                color="#808080"
                dashWidth="3dp"
                dashGap="1dp"/>
        </shape>
    </item>
</layer-list>
