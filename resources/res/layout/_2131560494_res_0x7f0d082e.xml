<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/container"
    paddingLeft="15dp"
    paddingTop="12dp"
    paddingRight="15dp"
    paddingBottom="12dp"
    layout_width="-2"
    android:layout_height="wrap_content"
    paddingHorizontal="15dp"
    paddingVertical="12dp">
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"/>
    <ImageView
        id="@+id/arrow"
        background="@drawable/_2131232355_res_0x7f080663"
        layout_width="20dp"
        android:layout_height="20dp"
        layout_marginTop="1dp"
        layout_marginStart="4dp"
        backgroundTint="@color/ContentContrast"
        NOT_FOUND_0x10="@+id/title"
        NOT_FOUND_0x11="@+id/title"
        NOT_FOUND_0x13="@+id/title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
