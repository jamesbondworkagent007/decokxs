<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/app_widget_item_linear_layout"
    layout_width="-1"
    android:layout_height="@dimen/height_56dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            orientation="0"
            layout_width="130dp"
            android:layout_height="wrap_content">
            <ImageView
                id="@+id/app_widget_icon_one"
                layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp24"/>
            <LinearLayout
                layout_gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/margin_8dp">
                <TextView
                    textSize="@dimen/sp_14"
                    textStyle="0x1"
                    textColor="@color/okTradeG900"
                    ellipsize="3"
                    id="@+id/app_widget_title_one"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxWidth="@dimen/width_60dp"
                    singleLine="true"
                    includeFontPadding="false"
                    style="@style/TextAppearance.Title.14SP.Semibold"/>
                <TextView
                    textSize="@dimen/text_size_10sp"
                    textColor="@color/okTradeG400"
                    ellipsize="3"
                    id="@+id/app_widget_subtitle_one"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    singleLine="true"
                    includeFontPadding="false"
                    layout_alignParentEnd="true"
                    style="@style/TextAppearance.Text.10SP"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            id="@+id/app_widget_kline_one"
            layout_width="@dimen/height_72dp"
            android:layout_height="@dimen/dp_24"
            scaleType="fillCenter"/>
        <LinearLayout
            gravity="0x800005"
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textStyle="0x1"
                textColor="@color/okTradeG900"
                ellipsize="3"
                id="@+id/app_widget_price_one"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                style="@style/TextAppearance.Title.12SP.Semibold"/>
            <TextView
                id="@+id/app_widget_percent_one"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Title.12SP"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
