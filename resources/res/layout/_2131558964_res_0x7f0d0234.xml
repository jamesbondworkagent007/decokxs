<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentPrimary"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_fdcabot_orderdetails_btn_end_cycle"
        style="@style/Label_1_Bold"/>
    <TextView
        textColor="@color/ContentSecondary"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_fdcabot_orderdetails_btn_end_cycle_desc"
        style="@style/Body_3_Regular"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp">
        <TextView
            textColor="@color/ContentSecondary"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_general_historical_pnl"
            layout_weight="1"
            style="@style/Label_2_Regular"/>
        <TextView
            gravity="0x800005"
            id="@+id/floatingPnlTv"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            style="@style/Label_2_Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <TextView
            textColor="@color/ContentSecondary"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_placeorder_dialog_estimated_fee"
            layout_weight="1"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/estFeeTv"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            style="@style/Label_2_Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
