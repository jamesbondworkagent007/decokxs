<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingTop="12dp"
    paddingRight="24dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp"
    paddingVertical="12dp">
    <ImageView
        id="@+id/ivLogo"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tvName"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="12dp"
        NOT_FOUND_0xf="@+id/tvUrl"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/ivLogo"
        NOT_FOUND_0x14="@+id/ivLogo"
        NOT_FOUND_0x15="2"
        style="@style/Label_1_Medium"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvUrl"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="1"
        layout_marginStart="12dp"
        NOT_FOUND_0xe="@+id/ivLogo"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/ivLogo"
        NOT_FOUND_0x13="@+id/tvName"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
