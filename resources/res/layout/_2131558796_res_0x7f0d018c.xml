<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131231155_res_0x7f0801b3"
    paddingLeft="12dp"
    paddingTop="14dp"
    paddingRight="12dp"
    paddingBottom="14dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginBottom="12dp"
    paddingHorizontal="12dp"
    paddingVertical="14dp"
    NOT_FOUND_0x12="0x1">
    <LinearLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_smartarb_botdetails_dialog_title_total_interest_deducted"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/totalInterestAmt"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="16dp"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
    <LinearLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_smartarb_botdetails_dialog_title_avg_annual_rate_since"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/avgInterestRateApy"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="16dp"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
    <LinearLayout
        id="@+id/interestDebtContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_borrowing_data_label_interest_bear_liability"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/interestDebt"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="16dp"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
    <LinearLayout
        id="@+id/nonInterestDebtContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_borrowing_data_label_interest_free_liability"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/nonInterestDebt"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="16dp"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
    <LinearLayout
        id="@+id/nextInterestContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/nextChargingTime"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/interestAmt"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="16dp"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
</LinearLayout>
