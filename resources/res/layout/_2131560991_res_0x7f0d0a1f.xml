<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_12dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/ivLogo"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x24="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/ivChainLogo"
        visibility="2"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginBottom="-1dp"
        layout_marginEnd="-1dp"
        translationZ="1dp"
        NOT_FOUND_0x1a="@+id/ivLogo"
        NOT_FOUND_0x1c="@+id/ivLogo"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        id="@+id/tvTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_12dp"
        layout_marginRight="@dimen/margin_12dp"
        layout_marginHorizontal="@dimen/margin_12dp"
        NOT_FOUND_0x1b="@+id/tvBody1"
        NOT_FOUND_0x1d="@+id/ivClose"
        NOT_FOUND_0x21="@+id/ivLogo"
        NOT_FOUND_0x24="@+id/ivLogo"
        NOT_FOUND_0x25="2"
        style="@style/Label_1_Medium"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvBody1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x19="true"
        NOT_FOUND_0x1a="@+id/ivLogo"
        NOT_FOUND_0x1d="@+id/bodyDivider"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="2"
        NOT_FOUND_0x21="@+id/ivLogo"
        NOT_FOUND_0x23="@+id/tvTitle"
        NOT_FOUND_0x26="@dimen/margin_12dp"
        NOT_FOUND_0x27="0dp"
        style="@style/Label_3_Regular"/>
    <View
        id="@+id/bodyDivider"
        background="@color/BorderSecondary"
        layout_width="@dimen/margin_1dp"
        android:layout_height="@dimen/margin_10dp"
        layout_marginStart="@dimen/margin_4dp"
        layout_marginEnd="@dimen/margin_4dp"
        NOT_FOUND_0x1a="@+id/tvBody1"
        NOT_FOUND_0x1d="@+id/tvBody2"
        NOT_FOUND_0x1f="2"
        NOT_FOUND_0x21="@+id/tvBody1"
        NOT_FOUND_0x24="@+id/tvBody1"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvBody2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x19="true"
        NOT_FOUND_0x1a="@+id/tvBody1"
        NOT_FOUND_0x1d="@+id/ivClose"
        NOT_FOUND_0x20="1"
        NOT_FOUND_0x21="@+id/bodyDivider"
        NOT_FOUND_0x27="0dp"
        style="@style/Label_3_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x11"
        id="@+id/ivClose"
        layout_width="20dp"
        android:layout_height="20dp"
        src="@drawable/_2131231675_res_0x7f0803bb"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x24="0"
        NOT_FOUND_0x28="@color/ContentContrast"/>
    <androidx.constraintlayout.widget.Group
        id="@+id/tvBody2Group"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x18="bodyDivider, tvBody2"/>
</androidx.constraintlayout.widget.ConstraintLayout>
