<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    layout_width="-2"
    android:layout_height="wrap_content">
    <ImageView
        layout_gravity="0x10"
        id="@+id/iv_icon"
        layout_width="25dp"
        android:layout_height="wrap_content"
        src="@drawable/_2131232434_res_0x7f0806b2"
        layout_marginStart="9dp"
        NOT_FOUND_0xf="@color/white_w900"/>
    <LinearLayout
        gravity="0x10"
        orientation="1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="6dp"
        layout_marginEnd="20dp">
        <TextView
            textSize="17sp"
            textColor="#ffffff"
            id="@+id/tv_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginBottom="6.5dp"
            hint="title"/>
        <View
            id="@+id/line"
            background="#33ffffff"
            layout_width="-1"
            android:layout_height="1dp"/>
    </LinearLayout>
</LinearLayout>
