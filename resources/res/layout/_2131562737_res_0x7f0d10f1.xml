<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/header_container"
    tag="layout/view_buy_sell_order_detail_header_0"
    paddingTop="@dimen/margin_24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="@dimen/padding_20dp"
    paddingEnd="@dimen/padding_20dp">
    <TextView
        textColor="@color/okTradeG900"
        gravity="0x10"
        id="@+id/order_status_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        drawablePadding="8dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        style="@style/TextAppearance.Title.24SP.Semibold"/>
    <TextView
        textColor="@color/grey_g500"
        id="@+id/order_status_sub_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        NOT_FOUND_0xf="@+id/order_status_title"
        style="@style/TextAppearance.Title.14SP.Medium"/>
    <TextView
        textColor="@color/orange_lv1"
        id="@+id/tv_swap_remind_new"
        background="@drawable/_2131231291_res_0x7f08023b"
        paddingTop="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        visibility="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        paddingStart="@dimen/padding_12dp"
        paddingEnd="@dimen/padding_12dp"
        NOT_FOUND_0xf="@+id/order_status_sub_title"
        style="@style/TextAppearance.Text.14SP"/>
    <View
        id="@+id/divider"
        layout_marginTop="@dimen/margin_24dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/tv_swap_remind_new"
        NOT_FOUND_0x11="@dimen/margin_24dp"
        style="@style/C2C_Divider"/>
</androidx.constraintlayout.widget.ConstraintLayout>
