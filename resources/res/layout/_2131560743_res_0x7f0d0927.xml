<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    id="@+id/ll_one_to_many"
    tag="layout/item_multi_send_board_0"
    background="@drawable/_2131233901_res_0x7f080c6d"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    translationZ="20dp"
    elevation="50dp"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_16dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/nav_icon"
        padding="@dimen/padding_4dp"
        layout_width="@dimen/width_48dp"
        android:layout_height="@dimen/height_48dp"/>
    <TextView
        textAppearance="@style/Title_1_Bold"
        textColor="@color/ContentPrimary_Dark"
        layout_gravity="0x10"
        id="@+id/nav_content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"
        layout_marginStart="@dimen/margin_12dp"/>
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x10"
        id="@+id/nav_arrow"
        visibility="1"
        layout_width="40dp"
        android:layout_height="40dp"
        layout_marginStart="@dimen/margin_12dp"/>
</LinearLayout>
