<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/sui_staking_main_layout"
    background="@drawable/_2131233182_res_0x7f08099e"
    paddingTop="@dimen/margin_24dp"
    paddingBottom="@dimen/margin_24dp"
    focusable="true"
    clickable="true"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/xsm"
    layout_marginRight="@dimen/xsm"
    layout_marginBottom="@dimen/margin_16dp"
    layout_marginHorizontal="@dimen/xsm">
    <TextView
        textAppearance="@style/TextAppearance.Silka"
        textSize="@dimen/text_size_16sp"
        textColor="@color/LiteGray400"
        id="@+id/tv_assets"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_investdetails_bot_pop_redeem_assets"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Silka.MeDium"
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_staked_amount_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Silka.MeDium"
        textSize="@dimen/text_size_14sp"
        textColor="@color/LiteGray400"
        id="@+id/tv_us_dollar_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        text="$24.91"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="@+id/tv_staked_amount_value"
        NOT_FOUND_0x1b="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Silka"
        textSize="@dimen/text_size_16sp"
        textColor="@color/LiteGray400"
        id="@+id/tv_validator"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_14dp"
        text="@string/pr_investdetails_bot_pop_redeem_validator"
        NOT_FOUND_0x18="@+id/tv_assets"
        NOT_FOUND_0x19="@+id/tv_us_dollar_value"
        NOT_FOUND_0x1b="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Silka.MeDium"
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_validator_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_14dp"
        NOT_FOUND_0x17="@+id/tv_staked_amount_value"
        NOT_FOUND_0x19="@+id/tv_us_dollar_value"
        NOT_FOUND_0x1b="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Silka"
        textSize="@dimen/text_size_16sp"
        textColor="@color/LiteGray400"
        id="@+id/tv_status"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_14dp"
        text="@string/pr_investredeem_card_item_status"
        NOT_FOUND_0x18="@+id/tv_validator"
        NOT_FOUND_0x19="@+id/tv_validator_name"
        NOT_FOUND_0x1b="2"/>
    <o.C55251xgS
        id="@+id/tv_status_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="@+id/tv_status"
        NOT_FOUND_0x17="@+id/tv_staked_amount_value"
        NOT_FOUND_0x1a="@+id/tv_status"
        NOT_FOUND_0x1b="2"
        NOT_FOUND_0x1c="-3"
        NOT_FOUND_0x1d="3"/>
    <TextView
        textAppearance="@style/TextAppearance.Silka"
        textSize="@dimen/text_size_12sp"
        textColor="@color/orange_o800"
        gravity="0x800003"
        id="@+id/tv_earning_reward_message"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text=""
        NOT_FOUND_0x15="true"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tv_staked_amount_value"
        NOT_FOUND_0x18="@+id/tv_status"
        NOT_FOUND_0x19="@+id/tv_status"
        NOT_FOUND_0x1b="2"/>
</androidx.constraintlayout.widget.ConstraintLayout>
