<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_dapp_interaction_network_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="16sp"
        textColor="@color/grey_g400"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_metax_wallet_home_details_list_network"
        layout_marginEnd="16dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="@+id/guideline"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="1"/>
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideline"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x10="0.5"/>
    <ImageView
        id="@+id/iv_network"
        layout_width="20dp"
        android:layout_height="20dp"
        layout_marginStart="32dp"
        NOT_FOUND_0xd="@+id/tv_title"
        NOT_FOUND_0xf="@+id/tv_network"
        NOT_FOUND_0x11="1"
        NOT_FOUND_0x12="2"
        NOT_FOUND_0x13="@+id/tv_title"
        NOT_FOUND_0x15="@+id/tv_title"/>
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="16sp"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/tv_network"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="8dp"
        NOT_FOUND_0xd="@+id/tv_title"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x13="@+id/iv_network"
        NOT_FOUND_0x15="@+id/tv_title"
        NOT_FOUND_0x16="1"/>
</androidx.constraintlayout.widget.ConstraintLayout>
