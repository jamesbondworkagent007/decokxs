<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    paddingLeft="@dimen/margin_default"
    paddingRight="@dimen/margin_default"
    layout_width="-1"
    android:layout_height="72dp"
    paddingHorizontal="@dimen/margin_default">
    <ImageView
        id="@+id/iv_selected"
        layout_width="22dp"
        android:layout_height="22dp"
        src="@drawable/_2131234264_res_0x7f080dd8"/>
    <ImageView
        id="@+id/iv_token_icon"
        background="@drawable/_2131231885_res_0x7f08048d"
        layout_width="@dimen/md"
        android:layout_height="@dimen/md"
        scaleType="6"
        layout_marginStart="@dimen/dp_8"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_token_symbol"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        layout_marginBottom="@dimen/xxxsm"
        layout_weight="1"
        layout_marginStart="@dimen/ok_dp_12"
        layout_marginVertical="@dimen/xxxsm"
        style="@style/Label_1_Medium"/>
    <o.wYC
        id="@+id/iv_pin"
        layout_width="@dimen/sm"
        android:layout_height="@dimen/sm"
        src="@drawable/_2131230920_res_0x7f0800c8"
        NOT_FOUND_0x10="@color/ContentPrimary"/>
    <o.wYC
        id="@+id/iv_drag"
        layout_width="@dimen/sm"
        android:layout_height="@dimen/sm"
        src="@drawable/_2131232291_res_0x7f080623"
        layout_marginStart="@dimen/xsm"
        NOT_FOUND_0x10="@color/ContentPrimary"/>
</LinearLayout>
