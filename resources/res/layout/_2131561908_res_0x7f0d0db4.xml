<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingLeft="@dimen/dp_24"
    paddingRight="@dimen/dp_24"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/dp_24">
    <LinearLayout
        orientation="1"
        id="@+id/content"
        paddingTop="@dimen/padding_20dp"
        paddingBottom="@dimen/padding_20dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/padding_20dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            minHeight="@dimen/height_48dp">
            <TextView
                textColor="@color/okTradeG900"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_trade_modal_input_repeat_alert"
                includeFontPadding="false"
                style="@style/TextAppearance.Title.16SP.Semibold"/>
            <TextView
                textColor="@color/okTradeG400"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_modal_text_every_time"
                includeFontPadding="false"
                style="@style/LiteTextAppearance.TextBlack.14SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_24"
            minHeight="@dimen/height_48dp">
            <TextView
                textColor="@color/okTradeG900"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_trade_modal_input_alert_once"
                includeFontPadding="false"
                style="@style/TextAppearance.Title.16SP.Semibold"/>
            <TextView
                textColor="@color/okTradeG400"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_modal_text_first_time"
                includeFontPadding="false"
                style="@style/LiteTextAppearance.TextBlack.14SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
