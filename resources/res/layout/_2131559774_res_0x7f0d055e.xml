<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/fragment_approve_coin_amt_0"
    paddingLeft="16dp"
    paddingRight="16dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="16dp">
    <TextView
        textAppearance="@style/TextAppearance.Title.15SP.Medium"
        textColor="@color/title_color"
        gravity="0x10"
        id="@+id/unLimited"
        background="@drawable/_2131233855_res_0x7f080c3f"
        paddingLeft="16dp"
        paddingTop="22dp"
        paddingRight="16dp"
        paddingBottom="22dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_metax_customcoin_textbtn_unlimited"
        layout_alignParentTop="true"
        paddingHorizontal="16dp"
        paddingVertical="22dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/customAmtLayout"
        background="@drawable/_2131233855_res_0x7f080c3f"
        paddingLeft="16dp"
        paddingTop="22dp"
        paddingRight="16dp"
        paddingBottom="22dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_below="@+id/unLimited"
        paddingHorizontal="16dp"
        paddingVertical="22dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.15SP.Medium"
            textColor="@color/title_color"
            id="@+id/customTv"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_metax_subtitle_gas_fee_customize"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x20="0"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/customAmtArrow"
            layout_width="12dp"
            android:layout_height="wrap_content"
            src="@drawable/_2131232479_res_0x7f0806df"
            rotation="90"
            NOT_FOUND_0x1c="@+id/customTv"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x20="@+id/customTv"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Title.12SP.Medium"
            textColor="@color/title_color"
            id="@+id/customAmtTitle"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="24dp"
            text="@string/pr_metax_text_pstmacitwospend"
            NOT_FOUND_0x1f="@+id/customTv"/>
        <o.C57230yeW
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            textColor="@color/grey_g900"
            gravity="0x10"
            id="@+id/customAmtValue"
            background="@drawable/_2131231508_res_0x7f080314"
            paddingTop="@dimen/padding_8dp"
            paddingBottom="@dimen/padding_8dp"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            textAlignment="5"
            paddingStart="12dp"
            paddingVertical="@dimen/padding_8dp"
            NOT_FOUND_0x1f="@+id/customAmtTitle"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance"
            textSize="12sp"
            textColor="@color/grey_g400"
            id="@+id/customAmtTip"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            NOT_FOUND_0x1f="@+id/customAmtValue"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <o.C52794wYp
        enabled="false"
        textAppearance="@style/TextAppearance.Text.Medium"
        gravity="0x11"
        id="@+id/saveBtm"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="20dp"
        minHeight="48dp"
        text="@string/pr_metax_btn_gas_fee_save"
        layout_alignParentBottom="true"
        NOT_FOUND_0x21="52"
        NOT_FOUND_0x22="0x101"/>
</RelativeLayout>
