<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/ok_dialog_0"
    background="@drawable/_2131233581_res_0x7f080b2d"
    paddingTop="@dimen/pattern_lock_dot_selected_size"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textAppearance="@style/OKDialog_Title"
        ellipsize="3"
        id="@+id/title"
        tag="binding_1"
        paddingBottom="@dimen/dp_8"
        layout_width="-1"
        android:layout_height="wrap_content"
        singleLine="true"
        layout_marginStart="@dimen/pattern_lock_dot_selected_size"
        layout_marginEnd="@dimen/pattern_lock_dot_selected_size"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"/>
    <TextView
        textAppearance="@style/OKDialog_Content"
        id="@+id/content"
        tag="binding_2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/pattern_lock_dot_selected_size"
        layout_marginEnd="@dimen/pattern_lock_dot_selected_size"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/title"/>
    <CheckBox
        textAppearance="@style/OKDialog_Check_Box_Text"
        id="@+id/checkbox"
        tag="binding_3"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/pattern_lock_dot_selected_size"
        layout_marginEnd="@dimen/pattern_lock_dot_selected_size"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/content"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/top_barrier"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0xf="3"
        NOT_FOUND_0x10="content, checkbox"/>
    <View
        id="@+id/horizontal_divider"
        background="@color/okTradeG100"
        layout_width="-1"
        android:layout_height="@dimen/ok_dp_0.5"
        layout_marginTop="@dimen/pattern_lock_dot_selected_size"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/top_barrier"/>
    <TextView
        textAppearance="@style/OKDialog_Negative"
        gravity="0x11"
        id="@+id/negative_button"
        tag="binding_4"
        padding="@dimen/ok_dp_12"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x13="@+id/vertical_divider"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/horizontal_divider"/>
    <View
        id="@+id/vertical_divider"
        tag="binding_5"
        background="@color/okTradeG100"
        layout_width="@dimen/ok_dp_0.5"
        android:layout_height="0dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="@+id/positive_button"
        NOT_FOUND_0x15="@+id/negative_button"
        NOT_FOUND_0x17="@+id/horizontal_divider"/>
    <TextView
        textAppearance="@style/OKDialog_Positive"
        gravity="0x11"
        id="@+id/positive_button"
        tag="binding_6"
        padding="@dimen/ok_dp_12"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="@+id/vertical_divider"
        NOT_FOUND_0x17="@+id/horizontal_divider"/>
</androidx.constraintlayout.widget.ConstraintLayout>
