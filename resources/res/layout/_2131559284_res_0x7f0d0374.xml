<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/avatar"
        layout_width="36dp"
        android:layout_height="36dp"
        layout_marginTop="@dimen/padding_16.6dp"
        layout_marginBottom="@dimen/padding_16.6dp"
        layout_marginVertical="@dimen/padding_16.6dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_address_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_16.6dp"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x13="true"
        NOT_FOUND_0x16="@+id/ic_platform"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="2"
        NOT_FOUND_0x19="@+id/avatar"
        NOT_FOUND_0x1c="0"
        style="@style/Label_1_Medium"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/ic_platform"
        background="@drawable/_2131231842_res_0x7f080462"
        padding="@dimen/dp_2"
        visibility="2"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginLeft="@dimen/margin_4dp"
        layout_marginRight="@dimen/margin_4dp"
        src="@drawable/_2131234480_res_0x7f080eb0"
        layout_marginHorizontal="@dimen/margin_4dp"
        NOT_FOUND_0x14="@+id/tv_address_name"
        NOT_FOUND_0x16="@+id/tv_balance_change"
        NOT_FOUND_0x19="@+id/tv_address_name"
        NOT_FOUND_0x1c="@+id/tv_address_name"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginBottom="@dimen/padding_16.6dp"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x19="@+id/avatar"
        NOT_FOUND_0x1b="@+id/tv_address_name"
        style="@style/Label_2_Regular"/>
    <o.C55064xcr
        layout_gravity="0x10"
        id="@+id/dot_view"
        background="@color/BorderSecondary"
        layout_width="3dp"
        android:layout_height="3dp"
        layout_marginStart="4dp"
        NOT_FOUND_0x14="@+id/tv_time"
        NOT_FOUND_0x19="@+id/tv_time"
        NOT_FOUND_0x1c="@+id/tv_time"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/chain_logo"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x14="@+id/tv_time"
        NOT_FOUND_0x19="@+id/dot_view"
        NOT_FOUND_0x1c="@+id/tv_time"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_token_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x14="@+id/tv_time"
        NOT_FOUND_0x19="@+id/chain_logo"
        NOT_FOUND_0x1c="@+id/tv_time"
        style="@style/Label_2_Regular"/>
    <TextView
        id="@+id/tv_balance_change"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_16.6dp"
        NOT_FOUND_0x16="@+id/ic_alert"
        NOT_FOUND_0x1c="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_percentage"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        layout_marginBottom="@dimen/padding_16.6dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/ic_alert"
        NOT_FOUND_0x1b="@+id/tv_balance_change"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/ic_alert"
        layout_width="32dp"
        android:layout_height="0dp"
        paddingStart="@dimen/margin_12dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="@drawable/_2131234096_res_0x7f080d30"
        NOT_FOUND_0x1e="@color/ContentPrimary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
