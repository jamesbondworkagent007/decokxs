<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/fragment_similar_address_tip_0"
    background="@color/BasePrimaryAlternative"
    clickable="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"
        overScrollMode="2">
        <LinearLayout
            orientation="1"
            paddingLeft="24dp"
            paddingRight="24dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="62dp"
            paddingHorizontal="24dp">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x1"
                id="@+id/risk_icon"
                layout_width="@dimen/height_100dp"
                android:layout_height="@dimen/height_100dp"
                layout_marginBottom="@dimen/margin_40dp"/>
            <TextView
                textAppearance="@style/Headline_5_Bold"
                textColor="@color/ContentPrimary"
                gravity="0x1"
                layout_gravity="0x1"
                id="@+id/risk_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginBottom="@dimen/margin_8dp"
                text="@string/pr_wallet_approve_alert_title_similar_adress_transfer"/>
            <View
                id="@+id/view_line"
                background="@color/BorderPrimary"
                layout_width="-1"
                android:layout_height="0.5dp"
                layout_marginTop="24dp"
                layout_marginBottom="22dp"/>
            <androidx.recyclerview.widget.RecyclerView
                orientation="1"
                id="@+id/similar_group"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0x14="androidx.recyclerview.widget.LinearLayoutManager"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <o.C57468yiw
        id="@+id/button_group"
        layout_width="-1"
        android:layout_height="wrap_content"/>
</LinearLayout>
