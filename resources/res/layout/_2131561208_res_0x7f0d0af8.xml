<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_defi_approve_risky_banner_0"
    paddingLeft="@dimen/padding_8dp"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/padding_8dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_8dp"
    paddingVertical="@dimen/padding_12dp">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Headline_5_Bold"
        textColor="@color/SemanticNotice"
        id="@+id/risky_approval_count"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_2_Bold"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/risky_approval_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="2"
        layout_marginStart="@dimen/margin_4dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x16="true"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="@+id/revoke_button"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="@+id/risky_approval_count"
        NOT_FOUND_0x1d="0"/>
    <TextView
        textAppearance="@style/Label_3_Medium"
        textColor="@color/ContentInverse"
        gravity="0x11"
        id="@+id/revoke_button"
        background="@drawable/_2131231343_res_0x7f08026f"
        paddingLeft="12dp"
        paddingTop="4dp"
        paddingRight="12dp"
        paddingBottom="4dp"
        focusable="true"
        clickable="true"
        layout_width="-2"
        android:layout_height="28dp"
        maxWidth="92dp"
        text="@string/pr_wallet_approve_btn_revoke"
        paddingHorizontal="12dp"
        paddingVertical="4dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1d="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
