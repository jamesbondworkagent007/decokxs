<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/rl_trade_notices_container"
    background="@color/okTradeOrange50"
    visibility="2"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/orange_lv1"
        ellipsize="3"
        id="@+id/tv_trade_notice_content"
        focusable="true"
        focusableInTouchMode="true"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_marginBottom="8dp"
        text=""
        maxLines="3"
        scrollHorizontally="true"
        marqueeRepeatLimit="-1"
        layout_marginStart="@dimen/margin_default"
        layout_marginEnd="43dp"/>
    <ImageView
        id="@+id/iv_trade_notice_close"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="14dp"
        src="@drawable/_2131233586_res_0x7f080b32"
        layout_marginEnd="@dimen/margin_default"
        layout_alignParentEnd="true"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Medium"
        textColor="@color/orange_lv1"
        id="@+id/tv_trade_notice_detail"
        paddingBottom="8dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_p2ptrade_btn_check_details"
        layout_below="@+id/tv_trade_notice_content"
        layout_alignStart="@+id/tv_trade_notice_content"/>
    <ImageView
        id="@+id/iv_trade_notice_rightIcon"
        paddingBottom="6dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131234483_res_0x7f080eb3"
        layout_alignTop="@+id/tv_trade_notice_detail"
        layout_alignBottom="@+id/tv_trade_notice_detail"
        layout_toEndOf="@+id/tv_trade_notice_detail"/>
</RelativeLayout>
