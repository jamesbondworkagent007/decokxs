<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="12dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="12dp">
    <ImageView
        id="@+id/iv_token_image"
        layout_width="36dp"
        android:layout_height="36dp"
        layout_marginBottom="@dimen/xxxxxsm"
        NOT_FOUND_0x12="@+id/tv_last_tx_value"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="@+id/tv_token_symbol"/>
    <ImageView
        id="@+id/iv_chain_icon"
        layout_width="14dp"
        android:layout_height="14dp"
        layout_marginBottom="-2dp"
        layout_marginEnd="-2dp"
        NOT_FOUND_0x12="@+id/iv_token_image"
        NOT_FOUND_0x14="@+id/iv_token_image"/>
    <TextView
        id="@+id/tv_token_symbol"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x13="@+id/tv_last_tx_value"
        NOT_FOUND_0x15="@+id/tv_token_name"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="2"
        NOT_FOUND_0x18="@+id/iv_token_image"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="2"
        NOT_FOUND_0x1d="24dp"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_token_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/xxxxsm"
        layout_marginRight="@dimen/xxxxsm"
        maxLines="1"
        layout_marginHorizontal="@dimen/xxxxsm"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x12="@+id/tv_token_symbol"
        NOT_FOUND_0x15="@+id/tv_mcap_label"
        NOT_FOUND_0x18="@+id/tv_token_symbol"
        NOT_FOUND_0x1b="@+id/tv_token_symbol"
        style="@style/Label_2_Regular"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_last_tx_label"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_common_last_transaction"
        maxLines="1"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x12="@+id/tv_last_tx_value"
        NOT_FOUND_0x15="@+id/tv_last_tx_value"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="2"
        NOT_FOUND_0x18="@+id/iv_token_image"
        NOT_FOUND_0x1b="@+id/tv_last_tx_value"
        NOT_FOUND_0x1d="24dp"
        style="@style/Label_3_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_last_tx_value"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/xxxxsm"
        layout_marginTop="@dimen/xxxxsm"
        layout_marginRight="@dimen/xxxxsm"
        maxLines="1"
        layout_marginHorizontal="@dimen/xxxxsm"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x12="@+id/iv_token_image"
        NOT_FOUND_0x15="@+id/tv_token_age"
        NOT_FOUND_0x18="@+id/tv_last_tx_label"
        NOT_FOUND_0x1a="@+id/tv_token_symbol"
        style="@style/Label_2_Regular"/>
    <TextView
        id="@+id/tv_token_age"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="@+id/tv_last_tx_value"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="1"
        NOT_FOUND_0x1b="@+id/tv_last_tx_value"
        style="@style/Label_2_Regular"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_mcap_label"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/xxxxxsm"
        layout_marginRight="@dimen/xxxxxsm"
        text="@string/pr_swaptrade_common_label_mcap"
        layout_marginHorizontal="@dimen/xxxxxsm"
        NOT_FOUND_0x12="@+id/tv_token_symbol"
        NOT_FOUND_0x15="@+id/tv_mcap_value"
        NOT_FOUND_0x16="1"
        NOT_FOUND_0x1b="@+id/tv_token_symbol"
        style="@style/Label_3_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_mcap_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="@+id/tv_token_symbol"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="1"
        NOT_FOUND_0x1b="@+id/tv_token_symbol"
        style="@style/Label_2_Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
