<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    id="@+id/flash_news_layout"
    visibility="2"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        layout_gravity="0x800015"
        orientation="0"
        id="@+id/llNews"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <ImageView
            layout_gravity="0x10"
            id="@+id/ivNews"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            src="@drawable/_2131233377_res_0x7f080a61"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP.Regular"
            textSize="@dimen/text_size_12sp"
            textColor="@color/ContentSecondary"
            ellipsize="4"
            layout_gravity="0x10"
            id="@+id/tv_news_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            marqueeRepeatLimit="-1"
            layout_marginStart="@dimen/dp_4"/>
    </LinearLayout>
    <ImageView
        layout_gravity="0x800015"
        id="@+id/iv_news_close"
        layout_width="@dimen/ok_dp_12"
        android:layout_height="@dimen/ok_dp_12"
        src="@drawable/_2131231675_res_0x7f0803bb"
        layout_marginStart="@dimen/dp_4"/>
</LinearLayout>
