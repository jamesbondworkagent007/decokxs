<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/margin_default"
    paddingTop="8dp"
    paddingRight="@dimen/margin_default"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default">
    <com.okinc.planet.widget.SimpleLabelValuePairView
        id="@+id/floatingPnlPair"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@color/ContentTertiary"
        NOT_FOUND_0x12="@string/pr_copytrade_mycopy_title_unrealized_pnl"
        NOT_FOUND_0x13="14sp"
        NOT_FOUND_0x14="14sp"/>
    <View
        id="@+id/divider"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="20dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/floatingPnlPair"/>
    <com.okinc.planet.widget.SimpleLabelValuePairView
        id="@+id/realisedPnlPair"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/divider"
        NOT_FOUND_0x11="@color/ContentTertiary"
        NOT_FOUND_0x12="@string/pr_copytrade_myleading_btmsheet_header_realized_pnl"
        NOT_FOUND_0x13="14sp"
        NOT_FOUND_0x14="14sp"/>
    <o.tUS
        id="@+id/detailsContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/realisedPnlPair"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        text="@string/pr_copytrade_myleading_btmsheet_desc_trading_funding"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/detailsContainer"/>
</androidx.constraintlayout.widget.ConstraintLayout>
