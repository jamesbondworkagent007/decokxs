<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/color_surface_structural_base"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x11"
        orientation="1"
        paddingLeft="32dp"
        paddingRight="32dp"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="44dp"
        layout_marginBottom="84dp">
        <ImageView
            layout_gravity="0x1"
            id="@+id/iv_icon"
            layout_width="90dp"
            android:layout_height="90dp"
            layout_marginTop="20dp"
            src="@drawable/_2131232752_res_0x7f0807f0"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.24SP.Semibold"
            textColor="@color/color_content_static_default"
            layout_gravity="0x1"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"
            text="@string/pr_safemode_home_title_safe_mode"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/color_content_static_subtle"
            gravity="0x11"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            text="@string/pr_safemode_home_subtitle_crash_and_resolve"
            lineSpacingExtra="6sp"/>
    </LinearLayout>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/color_content_static_subtle"
        id="@+id/tv_version_info"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="12dp"
        layout_above="@+id/btn_export_log"
        layout_centerHorizontal="true"/>
    <o.C52794wYp
        id="@+id/btn_export_log"
        focusable="true"
        clickable="true"
        layout_width="-1"
        android:layout_height="52dp"
        layout_marginLeft="16dp"
        layout_marginTop="12dp"
        layout_marginRight="16dp"
        layout_marginBottom="20dp"
        text="@string/pr_safemode_home_btn_export_log"
        layout_alignParentBottom="true"
        onClick="exportLog"
        NOT_FOUND_0x18="52"
        NOT_FOUND_0x19="0x101"
        NOT_FOUND_0x1a="-1"/>
</RelativeLayout>
