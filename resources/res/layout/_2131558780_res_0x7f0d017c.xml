<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131230869_res_0x7f080095"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginTop="60dp">
    <FrameLayout
        paddingLeft="@dimen/common_page_edge_space"
        paddingRight="@dimen/common_page_edge_space"
        layout_width="-1"
        android:layout_height="48dp"
        paddingHorizontal="@dimen/common_page_edge_space">
        <o.wYC
            layout_gravity="0x800015"
            id="@+id/closeButton"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231675_res_0x7f0803bb"
            tint="@color/ContentContrast"/>
    </FrameLayout>
    <ScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/title"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="32dp"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Headline_4_Bold"/>
            <LinearLayout
                orientation="0"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-1"
                android:layout_height="wrap_content"
                paddingHorizontal="@dimen/common_page_edge_space">
                <TextView
                    textColor="@color/ContentTertiary"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_authlogin_passkey_bttmsheet_label_time_request"
                    layout_weight="4"
                    style="@style/Label_1_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    gravity="0x800005"
                    id="@+id/time"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="6"
                    style="@style/Label_1_Regular"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                paddingHorizontal="@dimen/common_page_edge_space">
                <TextView
                    textColor="@color/ContentTertiary"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_authlogin_passkey_bttmsheet_label_location_request"
                    layout_weight="4"
                    style="@style/Label_1_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    gravity="0x800005"
                    id="@+id/location"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="6"
                    style="@style/Label_1_Regular"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                paddingHorizontal="@dimen/common_page_edge_space">
                <TextView
                    textColor="@color/ContentTertiary"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_authlogin_passkey_bttmsheet_label_ip_request"
                    layout_weight="4"
                    style="@style/Label_1_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    gravity="0x800005"
                    id="@+id/ip"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="6"
                    style="@style/Label_1_Regular"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                paddingHorizontal="@dimen/common_page_edge_space">
                <TextView
                    textColor="@color/ContentTertiary"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_authlogin_passkey_bttmsheet_label_device_request"
                    layout_weight="4"
                    style="@style/Label_1_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    gravity="0x800005"
                    id="@+id/device"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="6"
                    style="@style/Label_1_Regular"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        orientation="1"
        paddingLeft="@dimen/common_page_edge_space"
        paddingRight="@dimen/common_page_edge_space"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/common_page_edge_space">
        <com.okinc.uilab.reminder.OKReminder
            id="@+id/reminder"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            layout_marginBottom="16dp"
            layout_marginVertical="16dp"/>
        <LinearLayout
            orientation="0"
            paddingTop="16dp"
            paddingBottom="16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingVertical="16dp">
            <o.C52794wYp
                id="@+id/rejectButton"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_authlogin_passkey_bttmsheet_btn_reject"
                layout_weight="1"
                layout_marginEnd="12dp"
                NOT_FOUND_0x17="52"
                NOT_FOUND_0x18="0x102"/>
            <o.C52794wYp
                id="@+id/approveButton"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_authlogin_passkey_bttmsheet_btn_approve"
                layout_weight="1"
                NOT_FOUND_0x17="52"
                NOT_FOUND_0x18="0x101"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
