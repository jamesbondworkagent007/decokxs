<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root_layout"
    paddingTop="@dimen/share_dialog_top_spacing"
    layout_width="-1"
    android:layout_height="match_parent"
    contentDescription="shareDialogRoot">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        id="@+id/coordinator_layout"
        layout_width="-1"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            orientation="1"
            id="@+id/outline_layout"
            background="@drawable/_2131231376_res_0x7f080290"
            visibility="1"
            clickable="true"
            layout_width="-1"
            android:layout_height="wrap_content"
            baselineAligned="false"
            elevation="1dp"
            NOT_FOUND_0xb="0x50"
            NOT_FOUND_0xc="@string/bottom_sheet_behavior">
            <FrameLayout
                id="@+id/header_container"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0xf="@+id/preview_container"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x13="0"/>
            <FrameLayout
                id="@+id/preview_container"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0xd="true"
                NOT_FOUND_0xf="@+id/platforms_container"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="@+id/header_container"/>
            <FrameLayout
                id="@+id/platforms_container"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0xe="0"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="@+id/preview_container"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</FrameLayout>
