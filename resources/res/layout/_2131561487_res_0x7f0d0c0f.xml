<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/rl_container"
    clipChildren="false"
    clipToPadding="false"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x11"
        orientation="0"
        id="@+id/ll_tab_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0">
        <TextView
            gravity="0x11"
            id="@+id/tv_tab_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"
            style="@style/TextAppearance.Silka"/>
        <TextView
            textSize="8sp"
            textColor="@color/white"
            gravity="0x11"
            id="@+id/tv_tab_title_label"
            background="@drawable/_2131231162_res_0x7f0801ba"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            minHeight="12dp"
            singleLine="true"
            paddingStart="4dp"
            paddingEnd="4dp"
            style="@style/TextAppearance.Bold"/>
    </LinearLayout>
    <ImageView
        id="@+id/iv_dot"
        visibility="2"
        layout_width="7dp"
        android:layout_height="7dp"
        layout_marginTop="4dp"
        src="@drawable/_2131232046_res_0x7f08052e"
        layout_marginEnd="6dp"
        NOT_FOUND_0x13="@+id/ll_tab_title"
        NOT_FOUND_0x16="0"/>
    <TextView
        gravity="0x11"
        id="@+id/rtv_msg_tip"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"/>
    <ImageView
        id="@+id/iv_tag"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232573_res_0x7f08073d"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/rtv_msg_tip"
        NOT_FOUND_0x16="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
