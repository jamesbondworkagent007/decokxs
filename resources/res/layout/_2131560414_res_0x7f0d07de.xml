<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/im_page_margin"
    layout_marginRight="@dimen/im_page_margin"
    layout_marginBottom="8dp"
    layout_marginHorizontal="@dimen/im_page_margin">
    <o.C54989xbV
        id="@+id/all"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_marginEnd="@dimen/margin_8dp"
        NOT_FOUND_0x10="false"
        NOT_FOUND_0x11="1"
        NOT_FOUND_0x12="@string/pr_commonall_column_tab_all"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="-5"/>
    <o.C54989xbV
        id="@+id/unread"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/margin_8dp"
        NOT_FOUND_0x11="1"
        NOT_FOUND_0x12="@string/pr_message_vip_rm_tab_unread"
        NOT_FOUND_0x13="@+id/all"
        NOT_FOUND_0x15="@+id/all"
        NOT_FOUND_0x18="@+id/all"
        NOT_FOUND_0x19="-5"/>
    <o.C54989xbV
        id="@+id/flagged"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/margin_8dp"
        NOT_FOUND_0x11="1"
        NOT_FOUND_0x12="@string/pr_message_general_chat_tab_flagged"
        NOT_FOUND_0x13="@+id/unread"
        NOT_FOUND_0x15="@+id/unread"
        NOT_FOUND_0x18="@+id/unread"
        NOT_FOUND_0x19="-5"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/no_unread_chats_layout"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="32dp"
        layout_marginTop="24dp"
        layout_marginRight="32dp"
        layout_marginHorizontal="32dp"
        NOT_FOUND_0x17="@+id/unread">
        <ImageView
            id="@+id/no_unread_chats_image"
            layout_width="80dp"
            android:layout_height="80dp"
            layout_marginTop="9dp"
            layout_marginBottom="9dp"
            src="@drawable/_2131233558_res_0x7f080b16"
            layout_marginVertical="9dp"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="0"/>
        <TextView
            textSize="14sp"
            textColor="@color/color_content_static_default"
            id="@+id/no_unread_chats_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginBottom="9dp"
            text="@string/pr_message_vip_empty_title_no_unread_chats"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="@+id/no_unread_chats_image"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentTertiary"
            gravity="0x11"
            id="@+id/adjust_filter_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            text="@string/pr_message_vip_empty_text_all_caught_up"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="@+id/no_unread_chats_text"
            style="@style/Body_3_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/no_flagged_chats_layout"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="32dp"
        layout_marginTop="24dp"
        layout_marginRight="32dp"
        layout_marginHorizontal="32dp"
        NOT_FOUND_0x17="@+id/flagged">
        <ImageView
            id="@+id/no_flagged_chats_image"
            layout_width="80dp"
            android:layout_height="80dp"
            layout_marginTop="9dp"
            layout_marginBottom="9dp"
            src="@drawable/_2131233558_res_0x7f080b16"
            layout_marginVertical="9dp"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="0"/>
        <TextView
            textSize="14sp"
            textColor="@color/color_content_static_default"
            id="@+id/no_flagged_chats_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginBottom="9dp"
            text="@string/pr_message_general_empty_title_no_flagged_messages"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="@+id/no_flagged_chats_image"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentTertiary"
            gravity="0x11"
            id="@+id/flagged_adjust_filter_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            text="@string/pr_message_general_empty_text_flag_important_messages"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="@+id/no_flagged_chats_text"
            style="@style/Body_3_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
