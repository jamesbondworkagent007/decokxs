<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root_footer_layout"
    background="@drawable/_2131231377_res_0x7f080291"
    paddingLeft="24dp"
    paddingTop="16dp"
    paddingRight="24dp"
    paddingBottom="16dp"
    clipChildren="false"
    clipToPadding="false"
    layout_width="-1"
    android:layout_height="wrap_content"
    baselineAligned="false"
    paddingHorizontal="24dp"
    paddingVertical="16dp">
    <o.C6995aZr
        id="@+id/qr_share_code"
        background="@drawable/_2131231315_res_0x7f080253"
        visibility="0"
        layout_width="64dp"
        android:layout_height="64dp"
        NOT_FOUND_0x1a="2dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x22="0"/>
    <TextView
        textColor="@color/share_footer_title_color"
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_share_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        minHeight="20dp"
        maxLines="2"
        includeFontPadding="false"
        lineSpacingMultiplier="0.9"
        layout_marginEnd="16dp"
        NOT_FOUND_0x1c="@+id/tv_share_subtitle"
        NOT_FOUND_0x1e="@+id/qr_share_code"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x23="2"
        NOT_FOUND_0x24="0dp"
        style="@style/TextAppearance.Title.16SP"/>
    <TextView
        textColor="@color/share_footer_subtitle_color"
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_share_subtitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        minHeight="16dp"
        lines="1"
        includeFontPadding="false"
        layout_marginEnd="16dp"
        NOT_FOUND_0x1c="@+id/iv_share_logo"
        NOT_FOUND_0x1e="@+id/qr_share_code"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="@+id/tv_share_title"
        NOT_FOUND_0x24="0dp"
        style="@style/LiteTextAppearance.TextBlack.14SP.Bold"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_share_logo"
        visibility="0"
        layout_width="-2"
        android:layout_height="16dp"
        layout_marginTop="12dp"
        scaleType="fitStart"
        adjustViewBounds="true"
        layout_marginEnd="16dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="@+id/tv_share_subtitle"/>
</androidx.constraintlayout.widget.ConstraintLayout>
