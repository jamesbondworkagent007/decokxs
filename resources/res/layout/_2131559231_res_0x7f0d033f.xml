<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x800015"
    layout_width="-2"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_top_kline"
        layout_width="-2"
        android:layout_height="@dimen/height_24dp"
        src="@drawable/_2131231584_res_0x7f080360"
        scaleType="7"
        layout_centerVertical="true"
        contentDescription="web3_dex_shared_kline_button"
        paddingStart="@dimen/margin_10dp"
        layout_alignParentEnd="true"/>
    <FrameLayout
        id="@+id/container_view_more"
        layout_width="-2"
        android:layout_height="wrap_content"
        contentDescription="web3_dex_history_more_button"
        layout_marginStart="10dp">
        <View
            layout_gravity="0x800005"
            id="@+id/auto_confirm_setting_first_time_dot"
            background="@drawable/_2131232044_res_0x7f08052c"
            padding="@dimen/dp_2"
            layout_width="@dimen/dp_8"
            android:layout_height="@dimen/dp_8"
            backgroundTint="?attr/color_content_dataviz_categorical_1"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0"/>
        <androidx.appcompat.widget.AppCompatImageView
            layout_gravity="0x11"
            id="@+id/ic_background"
            layout_width="24dp"
            android:layout_height="24dp"
            layout_marginEnd="@dimen/dp_2"
            NOT_FOUND_0x16="@drawable/_2131233513_res_0x7f080ae9"
            NOT_FOUND_0x17="@color/ContentPrimary"/>
        <androidx.appcompat.widget.AppCompatTextView
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/tv_pending_order"
            background="@drawable/_2131234264_res_0x7f080dd8"
            visibility="2"
            layout_width="28dp"
            android:layout_height="28dp"
            includeFontPadding="true"
            fontFamily="@style/OKTextFont.Bold"
            textAlignment="4"
            backgroundTint="@color/ContentBrand"
            style="@style/Label_3_Bold"/>
    </FrameLayout>
</merge>
