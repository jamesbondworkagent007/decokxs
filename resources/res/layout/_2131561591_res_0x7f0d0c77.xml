<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/lite_limit_detail_coin_item_0"
    paddingBottom="@dimen/padding_32dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_16dp">
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/grey_g900"
        gravity="0x11"
        id="@+id/lite_limit_detail_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        fontFamily="@font/harmony_sans_bold"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <ImageView
        id="@+id/lite_limit_to_coin_icon"
        layout_width="@dimen/width_32dp"
        android:layout_height="@dimen/height_32dp"
        layout_marginTop="@dimen/margin_53dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/lite_limit_detail_title"/>
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/grey_g900"
        id="@+id/lite_limit_to_coin_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        fontFamily="@font/harmony_sans_bold"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x11="@+id/lite_limit_to_coin_icon"
        NOT_FOUND_0x14="@+id/lite_limit_to_coin_icon"/>
    <TextView
        id="@+id/lite_limit_to_coin_fullname"
        layout_width="-2"
        android:layout_height="wrap_content"
        fontFamily="@font/harmony_sans_regular"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x12="@+id/lite_limit_to_coin_name"
        NOT_FOUND_0x13="@+id/lite_limit_to_coin_name"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/system_green"
        gravity="0x800005"
        id="@+id/lite_limit_to_coin_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        fontFamily="@font/harmony_sans_bold"
        textDirection="3"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x14="@+id/lite_limit_to_coin_icon"/>
    <TextView
        id="@+id/from_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        text="@string/lt_alltransactions_details_label_from"
        fontFamily="@font/harmony_sans_regular"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/lite_limit_to_coin_fullname"/>
    <ImageView
        id="@+id/lite_limit_from_coin_icon"
        layout_width="@dimen/width_32dp"
        android:layout_height="@dimen/height_32dp"
        layout_marginTop="@dimen/margin_20dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/from_text"/>
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/grey_g900"
        id="@+id/lite_limit_from_coin_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        fontFamily="@font/harmony_sans_bold"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0x11="@+id/lite_limit_from_coin_icon"
        NOT_FOUND_0x14="@+id/lite_limit_from_coin_icon"/>
    <TextView
        id="@+id/lite_limit_from_coin_fullname"
        layout_width="-2"
        android:layout_height="wrap_content"
        fontFamily="@font/harmony_sans_regular"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x12="@+id/lite_limit_from_coin_name"
        NOT_FOUND_0x13="@+id/lite_limit_from_coin_name"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/system_red"
        gravity="0x800005"
        id="@+id/lite_limit_from_coin_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        fontFamily="@font/harmony_sans_bold"
        textDirection="3"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x14="@+id/lite_limit_from_coin_icon"/>
    <View
        id="@+id/divider"
        background="@color/grey_80"
        layout_width="@dimen/width_0dp"
        android:layout_height="@dimen/ok_dp_0.5"
        layout_marginTop="@dimen/margin_32dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/lite_limit_from_coin_fullname"/>
</androidx.constraintlayout.widget.ConstraintLayout>
