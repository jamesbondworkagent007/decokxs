<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_wallet_coin_asset_item_0"
    paddingTop="10dp"
    paddingBottom="10dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="16dp"
    paddingEnd="16dp">
    <ImageView
        id="@+id/img"
        layout_width="32dp"
        android:layout_height="32dp"
        src="?attr/st_color_g400"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textColor="?attr/st_color_g900"
        id="@+id/tv_coin"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0x11="@+id/tv_coin_des"
        NOT_FOUND_0x13="@+id/img"
        NOT_FOUND_0x16="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textColor="?attr/st_color_g900"
        gravity="0x800005"
        id="@+id/tv_coin_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        lines="1"
        layout_marginStart="12dp"
        NOT_FOUND_0x10="@+id/tv_coin"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/tv_coin"
        NOT_FOUND_0x16="@+id/tv_coin"/>
    <TextView
        textSize="14sp"
        textColor="?attr/st_color_g400"
        id="@+id/tv_coin_des"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="@+id/tv_coin"
        NOT_FOUND_0x15="@+id/tv_coin"/>
    <TextView
        textSize="14sp"
        textColor="?attr/st_color_g400"
        gravity="0x800005"
        id="@+id/tv_coin_currency_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        lines="1"
        NOT_FOUND_0x10="@+id/tv_coin_des"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/tv_coin_des"
        NOT_FOUND_0x16="@+id/tv_coin_des"/>
</androidx.constraintlayout.widget.ConstraintLayout>
