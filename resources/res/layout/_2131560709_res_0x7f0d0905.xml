<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/background_lv3"
    padding="@dimen/ok_dp_16"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textStyle="0x1"
        textColor="@color/blue"
        id="@+id/tv_legacy_deeplink"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_10"
        layout_marginBottom="@dimen/dp_10"
        layout_marginEnd="@dimen/dp_10"
        layout_marginVertical="@dimen/dp_10"
        NOT_FOUND_0x10="@+id/add_params"
        NOT_FOUND_0x11="0"
        style="@style/TextAppearance.Title.14SP"/>
    <TextView
        textColor="@color/okTradeG900"
        id="@+id/tv_v2_deeplink"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_10"
        layout_marginBottom="@dimen/dp_10"
        layout_marginEnd="@dimen/dp_10"
        layout_marginVertical="@dimen/dp_10"
        NOT_FOUND_0x10="@+id/add_params"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/tv_legacy_deeplink"
        style="@style/TextAppearance.Title.12SP"/>
    <ScrollView
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_10"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/tv_v2_deeplink">
        <LinearLayout
            orientation="0"
            id="@+id/param_container"
            layout_width="-2"
            android:layout_height="wrap_content"/>
    </ScrollView>
    <TextView
        textColor="@color/blue"
        gravity="0x11"
        id="@+id/add_params"
        layout_width="-2"
        android:layout_height="24dp"
        text="Add Param"
        tintMode="src_over"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x13="0"
        style="@style/TextAppearance.Title.14SP"/>
</androidx.constraintlayout.widget.ConstraintLayout>
