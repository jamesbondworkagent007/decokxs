<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/background_BasePrimary_BaseSecondary"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="42dp">
    <View
        id="@+id/divider"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="0.5dp"
        NOT_FOUND_0x1b="0"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/operatorLayout"
        layout_width="0dp"
        android:layout_height="0dp"
        layout_marginTop="6dp"
        layout_weight="1"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="@+id/action"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@+id/divider">
        <FrameLayout
            id="@+id/plus_layout"
            background="@drawable/_2131233416_res_0x7f080a88"
            layout_width="0dp"
            android:layout_height="0dp"
            layout_marginStart="@dimen/margin_10dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/minus_layout"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131233687_res_0x7f080b97"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/minus_layout"
            background="@drawable/_2131233416_res_0x7f080a88"
            layout_width="0dp"
            android:layout_height="0dp"
            layout_marginLeft="8dp"
            layout_marginRight="8dp"
            layout_marginHorizontal="8dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/mul_layout"
            NOT_FOUND_0x18="@+id/plus_layout"
            NOT_FOUND_0x1b="0">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131233505_res_0x7f080ae1"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/mul_layout"
            background="@drawable/_2131233416_res_0x7f080a88"
            layout_width="0dp"
            android:layout_height="0dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/div_layout"
            NOT_FOUND_0x18="@+id/minus_layout"
            NOT_FOUND_0x1b="0">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131231675_res_0x7f0803bb"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/div_layout"
            background="@drawable/_2131233416_res_0x7f080a88"
            layout_width="0dp"
            android:layout_height="0dp"
            layout_marginLeft="8dp"
            layout_marginRight="8dp"
            layout_marginHorizontal="8dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/bracket_left_layout"
            NOT_FOUND_0x18="@+id/mul_layout"
            NOT_FOUND_0x1b="0">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131232024_res_0x7f080518"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/bracket_left_layout"
            background="@drawable/_2131233416_res_0x7f080a88"
            layout_width="0dp"
            android:layout_height="0dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/bracket_right_layout"
            NOT_FOUND_0x18="@+id/div_layout"
            NOT_FOUND_0x1b="0">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131233320_res_0x7f080a28"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/bracket_right_layout"
            background="@drawable/_2131233416_res_0x7f080a88"
            layout_width="0dp"
            android:layout_height="0dp"
            layout_marginStart="8dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="@+id/bracket_left_layout"
            NOT_FOUND_0x1b="0">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131233804_res_0x7f080c0c"/>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        layout_gravity="0x11"
        id="@+id/action"
        paddingLeft="@dimen/padding_16dp"
        paddingTop="@dimen/padding_8dp"
        paddingRight="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="-2"
        android:layout_height="match_parent"
        text="@string/pr_commonall_button_text_done"
        paddingHorizontal="@dimen/padding_16dp"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x15="@+id/operatorLayout"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="@+id/operatorLayout"
        NOT_FOUND_0x1b="@+id/operatorLayout"
        style="@style/Label_2_Medium"/>
</merge>
