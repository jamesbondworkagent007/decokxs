<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    padding="@dimen/margin_16dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_intro_desc_trading_calendar"
        style="@style/Label_2_Bold"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentTertiary"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        text="@string/pr_trade_intro_desc_the_trading_calendar_displays"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_16"
        text="@string/pr_trade_intro_desc_daily_profitloss"
        style="@style/Label_2_Bold"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentTertiary"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        text="@string/pr_trade_intro_desc_the_daily_profit_or"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_16"
        text="@string/pr_trade_intro_desc_data_collection_time"
        style="@style/Label_2_Bold"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentTertiary"
        id="@+id/tv_collection_time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        layout_marginBottom="@dimen/dp_16"
        text="@string/pr_trade_intro_desc_the_daily_data_collection"
        style="@style/Label_2_Regular"/>
</androidx.appcompat.widget.LinearLayoutCompat>
