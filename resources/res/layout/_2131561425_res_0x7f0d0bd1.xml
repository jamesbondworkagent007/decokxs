<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/stateConnected"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="24dp"
    layout_marginRight="24dp"
    layout_marginHorizontal="24dp">
    <TextView
        textAppearance="@style/Headline_4_Bold"
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_account_security_mfa_passkey_title_device_connected"/>
    <TextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/color_content_static_default"
        id="@+id/desc"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_account_security_mfa_passkey_desc_device_connected"/>
    <ImageView
        layout_gravity="0x11"
        id="@+id/icon"
        layout_width="135dp"
        android:layout_height="135dp"
        layout_marginTop="40dp"/>
    <o.C52794wYp
        enabled="true"
        id="@+id/continueButton"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="44dp"
        layout_marginBottom="16dp"
        text="@string/pr_account_security_mfa_passkey_btn_ive_approved"
        NOT_FOUND_0xe="52"
        NOT_FOUND_0xf="0x101"
        style="@style/TextAppearance.Text.Bold.16SP"/>
</LinearLayout>
