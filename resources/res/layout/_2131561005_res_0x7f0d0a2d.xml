<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_withdrawal_select_network_0"
    background="@drawable/_2131231112_res_0x7f080188"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_24dp"
    layout_marginTop="@dimen/margin_16dp"
    layout_marginRight="@dimen/margin_24dp"
    layout_marginHorizontal="@dimen/margin_24dp">
    <ImageView
        id="@+id/icon"
        layout_width="24dp"
        android:layout_height="24dp"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        ellipsize="3"
        id="@+id/name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="8dp"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x11="@+id/icon"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/icon"
        NOT_FOUND_0x17="@+id/icon"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textColor="@color/grey_g400"
        ellipsize="3"
        id="@+id/tv_fee"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        maxLines="2"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="@+id/icon"
        NOT_FOUND_0x16="@+id/icon"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.12SP"
        textColor="@color/grey_g400"
        id="@+id/tv_arrival_time"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        layout_marginBottom="@dimen/margin_16dp"
        maxLines="1"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x12="@+id/reminderView"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="@+id/icon"
        NOT_FOUND_0x16="@+id/tv_fee"/>
    <View
        id="@+id/divider_bottom"
        background="@color/BorderPrimary"
        visibility="2"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginHorizontal="@dimen/margin_16dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/tv_arrival_time"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/reminderView"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_16dp"
        maxLines="2"
        layout_marginHorizontal="@dimen/margin_16dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/divider_bottom"/>
    <View
        id="@+id/upperLayerViewMask"
        background="@color/exchange_assets_item_mask_bg"
        visibility="2"
        layout_width="-1"
        android:layout_height="0dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
