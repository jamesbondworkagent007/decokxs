<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_withdrawal_select_coin_0"
    layout_width="-1"
    android:layout_height="72dp">
    <ImageView
        id="@+id/icon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginStart="@dimen/dp24"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        ellipsize="3"
        id="@+id/name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        maxLines="1"
        layout_marginStart="12dp"
        NOT_FOUND_0xf="16sp"
        NOT_FOUND_0x10="12sp"
        NOT_FOUND_0x11="2sp"
        NOT_FOUND_0x12="1"
        NOT_FOUND_0x15="@+id/tvCoinAmount"
        NOT_FOUND_0x16="0.44"
        NOT_FOUND_0x17="@+id/icon"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="2"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tvCoinAmount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        maxLines="1"
        layout_marginStart="12dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0xf="16sp"
        NOT_FOUND_0x10="12sp"
        NOT_FOUND_0x11="2sp"
        NOT_FOUND_0x12="1"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0.6"
        NOT_FOUND_0x17="@+id/name"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="2"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvCoinName"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        maxLines="1"
        includeFontPadding="false"
        NOT_FOUND_0x15="@+id/tvCurrency"
        NOT_FOUND_0x18="@+id/name"
        NOT_FOUND_0x19="@+id/name"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        gravity="0x800005"
        id="@+id/tvCurrency"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        maxLines="1"
        includeFontPadding="false"
        layout_marginStart="@dimen/margin_12dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/tvCoinName"
        NOT_FOUND_0x19="@+id/tvCoinAmount"/>
    <View
        id="@+id/upperLayerViewMask"
        background="@color/exchange_assets_item_mask_bg"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
