<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="@dimen/ok_top_bar_min_height">
    <o.wYC
        layout_gravity="0x800013"
        id="@+id/navigationView"
        layout_width="24dp"
        android:layout_height="24dp"
        contentDescription="backButton"
        layout_marginStart="16dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@drawable/_2131231645_res_0x7f08039d"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_gravity="0x11"
        id="@+id/titleContainer"
        layout_width="-2"
        android:layout_height="wrap_content">
        <com.google.android.material.textview.MaterialTextView
            textAppearance="@style/Title_2_Bold"
            ellipsize="3"
            gravity="0x11"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            minHeight="24dp"
            lines="1"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="0"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/icon"
            visibility="2"
            layout_width="20dp"
            android:layout_height="20dp"
            layout_marginEnd="6dp"
            NOT_FOUND_0x11="@+id/title"
            NOT_FOUND_0x13="@+id/title"
            NOT_FOUND_0x17="@+id/title"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/caret"
            visibility="2"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231589_res_0x7f080365"
            NOT_FOUND_0x11="@+id/title"
            NOT_FOUND_0x14="@+id/title"
            NOT_FOUND_0x17="@+id/title"/>
        <androidx.constraintlayout.widget.Barrier
            id="@+id/titleStart"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0xf="5"
            NOT_FOUND_0x10="icon,title"/>
        <androidx.constraintlayout.widget.Barrier
            id="@+id/titleEnd"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0xf="6"
            NOT_FOUND_0x10="title,caret"/>
        <com.google.android.material.textview.MaterialTextView
            textAppearance="@style/Label_4_Regular"
            ellipsize="3"
            gravity="0x11"
            id="@+id/subtitle"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            minHeight="12dp"
            lines="1"
            NOT_FOUND_0x12="@+id/titleEnd"
            NOT_FOUND_0x15="@+id/titleStart"
            NOT_FOUND_0x16="@+id/title"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        gravity="0x11"
        layout_gravity="0x800005"
        orientation="0"
        id="@+id/menu"
        layout_width="-2"
        android:layout_height="@dimen/ok_top_bar_min_height"
        layout_marginEnd="16dp"/>
</merge>
