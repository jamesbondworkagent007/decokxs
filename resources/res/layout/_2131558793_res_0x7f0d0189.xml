<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        id="@+id/item_layout"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0">
        <LinearLayout
            layout_gravity="0x10"
            orientation="0"
            id="@+id/leftContainer"
            layout_width="-2"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/userFlow"
                layout_width="-2"
                android:layout_height="wrap_content">
                <androidx.constraintlayout.helper.widget.Flow
                    id="@+id/headerFlow"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    NOT_FOUND_0xc="tvTitle"
                    NOT_FOUND_0xd="0"
                    NOT_FOUND_0xe="0"
                    NOT_FOUND_0xf="6dp"
                    NOT_FOUND_0x10="2"
                    NOT_FOUND_0x11="2"
                    NOT_FOUND_0x12="6dp"
                    NOT_FOUND_0x13="2"
                    NOT_FOUND_0x14="1"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x17="0"
                    NOT_FOUND_0x19="0"
                    NOT_FOUND_0x1a="0"/>
                <o.C55258xgZ
                    id="@+id/tvTitle"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    NOT_FOUND_0x15="true"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x19="0"
                    NOT_FOUND_0x1a="0"
                    NOT_FOUND_0x1b="2"
                    NOT_FOUND_0x1c="@color/ContentContrast"
                    NOT_FOUND_0x1d="@dimen/text_size_14sp"
                    NOT_FOUND_0x1e="400"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
        <Space
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/rightTvContainer"
            layout_width="-2"
            android:layout_height="wrap_content">
            <ImageView
                id="@+id/ivChevron"
                visibility="0"
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131231647_res_0x7f08039f"
                layout_marginStart="12dp"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1a="0"/>
            <TextView
                textColor="@color/pnl_modern_profit_graph"
                id="@+id/tvAprValue"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x18="@+id/ivChevron"
                NOT_FOUND_0x1a="0"
                style="@style/Label_2_Medium"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
