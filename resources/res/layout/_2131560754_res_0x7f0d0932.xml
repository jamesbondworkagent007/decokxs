<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_network_fee_select_crypto_0"
    paddingLeft="16dp"
    paddingRight="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="16dp"
    foreground="@drawable/_2131233879_res_0x7f080c57"
    paddingHorizontal="16dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_icon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginTop="26dp"
        layout_marginBottom="26dp"
        layout_marginVertical="26dp"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x27="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/grey_g900"
        id="@+id/tv_symbol"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0x21="@+id/rl_balance_and_credit"
        NOT_FOUND_0x24="@+id/iv_icon"
        NOT_FOUND_0x27="@+id/iv_icon"
        style="@style/TextAppearance.Title.16SP.Medium"/>
    <RelativeLayout
        orientation="0"
        id="@+id/rl_balance_and_credit"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1f="true"
        NOT_FOUND_0x20="@+id/iv_icon"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x25="@+id/tv_symbol"
        NOT_FOUND_0x26="@+id/tv_symbol">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/grey_g400"
            ellipsize="3"
            layout_gravity="0x10"
            id="@+id/tv_balance"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"
            layout_alignParentStart="true"
            style="@style/TextAppearance.Text.12SP"/>
        <View
            layout_gravity="0x10"
            id="@+id/aa_view_divider"
            background="@color/grey_g100"
            visibility="2"
            layout_width="1dp"
            android:layout_height="@dimen/height_16dp"
            layout_marginLeft="4dp"
            layout_marginRight="4dp"
            layout_toEndOf="@+id/tv_balance"
            layout_marginHorizontal="4dp"/>
        <LinearLayout
            layout_gravity="0x10"
            orientation="0"
            id="@+id/ll_gas_credit"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/grey_g400"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_gas_credit"
                layout_width="0dp"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_weight="1"
                style="@style/TextAppearance.Title.12SP"/>
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x10"
                id="@+id/iv_tip"
                layout_width="14dp"
                android:layout_height="14dp"
                src="@drawable/_2131232621_res_0x7f08076d"
                layout_marginStart="4dp"
                NOT_FOUND_0x2c="@color/grey_g400"/>
        </LinearLayout>
    </RelativeLayout>
    <View
        id="@+id/maskLayer"
        background="@color/shadow_00"
        focusable="true"
        visibility="2"
        clickable="true"
        layout_width="-1"
        android:layout_height="0dp"
        alpha="0.4"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x27="0"/>
    <o.C52794wYp
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/ContentPrimary"
        gravity="0x11"
        id="@+id/btn_fillUp"
        paddingLeft="12dp"
        paddingRight="12dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="24dp"
        paddingHorizontal="12dp"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x27="0"
        NOT_FOUND_0x28="48dp"
        NOT_FOUND_0x29="0x104"
        NOT_FOUND_0x2a="60dp"
        NOT_FOUND_0x2b="@color/okTradeBgLv3"/>
</androidx.constraintlayout.widget.ConstraintLayout>
