<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        id="@+id/address_input_card"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0xb="@color/BaseSecondary"
        NOT_FOUND_0xc="16dp"
        NOT_FOUND_0xd="0dp"
        NOT_FOUND_0x14="@android:color/transparent">
        <androidx.constraintlayout.widget.ConstraintLayout
            padding="@dimen/padding_16dp"
            layout_width="-1"
            android:layout_height="wrap_content">
            <o.C57440yiU
                id="@+id/chain_icons"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0xa="4dp"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x13="0"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/chain_names"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_12dp"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="@+id/chain_icons"
                style="@style/Label_2_Bold"/>
            <TextView
                textColor="@color/ContentTertiary"
                id="@+id/email_num"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0xe="@+id/chain_icons"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x13="@+id/chain_icons"
                style="@style/Label_2_Regular"/>
            <TextView
                textSize="@dimen/text_size_14sp"
                textColor="@color/ContentTertiary"
                id="@+id/from_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_16dp"
                text="@string/pr_trade_cedefi_recovery_from_cdf"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="@+id/chain_names"
                style="@style/TextAppearance.Regular"/>
            <TextView
                textSize="@dimen/text_size_14sp"
                textColor="@color/ContentPrimary"
                id="@+id/from_email_address"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/margin_10dp"
                NOT_FOUND_0xe="@+id/from_title"
                NOT_FOUND_0x10="@+id/from_title"
                NOT_FOUND_0x13="@+id/from_title"
                style="@style/TextAppearance.Regular"/>
            <TextView
                textSize="@dimen/text_size_14sp"
                textColor="@color/color_content_warning_default"
                id="@+id/warning_tip"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                text="@string/pr_trade_cedefi_desc_from_must_recovery_email_cdf"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="@+id/from_title"
                style="@style/TextAppearance.Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
