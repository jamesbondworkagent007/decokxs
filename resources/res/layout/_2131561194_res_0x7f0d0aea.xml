<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_dapp_interaction_approved_amount_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="16sp"
        textColor="@color/grey_g400"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_metax_customcoin_text_pamount"
        layout_marginEnd="16dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="@+id/guideline"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="1"/>
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideline"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x11="0.5"/>
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="16sp"
        textColor="@color/orange_lv1"
        ellipsize="3"
        id="@+id/tv_approved_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="32dp"
        NOT_FOUND_0xe="@+id/tv_title"
        NOT_FOUND_0x10="@+id/tv_approved_symbol"
        NOT_FOUND_0x12="1"
        NOT_FOUND_0x13="2"
        NOT_FOUND_0x14="@+id/tv_title"
        NOT_FOUND_0x16="@+id/tv_title"
        NOT_FOUND_0x17="1"/>
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="16sp"
        textColor="@color/orange_lv1"
        id="@+id/tv_approved_symbol"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="4dp"
        NOT_FOUND_0xe="@+id/tv_title"
        NOT_FOUND_0x10="@+id/iv_arrow"
        NOT_FOUND_0x14="@+id/tv_approved_amount"
        NOT_FOUND_0x16="@+id/tv_title"
        NOT_FOUND_0x17="1"
        NOT_FOUND_0x18="0dp"/>
    <ImageView
        id="@+id/iv_arrow"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131232354_res_0x7f080662"
        NOT_FOUND_0xe="@+id/tv_title"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x16="@+id/tv_title"
        NOT_FOUND_0x19="@color/grey_g400"/>
</androidx.constraintlayout.widget.ConstraintLayout>
