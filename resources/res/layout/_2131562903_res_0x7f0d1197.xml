<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <o.C55258xgZ
        gravity="0x10"
        id="@+id/title"
        tag="layout/view_strategy_order_confirm_tp_sl_view_0"
        layout_width="-2"
        android:layout_height="wrap_content"
        minHeight="50dp"
        layout_marginStart="16dp"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@color/okTradeG900"
        NOT_FOUND_0x1b="@dimen/text_size_16sp"
        NOT_FOUND_0x1c="@string/pr_demotrade_text_tp_loss"
        NOT_FOUND_0x1d="600"/>
    <View
        id="@+id/arrowClickArea"
        tag="layout/view_strategy_order_confirm_tp_sl_view_1"
        layout_width="36dp"
        android:layout_height="0dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x13="@+id/title"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="@+id/title"/>
    <ImageView
        id="@+id/arrow"
        tag="layout/view_strategy_order_confirm_tp_sl_view_2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232339_res_0x7f080653"
        layout_marginEnd="18dp"
        NOT_FOUND_0x13="@+id/title"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="@+id/title"/>
    <View
        id="@+id/line"
        tag="layout/view_strategy_order_confirm_tp_sl_view_3"
        background="@color/okTradeG200"
        layout_width="-1"
        android:layout_height="0.5dp"
        NOT_FOUND_0x17="@+id/title"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/content_cly"
        tag="layout/view_strategy_order_confirm_tp_sl_view_4"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        NOT_FOUND_0x17="@+id/line">
        <o.wYK
            theme="@style/OKUITheme"
            textColor="@color/okTradeG900"
            id="@+id/tpCheck"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_checkbox_market_stop_profit_str"
            layout_marginStart="16dp"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x1e="-4"/>
        <o.wYK
            theme="@style/OKUITheme"
            textColor="@color/okTradeG900"
            id="@+id/slCheck"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_checkbox_market_stop_loss_str"
            layout_marginStart="16dp"
            NOT_FOUND_0x15="@+id/tpCheck"
            NOT_FOUND_0x1e="-4"/>
        <o.C47988uAv
            id="@+id/tpPrice"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"
            NOT_FOUND_0x17="@+id/tpCheck"
            NOT_FOUND_0x1f="@string/pr_trade_history_item_take_profit"
            style="@style/OKTInputLayoutStyle_Bot"/>
        <o.C47988uAv
            id="@+id/slPrice"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="12dp"
            layout_marginRight="16dp"
            layout_marginHorizontal="16dp"
            NOT_FOUND_0x17="@+id/tpPrice"
            NOT_FOUND_0x1f="@string/pr_trade_history_item_stop_price"
            style="@style/OKTInputLayoutStyle_Bot"/>
        <TextView
            textSize="12sp"
            textColor="@color/okTradeOrange700"
            id="@+id/reminderText"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            text="@string/pr_trade_strategy_alert_risk_msg"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"
            NOT_FOUND_0x17="@+id/slPrice"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
