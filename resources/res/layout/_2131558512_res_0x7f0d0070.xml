<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/container"
    tag="layout/activity_debug_import_doh_0"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginEnd="16dp">
    <androidx.appcompat.widget.Toolbar
        id="@+id/toolbar"
        background="@android:color/transparent"
        layout_marginTop="40dp"
        NOT_FOUND_0x15="1"
        style="@style/AppTheme.Toolbar">
        <RelativeLayout
            id="@+id/ll_back"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatImageView
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131232347_res_0x7f08065b"
                layout_centerVertical="true"
                layout_alignParentStart="true"
                NOT_FOUND_0x19="@color/okTradeG900"/>
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>
    <ScrollView
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginStart="16dp">
        <RelativeLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <EditText
                textSize="12sp"
                textColor="@color/okTradeG900"
                textColorHint="@color/okTradeG300"
                gravity="0x30"
                id="@+id/et_doh_config"
                layout_width="-1"
                android:layout_height="200dp"
                hint="@string/pr_debug_doh_config_hint"
                layout_alignParentTop="true"/>
            <LinearLayout
                id="@+id/btn_layout"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="10dp"
                layout_below="@+id/et_doh_config"
                layout_alignParentStart="true">
                <o.C52794wYp
                    id="@+id/btn_process_config"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="开始解析(Start parsing)"
                    layout_weight="1"
                    NOT_FOUND_0x16="52"
                    NOT_FOUND_0x17="0x101"
                    NOT_FOUND_0x18="-2"
                    NOT_FOUND_0x1a="2"
                    style="@style/Button.Primary.Medium"/>
                <o.C52794wYp
                    id="@+id/btn_apply_config"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="应用(Use)"
                    layout_weight="1"
                    layout_marginStart="10dp"
                    NOT_FOUND_0x16="52"
                    NOT_FOUND_0x17="0x101"
                    NOT_FOUND_0x18="-2"
                    NOT_FOUND_0x1a="2"
                    style="@style/Button.Primary.Medium"/>
            </LinearLayout>
            <TextView
                textSize="@dimen/text_size_14sp"
                id="@+id/tv_process_status"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="10dp"
                text="Result: "
                layout_below="@+id/btn_layout"
                style="@style/TextAppearance.Button.Selectable.Medium"/>
            <TextView
                id="@+id/doh_debug_log"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="15dp"
                layout_below="@+id/tv_process_status"/>
        </RelativeLayout>
    </ScrollView>
</LinearLayout>
