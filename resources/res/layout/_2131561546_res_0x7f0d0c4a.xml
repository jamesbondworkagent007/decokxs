<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        id="@+id/ll_header_info"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="@dimen/margin_8dp">
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentContrast"
            id="@+id/tv_header_title"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <ImageView
            layout_gravity="0x10"
            id="@+id/iv_header_icon"
            visibility="2"
            layout_width="14dp"
            android:layout_height="14dp"
            src="@drawable/_2131232939_res_0x7f0808ab"
            layout_marginStart="4dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/list"
        layout_width="-1"
        android:layout_height="wrap_content"
        overScrollMode="2"/>
    <LinearLayout
        gravity="0x11"
        orientation="0"
        id="@+id/ll_more"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp">
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentPrimary"
            id="@+id/tv_arrow_title"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <ImageView
            id="@+id/iv_arrow_down_icon"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131231637_res_0x7f080395"
            layout_marginStart="10dp"
            NOT_FOUND_0xe="@color/ContentPrimary"/>
    </LinearLayout>
</merge>
