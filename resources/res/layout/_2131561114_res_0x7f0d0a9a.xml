<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/ok_dp_24"
    paddingRight="@dimen/ok_dp_24"
    paddingBottom="@dimen/height_34dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/ok_dp_24">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Title_1_Bold"
        gravity="0x10"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="52dp"
        text="@string/pr_trade_tokenunlocks_header_vesting_info"
        includeFontPadding="false"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"/>
    <TextView
        textAppearance="@style/Body_4"
        textColor="@color/okTradeG400"
        id="@+id/content"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/title"/>
    <TextView
        textAppearance="@style/Body_4"
        textColor="@color/okTradeG400"
        id="@+id/tv_data_source_info"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_20dp"
        layout_marginBottom="110dp"
        text="@string/pr_trade_tokenunlocks_data_source"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/content"/>
</androidx.constraintlayout.widget.ConstraintLayout>
