            android:layout_height="wrap_content"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x23="-5"/>
        <TextView
            ellipsize="3"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxsm"
