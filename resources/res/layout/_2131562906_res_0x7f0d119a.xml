            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            layout_marginBottom="8dp"
            maxLines="1"
            NOT_FOUND_0x19="@+id/content_bottom_barrier"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1e="@+id/tv_des"
            style="@style/Label_3_Regular"/>
        <androidx.constraintlayout.widget.Barrier
            id="@+id/content_bottom_barrier"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="false"
            NOT_FOUND_0x15="3"
