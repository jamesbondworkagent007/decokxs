<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_24dp"
    layout_marginRight="@dimen/margin_24dp"
    layout_marginHorizontal="@dimen/margin_24dp">
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        ellipsize="2"
        id="@+id/tv_token_name_header"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginBottom="@dimen/margin_8dp"
        text="@string/pr_swaptrade_selecttoken_colheader_token"
        maxLines="1"
        layout_marginVertical="@dimen/margin_8dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        style="@style/Label_4_Medium"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        ellipsize="2"
        id="@+id/tv_network_name_header"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginBottom="@dimen/margin_8dp"
        text="@string/pr_swaptrade_selecttoken_colheader_network"
        maxLines="1"
        layout_marginVertical="@dimen/margin_8dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        style="@style/Label_4_Medium"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/most_earned_tokens_rv"
        paddingTop="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/padding_16dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
