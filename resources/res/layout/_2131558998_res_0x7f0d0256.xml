<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x800003"
    orientation="1"
    layout_width="0dp"
    android:layout_height="wrap_content">
    <o.C55320xhi
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/parameter_field_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="3"
        includeFontPadding="false"/>
    <o.C55320xhi
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/parameter_field_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="5"
        includeFontPadding="false"/>
</LinearLayout>
