<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/header_container_in"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginBottom="15dp">
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/tv_base_trade_day"
        visibility="2"
        layout_width="-1"
        android:layout_height="28dp"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        style="@style/Label_3_Regular"/>
    <ImageView
        id="@+id/img_trade_type"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginTop="19dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/tv_base_trade_day"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/tv_trade_type_name"
        layout_width="-2"
        android:layout_height="match_parent"
        layout_marginTop="15dp"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0xe="@+id/img_trade_type"
        NOT_FOUND_0x10="@+id/tv_base_trade_day"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.12SP"
        textColor="@color/ContentContrast"
        id="@+id/trade_type_time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0xe="@+id/img_trade_type"
        NOT_FOUND_0x10="@+id/tv_trade_type_name"/>
    <LinearLayout
        gravity="0x800005"
        orientation="1"
        id="@+id/history_sub_recycleView"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="15dp"
        divider="@drawable/_2131231217_res_0x7f0801f1"
        showDividers="middle"
        layout_marginStart="20dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/tv_trade_type_name"
        NOT_FOUND_0x10="@+id/tv_base_trade_day"/>
</androidx.constraintlayout.widget.ConstraintLayout>
