<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <RelativeLayout
        id="@+id/depth_level_layout"
        layout_width="-1"
        android:layout_height="32dp">
        <TextView
            textSize="12sp"
            textColor="@color/ContentContrast"
            gravity="0x10"
            id="@+id/buy"
            layout_width="-2"
            android:layout_height="32dp"
            text="@string/pr_demotrade_btn_buy"
            layout_weight="1"
            layout_marginStart="16dp"
            layout_alignParentStart="true"/>
        <o.C55052xcf
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/depthLevel"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_centerInParent="true"
            NOT_FOUND_0x18="0.001"
            NOT_FOUND_0x19="-6"
            NOT_FOUND_0x1a="@dimen/margin_10dp"/>
        <TextView
            textSize="12sp"
            textColor="@color/ContentContrast"
            gravity="0x800015"
            id="@+id/sell"
            layout_width="-2"
            android:layout_height="32dp"
            text="@string/pr_demotrade_btn_sell"
            layout_weight="1"
            layout_centerVertical="true"
            paddingStart="5dp"
            layout_marginEnd="16dp"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
    <LinearLayout
        id="@+id/list_header"
        visibility="2"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginBottom="@dimen/margin_8dp"
        style="@style/HLinearHFill">
        <LinearLayout
            gravity="0x800003"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textSize="12sp"
                textColor="@color/ContentContrast"
                gravity="0x800003"
                id="@+id/chart_depth_buy"
                visibility="2"
                layout_width="@dimen/width_20dp"
                android:layout_height="@dimen/height_14dp"
                text="@string/pr_trade_charts_colheader_depth_bid_amount"
                layout_marginStart="@dimen/margin_16dp"
                layout_marginEnd="@dimen/margin_6dp"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentContrast"
                gravity="0x800003"
                id="@+id/chart_depth_buy_amount"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_marginStart="16dp"/>
        </LinearLayout>
        <TextView
            textSize="12sp"
            textColor="@color/ContentContrast"
            gravity="0x11"
            id="@+id/chart_depth_price"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"/>
        <LinearLayout
            gravity="0x800005"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textSize="12sp"
                textColor="@color/ContentContrast"
                gravity="0x800005"
                id="@+id/chart_depth_sell_amount"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_marginEnd="16dp"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentContrast"
                gravity="0x800005"
                id="@+id/chart_depth_sell"
                visibility="2"
                layout_width="@dimen/width_20dp"
                android:layout_height="@dimen/height_14dp"
                text="@string/pr_trade_charts_colheader_depth_ask_amount"
                layout_marginStart="@dimen/margin_6dp"
                layout_marginEnd="@dimen/margin_16dp"/>
        </LinearLayout>
    </LinearLayout>
    <o.C39807pzM
        id="@+id/mdv"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginHorizontal="@dimen/margin_16dp"/>
</LinearLayout>
