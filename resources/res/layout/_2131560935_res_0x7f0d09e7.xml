<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/sm"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/sm"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/sm"
    paddingVertical="@dimen/padding_16dp">
    <ImageView
        id="@+id/item_icon_iv"
        background="@drawable/_2131231180_res_0x7f0801cc"
        padding="@dimen/padding_8dp"
        layout_width="@dimen/width_40dp"
        android:layout_height="@dimen/height_40dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_12dp"
        layout_marginRight="@dimen/margin_12dp"
        layout_marginHorizontal="@dimen/margin_12dp"
        NOT_FOUND_0x13="@+id/tv_description"
        NOT_FOUND_0x15="@+id/iv_next"
        NOT_FOUND_0x16="@+id/item_icon_iv"
        NOT_FOUND_0x19="0"
        style="@style/Label_1_Regular"/>
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_description"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_12dp"
        layout_marginTop="@dimen/margin_4dp"
        layout_marginRight="@dimen/margin_12dp"
        layout_marginHorizontal="@dimen/margin_12dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="@+id/iv_next"
        NOT_FOUND_0x16="@+id/item_icon_iv"
        NOT_FOUND_0x18="@+id/tv_title"
        style="@style/Label_1_Regular"/>
    <ImageView
        id="@+id/iv_next"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231647_res_0x7f08039f"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@color/ContentContrast"/>
</androidx.constraintlayout.widget.ConstraintLayout>
