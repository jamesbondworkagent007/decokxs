            layout_marginLeft="16dp"
            layout_marginTop="16dp"
            layout_marginRight="16dp"
            text="@string/pr_metax_header_title_change_address"
            layout_marginHorizontal="16dp"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rv_cell"
