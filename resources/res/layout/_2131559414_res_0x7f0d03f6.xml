<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingTop="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/padding_24dp">
    <LinearLayout
        orientation="0"
        id="@+id/add_single_address"
        paddingLeft="@dimen/padding_24dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_24dp"
        paddingVertical="@dimen/padding_16dp">
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131233687_res_0x7f080b97"
            tint="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_bottom_sheet_add_address"
            layout_marginStart="@dimen/margin_12dp"
            style="@style/Label_1_Regular"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        id="@+id/bulk_import"
        paddingLeft="@dimen/padding_24dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_24dp"
        paddingVertical="@dimen/padding_16dp">
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131234335_res_0x7f080e1f"
            tint="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_bottom_sheet_bulk_import"
            layout_marginStart="@dimen/margin_12dp"
            style="@style/Label_1_Regular"/>
    </LinearLayout>
</LinearLayout>
