<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/icon"
        layout_width="56dp"
        android:layout_height="56dp"
        layout_marginTop="24dp"
        scaleType="fitStart"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/OKTextFont.Bold"
        textSize="@dimen/text_size_26sp"
        textColor="@color/text_amplified"
        gravity="0x11"
        id="@+id/title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="32dp"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginRight="32dp"
        layout_marginHorizontal="32dp"
        NOT_FOUND_0x11="@+id/icon"
        NOT_FOUND_0x13="@dimen/text_size_32sp"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/OKTextFont.Regular"
        textSize="15sp"
        textColor="@color/grey_g700"
        gravity="0x11"
        id="@+id/description"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="32dp"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginRight="32dp"
        layout_marginBottom="@dimen/margin_40dp"
        layout_marginHorizontal="32dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x11="@+id/title"
        NOT_FOUND_0x13="20sp"/>
    <o.wYK
        gravity="0x10"
        id="@+id/checkbox"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/description"
        NOT_FOUND_0x14="-4"/>
</merge>
