<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/BaseSecondary"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="match_parent">
        <FrameLayout
            layout_width="-1"
            android:layout_height="wrap_content">
            <com.airbnb.lottie.LottieAnimationView
                id="@+id/illustrationAnimation"
                layout_width="-1"
                android:layout_height="wrap_content"
                scaleType="fillCenter"
                adjustViewBounds="true"/>
            <View
                layout_gravity="0x30"
                id="@+id/lottieTopShadow"
                background="@drawable/_2131233673_res_0x7f080b89"
                layout_width="-1"
                android:layout_height="30dp"/>
            <View
                layout_gravity="0x50"
                id="@+id/lottieBotShadow"
                background="@drawable/_2131233672_res_0x7f080b88"
                layout_width="-1"
                android:layout_height="30dp"/>
        </FrameLayout>
        <TextView
            textColor="@color/ContentPrimary"
            layout_gravity="0x10"
            id="@+id/title"
            paddingLeft="24dp"
            paddingRight="24dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="24dp"
            text="@string/pr_orbit_upgrade_header_orbiter_plus"
            paddingHorizontal="24dp"
            style="@style/Headline_5_Bold"/>
        <LinearLayout
            orientation="0"
            paddingLeft="24dp"
            paddingTop="16dp"
            paddingRight="24dp"
            paddingBottom="16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            paddingHorizontal="24dp"
            paddingVertical="16dp">
            <ImageView
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131231718_res_0x7f0803e6"
                NOT_FOUND_0x27="@color/ContentPrimary"/>
            <TextView
                textColor="@color/ContentSecondary"
                layout_gravity="0x10"
                id="@+id/tv1"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_orbit_upgrade_textarea_create_larger_groups"
                layout_marginStart="7dp"
                style="@style/Label_1_Regular"/>
        </LinearLayout>
        <LinearLayout
            orientation="0"
            paddingLeft="24dp"
            paddingTop="16dp"
            paddingRight="24dp"
            paddingBottom="16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="24dp"
            paddingVertical="16dp">
            <ImageView
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131234301_res_0x7f080dfd"
                NOT_FOUND_0x27="@color/ContentPrimary"/>
            <TextView
                textColor="@color/ContentSecondary"
                layout_gravity="0x10"
                id="@+id/tv2"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_orbit_upgrade_textarea_livestream_signals"
                layout_marginStart="7dp"
                style="@style/Label_1_Regular"/>
        </LinearLayout>
        <LinearLayout
            orientation="0"
            paddingLeft="24dp"
            paddingTop="16dp"
            paddingRight="24dp"
            paddingBottom="16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="24dp"
            paddingVertical="16dp">
            <ImageView
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131233319_res_0x7f080a27"
                NOT_FOUND_0x27="@color/ContentPrimary"/>
            <TextView
                textColor="@color/ContentSecondary"
                layout_gravity="0x10"
                id="@+id/tv3"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_orbit_upgrade_textarea_get_featured"
                layout_marginStart="7dp"
                style="@style/Label_1_Regular"/>
        </LinearLayout>
        <androidx.cardview.widget.CardView
            id="@+id/card_upgrade_progress"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="24dp"
            layout_marginTop="16dp"
            layout_marginRight="24dp"
            layout_marginHorizontal="24dp"
            NOT_FOUND_0x22="16dp"
            NOT_FOUND_0x23="0dp">
            <LinearLayout
                gravity="0x10"
                orientation="1"
                background="@drawable/_2131232760_res_0x7f0807f8"
                paddingLeft="16dp"
                paddingRight="16dp"
                layout_width="-1"
                android:layout_height="88dp"
                paddingHorizontal="16dp">
                <LinearLayout
                    gravity="0x10"
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginBottom="12dp">
                    <ImageView
                        layout_width="16dp"
                        android:layout_height="16dp"
                        src="@drawable/_2131232783_res_0x7f08080f"
                        NOT_FOUND_0x27="@color/orbit_vip_color"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        textSize="20sp"
                        textColor="@color/orbit_vip_color"
                        id="@+id/tv_upgrade_title"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_orbit_upgrade_title_unlock_with_vip"
                        maxLines="1"
                        layout_marginStart="8dp"
                        NOT_FOUND_0x1e="20sp"
                        NOT_FOUND_0x1f="14sp"
                        NOT_FOUND_0x20="1sp"
                        NOT_FOUND_0x21="1"
                        style="@style/Label_2_Medium"/>
                </LinearLayout>
                <TextView
                    textColor="@color/orbit_vip_color"
                    gravity="0x10"
                    id="@+id/btn_add_funds"
                    focusable="true"
                    clickable="true"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_orbit_upgrade_btn_become_vip"
                    drawablePadding="8dp"
                    drawableEnd="@drawable/_2131233696_res_0x7f080ba0"
                    NOT_FOUND_0x24="@color/orbit_vip_color"
                    style="@style/Label_2_Medium"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <TextView
            textColor="@color/ContentContrast"
            gravity="0x11"
            id="@+id/testVip_tv"
            paddingLeft="24dp"
            paddingRight="24dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            text="@string/pr_orbit_upgrade_desc_orbiter_unavailable_trial"
            paddingHorizontal="24dp"
            style="@style/Body_4"/>
        <o.wYF
            layout_gravity="0x50"
            id="@+id/buttonBox"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="24dp"
            NOT_FOUND_0x25="52"
            NOT_FOUND_0x26="5"/>
    </LinearLayout>
</ScrollView>
