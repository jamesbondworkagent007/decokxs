<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/sm"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/sm"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/sm"
    paddingVertical="@dimen/padding_16dp">
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        textColor="@color/okTradeG400"
        ellipsize="3"
        id="@+id/tvTitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_invest_loan_desc_borrowed"
        maxLines="1"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_borrowed_content"
        background="@drawable/_2131233178_res_0x7f08099a"
        paddingLeft="@dimen/padding_12dp"
        paddingRight="@dimen/padding_12dp"
        layout_width="-2"
        android:layout_height="32dp"
        layout_marginTop="@dimen/margin_12dp"
        paddingHorizontal="@dimen/padding_12dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/tvTitle">
        <ImageView
            id="@+id/iv_borrowed_token_img"
            layout_width="@dimen/width_20dp"
            android:layout_height="@dimen/width_20dp"
            layout_marginEnd="@dimen/margin_8dp"/>
        <TextView
            textAppearance="@style/Label_2_Regular"
            textColor="@color/ContentPrimary"
            id="@+id/tv_borrowed_token_num"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="Est. daily yield"
            maxLines="1"/>
        <TextView
            textAppearance="@style/Label_2_Regular"
            textColor="@color/ContentPrimary"
            id="@+id/tv_borrowed_token_unit"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="ETH"
            maxLines="1"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
