<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="10dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginStart="@dimen/common_page_edge_space"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0">
        <TextView
            textAppearance="@style/TextAppearance.Title.15SP.Medium"
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/tv_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            drawablePadding="6dp"/>
    </LinearLayout>
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="@dimen/text_size_12sp"
        textColor="@color/okTradeG900"
        gravity="0x11"
        id="@+id/tv_cancel_status"
        background="@drawable/_2131234183_res_0x7f080d87"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_futuresgrid_btn_cancel"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x16="@+id/ll_title"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1c="@+id/ll_title"/>
    <o.C55251xgS
        id="@+id/tv_trade_type"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0x1a="@+id/ll_title"
        NOT_FOUND_0x1b="@+id/ll_title"/>
    <TextView
        textAppearance="@style/TextAppearance.Hint.12SP"
        gravity="0x10"
        id="@+id/tv_time"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginStart="6dp"
        NOT_FOUND_0x16="@+id/tv_trade_type"
        NOT_FOUND_0x19="@+id/tv_trade_type"
        NOT_FOUND_0x1c="@+id/tv_trade_type"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcv_view"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        layout_marginBottom="12dp"
        layout_marginStart="@dimen/common_page_edge_space"
        layout_marginEnd="@dimen/common_page_edge_space"
        touchscreenBlocksFocus="false"
        NOT_FOUND_0x15="true"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="@+id/tv_trade_type"/>
    <View
        id="@+id/view_line"
        layout_marginLeft="16dp"
        layout_marginTop="20dp"
        layout_marginRight="16dp"
        layout_marginHorizontal="16dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="@+id/rcv_view"
        style="@style/WidgetDivisionLine"/>
</androidx.constraintlayout.widget.ConstraintLayout>
