<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x11"
    layout_gravity="0x1"
    background="@color/BasePrimary"
    paddingTop="@dimen/xxsm"
    paddingBottom="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x11"
        id="@+id/ll_add_crypto"
        padding="@dimen/xxsm"
        layout_width="-2"
        android:layout_height="wrap_content">
        <ImageView
            layout_width="@dimen/xsm"
            android:layout_height="@dimen/xsm"
            src="@drawable/_2131233687_res_0x7f080b97"/>
        <TextView
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_market_watchlist_btn_add_tokens"
            layout_marginStart="@dimen/xxxsm"
            style="@style/Label_2_Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <View
        layout_gravity="0x10"
        background="@color/BorderPrimary"
        layout_width="1dp"
        android:layout_height="@dimen/xsm"
        layout_marginLeft="@dimen/xxxsm"
        layout_marginRight="@dimen/xxxsm"
        layout_marginHorizontal="@dimen/xxxsm"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x11"
        id="@+id/ll_manage_watchlist"
        padding="@dimen/xxsm"
        layout_width="-2"
        android:layout_height="wrap_content">
        <ImageView
            layout_width="@dimen/xsm"
            android:layout_height="@dimen/xsm"
            src="@drawable/_2131232074_res_0x7f08054a"/>
        <TextView
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_watchlist_manage_tokens"
            layout_marginStart="@dimen/xxxsm"
            style="@style/Label_2_Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
