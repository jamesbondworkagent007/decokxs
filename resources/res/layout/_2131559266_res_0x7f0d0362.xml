<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    paddingTop="@dimen/xxsm"
    paddingBottom="@dimen/xxsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/xxsm">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x800013"
        orientation="1"
        layout_width="@dimen/width_0dp"
        android:layout_height="match_parent"
        layout_weight="1"
        layout_marginEnd="@dimen/xxxsm">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/xxxxsm">
            <TextView
                textColor="?attr/tradeRiseDefault"
                gravity="0x11"
                id="@+id/txTag"
                background="@drawable/_2131231813_res_0x7f080445"
                layout_width="@dimen/xsm"
                android:layout_height="@dimen/xsm"
                maxLines="1"
                layout_marginEnd="@dimen/xxxxsm"
                style="@style/Label_3_Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="?attr/tradeRiseDefault"
                gravity="0x10"
                id="@+id/txAmountTv"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="1"
                style="@style/Label_1_Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentContrast"
            gravity="0x800033"
            layout_gravity="0x10"
            id="@+id/txTimeTv"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            lineSpacingExtra="@dimen/text_size_2sp"
            style="@style/Label_2_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x800015"
        orientation="1"
        layout_width="@dimen/width_0dp"
        android:layout_height="match_parent"
        layout_weight="1">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            gravity="0x800015"
            layout_gravity="0x10"
            id="@+id/tokenValueTv"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/xxxxsm"
            maxLines="1"
            style="@style/Label_1_Medium"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentContrast"
            gravity="0x800015"
            layout_gravity="0x10"
            id="@+id/tokenPriceTv"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_2_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
