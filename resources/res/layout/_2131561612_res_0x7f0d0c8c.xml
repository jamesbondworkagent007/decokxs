<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        layout_gravity="0x1"
        id="@+id/circleSelectedTop"
        background="@drawable/_2131232259_res_0x7f080603"
        layout_width="12dp"
        android:layout_height="12dp"/>
    <View
        layout_gravity="0x1"
        id="@+id/triangleUp"
        background="@drawable/_2131232800_res_0x7f080820"
        layout_width="8dp"
        android:layout_height="4dp"
        backgroundTint="@color/background_lv4"/>
    <LinearLayout
        orientation="1"
        id="@+id/llBottom"
        background="@drawable/_2131233401_res_0x7f080a79"
        padding="6dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        backgroundTint="@color/background_lv4">
        <TextView
            textSize="14sp"
            textColor="@color/white"
            id="@+id/tvTime"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="@dimen/width_200dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/white"
            id="@+id/tvFuturesPrice"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="@dimen/width_200dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/white"
            id="@+id/tvSpotIndex"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="@dimen/width_200dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/white"
            id="@+id/tvGap"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="@dimen/width_200dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/white"
            id="@+id/tvGapRate"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="@dimen/width_200dp"
            style="@style/TextAppearance"/>
    </LinearLayout>
    <View
        layout_gravity="0x1"
        id="@+id/triangleDown"
        background="@drawable/_2131232799_res_0x7f08081f"
        visibility="1"
        layout_width="8dp"
        android:layout_height="4dp"
        backgroundTint="@color/background_lv4"/>
    <View
        layout_gravity="0x1"
        id="@+id/circleSelectedBottom"
        background="@drawable/_2131232259_res_0x7f080603"
        visibility="1"
        layout_width="12dp"
        android:layout_height="12dp"/>
</LinearLayout>
