<?xml version="1.0" encoding="utf-8"?>
<androidx.browser.browseractions.BrowserActionsFallbackMenuView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_gravity="0x11"
    orientation="1"
    id="@+id/browser_actions_menu_view"
    background="@color/browser_actions_bg_grey"
    layout_width="-2"
    android:layout_height="wrap_content"
    minWidth="280dp">
    <TextView
        textSize="13sp"
        textStyle="0x1"
        textColor="@color/browser_actions_title_color"
        ellipsize="3"
        gravity="0x11"
        id="@+id/browser_actions_header_text"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        layout_marginBottom="10dp"
        maxLines="1"
        paddingStart="20dp"
        paddingEnd="20dp"/>
    <View
        background="@color/browser_actions_divider_color"
        layout_width="-1"
        android:layout_height="1dp"/>
    <ListView
        id="@+id/browser_actions_menu_items"
        paddingTop="8dp"
        paddingBottom="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        divider="@null"
        dividerHeight="0dp"/>
</androidx.browser.browseractions.BrowserActionsFallbackMenuView>
