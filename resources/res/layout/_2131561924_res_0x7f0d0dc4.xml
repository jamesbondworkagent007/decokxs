<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/dp24"
    paddingTop="@dimen/dp_16"
    paddingRight="@dimen/dp24"
    paddingBottom="@dimen/dp_16"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp24"
    paddingVertical="@dimen/dp_16">
    <ImageView
        id="@+id/icon"
        layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        src="@drawable/_2131231677_res_0x7f0803bd"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x27="0"/>
    <ImageView
        layout_gravity="0x800055"
        id="@+id/chain_icon"
        background="@drawable/_2131233431_res_0x7f080a97"
        layout_width="@dimen/dp_16"
        android:layout_height="@dimen/dp_16"
        src="@drawable/_2131231603_res_0x7f080373"
        translationX="2dp"
        translationY="2dp"
        NOT_FOUND_0x1e="@+id/icon"
        NOT_FOUND_0x20="@+id/icon"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.15SP.Medium"
        textColor="@color/okTradeG900"
        ellipsize="3"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        includeFontPadding="false"
        layout_marginStart="@dimen/dp_16"
        NOT_FOUND_0x1f="@+id/subTitle"
        NOT_FOUND_0x21="@+id/tv_dex_label"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x23="2"
        NOT_FOUND_0x24="@+id/icon"
        NOT_FOUND_0x27="0"
        NOT_FOUND_0x28="1"
        style="@style/TextAppearance.Title.14SP.Semibold"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentSecondary"
        gravity="0x10"
        layout_gravity="0x10"
        id="@+id/tv_dex_label"
        background="@drawable/_2131233195_res_0x7f0809ab"
        paddingLeft="4dp"
        paddingTop="@dimen/padding_1dp"
        paddingRight="4dp"
        paddingBottom="@dimen/padding_1dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_cedefi_title_dex"
        layout_marginStart="@dimen/dp_4"
        backgroundTint="@color/SurfacePrimary"
        paddingHorizontal="4dp"
        paddingVertical="@dimen/padding_1dp"
        NOT_FOUND_0x1e="@+id/title"
        NOT_FOUND_0x21="@+id/verify_layout"
        NOT_FOUND_0x24="@+id/title"
        NOT_FOUND_0x27="@+id/title"
        style="@style/TextAppearance.Text.10SP"/>
    <FrameLayout
        id="@+id/verify_layout"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1e="@+id/title"
        NOT_FOUND_0x21="@+id/iv_web3"
        NOT_FOUND_0x24="@+id/tv_dex_label"
        NOT_FOUND_0x27="@+id/title">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_label"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232446_res_0x7f0806be"
            tint="@color/BrandPrimaryAlternative"
            layout_marginStart="@dimen/dp_4"/>
        <o.C42991rgp
            id="@+id/iv_verified"
            visibility="2"
            layout_width="-2"
            android:layout_height="@dimen/dp_16"/>
    </FrameLayout>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_web3"
        visibility="2"
        layout_width="14dp"
        android:layout_height="14dp"
        src="@drawable/_2131233620_res_0x7f080b54"
        tint="@color/ContentContrast"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x1e="@+id/title"
        NOT_FOUND_0x21="@+id/incomeRate"
        NOT_FOUND_0x24="@+id/verify_layout"
        NOT_FOUND_0x27="@+id/title"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/okTradeG500"
        id="@+id/subTitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_2"
        includeFontPadding="false"
        layout_marginStart="16dp"
        NOT_FOUND_0x24="@+id/icon"
        NOT_FOUND_0x26="@+id/title"
        style="@style/TextAppearance.Text.12SP"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.15SP.Medium"
        textColor="@color/okTradeG900"
        id="@+id/incomeRate"
        layout_width="-2"
        android:layout_height="wrap_content"
        includeFontPadding="false"
        paddingStart="@dimen/margin_16dp"
        backgroundTint="@color/okTradeG300"
        NOT_FOUND_0x1e="@+id/title"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x27="@+id/title"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/okTradeG500"
        id="@+id/spl"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        text="@string/pr_savings_holdings_pop_card2_label2_apy"
        includeFontPadding="false"
        backgroundTint="@color/okTradeG300"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x26="@+id/incomeRate"
        style="@style/TextAppearance.Text.12SP"/>
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x800003"
        id="@+id/market_tv_liq"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        maxLines="1"
        layout_marginStart="@dimen/dp_48"
        NOT_FOUND_0x1b="12sp"
        NOT_FOUND_0x1c="6sp"
        NOT_FOUND_0x1d="1"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x26="@+id/subTitle"
        style="@style/TextAppearance.Text.12SP"/>
</androidx.constraintlayout.widget.ConstraintLayout>
