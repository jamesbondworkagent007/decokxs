<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingBottom="25dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="@dimen/text_size_18sp"
        textStyle="0x1"
        textColor="@color/grey_g900"
        id="@+id/tvTimeLike"
        paddingLeft="@dimen/margin_16dp"
        paddingRight="@dimen/margin_16dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginBottom="12dp"
        text="@string/pr_spotcharts_bot_header_timeframe_sheet_fav"
        paddingHorizontal="@dimen/margin_16dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_time_like"
        paddingLeft="16dp"
        paddingRight="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/llIntervalsAll"
        paddingLeft="@dimen/padding_16dp"
        paddingRight="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginBottom="@dimen/margin_2dp"
        paddingHorizontal="@dimen/padding_16dp">
        <TextView
            textSize="@dimen/text_size_18sp"
            textStyle="0x1"
            textColor="@color/grey_g900"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_spotcharts_bot_header_timeframe_sheet_all"
            layout_weight="1"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/ll_setting"
            layout_width="-2"
            android:layout_height="wrap_content">
            <TextView
                textSize="@dimen/text_size_12sp"
                textColor="@color/grey_g600"
                id="@+id/tv_setting"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_spotcharts_bot_header_timeframe_sheet_setting"/>
            <ImageView
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131232049_res_0x7f080531"
                layout_marginStart="@dimen/margin_4dp"/>
        </LinearLayout>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_time"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingStart="16dp"
        paddingEnd="8dp"/>
</LinearLayout>
