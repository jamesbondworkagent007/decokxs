<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_upload"
        background="@drawable/_2131231448_res_0x7f0802d8"
        layout_width="-1"
        android:layout_height="72dp">
        <ImageView
            layout_width="32dp"
            android:layout_height="32dp"
            src="@drawable/_2131233687_res_0x7f080b97"
            layout_marginStart="16dp"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_upload_file"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_compliance_common_btn_upload_file"
            layout_marginStart="24dp"
            layout_marginEnd="16dp"
            style="@style/TextAppearance.Text.Medium.16SP"/>
    </LinearLayout>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_upload_tip"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        style="@style/TextAppearance.Text.14SP"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_rv_top"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_uploaded_count"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginEnd="16dp"
            style="@style/TextAppearance.Text.Medium.14SP"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/ll_add"
            background="@drawable/_2131231446_res_0x7f0802d6"
            layout_width="-2"
            android:layout_height="wrap_content"
            minHeight="32dp"
            paddingStart="12dp"
            paddingEnd="12dp">
            <ImageView
                id="@+id/iv_add"
                layout_width="12dp"
                android:layout_height="12dp"
                src="@drawable/_2131233687_res_0x7f080b97"
                layout_marginStart="8dp"
                layout_marginEnd="8dp"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tv_add"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_compliance_common_btn_add_file"
                layout_marginEnd="8dp"
                style="@style/TextAppearance.Text.Medium.12SP"/>
        </LinearLayout>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/upload_files_recyclerview"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        overScrollMode="2"/>
</LinearLayout>
