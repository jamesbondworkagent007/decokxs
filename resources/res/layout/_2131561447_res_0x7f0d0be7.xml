<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    tag="layout/layout_recommendation_card_appeal_bottom_sheet_0"
    paddingTop="@dimen/xxxsm"
    scrollbars="horizontal"
    layout_width="-1"
    android:layout_height="wrap_content"
    fillViewport="true"
    overScrollMode="2"
    paddingStart="@dimen/xsm"
    paddingEnd="@dimen/xsm">
    <LinearLayout
        orientation="1"
        id="@+id/faq_container"
        background="@color/okTradeBgLv1"
        paddingBottom="20dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_recommendation_title_acc_restricted"
            style="@style/Headline_5_Bold"/>
        <TextView
            textColor="@color/ContentSecondary"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/sm"
            text="@string/pr_supportcenter_recommendation_desc_acc_restricted"
            style="@style/Body_3_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/sm"
            text="@string/pr_supportcenter_recommendation_title_to_do"
            style="@style/Title_1_Bold"/>
        <RelativeLayout
            id="@+id/layout_step1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/sm">
            <TextView
                textColor="@color/ContentInverse"
                gravity="0x11"
                id="@+id/tv_number1"
                background="@drawable/_2131231066_res_0x7f08015a"
                layout_width="24dp"
                android:layout_height="24dp"
                text="1"
                layout_alignParentTop="true"
                layout_alignParentStart="true"
                style="@style/Label_2_Bold"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tv_number1_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_supportcenter_recommendation_label_submit_appeal"
                layout_alignParentTop="true"
                layout_marginStart="@dimen/xxsm"
                layout_toEndOf="@+id/tv_number1"
                style="@style/Label_1_Bold"/>
            <View
                id="@+id/view_line_guide"
                background="@color/BorderPrimary"
                layout_width="1dp"
                android:layout_height="match_parent"
                layout_below="@+id/tv_number1"
                layout_marginStart="12dp"
                layout_alignParentStart="true"/>
            <TextView
                textColor="@color/ContentSecondary"
                linksClickable="true"
                id="@+id/tv_number1_des"
                focusable="false"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxxsm"
                text="@string/pr_supportcenter_recommendation_desc_submit_tx_appeal"
                layout_below="@+id/tv_number1_title"
                layout_marginStart="@dimen/xxsm"
                layout_toEndOf="@+id/tv_number1"
                style="@style/Body_2_Regular"/>
        </RelativeLayout>
        <RelativeLayout
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentInverse"
                gravity="0x11"
                id="@+id/tv_number2"
                background="@drawable/_2131231066_res_0x7f08015a"
                layout_width="24dp"
                android:layout_height="24dp"
                text="2"
                layout_alignParentTop="true"
                layout_alignParentStart="true"
                style="@style/Label_2_Bold"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tv_number2_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_supportcenter_recommendation_label_track_progress"
                layout_alignParentTop="true"
                layout_marginStart="@dimen/xxsm"
                layout_toEndOf="@+id/tv_number2"
                style="@style/Label_1_Bold"/>
            <TextView
                textColor="@color/ContentSecondary"
                id="@+id/tv_number2_des"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxxsm"
                text="@string/pr_supportcenter_recommendation_desc_track_progress"
                layout_below="@+id/tv_number2_title"
                layout_marginStart="@dimen/xxsm"
                layout_toEndOf="@+id/tv_number2"
                style="@style/Body_2_Regular"/>
        </RelativeLayout>
        <TextView
            textSize="14sp"
            textColor="@color/ContentSecondary"
            linksClickable="true"
            id="@+id/tv_bottom_guide"
            focusable="false"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/sm"
            layout_marginBottom="@dimen/sm"
            style="@style/TextAppearance.Text.Regular"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
