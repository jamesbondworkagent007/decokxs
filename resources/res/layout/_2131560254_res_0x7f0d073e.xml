<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    focusable="true"
    focusableInTouchMode="true"
    clickable="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        orientation="1"
        id="@+id/alert_creation_view"
        layout_width="-1"
        android:layout_height="match_parent">
        <TextView
            textColor="@color/ContentPrimary"
            paddingTop="@dimen/ok_dp_12"
            paddingBottom="@dimen/ok_dp_12"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginRight="@dimen/margin_24dp"
            text="@string/pr_swaptrade_history_assets_colheader_token"
            layout_marginHorizontal="@dimen/margin_24dp"
            paddingVertical="@dimen/ok_dp_12"
            style="@style/Title_1_Bold"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/select_token"
            background="@drawable/_2131230992_res_0x7f080110"
            paddingLeft="@dimen/ok_dp_12"
            paddingRight="@dimen/ok_dp_12"
            layout_width="-1"
            android:layout_height="@dimen/height_48dp"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginRight="@dimen/margin_24dp"
            layout_marginHorizontal="@dimen/margin_24dp"
            paddingHorizontal="@dimen/ok_dp_12">
            <FrameLayout
                id="@+id/ll_token_logo"
                layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24">
                <ImageView
                    id="@+id/token_image"
                    layout_width="22dp"
                    android:layout_height="22dp"
                    scaleType="7"
                    importantForAccessibility="2"/>
                <ImageView
                    id="@+id/chain_image"
                    background="@drawable/_2131231867_res_0x7f08047b"
                    layout_width="@dimen/dp_10"
                    android:layout_height="@dimen/dp_10"
                    layout_marginTop="@dimen/margin_14dp"
                    src="@drawable/_2131231603_res_0x7f080373"
                    scaleType="7"
                    importantForAccessibility="2"
                    layout_marginStart="@dimen/margin_14dp"
                    backgroundTint="@color/line_light"/>
            </FrameLayout>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x10"
                id="@+id/token_name"
                layout_width="0dp"
                android:layout_height="match_parent"
                layout_weight="1"
                layout_marginStart="@dimen/margin_8dp"
                layout_marginEnd="@dimen/ok_dp_16"
                style="@style/Body_2_Regular"/>
            <ImageView
                id="@+id/token_caret"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131231588_res_0x7f080364"
                importantForAccessibility="2"/>
        </LinearLayout>
        <TextView
            textColor="@color/ContentPrimary"
            paddingTop="@dimen/ok_dp_12"
            paddingBottom="@dimen/ok_dp_12"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginTop="@dimen/dp24"
            layout_marginRight="@dimen/margin_24dp"
            text="@string/pr_swaptrade_market_alerts_title_type"
            layout_marginHorizontal="@dimen/margin_24dp"
            paddingVertical="@dimen/ok_dp_12"
            style="@style/Title_1_Bold"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/select_alert_type"
            background="@drawable/_2131230992_res_0x7f080110"
            paddingLeft="@dimen/ok_dp_12"
            paddingRight="@dimen/ok_dp_12"
            layout_width="-1"
            android:layout_height="@dimen/height_48dp"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginRight="@dimen/margin_24dp"
            layout_marginHorizontal="@dimen/margin_24dp"
            paddingHorizontal="@dimen/ok_dp_12">
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x10"
                id="@+id/tv_alert_type"
                layout_width="0dp"
                android:layout_height="match_parent"
                layout_weight="1"
                layout_marginEnd="@dimen/ok_dp_16"
                style="@style/Body_2_Regular"/>
            <ImageView
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131231588_res_0x7f080364"
                importantForAccessibility="2"
                NOT_FOUND_0x2b="@color/ContentPrimary"/>
        </LinearLayout>
        <LinearLayout
            orientation="1"
            id="@+id/ll_price_value_change"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="@dimen/dp24"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <TextView
                    textColor="@color/ContentPrimary"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_modal_dialog_label_price"
                    style="@style/Label_2_Medium"/>
                <TextView
                    textColor="@color/ContentContrast"
                    gravity="0x800005"
                    id="@+id/tv_market_price_label"
                    visibility="2"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_create_alert_current"
                    layout_weight="1"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/market_price"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/dp_8"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
            <LinearLayout
                gravity="0x10"
                id="@+id/ll_price_input_view"
                background="@drawable/_2131231791_res_0x7f08042f"
                padding="@dimen/ok_dp_12"
                layout_width="-1"
                android:layout_height="@dimen/height_48dp"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="@dimen/dp_8"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/market_price_input_currency"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Body_2_Regular"/>
                <o.C55001xbh
                    theme="@style/OKUITheme.Alternative.Web3"
                    textAppearance="@style/Body_2_Regular"
                    textColor="@color/ContentPrimary"
                    textColorHint="@color/ContentDisabled"
                    layout_gravity="0x800013"
                    id="@+id/market_price_input"
                    background="@null"
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    hint="@string/pr_swaptrade_market_alerts_placeholder_enter_price"
                    singleLine="true"
                    layout_weight="1"
                    inputType="0x2002"
                    imeOptions="0x6"
                    textAlignment="5"
                    layout_marginStart="@dimen/ok_dp_12"/>
                <o.C55251xgS
                    id="@+id/market_price_percent_tag"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/ok_dp_16"
                    NOT_FOUND_0x2a="6"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                id="@+id/ll_price_options"
                layout_width="-1"
                android:layout_height="@dimen/height_32dp"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="@dimen/ok_dp_12"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp"/>
        </LinearLayout>
        <LinearLayout
            orientation="1"
            id="@+id/ll_price_value_change_percent"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="@dimen/dp24"
                layout_marginRight="@dimen/margin_24dp"
                text="@string/pr_swaptrade_market_alerts_title_price_change"
                layout_marginHorizontal="@dimen/margin_24dp"
                style="@style/Label_2_Medium"/>
            <LinearLayout
                gravity="0x10"
                orientation="0"
                id="@+id/ll_price_input_view_percent"
                background="@drawable/_2131231791_res_0x7f08042f"
                padding="@dimen/ok_dp_12"
                layout_width="-1"
                android:layout_height="@dimen/height_48dp"
                layout_marginLeft="@dimen/dp24"
                layout_marginTop="@dimen/margin_8dp"
                layout_marginRight="@dimen/dp24"
                layout_marginHorizontal="@dimen/dp24">
                <LinearLayout
                    gravity="0x10"
                    orientation="0"
                    id="@+id/ll_price_change_interval"
                    layout_width="-2"
                    android:layout_height="match_parent">
                    <TextView
                        textColor="@color/ContentPrimary"
                        id="@+id/tv_market_price_change_interval"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        style="@style/Label_1_Regular"/>
                    <ImageView
                        layout_width="@dimen/ok_dp_12"
                        android:layout_height="@dimen/ok_dp_12"
                        src="@drawable/_2131231588_res_0x7f080364"
                        importantForAccessibility="2"
                        layout_marginStart="@dimen/margin_2dp"
                        NOT_FOUND_0x2b="@color/ContentPrimary"/>
                </LinearLayout>
                <View
                    background="@color/BorderPrimary"
                    layout_width="1dp"
                    android:layout_height="@dimen/ok_dp_12"
                    layout_marginStart="@dimen/ok_dp_12"/>
                <o.C55001xbh
                    theme="@style/OKUITheme.Alternative.Web3"
                    textAppearance="@style/Body_2_Regular"
                    textColor="@color/ContentPrimary"
                    textColorHint="@color/ContentDisabled"
                    layout_gravity="0x800013"
                    id="@+id/market_price_change_percent"
                    background="@null"
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    hint="@string/pr_swaptrade_market_alerts_placeholder_enter_pct"
                    singleLine="true"
                    layout_weight="1"
                    inputType="0x2002"
                    imeOptions="0x6"
                    textAlignment="5"
                    layout_marginStart="@dimen/ok_dp_12"/>
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tv_percent"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="%"
                    layout_marginStart="@dimen/ok_dp_16"
                    style="@style/Label_1_Regular"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            orientation="1"
            id="@+id/ll_mcap_change"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="@dimen/dp24"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <TextView
                    textColor="@color/ContentPrimary"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_market_alerts_desc_mcap"
                    style="@style/Label_2_Medium"/>
                <TextView
                    textColor="@color/ContentContrast"
                    gravity="0x800005"
                    id="@+id/tv_market_cap_label"
                    visibility="2"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_create_alert_current"
                    layout_weight="1"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tv_market_cap"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/dp_8"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
            <LinearLayout
                gravity="0x10"
                id="@+id/ll_mcap_input_view"
                background="@drawable/_2131231791_res_0x7f08042f"
                padding="@dimen/ok_dp_12"
                layout_width="-1"
                android:layout_height="@dimen/height_48dp"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="@dimen/dp_8"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tv_mcap_input_currency"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Body_2_Regular"/>
                <o.C55001xbh
                    theme="@style/OKUITheme.Alternative.Web3"
                    textAppearance="@style/Body_2_Regular"
                    textColor="@color/ContentPrimary"
                    textColorHint="@color/ContentDisabled"
                    layout_gravity="0x800013"
                    id="@+id/market_cap_input"
                    background="@null"
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    hint="@string/pr_swaptrade_market_alerts_desc_mcap_enter"
                    singleLine="true"
                    layout_weight="1"
                    inputType="0x2002"
                    imeOptions="0x6"
                    textAlignment="5"
                    layout_marginStart="@dimen/ok_dp_12"/>
                <o.C55251xgS
                    id="@+id/market_cap_percent_tag"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginLeft="@dimen/ok_dp_12"
                    layout_marginRight="@dimen/ok_dp_12"
                    layout_marginHorizontal="@dimen/ok_dp_12"
                    NOT_FOUND_0x2a="6"/>
                <LinearLayout
                    gravity="0x10"
                    orientation="0"
                    id="@+id/ll_mcap_kmb"
                    layout_width="-2"
                    android:layout_height="wrap_content">
                    <TextView
                        textColor="@color/ContentPrimary"
                        id="@+id/tv_mcap_kmb"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        style="@style/Label_1_Regular"/>
                    <ImageView
                        layout_width="@dimen/ok_dp_12"
                        android:layout_height="@dimen/ok_dp_12"
                        src="@drawable/_2131231588_res_0x7f080364"
                        importantForAccessibility="2"
                        layout_marginStart="@dimen/margin_2dp"
                        NOT_FOUND_0x2b="@color/ContentPrimary"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <TextView
            textColor="@color/ContentPrimary"
            paddingTop="@dimen/ok_dp_12"
            paddingBottom="@dimen/ok_dp_12"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginTop="@dimen/dp24"
            layout_marginRight="@dimen/margin_24dp"
            text="@string/pr_swaptrade_market_alerts_title_frequency"
            layout_marginHorizontal="@dimen/margin_24dp"
            paddingVertical="@dimen/ok_dp_12"
            style="@style/Title_1_Bold"/>
        <LinearLayout
            orientation="0"
            layout_width="-1"
            android:layout_height="40dp"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginRight="@dimen/margin_24dp"
            layout_marginBottom="@dimen/margin_24dp"
            layout_marginHorizontal="@dimen/margin_24dp">
            <TextView
                gravity="0x11"
                id="@+id/alert_frequency_repeat"
                background="@drawable/_2131231791_res_0x7f08042f"
                layout_width="@dimen/width_0dp"
                android:layout_height="match_parent"
                text="@string/pr_swaptrade_market_alerts_desc_repeat"
                layout_weight="1"
                layout_marginEnd="@dimen/dp_8"
                style="@style/Label_2_Regular"/>
            <TextView
                gravity="0x11"
                id="@+id/alert_frequency_once"
                background="@drawable/_2131231791_res_0x7f08042f"
                layout_width="@dimen/width_0dp"
                android:layout_height="match_parent"
                text="@string/pr_swaptrade_market_alerts_desc_once"
                layout_weight="1"
                style="@style/Label_2_Regular"/>
        </LinearLayout>
        <o.wYF
            id="@+id/button_box"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x28="@string/pr_swaptrade_token_detail_tips_increase"
            NOT_FOUND_0x29="@string/pr_swaptrade_filter_dialog_btn_reset"/>
    </LinearLayout>
</LinearLayout>
