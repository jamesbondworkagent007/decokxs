<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@android:color/transparent"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_default"
    layout_marginTop="16dp"
    layout_marginRight="@dimen/margin_default"
    layout_marginBottom="16dp"
    layout_marginHorizontal="@dimen/margin_default"
    layout_marginVertical="16dp">
    <com.google.android.material.card.MaterialCardView
        id="@+id/videoCardView"
        layout_width="-1"
        android:layout_height="0dp"
        NOT_FOUND_0x1c="@color/ContentPrimary"
        NOT_FOUND_0x1d="16dp"
        NOT_FOUND_0x1e="0dp"
        NOT_FOUND_0x20="16:9"
        NOT_FOUND_0x24="0"
        NOT_FOUND_0x25="@color/BrandPrimaryAlternative"
        NOT_FOUND_0x26="2dp">
        <FrameLayout
            id="@+id/videoContainer"
            layout_width="-1"
            android:layout_height="match_parent">
            <FrameLayout
                id="@+id/playerContainer"
                layout_width="-1"
                android:layout_height="match_parent"/>
            <ImageView
                id="@+id/ivThumbnail"
                background="@color/SurfacePrimary_Dark"
                visibility="2"
                layout_width="-1"
                android:layout_height="match_parent"
                scaleType="fitStart"/>
            <View
                id="@+id/pausedOverlay"
                background="@color/ScrimPrimary"
                visibility="2"
                layout_width="-1"
                android:layout_height="match_parent"/>
            <ProgressBar
                layout_gravity="0x11"
                id="@+id/loadingIndicator"
                visibility="2"
                layout_width="32dp"
                android:layout_height="32dp"
                indeterminateTint="@color/ContentPrimary_Dark"/>
            <View
                layout_gravity="0x30"
                id="@+id/topGradient"
                background="@drawable/_2131231152_res_0x7f0801b0"
                layout_width="-1"
                android:layout_height="40dp"/>
            <LinearLayout
                gravity="0x10"
                orientation="0"
                id="@+id/viewerCountContainer"
                background="@drawable/_2131231456_res_0x7f0802e0"
                paddingLeft="4dp"
                paddingTop="2dp"
                paddingRight="4dp"
                paddingBottom="2dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_margin="8dp"
                paddingHorizontal="4dp"
                paddingVertical="2dp">
                <TextView
                    textColor="@color/ContentInverse_Light"
                    id="@+id/tvViewerCount"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_4_Medium"/>
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tvTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        maxLines="2"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x23="@+id/videoCardView"
        style="@style/Label_1_Medium"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/tokenTagCeFi"
        background="@drawable/_2131231423_res_0x7f0802bf"
        padding="4dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x23="@+id/tvTitle">
        <ImageView
            id="@+id/tokenIconCeFi"
            layout_width="16dp"
            android:layout_height="16dp"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tvTokenSymbolCeFi"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"
            style="@style/Label_3_Medium"/>
        <TextView
            id="@+id/tvTokenChangeCeFi"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="4dp"
            layout_marginRight="4dp"
            layout_marginHorizontal="4dp"
            style="@style/Label_3_Medium"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/tokenTagCeDeFi"
        background="@drawable/_2131231423_res_0x7f0802bf"
        padding="4dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x23="@+id/tvTitle">
        <o.C55389xiy
            id="@+id/tokenIconCeDeFi"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tvTokenSymbolCeDeFi"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"
            style="@style/Label_3_Medium"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
