<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/splash_screen"
    background="@color/BasePrimary"
    visibility="2"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        id="@+id/splash_dapp_icon_container"
        visibility="2"
        layout_width="72dp"
        android:layout_height="72dp"
        NOT_FOUND_0x10="@+id/splash_dapp_name"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0.5"
        NOT_FOUND_0x16="2">
        <com.airbnb.lottie.LottieAnimationView
            layout_gravity="0x11"
            id="@+id/splash_dapp_lottie_bg"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <ImageView
            layout_gravity="0x11"
            id="@+id/splash_dapp_logo"
            layout_width="64dp"
            android:layout_height="64dp"
            importantForAccessibility="2"/>
    </FrameLayout>
    <TextView
        textAppearance="@style/Title_1_Bold"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x11"
        id="@+id/splash_dapp_name"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginBottom="@dimen/dp_52"
        maxWidth="200dp"
        maxLines="1"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/splash_dapp_icon_container"/>
    <o.C55113xdn
        id="@+id/splash_website_spinner"
        visibility="2"
        layout_width="40dp"
        android:layout_height="40dp"
        layout_marginBottom="@dimen/dp_52"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0.5"/>
</androidx.constraintlayout.widget.ConstraintLayout>
