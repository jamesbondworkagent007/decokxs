<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/rowHardwareAddressMore"
    background="@drawable/_2131234015_res_0x7f080cdf"
    paddingLeft="@dimen/padding_16dp"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/padding_16dp"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_16dp"
    paddingVertical="@dimen/padding_16dp">
    <TextView
        textAppearance="@style/Label_3_Medium"
        textColor="@color/grey_g900"
        id="@+id/loadMoreTv"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_addwallet_btn_load_more_addresses"
        maxLines="1"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"/>
    <o.C55113xdn
        layout_gravity="0x11"
        id="@+id/loadingBar"
        layout_width="@dimen/ok_dp_16"
        android:layout_height="@dimen/ok_dp_16"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="@+id/tvLoading"
        NOT_FOUND_0x16="2"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"/>
    <TextView
        textAppearance="@style/Label_3_Medium"
        textColor="@color/grey_g300"
        id="@+id/tvLoading"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_addwallet_btn_loading_more_addresses"
        maxLines="1"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="2"
        NOT_FOUND_0x17="@+id/loadingBar"
        NOT_FOUND_0x19="0"/>
    <androidx.constraintlayout.widget.Group
        id="@+id/loadingGroup"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="loadingBar, tvLoading"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
