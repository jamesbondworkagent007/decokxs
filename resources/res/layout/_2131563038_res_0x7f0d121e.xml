<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_dualcoin_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"/>
    <LinearLayout
        orientation="1"
        id="@+id/ll_gains_content"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="@+id/tv_dualcoin_title"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_coin_amount_first"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="@+id/tv_dualcoin_title"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_coin_currency_first"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="@+id/tv_dualcoin_title"
        NOT_FOUND_0x11="@+id/tv_coin_amount_first"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="@dimen/width_0dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_coin_amount_second"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        maxLines="1"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="@+id/tv_dualcoin_title"
        NOT_FOUND_0x11="@+id/tv_coin_currency_first"
        NOT_FOUND_0x13="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_coin_currency_second"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="@+id/tv_dualcoin_title"
        NOT_FOUND_0x11="@+id/tv_coin_amount_second"
        NOT_FOUND_0x13="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        textColor="@color/orange_lv1"
        ellipsize="3"
        id="@+id/tv_coin_nodata"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_investdeposit_bot_colored_no_data"
        maxLines="1"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="@+id/tv_dualcoin_title"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="1"/>
</merge>
