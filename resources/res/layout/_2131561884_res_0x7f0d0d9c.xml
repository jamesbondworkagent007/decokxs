<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800013"
        id="@+id/tv_filter_striker"
        layout_width="0dp"
        android:layout_height="32dp"
        maxWidth="@dimen/dp_90"
        text="@string/pr_market_colheader_all_strike"
        maxLines="1"
        drawablePadding="4dp"
        drawableEnd="@drawable/_2131231589_res_0x7f080365"
        layout_marginStart="@dimen/common_page_edge_space"
        layout_marginEnd="@dimen/margin_4dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/tv_filter_type"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="1"
        style="@style/TextAppearance.Text.12SP"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800013"
        id="@+id/tv_filter_type"
        layout_width="-2"
        android:layout_height="32dp"
        text="@string/pr_market_colheader_all_type"
        maxLines="1"
        drawablePadding="4dp"
        drawableEnd="@drawable/_2131231589_res_0x7f080365"
        layout_marginStart="124dp"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0"
        style="@style/TextAppearance.Text.12SP"/>
    <androidx.constraintlayout.helper.widget.Flow
        id="@+id/flow"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginEnd="24dp"
        NOT_FOUND_0x11="tv_sort_price,tv_sort_ratio"
        NOT_FOUND_0x12="1"
        NOT_FOUND_0x13="2"
        NOT_FOUND_0x14="1"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="@+id/tv_filter_type"
        NOT_FOUND_0x1a="0"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_sort_price"
        paddingTop="2dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_market_colheader_mark_price"
        maxLines="1"
        drawablePadding="0dp"
        paddingVertical="2dp"
        NOT_FOUND_0x1c="0"
        style="@style/OkSortBar"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_sort_ratio"
        paddingTop="2dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_market_colheader_change_rate"
        maxLines="1"
        drawablePadding="0dp"
        layout_marginEnd="24dp"
        paddingVertical="2dp"
        NOT_FOUND_0x1d="0"
        style="@style/OkSortBar"/>
</merge>
