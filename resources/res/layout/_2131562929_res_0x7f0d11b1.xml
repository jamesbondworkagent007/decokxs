<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/view_video_primary_view_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        id="@+id/video_frame"
        layout_width="-1"
        android:layout_height="match_parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/control_panel"
        layout_width="-1"
        android:layout_height="match_parent">
        <o.wYB
            id="@+id/switch_camera_btn"
            background="@drawable/_2131231005_res_0x7f08011d"
            padding="12dp"
            visibility="2"
            layout_width="48dp"
            android:layout_height="48dp"
            layout_margin="16dp"
            src="@drawable/_2131231580_res_0x7f08035c"
            NOT_FOUND_0x1a="@color/ContentDisabled"
            NOT_FOUND_0x1b="@color/ContentPrimary"
            NOT_FOUND_0x1c="1"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x24="-3"/>
        <ImageView
            id="@+id/image_agent_okx_logo"
            visibility="2"
            layout_width="24dp"
            android:layout_height="24dp"
            layout_margin="24dp"
            src="@drawable/_2131233611_res_0x7f080b4b"
            scaleType="fitStart"
            contentDescription="@null"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x21="0"/>
        <ImageView
            id="@+id/image_okx_logo"
            visibility="2"
            layout_width="48dp"
            android:layout_height="48dp"
            src="@drawable/_2131232701_res_0x7f0807bd"
            scaleType="fitStart"
            contentDescription="@null"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x21="0"/>
        <TextView
            textSize="@dimen/text_size_18sp"
            textColor="@color/ContentPrimary"
            gravity="0x11"
            id="@+id/image_okx_logo_description"
            visibility="2"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="24dp"
            text="@string/pr_supportcenter_video_call_desc_video_call_wait"
            fontFamily="@font/harmony_sans_regular"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="@+id/image_okx_logo"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x23="2"/>
        <ImageView
            id="@+id/image_camera_off"
            visibility="2"
            layout_width="32dp"
            android:layout_height="32dp"
            src="@drawable/_2131234299_res_0x7f080dfb"
            scaleType="fitStart"
            contentDescription="@null"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="@+id/image_okx_logo_description"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x25="@color/SemanticNegative"/>
        <LinearLayout
            gravity="0x11"
            orientation="0"
            id="@+id/title"
            background="@drawable/_2131234011_res_0x7f080cdb"
            paddingLeft="4dp"
            paddingTop="2dp"
            paddingRight="4dp"
            paddingBottom="2dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_margin="12dp"
            paddingHorizontal="4dp"
            paddingVertical="2dp"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1f="0">
            <ImageView
                id="@+id/image_mic_off"
                layout_width="12dp"
                android:layout_height="12dp"
                src="@drawable/_2131233500_res_0x7f080adc"
                contentDescription="@null"
                layout_marginStart="4dp"
                NOT_FOUND_0x25="@color/SemanticNegative"/>
            <TextView
                textColor="@color/color_content_static_default"
                gravity="0x11"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_margin="2dp"
                text="@string/pr_supportcenter_video_call_label_agent"
                style="@style/Label_4_Regular"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
