        android:layout_height="match_parent"
        text=""
        layout_marginEnd="6dp"
        NOT_FOUND_0xd="@+id/finish"
        NOT_FOUND_0xe="0"/>
    <TextView
        textColor="@color/okTradeBlack"
        gravity="0x11"
        id="@+id/finish"
        layout_width="-2"
        android:layout_height="match_parent"
        text="@string/pr_resources_string_complete"
        NOT_FOUND_0xc="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
