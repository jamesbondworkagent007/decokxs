<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="16sp"
            textColor="?android:attr/textColorSecondary"
            ellipsize="4"
            id="@+id/fingerprint_subtitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            singleLine="true"
            marqueeRepeatLimit="-1"
            layout_marginStart="24dp"
            layout_marginEnd="24dp"/>
        <TextView
            textSize="16sp"
            textColor="?android:attr/textColorSecondary"
            id="@+id/fingerprint_description"
            paddingTop="0dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="4"
            layout_marginStart="24dp"
            layout_marginEnd="24dp"/>
        <ImageView
            layout_gravity="0x1"
            id="@+id/fingerprint_icon"
            layout_width="@dimen/fingerprint_icon_size"
            android:layout_height="@dimen/fingerprint_icon_size"
            layout_marginTop="32dp"
            scaleType="fillCenter"/>
        <TextView
            textSize="14sp"
            textColor="?android:attr/textColorSecondary"
            gravity="0x1"
            id="@+id/fingerprint_error"
            paddingTop="16dp"
            paddingBottom="24dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/fingerprint_dialog_touch_sensor"
            layout_marginStart="24dp"
            layout_marginEnd="24dp"
            accessibilityLiveRegion="1"/>
    </LinearLayout>
</ScrollView>
