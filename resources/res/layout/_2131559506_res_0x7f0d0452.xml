<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    theme="@style/OKUITheme.Alternative.Web3"
    paddingLeft="@dimen/margin_default"
    paddingRight="@dimen/margin_default"
    paddingBottom="28dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default">
    <TextView
        textSize="16sp"
        textColor="@color/ContentPrimary"
        id="@+id/label"
        paddingBottom="@dimen/ok_dp_12"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_market_bot_header_search_address"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        style="@style/Label_1_Bold"/>
    <com.okinc.uilab.edit.OKEditText
        theme="@style/OKUITheme.Alternative.Web3"
        textAppearance="@style/Body_1"
        textSize="@dimen/font_18"
        textColor="@color/ContentPrimary"
        textColorHint="@color/ContentContrast"
        gravity="0x800033"
        id="@+id/et_address"
        background="@null"
        padding="0dp"
        focusable="true"
        focusableInTouchMode="true"
        visibility="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/ok_dp_12"
        hint="@string/pr_swaptrade_general_placeholder_address"
        maxLines="3"
        includeFontPadding="false"
        lineSpacingExtra="0dp"
        inputType="0x20001"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="@+id/label"/>
    <o.C52794wYp
        id="@+id/btn_et_action"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        drawablePadding="@dimen/dp_8"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="@+id/et_address"
        NOT_FOUND_0x1e="36"
        NOT_FOUND_0x1f="0x104"/>
</androidx.constraintlayout.widget.ConstraintLayout>
