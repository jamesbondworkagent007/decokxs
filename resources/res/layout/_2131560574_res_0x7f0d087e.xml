<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/item_layout"
    tag="layout/item_im_entrance_with_summary_setting_item_0"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/margin_default"
    paddingTop="@dimen/xsm"
    paddingRight="@dimen/margin_default"
    paddingBottom="@dimen/xsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default"
    paddingVertical="@dimen/xsm">
    <TextView
        ellipsize="3"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginEnd="@dimen/xsm"
        NOT_FOUND_0x14="@+id/tv_summary"
        NOT_FOUND_0x16="@+id/iv_arrow"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"
        style="@style/Label_1_Regular"/>
    <TextView
        textColor="@color/ContentTertiary"
        id="@+id/tv_summary"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxxsm"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="@+id/tv_title"
        NOT_FOUND_0x17="@+id/tv_title"
        NOT_FOUND_0x18="@+id/tv_title"
        style="@style/Label_2_Regular"/>
    <ImageView
        id="@+id/iv_arrow"
        layout_width="-2"
        android:layout_height="wrap_content"
        importantForAccessibility="2"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@color/ContentContrast"/>
</androidx.constraintlayout.widget.ConstraintLayout>
