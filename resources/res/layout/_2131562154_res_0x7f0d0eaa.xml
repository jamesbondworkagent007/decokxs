<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/Body_3_Regular"
        textSize="@dimen/text_size_16sp"
        textColor="?android:attr/textColorPrimary"
        id="@+id/text1"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        lineHeight="22sp"/>
    <com.google.android.flexbox.FlexboxLayout
        id="@+id/constraint_layout"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="1">
        <TextView
            textAppearance="@style/Body_3_Regular"
            textSize="@dimen/text_size_16sp"
            ellipsize="3"
            id="@+id/text2"
            layout_width="-2"
            android:layout_height="wrap_content"
            lineHeight="22sp"
            NOT_FOUND_0x13="true"
            NOT_FOUND_0x15="@+id/avatar_container"
            NOT_FOUND_0x16="2"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/avatar_container"
            background="@drawable/_2131231162_res_0x7f0801ba"
            paddingLeft="@dimen/dp_5"
            paddingRight="@dimen/dp_5"
            layout_width="-2"
            android:layout_height="@dimen/dp_20"
            layout_marginStart="@dimen/dp_8"
            backgroundTint="@color/SurfacePrimary"
            paddingHorizontal="@dimen/dp_5"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x17="@+id/text2"
            NOT_FOUND_0x19="0">
            <ImageView
                id="@+id/avatar1"
                layout_width="@dimen/dp_14"
                android:layout_height="@dimen/dp_14"/>
            <ImageView
                id="@+id/avatar2"
                layout_width="@dimen/dp_14"
                android:layout_height="@dimen/dp_14"
                layout_marginStart="-6dp"/>
            <ImageView
                id="@+id/avatar3"
                layout_width="@dimen/dp_14"
                android:layout_height="@dimen/dp_14"
                layout_marginStart="-6dp"/>
            <TextView
                textAppearance="@style/Label_4_Regular"
                id="@+id/avatar_count"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="4dp"/>
        </LinearLayout>
    </com.google.android.flexbox.FlexboxLayout>
</merge>
