<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131231844_res_0x7f080464"
    padding="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_default"
    layout_marginRight="@dimen/margin_default"
    layout_marginBottom="@dimen/margin_12dp"
    layout_marginHorizontal="@dimen/margin_default">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <FrameLayout
            layout_width="36dp"
            android:layout_height="36dp">
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/token_icon"
                layout_width="36dp"
                android:layout_height="36dp"/>
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x800055"
                id="@+id/platform_icon"
                layout_width="12dp"
                android:layout_height="12dp"/>
        </FrameLayout>
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/margin_12dp">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    id="@+id/token_symbol"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    style="@style/Label_1_Medium"/>
                <TextView
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    id="@+id/token_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    minWidth="40dp"
                    maxLines="1"
                    layout_marginStart="@dimen/margin_4dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/token_time_label"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_3_Regular"/>
                <o.C55064xcr
                    layout_gravity="0x10"
                    id="@+id/dot_view"
                    background="@color/BorderSecondary"
                    layout_width="3dp"
                    android:layout_height="3dp"
                    layout_marginStart="4dp"/>
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/token_mcap_label"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_common_label_mcap_abbreviated"
                    layout_marginStart="@dimen/margin_4dp"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/SemanticNotice"
                    id="@+id/token_mcap_value"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/margin_4dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
        </LinearLayout>
        <o.C52794wYp
            id="@+id/buy_button"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_profile_cell_tag_buy"
            drawableLeft="@drawable/_2131233742_res_0x7f080bce"
            NOT_FOUND_0x1e="28"
            NOT_FOUND_0x1f="0x103"/>
    </LinearLayout>
    <View
        id="@+id/divider"
        background="@drawable/_2131232011_res_0x7f08050b"
        layout_width="-1"
        android:layout_height="1dp"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_16dp"
        layout_marginVertical="@dimen/margin_16dp"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/addresses_count"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_smartmoney_charts_tooltips_smart_money_bought"
            layout_marginStart="@dimen/margin_4dp"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/pnl_modern_profit_default"
            id="@+id/total_bought_amount"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/margin_4dp"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/trader_list_section"
        background="@drawable/_2131230992_res_0x7f080110"
        paddingLeft="@dimen/padding_8dp"
        paddingRight="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_4dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        paddingHorizontal="@dimen/padding_8dp">
        <LinearLayout
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="108dp"
                android:layout_height="wrap_content"
                text="@string/pr_asset_withdrawal_addressbook_details_address"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                layout_width="0dp"
                android:layout_height="wrap_content"
                minWidth="50dp"
                text="@string/pr_swaptrade_common_last_transaction"
                maxLines="1"
                layout_weight="1"
                layout_marginStart="@dimen/margin_8dp"
                layout_marginEnd="@dimen/margin_18dp"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/position_pnl_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_position_and_pnl_new"
                style="@style/Label_3_Regular"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/trader_list"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            nestedScrollingEnabled="false"/>
        <androidx.appcompat.widget.AppCompatImageView
            layout_gravity="0x1"
            id="@+id/expand_button"
            layout_width="12dp"
            android:layout_height="12dp"
            layout_marginTop="@dimen/margin_8dp"
            src="@drawable/_2131231637_res_0x7f080395"
            tint="@color/ContentContrast"/>
    </LinearLayout>
</LinearLayout>
