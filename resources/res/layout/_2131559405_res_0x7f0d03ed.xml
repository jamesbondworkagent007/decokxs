<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentSecondary"
        id="@+id/filter_title_tv"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_invest_smartmoney_card_label_pnl"
        style="@style/Label_2_Medium"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp">
        <com.google.android.material.textfield.TextInputLayout
            gravity="0x11"
            id="@+id/text_input_layout_min"
            background="@drawable/_2131231993_res_0x7f0804f9"
            paddingTop="3dp"
            layout_width="0dp"
            android:layout_height="48dp"
            layout_weight="1"
            NOT_FOUND_0x19="false"
            NOT_FOUND_0x1a="@color/ContentContrast">
            <o.C55001xbh
                theme="@style/OKUITheme.Alternative.Web3"
                textAppearance="@style/Body_2_Regular"
                textSize="@dimen/font_16"
                textColor="@color/ContentPrimary"
                textColorHint="@color/ContentContrast"
                id="@+id/filter_min_et"
                background="@null"
                layout_width="-1"
                android:layout_height="match_parent"
                inputType="0x2"
                paddingStart="@dimen/padding_12dp"
                paddingEnd="@dimen/padding_12dp"/>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            textColorHint="@color/ContentContrast"
            gravity="0x11"
            id="@+id/text_input_layout_max"
            background="@drawable/_2131231993_res_0x7f0804f9"
            paddingTop="3dp"
            layout_width="0dp"
            android:layout_height="48dp"
            layout_weight="1"
            layout_marginStart="12dp"
            NOT_FOUND_0x19="false"
            NOT_FOUND_0x1a="@color/ContentContrast">
            <o.C55001xbh
                theme="@style/OKUITheme.Alternative.Web3"
                textAppearance="@style/Body_2_Regular"
                textSize="@dimen/font_16"
                textColor="@color/ContentPrimary"
                textColorHint="@color/ContentContrast"
                id="@+id/filter_max_et"
                background="@null"
                layout_width="-1"
                android:layout_height="match_parent"
                inputType="0x2"
                paddingStart="@dimen/padding_12dp"
                paddingEnd="@dimen/padding_12dp"/>
        </com.google.android.material.textfield.TextInputLayout>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x11"
            orientation="0"
            id="@+id/unit_picker_view"
            background="@drawable/_2131230992_res_0x7f080110"
            paddingLeft="@dimen/xxsm"
            paddingRight="@dimen/xxsm"
            visibility="2"
            layout_width="0dp"
            android:layout_height="48dp"
            layout_weight="1"
            layout_marginStart="12dp"
            backgroundTint="@color/color_surface_interactive_default"
            paddingHorizontal="@dimen/xxsm">
            <TextView
                textColor="@color/color_content_static_placeholder"
                id="@+id/tv_unit_text"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/Body_2_Regular"/>
            <ImageView
                id="@+id/iv_unit_caret"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131231637_res_0x7f080395"
                NOT_FOUND_0x1b="@color/color_content_static_placeholder"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        textColor="@color/SemanticNegative"
        id="@+id/filter_error_tv"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_swaptrade_market_select_error_min_max"
        style="@style/Label_3_Regular"/>
</androidx.appcompat.widget.LinearLayoutCompat>
