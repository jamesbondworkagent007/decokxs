<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/BasePrimary"
    fitsSystemWindows="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        id="@+id/toolbar"
        background="@color/BasePrimary"
        layout_width="-1"
        android:layout_height="@dimen/appbar_height"
        NOT_FOUND_0xd="0dp"
        NOT_FOUND_0xe="0dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginLeft="@dimen/margin_default"
            layout_marginRight="@dimen/margin_default"
            layout_marginHorizontal="@dimen/margin_default">
            <o.wYC
                id="@+id/menu_back_icon"
                background="?attr/selectableItemBackgroundBorderless"
                layout_width="@dimen/width_28dp"
                android:layout_height="@dimen/width_28dp"
                src="@drawable/_2131232348_res_0x7f08065c"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="0"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/title_text"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="0"
                style="@style/TextAppearance.Title.18SP.Semibold"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>
    <androidx.core.widget.NestedScrollView
        background="@color/BasePrimary"
        layout_width="-1"
        android:layout_height="0dp"
        fillViewport="true"
        layout_weight="1">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.fragment.app.FragmentContainerView
                id="@+id/preview_container"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <androidx.fragment.app.FragmentContainerView
                id="@+id/info_container"
                layout_width="-1"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
