<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/icon"
        layout_width="56dp"
        android:layout_height="56dp"
        layout_marginTop="8dp"
        scaleType="fitStart"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xe="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        gravity="0x11"
        id="@+id/title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="36dp"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginRight="36dp"
        layout_marginHorizontal="36dp"
        NOT_FOUND_0xd="@+id/icon"
        style="@style/Title_2_Bold"/>
    <androidx.appcompat.widget.AppCompatTextView
        gravity="0x11"
        id="@+id/description"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="36dp"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginRight="36dp"
        layout_marginBottom="@dimen/margin_24dp"
        layout_marginHorizontal="36dp"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xd="@+id/title"
        style="@style/Body_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
