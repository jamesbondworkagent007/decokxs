<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingTop="20dp"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textAppearance="@style/TextAppearance.Title.12SP.Medium"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        text="@string/pr_swaptrade_address_details_title_receive_address"
        layout_marginHorizontal="16dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_address_input"
        background="@drawable/_2131231794_res_0x7f080432"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="4dp"
        layout_marginRight="16dp"
        layout_marginHorizontal="16dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_scan"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231953_res_0x7f0804d1"
            layout_marginEnd="10dp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1e="0"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_clear"
            visibility="1"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231952_res_0x7f0804d0"
            layout_marginEnd="10dp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="@+id/iv_scan"
            NOT_FOUND_0x1e="0"/>
        <o.C24739ijX
            textAppearance="@style/TextAppearance.Title.15SP"
            textColorHint="@color/okTradeG300"
            gravity="0x10"
            id="@+id/et_address"
            background="@null"
            paddingTop="12dp"
            paddingBottom="12dp"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_marginLeft="12dp"
            layout_marginRight="12dp"
            hint="@string/pr_swaptrade_details_inputbox_text_enter_address"
            scrollHorizontally="false"
            inputType="0x20001"
            imeOptions="0x2"
            layout_marginHorizontal="12dp"
            paddingVertical="12dp"
            NOT_FOUND_0x1c="@+id/iv_clear"
            NOT_FOUND_0x1d="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        textAppearance="@style/TextAppearance.Red.12SP"
        id="@+id/tv_error_notice"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="4dp"
        layout_marginRight="16dp"
        layout_marginHorizontal="16dp"/>
    <o.C24736ijU
        id="@+id/elv_address_list"
        layout_width="-1"
        android:layout_height="0dp"
        layout_marginTop="20dp"
        groupIndicator="@null"
        divider="@null"
        layout_weight="1"/>
</LinearLayout>
