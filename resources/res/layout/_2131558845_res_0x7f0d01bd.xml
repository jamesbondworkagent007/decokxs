<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@drawable/_2131231490_res_0x7f080302"
    paddingBottom="@dimen/padding_32dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <FrameLayout
        id="@+id/vTitle"
        layout_width="-1"
        android:layout_height="@dimen/width_48dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0">
        <TextView
            textAppearance="@style/TextAppearance.Title.18SP.Medium"
            layout_gravity="0x10"
            id="@+id/tv_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            minWidth="@dimen/width_48dp"
            layout_marginStart="@dimen/margin_24dp"
            layout_marginEnd="@dimen/margin_48dp"/>
        <ImageView
            layout_gravity="0x800005"
            id="@+id/iv_close"
            layout_width="-2"
            android:layout_height="match_parent"
            src="@drawable/_2131232438_res_0x7f0806b6"
            scaleType="7"
            minWidth="@dimen/width_48dp"
            layout_marginEnd="@dimen/margin_4dp"
            NOT_FOUND_0x17="@color/grey_g400"/>
    </FrameLayout>
    <View
        id="@+id/vDivider"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/vTitle"
        style="@style/C2C_Divider"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_payment_methods"
        background="@color/white_background_color"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x11="320dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/vDivider"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textColor="@color/grey_g400"
        gravity="0x11"
        id="@+id/tv_hint_maxcards"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_22dp"
        text="@string/lt_unipay_paymentmethod_drawer_hint_maxcards"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/rv_payment_methods"/>
    <o.C52794wYp
        id="@+id/button_add"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_22dp"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/tv_hint_maxcards"
        NOT_FOUND_0x15="52"
        NOT_FOUND_0x16="0x102"/>
</androidx.constraintlayout.widget.ConstraintLayout>
