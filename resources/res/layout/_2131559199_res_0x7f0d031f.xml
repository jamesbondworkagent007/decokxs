<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="20dp"
    layout_marginStart="17dp"
    layout_marginEnd="17dp">
    <LinearLayout
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <RelativeLayout
            id="@+id/rl_from_token"
            background="@drawable/_2131231880_res_0x7f080488"
            focusable="true"
            clickable="true"
            layout_width="-1"
            android:layout_height="72dp"
            paddingStart="@dimen/dp_8"
            paddingEnd="2dp">
            <TextView
                textSize="12sp"
                textColor="@color/grey_g400"
                gravity="0x11"
                id="@+id/from_chain_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="10dp"
                fontFamily="@font/font_alpha_regular"
                layout_marginStart="8dp"/>
            <ImageView
                id="@+id/from_coin_image"
                layout_width="28dp"
                android:layout_height="28dp"
                layout_marginTop="8dp"
                scaleType="7"
                layout_below="@+id/from_chain_desc"
                layout_alignStart="@+id/from_chain_desc"/>
            <TextView
                textSize="16sp"
                textColor="@color/grey_g900"
                gravity="0x11"
                id="@+id/from_token_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="12dp"
                singleLine="true"
                layout_below="@+id/from_chain_desc"
                fontFamily="@font/harmony_sans_bold"
                layout_marginStart="8dp"
                layout_marginEnd="6dp"
                layout_toEndOf="@+id/from_coin_image"/>
            <TextView
                textSize="60sp"
                textColor="@color/ContentContrast"
                id="@+id/from_number"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="2dp"
                includeFontPadding="false"
                alpha="0.1"
                fontFamily="@font/harmony_sans_bold"
                layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <ImageView
        layout_gravity="0x10"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231868_res_0x7f08047c"
        scaleType="7"/>
    <LinearLayout
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <RelativeLayout
            id="@+id/rl_bridge_token"
            background="@drawable/_2131231880_res_0x7f080488"
            paddingLeft="@dimen/dp_8"
            paddingRight="@dimen/dp_8"
            focusable="true"
            clickable="true"
            layout_width="-1"
            android:layout_height="72dp"
            paddingHorizontal="@dimen/dp_8">
            <TextView
                textSize="12sp"
                textColor="@color/grey_g400"
                gravity="0x11"
                id="@+id/bridge_chain_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="10dp"
                fontFamily="@font/font_alpha_regular"/>
            <ImageView
                id="@+id/bridge_coin_image"
                layout_width="28dp"
                android:layout_height="28dp"
                layout_marginTop="8dp"
                scaleType="7"
                layout_below="@+id/bridge_chain_desc"
                layout_alignStart="@+id/bridge_chain_desc"/>
            <TextView
                textSize="16sp"
                textColor="@color/grey_g900"
                ellipsize="3"
                gravity="0x11"
                id="@+id/bridge_token_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="12dp"
                lines="1"
                layout_below="@+id/bridge_chain_desc"
                fontFamily="@font/harmony_sans_bold"
                layout_marginStart="8dp"
                layout_toEndOf="@+id/bridge_coin_image"/>
            <TextView
                textSize="60sp"
                textColor="@color/ContentContrast"
                id="@+id/bridge_number"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="2dp"
                includeFontPadding="false"
                alpha="0.1"
                fontFamily="@font/harmony_sans_bold"
                layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <ImageView
        layout_gravity="0x10"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231868_res_0x7f08047c"
        scaleType="7"/>
    <LinearLayout
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <RelativeLayout
            id="@+id/rl_to_token"
            background="@drawable/_2131231880_res_0x7f080488"
            paddingLeft="@dimen/dp_8"
            paddingRight="@dimen/dp_8"
            focusable="true"
            clickable="true"
            layout_width="-1"
            android:layout_height="72dp"
            paddingHorizontal="@dimen/dp_8">
            <TextView
                textSize="12sp"
                textColor="@color/grey_g400"
                gravity="0x11"
                id="@+id/to_chain_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="10dp"
                fontFamily="@font/font_alpha_regular"/>
            <ImageView
                id="@+id/to_coin_image"
                layout_width="28dp"
                android:layout_height="28dp"
                layout_marginTop="8dp"
                scaleType="7"
                layout_below="@+id/to_chain_desc"
                layout_alignStart="@+id/to_chain_desc"/>
            <TextView
                textSize="16sp"
                textColor="@color/grey_g900"
                ellipsize="3"
                gravity="0x11"
                id="@+id/to_token_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="12dp"
                lines="1"
                layout_below="@+id/to_chain_desc"
                fontFamily="@font/harmony_sans_bold"
                layout_marginStart="8dp"
                layout_toEndOf="@+id/to_coin_image"/>
            <TextView
                textSize="60sp"
                textColor="@color/ContentContrast"
                id="@+id/to_number"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="2dp"
                includeFontPadding="false"
                alpha="0.1"
                fontFamily="@font/harmony_sans_bold"
                layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
