<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    paddingLeft="@dimen/padding_16dp"
    paddingRight="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="70dp"
    layout_marginTop="@dimen/margin_8dp"
    paddingHorizontal="@dimen/padding_16dp">
    <View
        background="@drawable/_2131231869_res_0x7f08047d"
        layout_width="-1"
        android:layout_height="2dp"
        layout_centerVertical="true"
        layout_toStartOf="@+id/exchange_to_coin"
        layout_toEndOf="@+id/exchange_from_coin"/>
    <o.C24484ieh
        id="@+id/exchange_from_coin"
        layout_width="36dp"
        android:layout_height="36dp"
        layout_centerVertical="true"
        layout_alignParentStart="true"/>
    <TextView
        textSize="14sp"
        gravity="0x11"
        id="@+id/tv_percent"
        background="@color/okTradeBgLv1"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        layout_marginStart="7dp"
        layout_toEndOf="@+id/exchange_from_coin"
        style="@style/TextAppearance.Title.14SP.Medium"/>
    <ImageView
        id="@+id/arrow_start"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231868_res_0x7f08047c"
        scaleType="7"
        layout_centerVertical="true"
        layout_marginStart="19dp"
        layout_toEndOf="@+id/tv_percent"/>
    <o.C24485iei
        id="@+id/coin_pair"
        layout_width="66dp"
        android:layout_height="58dp"
        layout_centerInParent="true"/>
    <ImageView
        id="@+id/arrow_end"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231868_res_0x7f08047c"
        scaleType="7"
        layout_centerVertical="true"
        layout_marginStart="44dp"
        layout_toEndOf="@+id/coin_pair"/>
    <o.C24484ieh
        id="@+id/exchange_to_coin"
        layout_width="36dp"
        android:layout_height="36dp"
        layout_centerVertical="true"
        layout_alignParentEnd="true"/>
</RelativeLayout>
