<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/total_container"
    background="@drawable/_2131231486_res_0x7f0802fe"
    layout_width="-2"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        id="@+id/ll_dialog_progress"
        padding="24dp"
        visibility="2"
        layout_width="280dp"
        android:layout_height="wrap_content">
        <TextView
            textSize="20sp"
            textColor="@color/primary_blue_color"
            id="@+id/tv_progress_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/app_name"/>
        <LinearLayout
            gravity="0x11"
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="20dp">
            <o.C55113xdn
                id="@+id/view_loading"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x18="true"/>
            <TextView
                textSize="16sp"
                textColor="@color/text_color"
                id="@+id/tv_progress_msg"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="15dp"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/ll_dialog_normal"
        layout_width="275dp"
        android:layout_height="wrap_content">
        <o.C55055xci
            id="@+id/content_panel"
            padding="@dimen/padding_24dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x17="@dimen/margin_16dp">
            <o.C55022xcB
                id="@+id/section"
                layout_width="-1"
                android:layout_height="wrap_content"/>
        </o.C55055xci>
        <FrameLayout
            id="@+id/fl_container"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="20dp"/>
        <LinearLayout
            orientation="1"
            id="@+id/ll_content"
            layout_width="-1"
            android:layout_height="wrap_content">
            <View
                background="@color/list_divider_color"
                layout_width="-1"
                android:layout_height="0.5dp"/>
            <LinearLayout
                orientation="0"
                id="@+id/ll_option"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textSize="16sp"
                    textColor="@color/subtitle_color"
                    ellipsize="3"
                    gravity="0x11"
                    id="@+id/tv_dialog_nav"
                    paddingLeft="@dimen/dialog_option_text_padding_horizontal"
                    paddingTop="@dimen/dialog_option_text_padding_vertical"
                    paddingRight="@dimen/dialog_option_text_padding_horizontal"
                    paddingBottom="@dimen/dialog_option_text_padding_vertical"
                    layout_width="0dp"
                    android:layout_height="@dimen/dialog_option_height"
                    maxLines="2"
                    layout_weight="1"
                    paddingHorizontal="@dimen/dialog_option_text_padding_horizontal"
                    paddingVertical="@dimen/dialog_option_text_padding_vertical"/>
                <View
                    id="@+id/v_dialog_btn_div"
                    background="@color/list_divider_color"
                    layout_width="0.5dp"
                    android:layout_height="@dimen/dialog_option_height"/>
                <TextView
                    textSize="16sp"
                    textColor="@color/primary_blue_color"
                    ellipsize="3"
                    gravity="0x11"
                    id="@+id/tv_dialog_positive"
                    paddingLeft="@dimen/dialog_option_text_padding_horizontal"
                    paddingTop="@dimen/dialog_option_text_padding_vertical"
                    paddingRight="@dimen/dialog_option_text_padding_horizontal"
                    paddingBottom="@dimen/dialog_option_text_padding_vertical"
                    layout_width="0dp"
                    android:layout_height="@dimen/dialog_option_height"
                    maxLines="2"
                    layout_weight="1"
                    paddingHorizontal="@dimen/dialog_option_text_padding_horizontal"
                    paddingVertical="@dimen/dialog_option_text_padding_vertical"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
