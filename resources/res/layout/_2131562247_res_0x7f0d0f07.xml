<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/titleContainer"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_smartarb_placeorder_tips_est_close_pnl"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/estClosePnlTv"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="16dp"
            style="@style/Label_2_Medium"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/advancedArrowIv"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231637_res_0x7f080395"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/advancedContainer"
        background="@drawable/_2131231155_res_0x7f0801b3"
        padding="@dimen/ok_dp_16"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_10dp"
        layout_below="@+id/titleContainer">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_smartarb_placeorder_tips_est_close_spread"
                layout_weight="1"
                layout_marginEnd="@dimen/ok_dp_16"
                style="@style/TextAppearance.Text.12SP"/>
            <TextView
                textColor="@color/ContentSecondary"
                id="@+id/estCloseSpreadTv"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Text.12SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_smartarb_botdetails_tips_spot_close_fee"
                layout_weight="1"
                layout_marginEnd="@dimen/ok_dp_16"
                style="@style/TextAppearance.Text.12SP"/>
            <TextView
                textColor="@color/ContentSecondary"
                id="@+id/spotCloseFeeTv"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Text.12SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_smartarb_botdetails_tips_futures_close_fee"
                layout_weight="1"
                layout_marginEnd="@dimen/ok_dp_16"
                style="@style/TextAppearance.Text.12SP"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Medium"
                textColor="@color/ContentSecondary"
                id="@+id/swapCloseFeeTv"
                layout_width="-2"
                android:layout_height="wrap_content"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/convertFeeContainer"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp">
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/convertFeeTitleTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                layout_marginEnd="@dimen/ok_dp_16"
                style="@style/TextAppearance.Text.12SP"/>
            <TextView
                textColor="@color/ContentSecondary"
                id="@+id/convertFeeTv"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Text.12SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <View
            background="@color/okTradeG100"
            layout_width="-1"
            android:layout_height="0.5dp"
            layout_marginTop="@dimen/margin_12dp"/>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/explainTv"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            style="@style/TextAppearance.Text.12SP"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</RelativeLayout>
