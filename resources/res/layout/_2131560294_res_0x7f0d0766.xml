<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/vg_trade_details"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        gravity="0x10"
        orientation="0"
        id="@+id/network_panel"
        layout_width="-1"
        android:layout_height="52dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            textColor="@color/ContentContrast"
            layout_gravity="0x10"
            id="@+id/tv_network_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_investdeposit_mid_text_network"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="0"/>
        <ImageView
            id="@+id/iv_network"
            layout_width="@dimen/width_24dp"
            android:layout_height="@dimen/height_24dp"
            layout_marginStart="20dp"
            layout_marginEnd="@dimen/margin_8dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/tv_network"
            NOT_FOUND_0x18="1"
            NOT_FOUND_0x19="2"
            NOT_FOUND_0x1a="@+id/tv_network_title"
            NOT_FOUND_0x1c="0"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP.Medium"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x10"
            id="@+id/tv_network"
            layout_width="0dp"
            android:layout_height="match_parent"
            maxLines="1"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x1a="@+id/iv_network"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/slippage_panel"
        paddingTop="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/padding_16dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            gravity="0x10"
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textAppearance="@style/TextAppearance.Title.16SP"
                textColor="@color/ContentContrast"
                gravity="0x800003"
                id="@+id/tvSlippageTitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_investredeem_mid_title_slippage_tolerance"
                textAlignment="5"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Title.16SP.Medium"
                textColor="@color/cell_title_color"
                gravity="0x800005"
                id="@+id/tv_mini_recived"
                layout_width="-2"
                android:layout_height="wrap_content"
                includeFontPadding="false"
                textAlignment="6"
                layout_marginStart="@dimen/margin_8dp"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x1c="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP"
            textColor="@color/orange_o700"
            id="@+id/tv_slippage_tips"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            layout_marginBottom="@dimen/margin_4dp"
            includeFontPadding="false"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</LinearLayout>
