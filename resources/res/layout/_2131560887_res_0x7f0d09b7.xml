<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="16dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="16dp">
    <ImageView
        id="@+id/image"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/token"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="12dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="@+id/barrier"
        NOT_FOUND_0x17="@+id/image"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="30dp"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/barrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x10="5"
        NOT_FOUND_0x11="amount,tv_no_price"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="1"
        NOT_FOUND_0x17="@+id/token"
        NOT_FOUND_0x1a="0"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/SemanticNotice"
        ellipsize="3"
        id="@+id/tv_no_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="1"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="1"
        NOT_FOUND_0x17="@+id/token"
        NOT_FOUND_0x19="@+id/amount"/>
</androidx.constraintlayout.widget.ConstraintLayout>
