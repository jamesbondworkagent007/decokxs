<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        id="@+id/upload_layout_ly"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x17="@+id/upload_files_recyclerview"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0">
        <LinearLayout
            gravity="0x1"
            orientation="1"
            id="@+id/upload_layout"
            background="@drawable/_2131231444_res_0x7f0802d4"
            paddingLeft="@dimen/padding_16dp"
            paddingTop="@dimen/padding_24dp"
            paddingRight="@dimen/padding_16dp"
            paddingBottom="@dimen/padding_24dp"
            focusable="true"
            clickable="true"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="@dimen/padding_16dp"
            paddingVertical="@dimen/padding_24dp">
            <ImageView
                id="@+id/upload_icon"
                visibility="0"
                layout_width="-2"
                android:layout_height="wrap_content"/>
            <o.C55113xdn
                id="@+id/upload_lottie_icon"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1d="true"/>
            <TextView
                textColor="?attr/uploadTitleColor"
                gravity="0x11"
                layout_gravity="0x1"
                id="@+id/upload_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                style="@style/TextAppearance.Text.16SP.Medium"/>
            <TextView
                textColor="?attr/uploadSubtitleColor"
                gravity="0x11"
                id="@+id/upload_subtitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                style="@style/TextAppearance.Text.16SP"/>
        </LinearLayout>
        <TextView
            textColor="?attr/uploadSubtitleColor"
            id="@+id/upload_error"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="@+id/upload_layout"
            style="@style/TextAppearance.Text.16SP"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/upload_files_recyclerview"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_20dp"
        layout_marginTop="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_20dp"
        layout_marginHorizontal="@dimen/margin_20dp"
        NOT_FOUND_0x15="true"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@+id/upload_layout_ly"
        NOT_FOUND_0x1c="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
