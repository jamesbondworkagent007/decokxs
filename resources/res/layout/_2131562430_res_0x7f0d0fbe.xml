<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    paddingLeft="16dp"
    paddingRight="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="16dp">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        id="@+id/category_name"
        tag="layout/trade_impl_view_bot_category_0"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/category_recycler_view"
        tag="layout/trade_impl_view_bot_category_1"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        layout_below="@+id/category_name"
        overScrollMode="2"/>
</merge>
