<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    id="@+id/month_navigation_bar"
    paddingTop="@dimen/mtrl_calendar_navigation_top_padding"
    paddingBottom="@dimen/mtrl_calendar_navigation_bottom_padding"
    layout_width="-1"
    android:layout_height="wrap_content">
    <FrameLayout
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1">
        <com.google.android.material.button.MaterialButton
            gravity="0x800013"
            layout_gravity="0x800003"
            id="@+id/month_navigation_fragment_toggle"
            layout_width="-2"
            android:layout_height="@dimen/mtrl_calendar_navigation_height"
            insetTop="0dp"
            insetBottom="0dp"
            NOT_FOUND_0xc="@drawable/_2131233489_res_0x7f080ad1"
            NOT_FOUND_0xd="0x4"
            NOT_FOUND_0xe="4dp"
            style="?attr/materialCalendarYearNavigationButton"/>
    </FrameLayout>
    <com.google.android.material.button.MaterialButton
        gravity="0x11"
        id="@+id/month_navigation_previous"
        layout_width="@dimen/mtrl_min_touch_target_size"
        android:layout_height="@dimen/mtrl_calendar_navigation_height"
        insetTop="0dp"
        insetBottom="0dp"
        contentDescription="@string/mtrl_picker_a11y_prev_month"
        NOT_FOUND_0xc="@drawable/_2131233487_res_0x7f080acf"
        style="?attr/materialCalendarMonthNavigationButton"/>
    <com.google.android.material.button.MaterialButton
        gravity="0x11"
        id="@+id/month_navigation_next"
        layout_width="@dimen/mtrl_min_touch_target_size"
        android:layout_height="@dimen/mtrl_calendar_navigation_height"
        insetTop="0dp"
        insetBottom="0dp"
        contentDescription="@string/mtrl_picker_a11y_next_month"
        NOT_FOUND_0xc="@drawable/_2131233486_res_0x7f080ace"
        style="?attr/materialCalendarMonthNavigationButton"/>
</LinearLayout>
