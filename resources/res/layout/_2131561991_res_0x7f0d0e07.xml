<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="@dimen/mtrl_calendar_header_height_fullscreen">
    <LinearLayout
        layout_gravity="0x31"
        orientation="0"
        id="@+id/fullscreen_header"
        paddingLeft="@dimen/mtrl_calendar_header_content_padding_fullscreen"
        paddingTop="@dimen/mtrl_calendar_header_content_padding_fullscreen"
        paddingRight="@dimen/mtrl_calendar_header_content_padding_fullscreen"
        layout_width="-1"
        android:layout_height="@dimen/mtrl_calendar_header_height_fullscreen"
        paddingStart="@dimen/mtrl_calendar_header_content_padding_fullscreen"
        paddingEnd="@dimen/mtrl_calendar_header_content_padding_fullscreen"
        style="?attr/materialCalendarHeaderLayout">
        <com.google.android.material.button.MaterialButton
            gravity="0x11"
            layout_gravity="0x30"
            id="@+id/cancel_button"
            padding="12dp"
            layout_width="@dimen/mtrl_min_touch_target_size"
            android:layout_height="@dimen/mtrl_min_touch_target_size"
            insetTop="0dp"
            insetBottom="0dp"
            contentDescription="@string/mtrl_picker_cancel"
            NOT_FOUND_0x15="@drawable/_2131233483_res_0x7f080acb"
            style="?attr/materialCalendarHeaderCancelButton"/>
        <FrameLayout
            id="@+id/mtrl_picker_header_title_and_selection"
            paddingLeft="@dimen/mtrl_calendar_header_text_padding"
            focusable="true"
            focusableInTouchMode="true"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            paddingStart="@dimen/mtrl_calendar_header_text_padding">
            <TextView
                gravity="0x800053"
                layout_gravity="0x800033"
                id="@+id/mtrl_picker_title_text"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0x14="@dimen/mtrl_calendar_title_baseline_to_top_fullscreen"
                style="?attr/materialCalendarHeaderTitle"/>
            <TextView
                gravity="0x800053"
                layout_gravity="0x800033"
                id="@+id/mtrl_picker_header_selection_text"
                paddingBottom="@dimen/mtrl_calendar_pre_l_text_clip_padding"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0x14="@dimen/mtrl_calendar_selection_baseline_to_top_fullscreen"
                NOT_FOUND_0x16="@dimen/mtrl_calendar_header_selection_line_height"
                style="?attr/materialCalendarHeaderSelection"/>
        </FrameLayout>
        <LinearLayout
            orientation="@integer/mtrl_calendar_header_orientation"
            layout_width="-2"
            android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                layout_gravity="0x800035"
                id="@+id/confirm_button"
                layout_width="-2"
                android:layout_height="@dimen/mtrl_min_touch_target_size"
                text="@string/mtrl_picker_save"
                contentDescription="@string/mtrl_picker_save"
                style="?attr/materialCalendarHeaderConfirmButton"/>
            <include layout="@layout/_2131561994_res_0x7f0d0e0a"/>
        </LinearLayout>
    </LinearLayout>
    <View
        layout_gravity="0x50"
        layout_width="-1"
        android:layout_height="@dimen/mtrl_calendar_header_divider_thickness"
        style="?attr/materialCalendarHeaderDivider"/>
</merge>
