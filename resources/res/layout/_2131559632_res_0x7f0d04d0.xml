<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/high_risk_lin"
    background="@color/background_BasePrimary_BaseSecondary"
    paddingLeft="@dimen/dp24"
    paddingRight="@dimen/dp24"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp24">
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x1"
        id="@+id/risk_icon"
        layout_width="128dp"
        android:layout_height="128dp"
        layout_marginTop="@dimen/height_150dp"
        src="@drawable/_2131233107_res_0x7f080953"/>
    <TextView
        textSize="@dimen/text_size_24sp"
        textColor="@color/ContentPrimary"
        layout_gravity="0x1"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_20dp"
        text="@string/pr_wallet_dapps_popup_scam_alert"
        style="@style/TextAppearance.Title.24SP.Medium"/>
    <TextView
        textSize="@dimen/font_16"
        textColor="@color/ContentSecondary"
        id="@+id/desc_high_level_risk"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/ok_dp_12"
        text="@string/pr_wallet_dapps_popup_scam_alert_desc1"
        style="@style/Body_3_Regular"/>
</LinearLayout>
