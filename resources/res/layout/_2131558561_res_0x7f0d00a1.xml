<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="match_parent">
    <ImageView
        id="@+id/coverImage"
        layout_width="0dp"
        android:layout_height="150dp"
        foreground="@drawable/_2131231138_res_0x7f0801a2"
        scaleType="6"
        adjustViewBounds="true"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="112dp"
        text="@string/pr_orbit_onboarding_header_follow_top_orbiters"
        layout_marginStart="24dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0"
        style="@style/Headline_4_Bold"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/recyclerView"
        paddingTop="8dp"
        paddingBottom="8dp"
        clipToPadding="false"
        layout_width="0dp"
        android:layout_height="0dp"
        layout_marginBottom="16dp"
        NOT_FOUND_0x1b="@+id/bottomBar"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@+id/title"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/bottomBar"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        weightSum="1"
        layout_marginStart="24dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0">
        <o.C52794wYp
            id="@+id/btnSkip"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_feed_btn_skip"
            layout_weight="0.5"
            NOT_FOUND_0x23="52"
            NOT_FOUND_0x24="0x104"/>
        <Space
            layout_width="12dp"
            android:layout_height="1dp"/>
        <o.C52794wYp
            enabled="false"
            id="@+id/btnFollow"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="0.5"
            NOT_FOUND_0x23="52"
            NOT_FOUND_0x24="0x50"/>
    </LinearLayout>
    <o.C55113xdn
        id="@+id/loadingView"
        background="@color/BasePrimary"
        paddingLeft="@dimen/margin_default"
        paddingTop="@dimen/margin_default"
        paddingRight="@dimen/margin_default"
        visibility="2"
        layout_width="0dp"
        android:layout_height="0dp"
        scaleType="fillCenter"
        paddingHorizontal="@dimen/margin_default"
        NOT_FOUND_0x1b="@+id/bottomBar"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@+id/title"
        NOT_FOUND_0x20="false"
        NOT_FOUND_0x21="true"
        NOT_FOUND_0x22="-1"/>
    <o.C55173xeu
        id="@+id/emptyView"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="32dp"
        layout_marginEnd="32dp"
        NOT_FOUND_0x19="8"
        NOT_FOUND_0x1b="@+id/bottomBar"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@+id/title"
        NOT_FOUND_0x25="@string/pr_orbit_empty_text_refresh_try_again"
        NOT_FOUND_0x26="@string/pr_orbit_empty_btn_refresh"
        NOT_FOUND_0x27="@string/pr_orbit_empty_title_network_issue"/>
</androidx.constraintlayout.widget.ConstraintLayout>
