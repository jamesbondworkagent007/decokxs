        textAppearance="@style/TextAppearance.Red.16SP"
        textColor="?attr/wallet_switch_color_r500"
        ellipsize="3"
        id="@+id/backUpText"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="12dp"
        layout_marginTop="8dp"
        layout_marginRight="12dp"
        layout_marginBottom="8dp"
        layout_marginHorizontal="12dp"
        layout_marginVertical="8dp"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/backUpArrow"
        NOT_FOUND_0x15="@+id/backUpWarningIcon"
        NOT_FOUND_0x17="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
