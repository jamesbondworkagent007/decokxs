<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingTop="8dp"
    paddingRight="24dp"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="24dp">
    <LinearLayout
        orientation="0"
        id="@+id/currentPriceContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            textColor="@color/ContentContrast"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_fixedpricebuy_placeorder_charttext_current_price"
            maxLines="2"
            layout_weight="6"
            textAlignment="5"
            layout_marginEnd="8dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Black.16SP.Medium"
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/currentPriceValue"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="2"
            layout_weight="4"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        id="@+id/priceRangeContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/currentPriceContainer">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800033"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_trade_grid_title_price_range"
            maxLines="2"
            layout_weight="6"
            layout_marginEnd="8dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Black.16SP.Medium"
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/priceRangeValue"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="2"
            layout_weight="4"/>
    </LinearLayout>
    <com.okinc.uilab.reminder.OKReminder
        id="@+id/reminder"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/priceRangeContainer"/>
</androidx.constraintlayout.widget.ConstraintLayout>
