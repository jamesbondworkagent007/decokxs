<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="56dp">
        <o.wYK
            id="@+id/cb"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginEnd="@dimen/margin_16dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="@drawable/_2131232409_res_0x7f080699"
            NOT_FOUND_0x1d="-5"/>
        <TextView
            textSize="@dimen/font_15"
            textColor="@color/grey_g900"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="Background"
            layout_weight="1"/>
        <RelativeLayout
            gravity="0x11"
            orientation="1"
            id="@+id/rl_color"
            background="@drawable/_2131231014_res_0x7f080126"
            layout_width="@dimen/width_28dp"
            android:layout_height="@dimen/width_28dp">
            <View
                background="@drawable/_2131231437_res_0x7f0802cd"
                layout_width="@dimen/width_16dp"
                android:layout_height="@dimen/height_16dp"/>
            <ImageView
                id="@+id/iv_color"
                background="@drawable/_2131231224_res_0x7f0801f8"
                layout_width="@dimen/width_16dp"
                android:layout_height="@dimen/height_16dp"/>
        </RelativeLayout>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        gravity="0x10"
        orientation="0"
        id="@+id/cl_bg"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_5dp">
        <androidx.appcompat.widget.AppCompatSeekBar
            id="@+id/sb_bg"
            background="@null"
            paddingTop="3dp"
            paddingBottom="3dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxHeight="4dp"
            max="255"
            progress="20"
            progressDrawable="@drawable/_2131231137_res_0x7f0801a1"
            minHeight="4dp"
            thumb="@drawable/_2131234007_res_0x7f080cd7"
            layout_marginStart="@dimen/margin_20dp"
            layout_marginEnd="@dimen/margin_20dp"
            splitTrack="false"
            paddingVertical="3dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="0"/>
        <TextView
            textSize="@dimen/font_12"
            textColor="@color/grey_g700"
            id="@+id/tv_progress"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="8%"
            fontFamily="@font/font_alpha_medium"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
