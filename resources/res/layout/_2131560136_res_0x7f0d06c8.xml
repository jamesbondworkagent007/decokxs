<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/fragment_safe_related_risk_tip_0"
    background="@color/BasePrimaryAlternative"
    clickable="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"
        overScrollMode="2">
        <LinearLayout
            orientation="1"
            paddingLeft="24dp"
            paddingRight="24dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="62dp"
            paddingHorizontal="24dp">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x1"
                id="@+id/risk_icon"
                layout_width="@dimen/height_100dp"
                android:layout_height="@dimen/height_100dp"
                layout_marginBottom="@dimen/margin_40dp"
                src="@drawable/_2131232932_res_0x7f0808a4"/>
            <TextView
                textAppearance="@style/Headline_5_Bold"
                textColor="@color/ContentPrimary"
                gravity="0x1"
                layout_gravity="0x1"
                id="@+id/risk_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginBottom="@dimen/margin_8dp"/>
            <TextView
                textAppearance="@style/Label_1_Regular"
                textColor="@color/ContentContrast"
                id="@+id/risk_subTitle"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginBottom="16dp"
                textAlignment="4"/>
            <TextView
                textAppearance="@style/Label_1_Regular"
                textColor="@color/ContentPrimary"
                gravity="0x11"
                id="@+id/tv_risk_subTitleClickableText"
                layout_width="-1"
                android:layout_height="wrap_content"
                minHeight="36dp"
                textAlignment="4"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <TextView
        textAppearance="@style/Label_3_Bold"
        textColor="@color/ContentPrimary"
        gravity="0x11"
        id="@+id/tv_not_risky_token"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        minHeight="32dp"
        textAlignment="4"
        layout_marginHorizontal="@dimen/margin_24dp"/>
    <LinearLayout
        orientation="1"
        id="@+id/button_group_vertical"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="12dp"
        layout_marginRight="24dp"
        layout_marginBottom="20dp"
        layout_marginHorizontal="24dp">
        <o.C52794wYp
            id="@+id/btn_primary"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1a="52"
            NOT_FOUND_0x1b="0x101"/>
        <View
            id="@+id/btn_space"
            visibility="2"
            layout_width="-1"
            android:layout_height="12dp"/>
        <o.C52794wYp
            id="@+id/btn_secondary"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1a="52"
            NOT_FOUND_0x1b="0x104"/>
    </LinearLayout>
    <o.C57468yiw
        id="@+id/button_group_horizontal"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"/>
</LinearLayout>
