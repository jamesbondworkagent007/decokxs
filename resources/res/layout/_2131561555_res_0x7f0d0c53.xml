<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textSize="16sp"
        textColor="@color/ContentContrast"
        id="@+id/input_label"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginRight="24dp"
        layout_marginHorizontal="24dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/input_list"
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        overScrollMode="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textSize="16sp"
        textColor="@color/ContentContrast"
        id="@+id/output_label"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="32dp"
        layout_marginRight="24dp"
        layout_marginHorizontal="24dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/output_list"
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        overScrollMode="2"/>
</merge>
