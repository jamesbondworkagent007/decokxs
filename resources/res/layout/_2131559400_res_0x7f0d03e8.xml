<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/margin_default"
    paddingTop="12dp"
    paddingRight="@dimen/margin_default"
    paddingBottom="@dimen/dp_4"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default">
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideline_center"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="0.5"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_chart_label_balance_short"
        maxLines="1"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/tv_balance_value"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="2"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0"
        style="@style/Label_2_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800003"
        id="@+id/tv_balance_value"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="4dp"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/guideline_center"
        NOT_FOUND_0x18="@+id/title"
        NOT_FOUND_0x1a="0"
        style="@style/Label_2_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_asset_value"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="8dp"
        layout_marginEnd="4dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/tv_asset_percentage"
        NOT_FOUND_0x19="@+id/guideline_center"
        NOT_FOUND_0x1a="0"
        style="@style/Label_2_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_asset_percentage"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="4dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/iv_chevron"
        NOT_FOUND_0x1a="0"
        style="@style/Label_2_Regular"/>
    <ImageView
        id="@+id/iv_chevron"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231656_res_0x7f0803a8"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="@color/ContentSecondary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
