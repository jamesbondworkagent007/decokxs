<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/margin_16dp"
    paddingBottom="@dimen/margin_8dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_banner"
        scrollbars="horizontal"
        clipToPadding="false"
        layout_width="0dp"
        android:layout_height="wrap_content"
        overScrollMode="2"
        translationZ="0dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"/>
    <androidx.cardview.widget.CardView
        id="@+id/cardViewCounter"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        layout_marginEnd="40dp"
        translationZ="1dp"
        NOT_FOUND_0x11="@color/SurfaceContrast"
        NOT_FOUND_0x12="100dp"
        NOT_FOUND_0x13="0dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentSecondary"
            id="@+id/textViewCounter"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_8dp"
            layout_marginTop="@dimen/margin_4dp"
            layout_marginRight="@dimen/margin_8dp"
            layout_marginBottom="@dimen/margin_4dp"
            layout_marginHorizontal="@dimen/margin_8dp"
            layout_marginVertical="@dimen/margin_4dp"
            style="@style/Label_3_Medium"/>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
