<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/root_layout"
    background="@color/BasePrimary"
    descendantFocusability="2"
    layout_width="-1"
    android:layout_height="52dp"
    baselineAligned="false"
    minHeight="?attr/listPreferredItemHeight">
    <o.wYK
        id="@+id/cb_check"
        focusable="false"
        focusableInTouchMode="false"
        clickable="false"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_16"
        NOT_FOUND_0x16="@drawable/_2131232409_res_0x7f080699"
        NOT_FOUND_0x17="-5"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        ellipsize="3"
        id="@+id/tv_symbol"
        layout_width="0dp"
        android:layout_height="wrap_content"
        singleLine="true"
        layout_weight="1"
        layout_marginStart="@dimen/dp_16"/>
    <FrameLayout
        layout_gravity="0x800013"
        layout_width="68dp"
        android:layout_height="@dimen/dp_24"
        layout_marginStart="8dp">
        <ImageView
            id="@+id/btn_top"
            background="?attr/selectableItemBackgroundBorderless"
            layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            src="@drawable/_2131233083_res_0x7f08093b"
            scaleType="fillEnd"
            NOT_FOUND_0x18="@color/grey_g700"/>
    </FrameLayout>
    <ImageView
        id="@+id/btn_sort"
        background="?attr/selectableItemBackgroundBorderless"
        layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        src="@drawable/_2131232291_res_0x7f080623"
        layout_marginEnd="16dp"
        tintMode="src_in"
        NOT_FOUND_0x18="@color/grey_g700"/>
</LinearLayout>
