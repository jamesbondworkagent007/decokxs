<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    scrollbars="horizontal"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x1"
        orientation="1"
        paddingBottom="@dimen/margin_40dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/image"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            layout_marginBottom="16dp"
            src="@drawable/_2131231677_res_0x7f0803bd"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Headline_5_Bold"
            textSize="@dimen/text_size_24sp"
            textStyle="0x1"
            textColor="@color/ContentPrimary"
            gravity="0x11"
            id="@+id/tv_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginRight="16dp"
            layout_marginHorizontal="16dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_2_Regular"
            textSize="@dimen/text_size_14sp"
            textColor="@color/ContentContrast"
            gravity="0x1"
            id="@+id/tv_subtitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="12dp"
            layout_marginRight="16dp"
            layout_marginHorizontal="16dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
