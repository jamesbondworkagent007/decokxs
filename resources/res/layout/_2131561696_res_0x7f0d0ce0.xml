<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/BasePrimary"
    paddingLeft="24dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp">
    <View
        id="@+id/viewBackground"
        background="@drawable/_2131233438_res_0x7f080a9e"
        layout_width="0dp"
        android:layout_height="0dp"
        layout_marginStart="39dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"/>
    <TextView
        textSize="10dp"
        textColor="@color/ContentContrast"
        id="@+id/time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        style="@style/Label_4_Regular"/>
    <ImageView
        id="@+id/icon"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginTop="12dp"
        importantForAccessibility="2"
        layout_marginStart="12dp"
        NOT_FOUND_0x16="@+id/viewBackground"
        NOT_FOUND_0x18="@+id/viewBackground"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="4dp"
        NOT_FOUND_0x11="@+id/icon"
        NOT_FOUND_0x15="@+id/icon"
        NOT_FOUND_0x18="@+id/icon"
        style="@style/Label_3_Medium"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/barrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xf="3"
        NOT_FOUND_0x10="unlockedTitle,nextUnlockTitle,lockedOrUntrackedTitle"/>
    <TextView
        textSize="10dp"
        textColor="@color/ContentContrast"
        id="@+id/unlockedTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_trade_discover_title_unlocked"
        NOT_FOUND_0x13="@+id/nextUnlockTitle"
        NOT_FOUND_0x16="@+id/icon"
        NOT_FOUND_0x17="@+id/icon"
        style="@style/Label_4_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/unlockedTitleValue"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x16="@+id/unlockedTitle"
        NOT_FOUND_0x17="@+id/barrier"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/unlockedValuePercentage"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x16="@+id/unlockedTitleValue"
        NOT_FOUND_0x17="@+id/unlockedTitleValue"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="10dp"
        textColor="@color/ContentContrast"
        id="@+id/nextUnlockTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_discover_title_next_unlock"
        layout_marginStart="8dp"
        NOT_FOUND_0x13="@+id/lockedOrUntrackedTitle"
        NOT_FOUND_0x15="@+id/unlockedTitle"
        NOT_FOUND_0x18="@+id/unlockedTitle"
        style="@style/Label_4_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/SemanticNotice"
        id="@+id/nextUnlockTitleValue"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x16="@+id/nextUnlockTitle"
        NOT_FOUND_0x17="@+id/barrier"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/SemanticNotice"
        id="@+id/nextUnlockValuePercentage"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x16="@+id/nextUnlockTitleValue"
        NOT_FOUND_0x17="@+id/nextUnlockTitleValue"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="10dp"
        textColor="@color/ContentContrast"
        id="@+id/lockedOrUntrackedTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_discover_lockeduntracked"
        layout_marginStart="8dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x12="@+id/viewBackground"
        NOT_FOUND_0x15="@+id/nextUnlockTitle"
        NOT_FOUND_0x18="@+id/nextUnlockTitle"
        style="@style/Label_4_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentTertiary"
        id="@+id/lockedOrUntrackedTitleValue"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x16="@+id/lockedOrUntrackedTitle"
        NOT_FOUND_0x17="@+id/barrier"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentTertiary"
        id="@+id/lockedOrUntrackedValuePercentage"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x16="@+id/lockedOrUntrackedTitleValue"
        NOT_FOUND_0x17="@+id/lockedOrUntrackedTitleValue"
        style="@style/Label_3_Regular"/>
    <View
        id="@+id/lockedOrUntrackedProgressView"
        background="@drawable/_2131233439_res_0x7f080a9f"
        layout_width="0dp"
        android:layout_height="4dp"
        layout_marginTop="4dp"
        layout_marginBottom="12dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x11="@+id/viewBackground"
        NOT_FOUND_0x12="@+id/viewBackground"
        NOT_FOUND_0x16="@+id/unlockedValuePercentage"
        NOT_FOUND_0x17="@+id/unlockedValuePercentage"/>
    <View
        id="@+id/nextUnlockedProgressView"
        background="@drawable/_2131233440_res_0x7f080aa0"
        layout_width="0dp"
        android:layout_height="4dp"
        NOT_FOUND_0x12="@+id/lockedOrUntrackedProgressView"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/lockedOrUntrackedProgressView"
        NOT_FOUND_0x18="@+id/lockedOrUntrackedProgressView"/>
    <View
        id="@+id/unlockedProgressView"
        background="@drawable/_2131233441_res_0x7f080aa1"
        layout_width="0dp"
        android:layout_height="4dp"
        NOT_FOUND_0x12="@+id/lockedOrUntrackedProgressView"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/nextUnlockedProgressView"
        NOT_FOUND_0x18="@+id/nextUnlockedProgressView"/>
</androidx.constraintlayout.widget.ConstraintLayout>
