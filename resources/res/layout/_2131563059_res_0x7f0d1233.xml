<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    layout_width="-2"
    android:layout_height="wrap_content">
    <RelativeLayout
        orientation="0"
        id="@+id/ll_content"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1">
        <o.wYC
            id="@+id/searchIcon"
            layout_width="@dimen/width_20dp"
            android:layout_height="@dimen/width_20dp"
            src="@drawable/search"
            layout_centerVertical="true"/>
        <com.okinc.uilab.edit.OKEditText
            gravity="0x800013"
            id="@+id/searchEdit"
            background="@null"
            layout_width="-1"
            android:layout_height="match_parent"
            maxLines="1"
            layout_centerVertical="true"
            textAlignment="5"
            paddingStart="6dp"
            paddingEnd="6dp"
            layout_toStartOf="@+id/clearIcon"
            layout_toEndOf="@+id/searchIcon"
            NOT_FOUND_0x15="14"
            NOT_FOUND_0x16="14"/>
        <ImageView
            id="@+id/clearIcon"
            visibility="2"
            layout_width="@dimen/width_20dp"
            android:layout_height="@dimen/width_20dp"
            src="@drawable/_2131232524_res_0x7f08070c"
            layout_centerVertical="true"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
    <TextView
        textAppearance="@style/OKTextFont.Medium"
        textSize="14sp"
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/cancelTextView"
        visibility="2"
        layout_width="-2"
        android:layout_height="match_parent"
        layout_marginStart="8dp"/>
</LinearLayout>
