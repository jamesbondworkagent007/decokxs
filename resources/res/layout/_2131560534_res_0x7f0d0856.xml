<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    layout_width="-2"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP"
        textColor="@color/selector_selected_text_blue_color"
        id="@+id/h1DynamicSelectView"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        layout_marginBottom="8dp"
        NOT_FOUND_0x8="0"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xb="0"/>
    <FrameLayout
        id="@+id/h1DynamicSelectViewIndicator"
        background="@drawable/_2131233923_res_0x7f080c83"
        layout_width="0dp"
        android:layout_height="2dp"
        layout_marginBottom="2dp"
        NOT_FOUND_0x8="0"
        NOT_FOUND_0x9="@+id/h1DynamicSelectView"
        NOT_FOUND_0xa="@+id/h1DynamicSelectView"/>
</androidx.constraintlayout.widget.ConstraintLayout>
