<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/divider"
        background="@drawable/_2131232025_res_0x7f080519"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="8dp"
        layout_marginBottom="8dp"
        layout_marginVertical="8dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        orientation="1"
        id="@+id/constraint_layout_container"
        background="@color/BasePrimary"
        paddingTop="16dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/header"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x20="0">
            <o.C35893oHp
                id="@+id/iv_avatar"
                layout_width="40dp"
                android:layout_height="40dp"
                layout_marginEnd="12dp"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                orientation="1"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1">
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    id="@+id/tv_author_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    singleLine="true"
                    style="@style/Label_1_Medium"/>
                <TextView
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    id="@+id/tv_post_time"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    singleLine="true"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    id="@+id/tv_edited_by"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    singleLine="true"
                    style="@style/Label_3_Regular"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <ImageView
                id="@+id/iv_pin"
                visibility="2"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131233658_res_0x7f080b7a"
                layout_marginEnd="8dp"
                NOT_FOUND_0x21="@color/ContentContrast"/>
            <androidx.appcompat.widget.AppCompatCheckBox
                id="@+id/cb_selection"
                focusable="false"
                focusableInTouchMode="false"
                visibility="2"
                clickable="false"
                layout_width="24dp"
                android:layout_height="24dp"
                layout_marginEnd="8dp"
                style="@style/CheckBox.IMCircleTick"/>
            <ImageView
                id="@+id/iv_menu"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131232708_res_0x7f0807c4"
                NOT_FOUND_0x21="@color/ContentContrast"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <TextView
            textSize="16sp"
            textColor="@color/ContentSecondary"
            ellipsize="3"
            id="@+id/tv_content"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            maxLines="3"
            lineSpacingExtra="4dp"
            fontFamily="@font/okx_sans_tab_regular"
            layout_marginEnd="@dimen/dp_12"
            lineHeight="22sp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="@+id/iv_chevron"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="@+id/header"/>
        <ImageView
            id="@+id/iv_chevron"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="@+id/tv_content"
            NOT_FOUND_0x1f="@+id/header"
            NOT_FOUND_0x21="@color/ContentContrast"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
