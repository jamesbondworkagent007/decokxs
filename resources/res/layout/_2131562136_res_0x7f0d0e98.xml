<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingTop="16dp"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="16dp">
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tvTitle"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxLines="2"
        includeFontPadding="false"
        style="@style/Title_2_Medium"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp">
        <include
            id="@+id/tokenTagContainer"
            visibility="2"
            layout="@layout/_2131562145_res_0x7f0d0ea1"/>
        <View
            layout_width="0dp"
            android:layout_height="0dp"
            layout_weight="1"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/sourceContainer"
            layout_width="-2"
            android:layout_height="wrap_content">
            <ImageView
                id="@+id/ivSourceLogo"
                layout_width="16dp"
                android:layout_height="16dp"
                scaleType="6"/>
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tvSourceName"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginStart="4dp"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tvDot"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginLeft="4dp"
                layout_marginRight="4dp"
                text="•"
                layout_marginHorizontal="4dp"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tvTime"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                style="@style/Label_3_Regular"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
