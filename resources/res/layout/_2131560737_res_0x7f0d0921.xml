<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/item_mpc_private_key_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        orientation="1"
        id="@+id/itemClickView"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/icon"
            layout_width="32dp"
            android:layout_height="32dp"
            layout_marginTop="@dimen/margin_18dp"
            layout_marginBottom="@dimen/margin_18dp"
            layout_marginVertical="@dimen/margin_18dp"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x26="0"
            NOT_FOUND_0x28="0"/>
        <LinearLayout
            orientation="1"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="12dp"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x25="@+id/icon"
            NOT_FOUND_0x28="0">
            <TextView
                textAppearance="@style/TextAppearance.Title.16SP.Medium"
                ellipsize="3"
                id="@+id/chainName"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x1b="16sp"
                NOT_FOUND_0x1c="12sp"
                NOT_FOUND_0x1d="2sp"
                NOT_FOUND_0x1e="1"
                NOT_FOUND_0x23="@+id/tvCoinAmount"
                NOT_FOUND_0x24="0.44"
                NOT_FOUND_0x25="@+id/icon"
                NOT_FOUND_0x28="0"
                NOT_FOUND_0x29="2"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP"
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tvCoinAddress"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_2dp"
                maxLines="1"/>
        </LinearLayout>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/arrow"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232335_res_0x7f08064f"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x28="0"
            NOT_FOUND_0x2d="@color/grey_g400"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/private_key_container"
        background="@color/background_lv2"
        paddingLeft="@dimen/margin_16dp"
        paddingTop="32dp"
        paddingRight="@dimen/margin_16dp"
        paddingBottom="32dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_16dp"
        paddingVertical="32dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/private_key_base_container"
            background="@drawable/_2131231150_res_0x7f0801ae"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x26="0"
            NOT_FOUND_0x28="0">
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP"
                textColor="@color/ContentPrimary"
                id="@+id/tv_private_key"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_16dp"
                layout_marginTop="@dimen/margin_20dp"
                layout_marginRight="@dimen/margin_16dp"
                layout_marginHorizontal="@dimen/margin_16dp"
                NOT_FOUND_0x22="0"
                NOT_FOUND_0x26="0"
                NOT_FOUND_0x28="0"/>
            <ImageView
                id="@+id/icon_eye"
                layout_width="24dp"
                android:layout_height="24dp"
                layout_marginBottom="@dimen/margin_8dp"
                src="@drawable/_2131232514_res_0x7f080702"
                layout_marginEnd="@dimen/margin_12dp"
                NOT_FOUND_0x21="0"
                NOT_FOUND_0x22="0"
                NOT_FOUND_0x27="@+id/tv_private_key"/>
            <com.google.android.material.imageview.ShapeableImageView
                id="@+id/private_key_protect_mask"
                visibility="2"
                layout_width="-1"
                android:layout_height="match_parent"
                scaleType="fillCenter"
                NOT_FOUND_0x1f="true"
                NOT_FOUND_0x20="true"
                NOT_FOUND_0x21="0"
                NOT_FOUND_0x22="0"
                NOT_FOUND_0x26="0"
                NOT_FOUND_0x28="0"
                NOT_FOUND_0x2a="@style/roundedCornerStyle"
                NOT_FOUND_0x2b="@color/SurfacePrimary"
                NOT_FOUND_0x2c="1dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <ImageView
            id="@+id/icon_eye_close"
            visibility="2"
            layout_width="32dp"
            android:layout_height="32dp"
            src="@drawable/_2131232515_res_0x7f080703"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x26="0"
            NOT_FOUND_0x28="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
