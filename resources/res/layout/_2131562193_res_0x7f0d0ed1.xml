<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/cardView"
    tag="layout/plugin_spot_card_0"
    padding="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    NOT_FOUND_0x11="@color/SurfacePrimary"
    NOT_FOUND_0x12="16dp"
    NOT_FOUND_0x13="0dp">
    <LinearLayout
        orientation="1"
        id="@+id/cardBackground"
        padding="16dp"
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/header"
            layout_width="-1"
            android:layout_height="wrap_content">
            <ImageView
                id="@+id/ivCoinIcon"
                layout_width="20dp"
                android:layout_height="20dp"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tvCoinName"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="6dp"
                style="@style/Label_2_Medium"/>
            <o.C55251xgS
                id="@+id/tvCurrentHolding"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_sharingcard_tag_spot_holdings"
                layout_marginStart="6dp"
                NOT_FOUND_0x1a="-5"
                NOT_FOUND_0x1b="12"/>
            <View
                layout_width="0dp"
                android:layout_height="0dp"
                layout_weight="1"/>
            <o.C52794wYp
                id="@+id/tradeButton"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_sharingcard_btn_trade"
                NOT_FOUND_0x18="24"
                NOT_FOUND_0x19="0x101"/>
        </LinearLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/expandedContent"
            visibility="0"
            layout_width="-1"
            android:layout_height="wrap_content">
            <o.C46496tWm
                id="@+id/chartView"
                layout_width="-1"
                android:layout_height="108dp"
                NOT_FOUND_0x14="0dp"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1c="24dp"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tvCumulativePnlLabel"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_sharingcard_title_cumulative_pnl"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x16="@+id/chartView"
                style="@style/Label_3_Regular"/>
            <LinearLayout
                gravity="0x50"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="2dp"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x16="@+id/tvCumulativePnlLabel">
                <TextView
                    textColor="@color/pnl_modern_loss_surface_default"
                    id="@+id/tvCumulativePnlValue"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    lines="1"
                    layout_marginEnd="8dp"
                    style="@style/Headline_5_Medium"/>
                <TextView
                    textColor="@color/pnl_modern_loss_surface_default"
                    id="@+id/tvCumulativePnlPercent"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    lines="1"
                    style="@style/Label_1_Medium"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            orientation="0"
            id="@+id/bottom"
            visibility="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp">
            <LinearLayout
                orientation="0"
                id="@+id/pnLLayout"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingEnd="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tvPnlLabel"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_social_planet_selectioncard_post_pnl"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/pnl_modern_loss_surface_default"
                    id="@+id/tvPnlValue"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="4dp"
                    style="@style/Label_3_Medium"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingEnd="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tvCostPriceLabel"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_sharingcard_title_cost_price"
                    lines="1"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tvCostPriceValue"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    lines="1"
                    layout_marginStart="4dp"
                    style="@style/Label_3_Medium"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                id="@+id/lastLayout"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tvLastPriceLabel"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_sharingcard_title_last_price"
                    lines="1"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tvLastPriceValue"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    lines="1"
                    layout_marginStart="4dp"
                    style="@style/Label_3_Medium"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            orientation="0"
            id="@+id/lastLayout2"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tvLastPriceLabel2"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_sharingcard_title_last_price"
                lines="1"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tvLastPriceValue2"
                layout_width="-2"
                android:layout_height="wrap_content"
                lines="1"
                layout_marginStart="4dp"
                style="@style/Label_3_Medium"/>
        </LinearLayout>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tvCostPriceEmpty"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            text="@string/pr_trade_sharingcard_desc_data_unavailable_manually_cost"
            style="@style/Label_3_Medium"/>
    </LinearLayout>
    <o.C55113xdn
        layout_gravity="0x11"
        id="@+id/loading"
        visibility="2"
        layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"/>
</androidx.cardview.widget.CardView>
