<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/item_input_choice_subinput_item_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/line"
        layout_width="-1"
        android:layout_height="@dimen/height_16dp"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="1"
        id="@+id/choice_ly"
        background="@drawable/_2131231183_res_0x7f0801cf"
        padding="20dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="@dimen/height_48dp">
        <TextView
            textColor="@color/grey_g900"
            id="@+id/choice"
            layout_width="-1"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Text.16SP"/>
        <TextView
            textColor="@color/grey_g400"
            id="@+id/choice_content"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            style="@style/TextAppearance.Text.14SP"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            id="@+id/choice_inputLy"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/choice_inputLabel"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                style="@style/TextAppearance.Text.14SP"/>
            <LinearLayout
                orientation="0"
                id="@+id/choice_inputEditLy"
                background="@drawable/_2131231659_res_0x7f0803ab"
                paddingBottom="@dimen/margin_8dp"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_10dp">
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/input_prefix_text"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    paddingEnd="5dp"
                    style="@style/TextAppearance.Text.16SP"/>
                <o.C55001xbh
                    textColor="@color/ContentPrimary"
                    textColorHint="@color/ContentDisabled"
                    id="@+id/choice_input"
                    background="@color/transparent"
                    focusable="true"
                    focusableInTouchMode="true"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    NOT_FOUND_0x13="true"
                    style="@style/TextAppearance.Text.16SP"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/input_suffix_text"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    paddingStart="5dp"
                    style="@style/TextAppearance.Text.16SP"/>
            </LinearLayout>
            <TextView
                textColor="@color/color_content_danger_default"
                id="@+id/input_text_error"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_8"
                style="@style/TextAppearance.Text.14SP"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
