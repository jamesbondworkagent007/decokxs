<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        src="@drawable/_2131232905_res_0x7f080889"/>
    <LinearLayout
        gravity="0x10"
        layout_width="-1"
        android:layout_height="42dp"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginHorizontal="@dimen/margin_16dp">
        <ImageView
            id="@+id/iv_nav_back"
            background="?attr/selectableItemBackgroundBorderless"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232720_res_0x7f0807d0"/>
        <TextView
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_discover_crypto_market_monitor_bottomsheet_items_per_page"
            layout_marginStart="@dimen/margin_6dp"
            style="@style/TextAppearance.Title.18SP.Medium"/>
    </LinearLayout>
    <View
        background="@drawable/_2131232025_res_0x7f080519"
        layout_width="-1"
        android:layout_height="@dimen/height_0.5dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_page_size"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_16dp"
        layout_marginVertical="@dimen/margin_16dp"/>
</LinearLayout>
