<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/root_layout"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/padding_8dp"
    paddingRight="@dimen/padding_8dp"
    descendantFocusability="2"
    layout_width="-1"
    android:layout_height="48dp"
    baselineAligned="false"
    minHeight="?attr/listPreferredItemHeight"
    paddingHorizontal="@dimen/padding_8dp">
    <ImageView
        id="@+id/btn_delete"
        background="?attr/selectableItemBackgroundBorderless"
        padding="@dimen/padding_4dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232996_res_0x7f0808e4"
        layout_marginEnd="@dimen/margin_4dp"/>
    <LinearLayout
        orientation="0"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <TextView
            textSize="16sp"
            textColor="@color/title_color"
            id="@+id/tv_name"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="3分"
            singleLine="true"/>
        <TextView
            textSize="@dimen/text_size_10sp"
            textColor="@color/yellow_y700"
            id="@+id/tv_margin_num"
            background="@drawable/_2131231195_res_0x7f0801db"
            paddingLeft="4dp"
            paddingRight="4dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="5dp"
            backgroundTint="@color/yellow_y50"
            paddingHorizontal="4dp"
            style="@style/TextAppearance.Orange"/>
    </LinearLayout>
    <ImageView
        id="@+id/btn_top"
        background="?attr/selectableItemBackgroundBorderless"
        padding="8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232899_res_0x7f080883"
        layout_marginStart="8dp"/>
    <ImageView
        id="@+id/btn_sort"
        background="?attr/selectableItemBackgroundBorderless"
        padding="8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232496_res_0x7f0806f0"
        layout_marginStart="8dp"/>
</LinearLayout>
