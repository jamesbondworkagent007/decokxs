<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/view_trade_with_select_coin_item_0"
    layout_width="-1"
    android:layout_height="68dp">
    <ImageView
        id="@+id/coin_icon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginBottom="@dimen/margin_12dp"
        layout_centerVertical="true"
        layout_marginVertical="@dimen/margin_12dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP.Medium"
        textColor="@color/grey_g900"
        id="@+id/coin_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        layout_marginStart="@dimen/margin_12dp"
        layout_toEndOf="@+id/coin_icon"/>
    <ImageView
        id="@+id/iv_select"
        visibility="1"
        clickable="false"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232426_res_0x7f0806aa"
        layout_centerVertical="true"
        layout_alignParentEnd="true"/>
</RelativeLayout>
