<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/margin_default"
    paddingRight="@dimen/margin_default"
    layout_width="-1"
    android:layout_height="@dimen/xlg"
    paddingHorizontal="@dimen/margin_default">
    <TextView
        gravity="0x800013"
        id="@+id/tv_rank_no"
        layout_width="24dp"
        android:layout_height="wrap_content"
        lines="1"
        NOT_FOUND_0x1b="14sp"
        NOT_FOUND_0x1c="8sp"
        NOT_FOUND_0x1d="1sp"
        NOT_FOUND_0x1e="1"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x24="0"
        NOT_FOUND_0x26="0"
        style="@style/Label_1_Bold"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_token_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="106dp"
        maxLines="1"
        layout_marginStart="4dp"
        transitionName="shared_holder_address"
        NOT_FOUND_0x20="@+id/dex_tag"
        NOT_FOUND_0x23="@+id/tv_rank_no"
        NOT_FOUND_0x26="@+id/tv_rank_no"
        style="@style/Label_2_Medium"/>
    <o.wYC
        id="@+id/ic_following"
        visibility="2"
        layout_width="@dimen/xsm"
        android:layout_height="@dimen/xsm"
        src="@drawable/_2131233325_res_0x7f080a2d"
        tint="@color/BrandPrimaryAlternative"
        layout_marginStart="@dimen/xxxxsm"
        NOT_FOUND_0x1f="@+id/tv_token_address"
        NOT_FOUND_0x23="@+id/tv_token_address"
        NOT_FOUND_0x26="@+id/tv_token_address"/>
    <o.C28067kNr
        orientation="0"
        id="@+id/dex_tag"
        visibility="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        maxWidth="@dimen/height_100dp"
        layout_marginStart="4dp"
        NOT_FOUND_0x1f="@+id/tv_rank_no"
        NOT_FOUND_0x23="@+id/tv_rank_no"
        NOT_FOUND_0x25="@+id/tv_token_address"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/ll_transaction"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="120dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x22="@+id/ll_realized"
        NOT_FOUND_0x23="@+id/tv_rank_no"
        NOT_FOUND_0x26="0">
        <LinearLayout
            gravity="0x800015"
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="?attr/tradeRiseDefault"
                ellipsize="3"
                gravity="0x800015"
                id="@+id/tv_buy"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_weight="1"
                layout_marginEnd="4dp"
                NOT_FOUND_0x1b="14sp"
                NOT_FOUND_0x1c="10sp"
                NOT_FOUND_0x1d="1sp"
                NOT_FOUND_0x1e="1"
                style="@style/Label_2_Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="?attr/tradeRiseDefault"
                gravity="0x11"
                id="@+id/tvAvgBuyTag"
                background="@drawable/_2131231813_res_0x7f080445"
                layout_width="@dimen/xsm"
                android:layout_height="wrap_content"
                minHeight="@dimen/xsm"
                text="@string/pr_swaptrade_token_detail_label_buy"
                maxLines="1"
                style="@style/Label_3_Medium"/>
        </LinearLayout>
        <LinearLayout
            gravity="0x800015"
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_4">
            <TextView
                textColor="?attr/tradeFallDefault"
                ellipsize="3"
                gravity="0x800015"
                id="@+id/tv_sell"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_weight="1"
                layout_marginEnd="4dp"
                NOT_FOUND_0x1b="14sp"
                NOT_FOUND_0x1c="10sp"
                NOT_FOUND_0x1d="1sp"
                NOT_FOUND_0x1e="1"
                style="@style/Label_2_Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="?attr/tradeFallDefault"
                gravity="0x11"
                id="@+id/tvAvgSellTag"
                background="@drawable/_2131231809_res_0x7f080441"
                layout_width="@dimen/xsm"
                android:layout_height="wrap_content"
                minHeight="@dimen/xsm"
                text="@string/pr_swaptrade_token_detail_label_sell"
                maxLines="1"
                style="@style/Label_3_Medium"/>
        </LinearLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <LinearLayout
        orientation="1"
        id="@+id/ll_realized"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x23="@+id/ll_transaction"
        NOT_FOUND_0x26="0">
        <TextView
            textColor="?attr/tradeRiseDefault"
            gravity="0x800005"
            id="@+id/tv_pnl_amount"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0x1b="14sp"
            NOT_FOUND_0x1c="10sp"
            NOT_FOUND_0x1d="1sp"
            NOT_FOUND_0x1e="1"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x26="0"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_pnl_percentage"
            paddingTop="1dp"
            paddingBottom="1dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            maxLines="1"
            paddingVertical="1dp"
            NOT_FOUND_0x1b="14sp"
            NOT_FOUND_0x1c="10sp"
            NOT_FOUND_0x1d="1sp"
            NOT_FOUND_0x1e="1"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
