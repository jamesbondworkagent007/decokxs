<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="150dp"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.White.10SP"
        textSize="14dp"
        id="@+id/title"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        textAlignment="5"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/title">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x30"
            orientation="0"
            paddingLeft="@dimen/padding_4dp"
            paddingRight="@dimen/padding_4dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="@dimen/padding_4dp">
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800013"
                id="@+id/title1"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxWidth="@dimen/width_60dp"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="1"
                layout_marginEnd="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800015"
                id="@+id/value1"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="2"
                layout_marginStart="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x30"
            orientation="0"
            paddingLeft="@dimen/padding_4dp"
            paddingRight="@dimen/padding_4dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_1dp"
            paddingHorizontal="@dimen/padding_4dp">
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800013"
                id="@+id/title2"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxWidth="@dimen/width_60dp"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="1"
                layout_marginEnd="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800015"
                id="@+id/value2"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="2"
                layout_marginStart="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x30"
            orientation="0"
            paddingLeft="@dimen/padding_4dp"
            paddingRight="@dimen/padding_4dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_1dp"
            paddingHorizontal="@dimen/padding_4dp">
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800013"
                id="@+id/title3"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxWidth="@dimen/width_60dp"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="1"
                layout_marginEnd="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800015"
                id="@+id/value3"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="2.3"
                layout_marginStart="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x30"
            orientation="0"
            paddingLeft="@dimen/padding_4dp"
            paddingRight="@dimen/padding_4dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_1dp"
            paddingHorizontal="@dimen/padding_4dp">
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800013"
                id="@+id/title4"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxWidth="@dimen/width_60dp"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="1"
                layout_marginEnd="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800015"
                id="@+id/value4"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="2.3"
                layout_marginStart="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x30"
            orientation="0"
            paddingLeft="@dimen/padding_4dp"
            paddingRight="@dimen/padding_4dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_1dp"
            paddingHorizontal="@dimen/padding_4dp">
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800013"
                id="@+id/title5"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxWidth="@dimen/width_60dp"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="1"
                layout_marginEnd="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                gravity="0x800015"
                id="@+id/value5"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="3"
                includeFontPadding="false"
                layout_weight="2.3"
                layout_marginStart="@dimen/margin_2dp"
                style="@style/TextAppearance"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
