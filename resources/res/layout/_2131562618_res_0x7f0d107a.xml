<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/ll_content"
    tag="layout/uilib_bottom_sheet_image_picker_0"
    background="@color/background_lv1"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textAppearance="@style/TextAppearance.Title.Medium.16SP"
        gravity="0x11"
        id="@+id/takePicture"
        layout_width="-1"
        android:layout_height="50dp"
        layout_marginTop="@dimen/padding_12dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.Medium.16SP"
        gravity="0x11"
        id="@+id/pickImage"
        layout_width="-1"
        android:layout_height="50dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.Medium.16SP"
        gravity="0x11"
        id="@+id/selectFile"
        visibility="2"
        layout_width="-1"
        android:layout_height="50dp"/>
    <View
        background="@drawable/_2131232025_res_0x7f080519"
        layout_width="-1"
        android:layout_height="@dimen/height_0.5dp"
        layout_marginTop="@dimen/padding_12dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.Medium.16SP"
        gravity="0x11"
        id="@+id/cancel"
        layout_width="-1"
        android:layout_height="50dp"
        layout_marginTop="@dimen/padding_12dp"/>
</LinearLayout>
