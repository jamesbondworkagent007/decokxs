<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="1"
    id="@+id/list_top_item"
    paddingLeft="@dimen/margin_default"
    paddingRight="@dimen/margin_default"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/xxxsm"
    paddingHorizontal="@dimen/margin_default">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content">
        <RelativeLayout
            orientation="0"
            paddingTop="@dimen/margin_8dp"
            paddingBottom="@dimen/margin_8dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingVertical="@dimen/margin_8dp">
            <o.C55052xcf
                id="@+id/filter_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_centerVertical="true"
                layout_marginEnd="@dimen/ok_dp_16"
                NOT_FOUND_0x23="@string/pr_swaptrade_token_detail_dropdown_all_labels"/>
            <androidx.appcompat.widget.SwitchCompat
                id="@+id/switch_token"
                background="@drawable/_2131233752_res_0x7f080bd8"
                padding="2dp"
                layout_width="-2"
                android:layout_height="20dp"
                thumb="@drawable/_2131232010_res_0x7f08050a"
                layout_centerVertical="true"
                layout_marginEnd="@dimen/ok_dp_12"
                layout_toStartOf="@+id/iv_filter"
                backgroundTint="@color/SurfacePrimary"
                NOT_FOUND_0x28="@color/SurfacePrimary"/>
            <ImageView
                id="@+id/iv_filter"
                layout_width="@dimen/width_20dp"
                android:layout_height="@dimen/width_20dp"
                src="@drawable/_2131232227_res_0x7f0805e3"
                layout_centerVertical="true"
                layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="@dimen/sm">
        <o.C55258xgZ
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_address_helper"
            layout_width="132dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_token_detail_textarea_address"
            maxLines="1"
            layout_weight="1"
            layout_marginEnd="12dp"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x24="0"
            NOT_FOUND_0x25="@string/pr_swaptrade_list_colheader_address"
            NOT_FOUND_0x26="@style/Label_3_Regular"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_label_value_price"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginLeft="12dp"
            layout_marginRight="12dp"
            text="@string/pr_swaptrade_token_detail_item_avg_price"
            maxLines="1"
            layout_weight="1"
            layout_marginHorizontal="12dp"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1f="@+id/label_sort"
            NOT_FOUND_0x20="@+id/tv_address_helper"
            NOT_FOUND_0x22="0"
            style="@style/Label_3_Regular"/>
        <com.okinc.uilab.view.OKSortTextView
            ellipsize="3"
            gravity="0x800005"
            id="@+id/label_sort"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_token_detail_item_pnl"
            maxLines="1"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x20="@+id/tv_label_value_price"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x27="2"
            style="@style/OKSortTextView_Holder"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
