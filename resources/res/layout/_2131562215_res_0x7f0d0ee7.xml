<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    id="@+id/recurring_item"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="12dp">
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textColor="@color/okTradeG400"
        id="@+id/tv_rec_item_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textColor="@color/okTradeG900"
        id="@+id/tv_rec_item_text"
        layout_width="-2"
        android:layout_height="wrap_content"/>
</LinearLayout>
