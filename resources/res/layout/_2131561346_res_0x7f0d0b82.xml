<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_16dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_wallet"
        layout_width="@dimen/width_32dp"
        android:layout_height="@dimen/height_32dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <TextView
        textColor="@color/color_content_static_default"
        id="@+id/tv_wallet_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x11="@+id/iv_wallet"
        NOT_FOUND_0x14="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/color_content_static_subtle"
        id="@+id/tv_released_time"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="2"
        NOT_FOUND_0x12="@+id/tv_wallet_name"
        NOT_FOUND_0x13="@+id/tv_wallet_name"
        NOT_FOUND_0x15="1"
        style="@style/Label_3_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_arrow"
        layout_width="24dp"
        android:layout_height="24dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@color/ContentPrimary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
