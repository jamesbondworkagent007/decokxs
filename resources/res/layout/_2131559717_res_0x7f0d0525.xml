<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/scroll_layout"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        id="@+id/content_layout"
        paddingBottom="@dimen/padding_25dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        baselineAligned="false">
        <TextView
            textSize="@dimen/text_size_16sp"
            gravity="0x11"
            id="@+id/tv_title"
            paddingTop="@dimen/padding_12dp"
            paddingBottom="@dimen/padding_12dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingVertical="@dimen/padding_12dp"
            style="@style/Title_1_Bold"/>
        <com.okinc.uilab.item.OKRegularCell
            id="@+id/tv_camera"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0xd="@drawable/_2131231577_res_0x7f080359">
            <ImageView
                layout_gravity="0x10"
                layout_width="@dimen/width_24dp"
                android:layout_height="@dimen/height_24dp"
                src="@drawable/_2131231647_res_0x7f08039f"
                layout_marginStart="4dp"
                NOT_FOUND_0xe="@color/cell_description_color"/>
        </com.okinc.uilab.item.OKRegularCell>
        <com.okinc.uilab.item.OKRegularCell
            id="@+id/tv_gallery"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0xd="@drawable/_2131234272_res_0x7f080de0">
            <ImageView
                layout_gravity="0x10"
                layout_width="@dimen/width_24dp"
                android:layout_height="@dimen/height_24dp"
                src="@drawable/_2131231647_res_0x7f08039f"
                layout_marginStart="4dp"
                NOT_FOUND_0xe="@color/cell_description_color"/>
        </com.okinc.uilab.item.OKRegularCell>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
