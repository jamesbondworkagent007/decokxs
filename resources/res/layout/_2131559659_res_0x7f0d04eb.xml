<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textAppearance="@style/TextAppearance.Silka.Bold"
        textSize="@dimen/text_size_18sp"
        textColor="@color/grey_g900"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_trade_recurbot_detail_tunbibao_balance_mode"/>
    <TextView
        textColor="@color/grey_g700"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_smartportfolio_placeorder_tooltip_rebalance_mode_explain"
        style="@style/TextAppearance.Text.15SP"/>
    <TextView
        textColor="@color/grey_g700"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_trade_recurbot_detail_tunbibao_balance_mode_rate"
        style="@style/TextAppearance.Text.14SP.Medium"/>
    <TextView
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_6dp"
        text="@string/pr_smartportfolio_placeorder_tooltip_mode_proportional"
        style="@style/TextAppearance.Text.14SP.Medium"/>
    <TextView
        textColor="@color/grey_g700"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_trade_recurbot_detail_tunbibao_balance_mode_time"
        style="@style/TextAppearance.Text.14SP.Medium"/>
    <TextView
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_6dp"
        text="@string/pr_smartportfolio_placeorder_tooltip_mode_scheduled"
        style="@style/TextAppearance.Text.14SP.Medium"/>
</LinearLayout>
