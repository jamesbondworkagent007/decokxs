<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    tag="layout/trade_impl_fragment_mp_bot_category_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    overScrollMode="2">
    <RelativeLayout
        paddingLeft="@dimen/margin_default"
        paddingRight="@dimen/margin_default"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_default">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/bot_type_recycler_view"
            paddingTop="@dimen/padding_20dp"
            paddingBottom="@dimen/padding_20dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            overScrollMode="2"
            nestedScrollingEnabled="false"
            paddingVertical="@dimen/padding_20dp"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/bot_category_recycler_view"
            paddingBottom="@dimen/padding_32dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_below="@+id/bot_type_recycler_view"
            overScrollMode="2"
            nestedScrollingEnabled="false"/>
    </RelativeLayout>
</androidx.core.widget.NestedScrollView>
