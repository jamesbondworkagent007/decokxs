<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textSize="18sp"
        textColor="@color/ContentPrimary"
        id="@+id/title"
        tag="layout/layout_defi_asset_allocation_view_0"
        paddingTop="18dp"
        paddingBottom="18dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_home_header_allocation"
        paddingVertical="18dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        style="@style/Title_2_Bold"/>
    <o.C14705dqW
        id="@+id/percentageView"
        tag="layout/layout_defi_asset_allocation_view_1"
        layout_width="-1"
        android:layout_height="6dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/title"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/walletLayout"
        tag="layout/layout_defi_asset_allocation_view_2"
        layout_width="-1"
        android:layout_height="32dp"
        layout_marginTop="8dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/percentageView">
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="7dp"
            android:layout_height="7dp"
            src="@drawable/_2131231756_res_0x7f08040c"
            tint="@color/BrandPrimaryAlternative"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_home_title_crypto_num"
            layout_marginStart="8dp"
            style="@style/Label_3_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentContrast"
            id="@+id/walletPercent"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_3_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/walletAsset"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="10dp"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/defiLayout"
        tag="layout/layout_defi_asset_allocation_view_3"
        layout_width="-1"
        android:layout_height="32dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/walletLayout">
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="7dp"
            android:layout_height="7dp"
            src="@drawable/_2131231756_res_0x7f08040c"
            tint="@color/HighlightsInteractiveProfit"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_home_title_defi_num"
            layout_marginStart="8dp"
            style="@style/Label_3_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentContrast"
            id="@+id/defiPercent"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_3_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/defiAsset"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="10dp"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/nftLayout"
        tag="layout/layout_defi_asset_allocation_view_4"
        layout_width="-1"
        android:layout_height="32dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/defiLayout">
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="7dp"
            android:layout_height="7dp"
            src="@drawable/_2131231756_res_0x7f08040c"
            tint="@color/PreferenceTintedProfitModern"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_home_title_nft_num"
            layout_marginStart="8dp"
            style="@style/Label_3_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentContrast"
            id="@+id/nftPercent"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_3_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/nftAsset"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="10dp"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
</merge>
