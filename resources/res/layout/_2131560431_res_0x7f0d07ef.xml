<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/root"
    tag="layout/item_dapp_tab_0"
    background="@drawable/_2131231094_res_0x7f080176"
    layout_width="-1"
    android:layout_height="wrap_content">
    <RelativeLayout
        id="@+id/title_layout"
        background="@drawable/_2131231250_res_0x7f080212"
        layout_width="-1"
        android:layout_height="@dimen/height_36dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0">
        <ImageView
            id="@+id/icon"
            layout_width="@dimen/margin_20dp"
            android:layout_height="@dimen/margin_20dp"
            layout_centerVertical="true"
            layout_marginStart="8dp"/>
        <TextView
            textSize="@dimen/text_size_15sp"
            textColor="@color/okTradeG900"
            ellipsize="3"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_centerVertical="true"
            layout_marginStart="6dp"
            layout_toStartOf="@+id/close"
            layout_toEndOf="@+id/icon"
            style="@style/TextAppearance.Medium"/>
        <ImageView
            id="@+id/close"
            layout_width="-2"
            android:layout_height="@dimen/height_36dp"
            src="@drawable/_2131232980_res_0x7f0808d4"
            paddingStart="@dimen/margin_20dp"
            paddingEnd="8dp"
            layout_alignParentEnd="true"/>
        <View
            background="@color/dapp_tab_divide"
            layout_width="-1"
            android:layout_height="@dimen/margin_1dp"
            layout_alignParentBottom="true"/>
    </RelativeLayout>
    <o.C55064xcr
        id="@+id/thumb"
        layout_width="-1"
        android:layout_height="160dp"
        scaleType="6"
        NOT_FOUND_0x16="@+id/title_layout"
        NOT_FOUND_0x18="@dimen/margin_16dp"
        NOT_FOUND_0x19="@dimen/margin_16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
