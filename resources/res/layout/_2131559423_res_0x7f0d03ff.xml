<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    fillViewport="true">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginRight="@dimen/margin_default"
        layout_marginBottom="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default">
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_market_cap"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_commonall_filter_title_market_cap"
            style="@style/Label_2_Medium"/>
        <o.C28024kMb
            id="@+id/widget_market_cap_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_volume"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_commonall_filter_title_volume"
            style="@style/Label_2_Medium"/>
        <o.C28024kMb
            id="@+id/widget_volume_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_holders"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_invest_smartmoney_filter_input_title_holders"
            style="@style/Label_2_Medium"/>
        <o.C28034kMl
            id="@+id/widget_holders_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tv_token_age_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/height_16dp"
                layout_marginBottom="@dimen/xxxsm"
                text="@string/pr_swaptrade_market_custom_option_time_created"
                style="@style/Label_2_Medium"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.C55008xbo
                    id="@+id/input_token_age_min"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    inputType="0x2"
                    NOT_FOUND_0x16="48"
                    NOT_FOUND_0x17="1"
                    NOT_FOUND_0x18="@string/pr_wallet_pnl_select_label_min"
                    NOT_FOUND_0x19="1"
                    NOT_FOUND_0x1a="2"/>
                <o.C55008xbo
                    id="@+id/input_token_age_max"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginLeft="@dimen/xxsm"
                    layout_marginRight="@dimen/xxsm"
                    layout_weight="1"
                    inputType="0x2"
                    layout_marginHorizontal="@dimen/xxsm"
                    NOT_FOUND_0x16="48"
                    NOT_FOUND_0x17="1"
                    NOT_FOUND_0x18="@string/pr_swaptrade_general_placeholder_max"
                    NOT_FOUND_0x19="1"
                    NOT_FOUND_0x1a="2"/>
                <androidx.appcompat.widget.LinearLayoutCompat
                    gravity="0x11"
                    orientation="0"
                    id="@+id/cl_token_age_unit"
                    background="@drawable/_2131230992_res_0x7f080110"
                    paddingLeft="@dimen/xxsm"
                    paddingRight="@dimen/xxsm"
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    layout_weight="1"
                    backgroundTint="@color/color_surface_interactive_default"
                    paddingHorizontal="@dimen/xxsm">
                    <TextView
                        textColor="@color/color_content_static_placeholder"
                        id="@+id/tv_token_age_unit"
                        layout_width="0dp"
                        android:layout_height="wrap_content"
                        layout_weight="1"
                        style="@style/Body_2_Regular"/>
                    <ImageView
                        id="@+id/iv_token_age_unit"
                        layout_width="20dp"
                        android:layout_height="20dp"
                        src="@drawable/_2131231637_res_0x7f080395"
                        NOT_FOUND_0x1b="@color/color_content_static_placeholder"/>
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <TextView
                textColor="@color/SemanticNegative"
                id="@+id/tv_token_age_error"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_swaptrade_market_select_error_min_max"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_transactions"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_commonall_filter_title_transactions"
            style="@style/Label_2_Medium"/>
        <o.C28034kMl
            id="@+id/widget_transactions_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_buy_transactions"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_invest_smartmoney_filter_input_title_buy_txns"
            style="@style/Label_2_Medium"/>
        <o.C28034kMl
            id="@+id/widget_buy_transactions_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_sell_transactions"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_invest_smartmoney_filter_input_title_sell_txns"
            style="@style/Label_2_Medium"/>
        <o.C28034kMl
            id="@+id/widget_sell_transactions_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
