<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_24dp"
    paddingRight="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp">
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP.Medium"
        textColor="@color/ContentPrimary"
        id="@+id/what_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        text="@string/pr_acct_passkey_title1_what_is_passkey"
        NOT_FOUND_0x11="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/ContentTertiary"
        id="@+id/what_content"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_acct_passkey_desc1_what_is_passkey"
        NOT_FOUND_0x10="@+id/what_title"
        NOT_FOUND_0x12="22dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP.Medium"
        textColor="@color/ContentPrimary"
        id="@+id/how_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_acct_passkey_title2_keep_account_safe"
        NOT_FOUND_0x10="@+id/what_content"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/ContentTertiary"
        id="@+id/how_content"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_acct_passkey_desc2_keep_account_safe"
        NOT_FOUND_0x10="@+id/how_title"
        NOT_FOUND_0x12="22dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/ContentPrimary"
        id="@+id/link"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        layout_marginBottom="24dp"
        text="@string/pr_acct_passkey_link_how_to_manage_passkeys"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/how_content"/>
    <ImageView
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131233620_res_0x7f080b54"
        layout_marginStart="4dp"
        NOT_FOUND_0xd="@+id/link"
        NOT_FOUND_0xe="@+id/link"
        NOT_FOUND_0x11="@+id/link"/>
    <View
        layout_width="-1"
        android:layout_height="24dp"
        NOT_FOUND_0x10="@+id/link"/>
</androidx.constraintlayout.widget.ConstraintLayout>
