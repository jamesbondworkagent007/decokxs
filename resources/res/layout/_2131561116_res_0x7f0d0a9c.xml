<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="0dp"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        layout_width="-2"
        android:layout_height="wrap_content">
        <ImageView
            layout_gravity="0x10"
            id="@+id/titlePrefix"
            layout_width="@dimen/dp_8"
            android:layout_height="@dimen/dp_8"
            src="@drawable/_2131234003_res_0x7f080cd3"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_3_Regular"
            textColor="@color/okTradeG400"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/dp_4"/>
    </LinearLayout>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_2_Medium"
        textColor="@color/okTradeG900"
        id="@+id/amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/okTradeG400"
        id="@+id/progress"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"/>
</LinearLayout>
