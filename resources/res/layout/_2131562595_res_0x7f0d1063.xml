<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="12dp">
    <ImageView
        id="@+id/iv_dot"
        layout_width="4dp"
        android:layout_height="4dp"
        layout_marginTop="@dimen/margin_8dp"
        src="@drawable/_2131231010_res_0x7f080122"
        layout_marginEnd="@dimen/margin_6dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        id="@+id/tv_content"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_toEndOf="@+id/iv_dot"/>
</RelativeLayout>
