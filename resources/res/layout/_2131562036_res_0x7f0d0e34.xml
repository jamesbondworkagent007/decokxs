<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x11"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/okim_ext_plugin_icon"
        layout_width="56dp"
        android:layout_height="56dp"/>
    <TextView
        textAppearance="@style/Label_3_Medium"
        textSize="12sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x11"
        layout_gravity="0x1"
        id="@+id/okim_ext_plugin_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_6dp"
        maxWidth="75dp"
        maxLines="1"
        singleLine="true"/>
</LinearLayout>
