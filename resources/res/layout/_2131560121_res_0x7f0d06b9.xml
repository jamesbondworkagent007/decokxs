<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/ll_content"
    tag="layout/fragment_recover_over_limit_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_8dp">
    <ImageView
        layout_gravity="0x1"
        id="@+id/iv_state"
        layout_width="136dp"
        android:layout_height="136dp"/>
    <TextView
        textAppearance="@style/Headline_5_Bold"
        textSize="@dimen/text_size_24sp"
        textColor="@color/ContentPrimary"
        gravity="0x1"
        id="@+id/tv_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginTop="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp"/>
    <TextView
        textAppearance="@style/Body_2_Regular"
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentSecondary"
        gravity="0x1"
        id="@+id/tv_sub_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginTop="16dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginBottom="24dp"
        layout_marginHorizontal="@dimen/margin_24dp"/>
</LinearLayout>
