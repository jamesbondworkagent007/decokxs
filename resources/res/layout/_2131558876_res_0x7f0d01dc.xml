<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="@dimen/dp_40">
    <LinearLayout
        gravity="0x11"
        orientation="0"
        id="@+id/load_more_loading_view"
        layout_width="-1"
        android:layout_height="match_parent">
        <ProgressBar
            id="@+id/loading_progress"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginRight="@dimen/dp_4"
            style="?android:attr/progressBarStyleSmall"/>
        <TextView
            textSize="@dimen/sp_14"
            textColor="@android:color/black"
            id="@+id/loading_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/dp_4"
            text="@string/brvah_loading"/>
    </LinearLayout>
    <FrameLayout
        id="@+id/load_more_load_fail_view"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent">
        <TextView
            layout_gravity="0x11"
            id="@+id/tv_prompt"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/brvah_load_failed"/>
    </FrameLayout>
    <FrameLayout
        id="@+id/load_more_load_end_view"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent">
        <TextView
            textColor="@android:color/darker_gray"
            layout_gravity="0x11"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/brvah_load_end"/>
    </FrameLayout>
</FrameLayout>
