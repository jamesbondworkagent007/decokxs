<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/campaign_card_container"
    visibility="2"
    layout_width="-1"
    android:layout_height="wrap_content"
    NOT_FOUND_0x12="@color/SurfacePrimary"
    NOT_FOUND_0x13="12dp"
    NOT_FOUND_0x14="0dp"
    NOT_FOUND_0x15="true"
    NOT_FOUND_0x16="false"
    NOT_FOUND_0x1c="@color/BorderPrimary"
    NOT_FOUND_0x1d="0.5dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <FrameLayout
            id="@+id/imageLy"
            background="@drawable/_2131233662_res_0x7f080b7e"
            layout_width="0dp"
            android:layout_height="0dp"
            NOT_FOUND_0x17="16:9"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0">
            <com.google.android.material.imageview.ShapeableImageView
                id="@+id/campaign_image"
                layout_width="-1"
                android:layout_height="match_parent"
                scaleType="fitStart"
                adjustViewBounds="true"/>
            <View
                id="@+id/overlay"
                background="@drawable/_2131233665_res_0x7f080b81"
                visibility="2"
                layout_width="-1"
                android:layout_height="match_parent"/>
            <o.C55113xdn
                layout_gravity="0x11"
                id="@+id/progress"
                visibility="2"
                layout_width="24dp"
                android:layout_height="24dp"/>
            <ImageView
                layout_gravity="0x11"
                id="@+id/retry"
                visibility="2"
                layout_width="24dp"
                android:layout_height="24dp"
                src="@drawable/_2131233783_res_0x7f080bf7"
                NOT_FOUND_0x1e="@color/white"/>
        </FrameLayout>
        <LinearLayout
            orientation="1"
            id="@+id/campaign_text_container"
            padding="16dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="@+id/imageLy">
            <TextView
                textAppearance="@style/Label_1_Medium"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/campaign_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="2"/>
            <TextView
                textAppearance="@style/Label_2_Regular"
                textColor="@color/ContentTertiary"
                ellipsize="3"
                id="@+id/campaign_description"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                maxLines="2"/>
        </LinearLayout>
        <FrameLayout
            id="@+id/campaign_card_close"
            layout_width="20dp"
            android:layout_height="20dp"
            layout_marginTop="12dp"
            contentDescription="@string/pr_commonall_enterfield_btn_close"
            layout_marginEnd="12dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1b="0">
            <View
                layout_gravity="0x11"
                background="@color/BasePrimary"
                layout_width="10dp"
                android:layout_height="10dp"/>
            <ImageView
                layout_gravity="0x11"
                layout_width="-1"
                android:layout_height="match_parent"
                src="@drawable/_2131231668_res_0x7f0803b4"
                NOT_FOUND_0x1e="@color/ContentSecondary"/>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
