<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_20dp">
        <TextView
            textSize="20sp"
            textStyle="0x1"
            textColor="@color/grey_g900"
            id="@+id/tv_coin_name"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="BTCUSDT 永续"
            layout_marginStart="@dimen/margin_16dp"
            NOT_FOUND_0x1c="@+id/tv_running"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x20="0"
            style="@style/TextAppearance.Text.Bold"/>
        <TextView
            textSize="14sp"
            textColor="@color/grey_g900"
            gravity="0x800005"
            id="@+id/tv_running"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="停止"
            layout_marginStart="@dimen/margin_16dp"
            layout_marginEnd="@dimen/margin_16dp"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="@+id/tv_coin_name"
            NOT_FOUND_0x20="0"
            NOT_FOUND_0x21="0.3"
            style="@style/TextAppearance"/>
        <com.google.android.flexbox.FlexboxLayout
            id="@+id/tab_layout"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            NOT_FOUND_0x18="2"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="1"
            NOT_FOUND_0x1c="@+id/tv_running"
            NOT_FOUND_0x1e="@+id/tv_coin_name"
            NOT_FOUND_0x1f="@+id/tv_coin_name">
            <TextView
                textAppearance="@style/TextAppearance"
                textSize="@dimen/ok_dp_12"
                textColor="@color/grey_g700"
                id="@+id/tv_funture_type"
                background="@drawable/_2131231485_res_0x7f0802fd"
                paddingLeft="4dp"
                paddingTop="2dp"
                paddingRight="4dp"
                paddingBottom="2dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_margin="2dp"
                backgroundTint="@color/BackgroundLv3"
                paddingHorizontal="4dp"
                paddingVertical="2dp"
                NOT_FOUND_0x1e="@+id/ll_title"
                NOT_FOUND_0x1f="@+id/ll_title"/>
            <TextView
                textAppearance="@style/TextAppearance.Red.12SP"
                id="@+id/tv_buy_type"
                background="@drawable/_2131231485_res_0x7f0802fd"
                paddingLeft="4dp"
                paddingTop="2dp"
                paddingRight="4dp"
                paddingBottom="2dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_margin="2dp"
                backgroundTint="@color/okTradeRed50"
                paddingHorizontal="4dp"
                paddingVertical="2dp"
                NOT_FOUND_0x1d="@+id/tv_ord_type"
                NOT_FOUND_0x1f="@+id/ll_title"
                NOT_FOUND_0x22="@dimen/width_0dp"/>
            <TextView
                textAppearance="@style/TextAppearance.Subtitle.12SP"
                id="@+id/tv_lever"
                background="@drawable/_2131231485_res_0x7f0802fd"
                paddingLeft="4dp"
                paddingTop="2dp"
                paddingRight="4dp"
                paddingBottom="2dp"
                layout_width="-2"
                android:layout_height="match_parent"
                layout_margin="2dp"
                backgroundTint="@color/background_lv3"
                paddingHorizontal="4dp"
                paddingVertical="2dp"/>
        </com.google.android.flexbox.FlexboxLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g400"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_14dp"
        text="@string/pr_trade_bot_text_data_update"
        layout_marginStart="@dimen/margin_16dp"
        style="@style/TextAppearance"/>
    <LinearLayout
        orientation="1"
        background="@drawable/_2131233424_res_0x7f080a90"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_20dp"
        layout_marginBottom="@dimen/margin_8dp"
        layout_marginStart="@dimen/margin_16dp"
        layout_marginEnd="@dimen/margin_16dp">
        <LinearLayout
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textSize="14sp"
                textColor="@color/grey_g400"
                id="@+id/tv_profit"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_16dp"
                text="@string/pr_trade_bot_title_dissolve_moisture"
                layout_weight="1"
                layout_marginStart="@dimen/margin_12dp"
                style="@style/TextAppearance"/>
            <TextView
                textSize="14sp"
                textColor="@color/grey_g400"
                id="@+id/tv_profit_value"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_16dp"
                text="@string/pr_trade_bot_title_pnl_usdt"
                layout_marginEnd="@dimen/margin_12dp"
                style="@style/TextAppearance"/>
        </LinearLayout>
        <LinearLayout
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/margin_20dp">
            <TextView
                textSize="20sp"
                textStyle="0x1"
                textColor="@color/grey_g900"
                id="@+id/tv_ProfitSharing"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="5167.65"
                layout_weight="1"
                layout_marginStart="@dimen/margin_12dp"
                style="@style/TextAppearance.Text.Bold"/>
            <TextView
                textSize="20sp"
                textStyle="0x1"
                textColor="@color/positive"
                id="@+id/tv_income"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="+4,3567"
                layout_marginEnd="@dimen/margin_12dp"
                style="@style/TextAppearance.Text.Bold"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <TextView
            textSize="14sp"
            textColor="@color/grey_g400"
            id="@+id/tv_allocation_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_bot_title_expected_discharge"
            layout_weight="1"
            layout_marginStart="@dimen/margin_16dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/grey_g900"
            id="@+id/tv_allocation"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="+4,3567"
            layout_marginEnd="@dimen/margin_16dp"
            style="@style/TextAppearance.Text.Bold"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <TextView
            textSize="14sp"
            textColor="@color/grey_g400"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_dialog_text_proportion_moistening"
            layout_weight="1"
            layout_marginStart="@dimen/margin_16dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/grey_g900"
            id="@+id/tv_scale"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="10%"
            layout_marginEnd="@dimen/margin_16dp"
            style="@style/TextAppearance.Text.Bold"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <TextView
            textSize="14sp"
            textColor="@color/grey_g400"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_bot_title_pnl_percent"
            layout_weight="1"
            layout_marginStart="@dimen/margin_16dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/grey_g900"
            id="@+id/tv_rate"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="+308.55%"
            layout_marginEnd="@dimen/margin_16dp"
            style="@style/TextAppearance.Text.Bold"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <TextView
            textSize="14sp"
            textColor="@color/grey_g400"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_marketplace_home_botcard_running"
            layout_weight="1"
            layout_marginStart="@dimen/margin_16dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/grey_g900"
            id="@+id/tv_run_time"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="29天23时58分"
            layout_marginEnd="@dimen/margin_16dp"
            style="@style/TextAppearance.Text.Bold"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <TextView
            textSize="14sp"
            textColor="@color/grey_g400"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_bot_sort_bar_num_followers"
            layout_weight="1"
            layout_marginStart="@dimen/margin_16dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/grey_g900"
            id="@+id/tv_numbers"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="462156.78"
            layout_marginEnd="@dimen/margin_16dp"
            style="@style/TextAppearance.Text.Bold"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <TextView
            textSize="14sp"
            textColor="@color/grey_g400"
            id="@+id/tv_tape_scale_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_bot_title_tape_scale"
            layout_weight="1"
            layout_marginStart="@dimen/margin_16dp"
            style="@style/TextAppearance"/>
        <TextView
            textSize="14sp"
            textColor="@color/grey_g900"
            id="@+id/tv_tape_scale"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="316,09.14"
            layout_marginEnd="@dimen/margin_16dp"
            style="@style/TextAppearance.Text.Bold"/>
    </LinearLayout>
    <View
        id="@+id/v_divder"
        layout_marginTop="@dimen/dp24"
        style="@style/WidgetDivisionHistoryLine"/>
</LinearLayout>
