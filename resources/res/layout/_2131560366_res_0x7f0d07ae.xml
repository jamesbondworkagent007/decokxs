<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_buy_sell_select_payment_method_large_style_0"
    background="@drawable/_2131233822_res_0x7f080c1e"
    paddingTop="@dimen/dp_8"
    paddingBottom="@dimen/dp_8"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_8dp"
    paddingStart="@dimen/padding_16dp"
    paddingEnd="@dimen/padding_12dp"
    paddingVertical="@dimen/dp_8">
    <ImageView
        id="@+id/iv_method_icon"
        layout_width="@dimen/width_24dp"
        android:layout_height="@dimen/height_24dp"
        scaleType="fitStart"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x20="0"/>
    <Space
        id="@+id/space_between_icon_name"
        layout_width="@dimen/dp_4"
        android:layout_height="match_parent"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="@+id/iv_method_icon"
        NOT_FOUND_0x20="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.Bold.16SP"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/tv_method_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        maxWidth="156dp"
        lines="1"
        NOT_FOUND_0x1a="@+id/tv_method_description_below"
        NOT_FOUND_0x1d="@+id/space_between_icon_name"
        NOT_FOUND_0x20="0"/>
    <TextView
        textColor="@color/grey_g900"
        id="@+id/tv_method_name_large"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        layout_marginEnd="@dimen/ok_dp_16"
        NOT_FOUND_0x1c="@+id/iv_selected"
        NOT_FOUND_0x1d="@+id/space_between_icon_name"
        NOT_FOUND_0x20="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/tv_account"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        maxWidth="156dp"
        lines="1"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x1a="@+id/tv_method_description_below"
        NOT_FOUND_0x1d="@+id/tv_method_name"
        NOT_FOUND_0x20="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Medium"
        textColor="@color/white"
        id="@+id/tv_method_tag"
        background="@drawable/_2131233820_res_0x7f080c1c"
        paddingLeft="@dimen/dp_4"
        paddingTop="@dimen/padding_2dp"
        paddingRight="@dimen/dp_4"
        paddingBottom="@dimen/padding_2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_8"
        paddingHorizontal="@dimen/dp_4"
        paddingVertical="@dimen/padding_2dp"
        NOT_FOUND_0x19="@+id/iv_method_icon"
        NOT_FOUND_0x1d="@+id/tv_account"
        NOT_FOUND_0x20="@+id/iv_method_icon"/>
    <TextView
        textColor="@color/grey_g900"
        gravity="0x800003"
        id="@+id/tv_method_account_bottom"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/tv_method_name"
        style="@style/Body_4"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentTertiary"
        gravity="0x800003"
        id="@+id/tv_method_bank_account_type"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="@+id/space_between_icon_name"
        NOT_FOUND_0x1f="@+id/tv_method_name"
        style="@style/Body_4"/>
    <TextView
        textColor="@color/ContentSecondary"
        gravity="0x800003"
        id="@+id/tv_method_description"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0x1c="@+id/iv_selected"
        NOT_FOUND_0x1d="@+id/space_between_icon_name"
        NOT_FOUND_0x1f="@+id/tv_method_name_large"
        style="@style/Body_4"/>
    <TextView
        textColor="@color/ContentTertiary"
        gravity="0x800003"
        id="@+id/tv_method_description_below"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0x1c="@+id/iv_selected"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/tv_method_name"
        style="@style/Body_4"/>
    <ImageView
        id="@+id/iv_selected"
        visibility="1"
        layout_width="@dimen/width_18dp"
        android:layout_height="@dimen/width_18dp"
        src="@drawable/_2131232407_res_0x7f080697"
        scaleType="fitStart"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x20="0"/>
    <ImageView
        id="@+id/iv_change"
        visibility="1"
        layout_width="@dimen/ok_dp_16"
        android:layout_height="@dimen/ok_dp_16"
        src="@drawable/_2131232394_res_0x7f08068a"
        scaleType="fitStart"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="@color/Bluebell30"/>
</androidx.constraintlayout.widget.ConstraintLayout>
