<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x800015"
        layout_gravity="0x800015"
        orientation="0"
        id="@+id/layout_switch"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingStart="@dimen/xsm"
        paddingEnd="@dimen/xsm">
        <ImageView
            layout_gravity="0x10"
            id="@+id/iv_switch"
            layout_width="@dimen/xsm"
            android:layout_height="@dimen/xsm"
            src="@drawable/trading"
            contentDescription="transaction_switch_menu_icon"
            layout_marginEnd="@dimen/xxxxsm"
            NOT_FOUND_0x11="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            layout_gravity="0x10"
            id="@+id/tv_pool_switch"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"
            style="@style/Label_2_Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x800015"
        layout_gravity="0x800015"
        orientation="0"
        id="@+id/layout_validator"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/xsm">
        <ImageView
            id="@+id/iv_validator"
            layout_width="@dimen/xsm"
            android:layout_height="@dimen/xsm"
            scaleType="fitStart"
            contentDescription="transaction_switch_validator_icon"
            layout_marginEnd="@dimen/xxxxsm"
            NOT_FOUND_0x11="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            layout_gravity="0x800005"
            id="@+id/tv_validator_first_name"
            layout_width="-1"
            android:layout_height="wrap_content"
            text=""
            singleLine="true"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            layout_gravity="0x800005"
            id="@+id/tv_validator_last_name"
            layout_width="-2"
            android:layout_height="wrap_content"
            text=""
            singleLine="true"
            style="@style/Label_2_Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</FrameLayout>
