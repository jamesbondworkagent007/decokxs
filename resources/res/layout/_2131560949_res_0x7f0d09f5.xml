<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/card_view"
    layout_width="295dp"
    android:layout_height="wrap_content"
    layout_marginStart="12dp"
    NOT_FOUND_0x1a="@color/SurfacePrimary"
    NOT_FOUND_0x1b="@dimen/dp_20"
    NOT_FOUND_0x1c="0dp">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            paddingLeft="16dp"
            paddingRight="16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="16dp">
            <o.C35893oHp
                id="@+id/iv_avatar"
                layout_width="36dp"
                android:layout_height="36dp"
                src="@drawable/_2131232466_res_0x7f0806d2"
                scaleType="fitStart"
                importantForAccessibility="2"
                NOT_FOUND_0x1f="@+id/tv_member_count"
                NOT_FOUND_0x25="0"
                NOT_FOUND_0x27="@+id/tv_group_name"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_group_name"
                layout_width="0dp"
                android:layout_height="wrap_content"
                minHeight="24dp"
                maxLines="1"
                fontFamily="@font/okx_sans_tab_medium"
                layout_marginStart="12dp"
                NOT_FOUND_0x21="@+id/iv_premium"
                NOT_FOUND_0x22="0"
                NOT_FOUND_0x23="2"
                NOT_FOUND_0x24="@+id/iv_avatar"
                NOT_FOUND_0x27="0"
                NOT_FOUND_0x28="1"
                NOT_FOUND_0x29="-2"
                NOT_FOUND_0x2a="0dp"
                style="@style/Title_2_Medium"/>
            <ImageView
                id="@+id/iv_premium"
                visibility="2"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131233718_res_0x7f080bb6"
                baselineAligned="true"
                layout_marginStart="4dp"
                NOT_FOUND_0x1f="@+id/tv_group_name"
                NOT_FOUND_0x21="@+id/iv_official"
                NOT_FOUND_0x24="@+id/tv_group_name"
                NOT_FOUND_0x27="@+id/tv_group_name"/>
            <ImageView
                id="@+id/iv_official"
                visibility="2"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131234290_res_0x7f080df2"
                importantForAccessibility="2"
                layout_marginStart="@dimen/xxxxsm"
                NOT_FOUND_0x1f="@+id/tv_group_name"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x22="0"
                NOT_FOUND_0x24="@+id/iv_premium"
                NOT_FOUND_0x27="@+id/tv_group_name"
                NOT_FOUND_0x2b="@color/BrandPrimaryAlternative"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x10"
                id="@+id/tv_member_count"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_4"
                drawablePadding="4dp"
                NOT_FOUND_0x1d="@drawable/_2131232458_res_0x7f0806ca"
                NOT_FOUND_0x1e="@color/ContentContrast"
                NOT_FOUND_0x25="@+id/tv_group_name"
                NOT_FOUND_0x26="@+id/tv_group_name"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            textSize="@dimen/text_size_14sp"
            textColor="@color/ContentTertiary"
            ellipsize="3"
            id="@+id/tv_description"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="8dp"
            layout_marginRight="16dp"
            layout_marginBottom="16dp"
            minHeight="20dp"
            maxLines="1"
            fontFamily="@font/okx_sans_tab_regular"
            layout_marginHorizontal="16dp"
            NOT_FOUND_0x20="0"
            NOT_FOUND_0x25="0"
            NOT_FOUND_0x26="@+id/tv_member_count"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
