<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        paddingLeft="@dimen/mtrl_calendar_content_padding"
        paddingTop="16dp"
        paddingRight="@dimen/mtrl_calendar_content_padding"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <com.google.android.material.textfield.TextInputLayout
            id="@+id/mtrl_picker_text_input_range_start"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_weight="1">
            <com.google.android.material.textfield.TextInputEditText
                layout_width="-1"
                android:layout_height="wrap_content"
                hint="@string/mtrl_picker_text_input_date_range_start_hint"
                inputType="0x14"
                imeOptions="0x10000000"/>
        </com.google.android.material.textfield.TextInputLayout>
        <Space
            layout_width="8dp"
            android:layout_height="0dp"/>
        <com.google.android.material.textfield.TextInputLayout
            id="@+id/mtrl_picker_text_input_range_end"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_weight="1">
            <com.google.android.material.textfield.TextInputEditText
                layout_width="-1"
                android:layout_height="wrap_content"
                hint="@string/mtrl_picker_text_input_date_range_end_hint"
                inputType="0x14"
                imeOptions="0x10000000"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</ScrollView>
