        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        gravity="0x800033"
        layout_gravity="0x800003"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginTop="@dimen/margin_20dp"
        layout_marginRight="@dimen/margin_24dp"
        text="@string/pr_fdcabot_orderdetails_dialog_tips_your_profit_wont_be"
