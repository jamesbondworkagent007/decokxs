        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentPrimary"
        gravity="0x800033"
        layout_gravity="0x800003"
        id="@+id/reinvest_txt"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_24dp"
        text="@string/pr_fdcabot_orderdetails_title_reinvest_profits_in_next"
