        id="@+id/reinvest_switch"
        layout_width="-2"
        android:layout_height="wrap_content"
        checked="true"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="@+id/reinvest_txt"
        NOT_FOUND_0x1a="-5"/>
