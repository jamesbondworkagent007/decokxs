<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/container"
    tag="layout/item_input_description_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        id="@+id/input_text_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
    <com.okinc.uilab.edit.OKEditText
        enabled="true"
        gravity="0x30"
        id="@+id/text_input_description"
        background="@color/SurfacePrimary"
        padding="12dp"
        focusableInTouchMode="true"
        layout_width="-1"
        android:layout_height="150dp"
        layout_marginTop="4dp"
        maxLines="10"
        minLines="3"
        singleLine="false"
        inputType="0x20001"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/input_text_title"
        NOT_FOUND_0x18="0dp"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/input_image_clear"
        padding="10dp"
        visibility="2"
        layout_width="40dp"
        android:layout_height="40dp"
        src="@drawable/_2131232524_res_0x7f08070c"
        NOT_FOUND_0x12="@+id/text_input_description"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x19="@color/grey_g500"/>
    <TextView
        gravity="0x800003"
        id="@+id/input_text_error"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginEnd="@dimen/margin_8dp"
        NOT_FOUND_0x14="@+id/input_text_num"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/text_input_description"/>
    <TextView
        textColor="@color/grey_g300"
        id="@+id/input_text_num"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="@+id/text_input_description"/>
</androidx.constraintlayout.widget.ConstraintLayout>
