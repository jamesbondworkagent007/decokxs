<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/container"
    tag="layout/layout_item_nft_imagevideo_picker_0"
    layout_width="-2"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/icon"
        layout_width="109dp"
        android:layout_height="109dp"
        scaleType="fitEnd"/>
    <ImageView
        layout_gravity="0x35"
        id="@+id/choosed"
        visibility="2"
        layout_width="22dp"
        android:layout_height="22dp"
        layout_marginTop="7dp"
        layout_marginRight="7dp"
        src="@drawable/_2131232476_res_0x7f0806dc"/>
    <ImageView
        layout_gravity="0x50"
        id="@+id/durationMask"
        background="@drawable/_2131232277_res_0x7f080615"
        layout_width="-1"
        android:layout_height="24dp"/>
    <TextView
        textColor="@color/white_w900"
        layout_gravity="0x55"
        id="@+id/duration"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginRight="4dp"
        layout_marginBottom="4dp"/>
    <ImageView
        id="@+id/mask"
        layout_width="-1"
        android:layout_height="match_parent"
        alpha="0.25"/>
</FrameLayout>
