<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/margin_default"
    paddingTop="8dp"
    paddingRight="@dimen/margin_default"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default">
    <com.okinc.planet.widget.SimpleLabelValuePairView
        id="@+id/avgPxPair"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@color/ContentTertiary"
        NOT_FOUND_0x12="@string/pr_trade_overview_label_open_price"
        NOT_FOUND_0x13="14sp"
        NOT_FOUND_0x14="14sp"/>
    <com.okinc.planet.widget.SimpleLabelValuePairView
        id="@+id/bePxPair"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/avgPxPair"
        NOT_FOUND_0x11="@color/ContentTertiary"
        NOT_FOUND_0x12="@string/pr_trade_function_label_breakeven_price"
        NOT_FOUND_0x13="14sp"
        NOT_FOUND_0x14="14sp"/>
    <View
        id="@+id/divider"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="16dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/bePxPair"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_trade_function_desc_breakeven_price"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="@+id/divider"/>
</androidx.constraintlayout.widget.ConstraintLayout>
