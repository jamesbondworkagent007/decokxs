<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131231257_res_0x7f080219"
    layout_width="120dp"
    android:layout_height="104dp"
    minWidth="120dp"
    layout_marginEnd="8dp"
    backgroundTint="@color/BaseSecondary">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/ll_modules"
        paddingLeft="@dimen/xxsm"
        paddingTop="@dimen/xxsm"
        paddingRight="@dimen/xxsm"
        paddingBottom="@dimen/xxsm"
        layout_width="-1"
        android:layout_height="match_parent"
        paddingHorizontal="@dimen/xxsm"
        paddingVertical="@dimen/xxsm">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_module_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            includeFontPadding="false"
            style="@style/Label_1_Regular"/>
        <TextView
            textColor="?attr/tradeRiseDefault"
            ellipsize="3"
            id="@+id/tv_module_change"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            maxLines="1"
            NOT_FOUND_0x15="16sp"
            NOT_FOUND_0x16="12sp"
            NOT_FOUND_0x17="1sp"
            NOT_FOUND_0x18="1"
            style="@style/Label_1_Medium"/>
        <View
            layout_width="0dp"
            android:layout_height="0dp"
            layout_weight="1"/>
        <FrameLayout
            id="@+id/fl_coins"
            layout_width="-2"
            android:layout_height="wrap_content"
            minHeight="20dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</FrameLayout>
