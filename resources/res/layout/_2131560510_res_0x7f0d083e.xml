<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/cl_faq_item"
    tag="layout/item_faq_0"
    paddingTop="@dimen/margin_8dp"
    paddingBottom="@dimen/margin_8dp"
    focusable="true"
    clickable="true"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/margin_8dp">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_1"
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_faq_question"
        tag="binding_1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        NOT_FOUND_0x14="@+id/iv_faq_chevron"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_faq_chevron"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231637_res_0x7f080395"
        tint="@color/ContentPrimary"
        NOT_FOUND_0x12="@+id/tv_faq_question"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x17="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_2_Regular"
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentTertiary"
        id="@+id/tv_faq_answer"
        tag="binding_2"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/tv_faq_question"/>
</androidx.constraintlayout.widget.ConstraintLayout>
