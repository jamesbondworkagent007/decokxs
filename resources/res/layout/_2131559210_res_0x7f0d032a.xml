<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    paddingLeft="33dp"
    paddingRight="33dp"
    layout_width="-1"
    android:layout_height="70dp"
    layout_marginTop="4dp"
    paddingHorizontal="33dp">
    <View
        id="@+id/start_line_vertical"
        background="@drawable/_2131231870_res_0x7f08047e"
        layout_width="1dp"
        android:layout_height="match_parent"
        layout_alignParentStart="true"/>
    <View
        background="@drawable/_2131231869_res_0x7f08047d"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_centerVertical="true"/>
    <TextView
        textSize="14sp"
        gravity="0x11"
        id="@+id/tv_percent"
        background="@color/okTradeBgLv1"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        layout_marginStart="@dimen/margin_9dp"
        style="@style/TextAppearance.Title.14SP.Medium"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_two_pair"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        paddingEnd="16dp"
        layout_toStartOf="@+id/end_line_vertical"
        layout_toEndOf="@+id/tv_percent">
        <ImageView
            id="@+id/arrow_start"
            layout_width="0dp"
            android:layout_height="wrap_content"
            src="@drawable/_2131231868_res_0x7f08047c"
            scaleType="7"
            layout_weight="1"/>
        <o.C24485iei
            id="@+id/coin_pair"
            layout_width="66dp"
            android:layout_height="58dp"
            layout_marginStart="1dp"/>
        <ImageView
            id="@+id/arrow_starts"
            layout_width="0dp"
            android:layout_height="wrap_content"
            src="@drawable/_2131231868_res_0x7f08047c"
            scaleType="7"
            layout_weight="5"/>
        <o.C24485iei
            id="@+id/coin_pair_double"
            layout_width="66dp"
            android:layout_height="58dp"/>
    </LinearLayout>
    <View
        id="@+id/end_line_vertical"
        background="@drawable/_2131231870_res_0x7f08047e"
        layout_width="1dp"
        android:layout_height="match_parent"
        layout_alignParentEnd="true"/>
</RelativeLayout>
