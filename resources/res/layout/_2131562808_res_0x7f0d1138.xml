<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    background="@color/BasePrimary"
    scrollbars="horizontal"
    layout_width="48dp"
    android:layout_height="wrap_content">
    <RelativeLayout
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            gravity="0x1"
            orientation="1"
            id="@+id/ll_main"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexVol"
                layout_width="-1"
                android:layout_height="24dp"
                text="VOL"/>
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexMa"
                layout_width="-1"
                android:layout_height="24dp"
                text="MA"/>
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexEma"
                layout_width="-1"
                android:layout_height="24dp"
                text="EMA"/>
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexBoll"
                layout_width="-1"
                android:layout_height="24dp"
                text="BOLL"/>
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexSar"
                layout_width="-1"
                android:layout_height="24dp"
                text="SAR"/>
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexSr"
                layout_width="-1"
                android:layout_height="24dp"
                text="@string/pr_trade_function_title_chart_indicator_resist"/>
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexSt"
                paddingLeft="1dp"
                paddingRight="1dp"
                layout_width="-1"
                android:layout_height="24dp"
                text="@string/pr_trade_charts_tag_supertrend"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeMinTextSize="4sp"
                paddingHorizontal="1dp"
                autoSizeMaxTextSize="10sp"/>
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexEnvelope"
                paddingLeft="1dp"
                paddingRight="1dp"
                layout_width="-1"
                android:layout_height="24dp"
                text="@string/pr_trade_charts_textarea_header_nadaraya_watson_envelope"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeMinTextSize="4sp"
                paddingHorizontal="1dp"
                autoSizeMaxTextSize="10sp"/>
            <TextView
                textSize="10sp"
                textColor="@color/tab_text_color"
                gravity="0x11"
                id="@+id/mTvIndexVWAP"
                paddingLeft="1dp"
                paddingRight="1dp"
                layout_width="-1"
                android:layout_height="24dp"
                text="@string/pr_trade_chart_main_indicator_option_vwap"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeMinTextSize="4sp"
                paddingHorizontal="1dp"
                autoSizeMaxTextSize="10sp"/>
            <View
                background="@color/okTradeG200"
                layout_width="32dp"
                android:layout_height="1px"
                layout_marginTop="4dp"/>
        </LinearLayout>
        <o.pAI
            id="@+id/mIndexRecyclerView"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_below="@+id/ll_main"/>
    </RelativeLayout>
</ScrollView>
