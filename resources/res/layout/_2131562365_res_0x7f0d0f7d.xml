<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/trade_impl_grid_edit_confirm_dialog_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    overScrollMode="2">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        paddingLeft="@dimen/padding_24dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/margin_10dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_24dp">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/before_recycler_view"
            layout_width="-1"
            android:layout_height="wrap_content"/>
        <View
            id="@+id/view_line"
            visibility="0"
            layout_marginTop="24dp"
            style="@style/WidgetDivisionLine"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/after_recycler_view"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"/>
        <View
            id="@+id/view_line_1"
            visibility="0"
            layout_marginTop="24dp"
            style="@style/WidgetDivisionLine"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/allocationlly"
            background="@drawable/_2131231494_res_0x7f080306"
            paddingLeft="@dimen/padding_12dp"
            paddingTop="@dimen/padding_16dp"
            paddingRight="@dimen/padding_12dp"
            paddingBottom="@dimen/padding_16dp"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp24"
            backgroundTint="@color/SurfacePrimary"
            paddingHorizontal="@dimen/padding_12dp"
            paddingVertical="@dimen/padding_16dp">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tvAllocationTitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_spotgrid_confirmorder_cardtitle_est_initial_allocation"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x15="0"
                style="@style/TextAppearance.Text.14SP.Medium"/>
            <o.wUX
                id="@+id/distributionBarView"
                background="@color/SurfacePrimary"
                layout_width="0dp"
                android:layout_height="@dimen/dp_6"
                layout_marginTop="@dimen/padding_12dp"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x14="@+id/tvAllocationTitle"/>
            <LinearLayout
                orientation="0"
                id="@+id/coinTextLly"
                visibility="2"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/padding_12dp"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x14="@+id/distributionBarView"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            id="@+id/view_line_2"
            visibility="2"
            layout_marginTop="@dimen/padding_16dp"
            style="@style/WidgetDivisionLine"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_waring_text"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/padding_12dp"
            text="@string/pr_spotgrid_confirmorder_reminder_actual_alloc_vary"
            style="@style/TextAppearance.Text.12SP.Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
