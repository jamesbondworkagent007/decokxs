<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/ll_content_kline"
    layout_width="-1"
    android:layout_height="match_parent">
    <o.C57591ylM
        id="@+id/mMarketStatusBar"
        layout_width="-1"
        android:layout_height="0dp"/>
    <o.C57585ylG
        id="@+id/simulation_change_head_rll"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/mLlMarketBar"
        layout_width="-1"
        android:layout_height="44dp">
        <ImageView
            id="@+id/mIvMarketBack"
            layout_width="-2"
            android:layout_height="match_parent"
            src="@drawable/_2131232719_res_0x7f0807cf"
            paddingStart="16dp"
            paddingEnd="16dp"
            NOT_FOUND_0x2c="@color/grey_g900_white_w900"/>
        <FrameLayout
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1">
            <LinearLayout
                gravity="0x800013"
                layout_gravity="0x800013"
                id="@+id/mLlMarketSeach"
                layout_width="-2"
                android:layout_height="match_parent">
                <TextView
                    textAppearance="@style/TextAppearance.Title.14SP.Semibold"
                    ellipsize="3"
                    gravity="0x800013"
                    layout_gravity="0x800013"
                    id="@+id/mTvMarketCoinName"
                    clickable="false"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="买 BTCUSDT\10卖BTCUSDTSWap"
                    maxLines="2"/>
                <ImageView
                    layout_gravity="0x800013"
                    id="@+id/mMarketIvArrow"
                    background="@drawable/_2131233921_res_0x7f080c81"
                    layout_width="16dp"
                    android:layout_height="16dp"
                    layout_marginStart="@dimen/dp_6"/>/&gt; 
            </LinearLayout>
            <LinearLayout
                layout_gravity="0x50"
                orientation="0"
                id="@+id/ll_vice_title"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textSize="@dimen/text_size_12sp"
                    ellipsize="3"
                    id="@+id/tv_vice_price"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginBottom="@dimen/margin_4dp"
                    singleLine="true"
                    includeFontPadding="false"
                    fontFamily="@font/font_alpha_bold"/>
                <TextView
                    textSize="@dimen/text_size_12sp"
                    ellipsize="3"
                    id="@+id/tv_vice_range"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginBottom="@dimen/margin_4dp"
                    singleLine="true"
                    includeFontPadding="false"
                    fontFamily="@font/font_alpha_medium"
                    layout_marginStart="12dp"/>
                <TextView
                    textSize="@dimen/text_size_12sp"
                    ellipsize="3"
                    id="@+id/tv_vice_local_price"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginBottom="@dimen/margin_4dp"
                    singleLine="true"
                    includeFontPadding="false"
                    fontFamily="@font/font_alpha_medium"
                    layout_marginStart="12dp"/>
            </LinearLayout>
        </FrameLayout>
        <ImageView
            id="@+id/mIvMarketOption"
            background="@drawable/_2131233467_res_0x7f080abb"
            visibility="2"
            layout_width="24dp"
            android:layout_height="24dp"
            backgroundTint="@color/kline_start_selector"/>
        <ImageView
            id="@+id/mIvMarket_Share"
            visibility="0"
            layout_width="-2"
            android:layout_height="match_parent"
            src="@drawable/_2131234035_res_0x7f080cf3"
            contentDescription="klineDetailsShareBtn"
            paddingEnd="16dp"
            layout_marginStart="12dp"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="0dp"
            layout_weight="1">
            <com.google.android.material.tabs.TabLayout
                id="@+id/kline_tabLayout"
                background="@color/transparent"
                layout_width="-1"
                android:layout_height="36dp"
                layout_marginStart="@dimen/dp_4"
                NOT_FOUND_0x20="@android:color/transparent"
                NOT_FOUND_0x21="0"
                NOT_FOUND_0x22="@color/color_kline_tab"
                NOT_FOUND_0x23="false"
                NOT_FOUND_0x24="20dp"
                NOT_FOUND_0x25="0"
                NOT_FOUND_0x26="12dp"
                NOT_FOUND_0x27="12dp"
                NOT_FOUND_0x28="@color/transparent"
                NOT_FOUND_0x29="@color/color_tab_select"
                NOT_FOUND_0x2a="@style/TextAppearance.Text.14SP.TabMedium"
                NOT_FOUND_0x2b="@color/color_tab_un_select"
                style="@style/TabLayout.Title.Scrollable"/>
            <View
                id="@+id/header_divider_line"
                layout_width="-1"
                android:layout_height="0.5dp"/>
            <o.pAK
                id="@+id/kline_viewpager"
                visibility="0"
                layout_width="-1"
                android:layout_height="match_parent"/>
        </LinearLayout>
        <LinearLayout
            orientation="1"
            id="@+id/ll_bottom_Layout"
            layout_width="-1"
            android:layout_height="wrap_content">
            <View
                id="@+id/bottom_divider_line"
                layout_width="-1"
                android:layout_height="1px"/>
            <LinearLayout
                gravity="0x10"
                id="@+id/mLlBottomTrade"
                background="@color/background_lv2"
                layout_width="-1"
                android:layout_height="68dp"
                paddingStart="16dp">
                <o.C52794wYp
                    textSize="@dimen/text_size_16sp"
                    gravity="0x11"
                    id="@+id/mArbToTrade"
                    layout_width="0dp"
                    android:layout_height="40dp"
                    text="@string/pr_chart_btn_trade"
                    layout_weight="1"
                    NOT_FOUND_0x1e="40"
                    NOT_FOUND_0x1f="0x103"/>
                <o.C33624mzv
                    textSize="@dimen/text_size_10sp"
                    textColor="@color/kline_bottom_icon"
                    gravity="0x11"
                    id="@+id/mIvFirst"
                    visibility="1"
                    layout_width="44dp"
                    android:layout_height="match_parent"
                    text="@string/pr_chart_bottom_spot"
                    drawableTop="@drawable/_2131232913_res_0x7f080891"
                    lineSpacingMultiplier="0.8"
                    layout_marginStart="@dimen/margin_8dp"
                    layout_marginEnd="@dimen/margin_4dp"
                    NOT_FOUND_0x1d="@color/grey_g900"/>
                <o.C33624mzv
                    textSize="@dimen/text_size_10sp"
                    textColor="@color/kline_bottom_icon"
                    gravity="0x11"
                    id="@+id/mIvSecond"
                    visibility="1"
                    layout_width="44dp"
                    android:layout_height="match_parent"
                    text="@string/pr_chart_bottom_margin"
                    drawableTop="@drawable/_2131232909_res_0x7f08088d"
                    lineSpacingMultiplier="0.8"
                    layout_marginEnd="@dimen/margin_4dp"
                    NOT_FOUND_0x1d="@color/grey_g900"/>
                <o.C33624mzv
                    textSize="@dimen/text_size_10sp"
                    textColor="@color/kline_bottom_icon"
                    gravity="0x11"
                    id="@+id/mIvMarketPriceRemind"
                    layout_width="44dp"
                    android:layout_height="match_parent"
                    text="@string/pr_chart_bottom_alert"
                    maxLines="2"
                    drawableTop="@drawable/_2131232698_res_0x7f0807ba"
                    lineSpacingMultiplier="0.8"
                    layout_marginEnd="@dimen/margin_8dp"
                    NOT_FOUND_0x1d="@color/grey_g900"/>
            </LinearLayout>
            <LinearLayout
                gravity="0x10"
                id="@+id/mLlBottomTradeRight"
                background="@color/background_lv2"
                visibility="2"
                layout_width="-1"
                android:layout_height="68dp">
                <o.C33624mzv
                    textSize="@dimen/text_size_10sp"
                    textColor="@color/kline_bottom_icon"
                    gravity="0x11"
                    id="@+id/mIvMarketPriceRemindRight"
                    layout_width="44dp"
                    android:layout_height="match_parent"
                    text="@string/pr_chart_bottom_alert"
                    maxLines="2"
                    drawableTop="@drawable/_2131232698_res_0x7f0807ba"
                    lineSpacingMultiplier="0.8"
                    layout_marginStart="@dimen/margin_8dp"
                    layout_marginEnd="@dimen/margin_4dp"
                    NOT_FOUND_0x1d="@color/grey_g900"/>
                <o.C33624mzv
                    textSize="@dimen/text_size_10sp"
                    textColor="@color/kline_bottom_icon"
                    gravity="0x11"
                    id="@+id/mIvSecondRight"
                    visibility="1"
                    layout_width="44dp"
                    android:layout_height="match_parent"
                    text="@string/pr_chart_bottom_margin"
                    drawableTop="@drawable/_2131232909_res_0x7f08088d"
                    lineSpacingMultiplier="0.8"
                    layout_marginEnd="@dimen/margin_4dp"
                    NOT_FOUND_0x1d="@color/grey_g900"/>
                <o.C33624mzv
                    textSize="@dimen/text_size_10sp"
                    textColor="@color/kline_bottom_icon"
                    gravity="0x11"
                    id="@+id/mIvFirstRight"
                    visibility="1"
                    layout_width="44dp"
                    android:layout_height="match_parent"
                    text="@string/pr_chart_bottom_spot"
                    drawableTop="@drawable/_2131232913_res_0x7f080891"
                    lineSpacingMultiplier="0.8"
                    layout_marginEnd="@dimen/margin_8dp"
                    NOT_FOUND_0x1d="@color/grey_g900"/>
                <o.C52794wYp
                    textSize="@dimen/text_size_16sp"
                    gravity="0x11"
                    id="@+id/mArbToTradeRight"
                    layout_width="0dp"
                    android:layout_height="40dp"
                    text="@string/pr_chart_btn_trade"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    NOT_FOUND_0x1e="40"
                    NOT_FOUND_0x1f="0x103"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
