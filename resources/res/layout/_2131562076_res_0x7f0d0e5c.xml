<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/ellipsis"
        layout_width="8dp"
        android:layout_height="8dp"
        src="@drawable/_2131231661_res_0x7f0803ad"
        layout_alignBottom="@+id/createTimeTv"
        layout_alignParentTop="true"
        contentDescription="@null"
        NOT_FOUND_0x1d="@color/ContentPrimary"/>
    <View
        id="@+id/timeline"
        background="@drawable/_2131234292_res_0x7f080df4"
        layout_width="-2"
        android:layout_height="match_parent"
        layout_below="@+id/createTimeTv"
        layout_alignBottom="@+id/bottomMargin"
        layout_alignStart="@+id/ellipsis"
        layout_alignEnd="@+id/ellipsis"
        backgroundTint="@color/BorderSecondary"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/createTimeTv"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginStart="8dp"
        layout_toEndOf="@+id/ellipsis"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/detailContainer"
        background="@drawable/_2131231413_res_0x7f0802b5"
        paddingLeft="@dimen/padding_12dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_12dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_below="@+id/createTimeTv"
        layout_alignStart="@+id/createTimeTv"
        paddingHorizontal="@dimen/padding_12dp"
        paddingVertical="@dimen/padding_16dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/titleTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                layout_marginEnd="12dp"
                style="@style/Label_2_Medium"/>
            <o.C52794wYp
                id="@+id/detailButton"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_botdetails_dialog_details"
                NOT_FOUND_0x1b="24"
                NOT_FOUND_0x1c="0x104"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/recyclerView"
            layout_width="-1"
            android:layout_height="wrap_content"
            overScrollMode="2"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <View
        id="@+id/bottomMargin"
        layout_width="-1"
        android:layout_height="18dp"
        layout_below="@+id/detailContainer"/>
</RelativeLayout>
