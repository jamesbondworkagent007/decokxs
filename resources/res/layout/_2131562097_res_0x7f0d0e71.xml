<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/planet_dialog_profile_setting_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_8dp"
    layout_marginBottom="@dimen/margin_24dp">
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/settings"
        paddingLeft="@dimen/padding_24dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/padding_16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_commonall_modal_btn_settings"
        drawablePadding="@dimen/padding_12dp"
        paddingHorizontal="@dimen/padding_24dp"
        paddingVertical="@dimen/padding_16dp"
        NOT_FOUND_0x1b="@drawable/_2131231650_res_0x7f0803a2"
        NOT_FOUND_0x1c="@drawable/_2131233932_res_0x7f080c8c"
        NOT_FOUND_0x1d="@color/ContentPrimary"
        style="@style/Label_1_Regular"/>
    <RelativeLayout
        gravity="0x10"
        id="@+id/edit_alias_name"
        paddingLeft="@dimen/padding_24dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/padding_16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_24dp"
        paddingVertical="@dimen/padding_16dp">
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x10"
            id="@+id/edit_alias_name_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_message_profile_input_title_alias"
            drawablePadding="@dimen/padding_12dp"
            layout_centerVertical="true"
            layout_alignParentStart="true"
            NOT_FOUND_0x1c="@drawable/_2131234283_res_0x7f080deb"
            NOT_FOUND_0x1d="@color/ContentPrimary"
            style="@style/Label_1_Regular"/>
        <ImageView
            id="@+id/edit_alias_name_arrow"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131231650_res_0x7f0803a2"
            layout_centerVertical="true"
            contentDescription="@null"
            layout_alignParentEnd="true"
            NOT_FOUND_0x1e="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/edit_alias_name_value"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_centerVertical="true"
            layout_marginEnd="@dimen/margin_12dp"
            layout_toStartOf="@+id/edit_alias_name_arrow"
            layout_alignParentEnd="false"
            style="@style/Label_2_Regular"/>
    </RelativeLayout>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/my_activity"
        paddingLeft="@dimen/padding_24dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/padding_16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_orbit_profile_cell_tag_my_activity"
        drawablePadding="@dimen/padding_12dp"
        paddingHorizontal="@dimen/padding_24dp"
        paddingVertical="@dimen/padding_16dp"
        NOT_FOUND_0x1b="@drawable/_2131231650_res_0x7f0803a2"
        NOT_FOUND_0x1c="@drawable/_2131231523_res_0x7f080323"
        NOT_FOUND_0x1d="@color/ContentPrimary"
        style="@style/Label_1_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/share_profile"
        paddingLeft="@dimen/padding_24dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_orbit_profile_cell_tag_share_profile"
        drawablePadding="@dimen/padding_12dp"
        paddingHorizontal="@dimen/padding_24dp"
        paddingVertical="@dimen/padding_16dp"
        NOT_FOUND_0x1b="@drawable/_2131231650_res_0x7f0803a2"
        NOT_FOUND_0x1c="@drawable/_2131234035_res_0x7f080cf3"
        NOT_FOUND_0x1d="@color/ContentPrimary"
        style="@style/Label_1_Regular"/>
</LinearLayout>
