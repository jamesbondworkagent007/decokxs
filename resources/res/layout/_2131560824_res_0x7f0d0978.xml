<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_recurring_buy_plan_detail_pnl_block_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <FrameLayout
        layout_gravity="0x11"
        id="@+id/icon_container"
        background="@drawable/_2131233690_res_0x7f080b9a"
        padding="@dimen/dp_4"
        layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/title"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0">
        <ImageView
            id="@+id/icon"
            layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            scaleType="7"
            contentDescription="@null"/>
    </FrameLayout>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="2"
        gravity="0x800003"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/dp_12"
        NOT_FOUND_0x10="@dimen/text_size_16sp"
        NOT_FOUND_0x11="@dimen/text_size_12sp"
        NOT_FOUND_0x12="@dimen/text_size_1sp"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x15="@+id/subtitle"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="@+id/icon_container"
        NOT_FOUND_0x1d="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentTertiary"
        gravity="0x800003"
        id="@+id/subtitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/subtitle_icon"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="2"
        NOT_FOUND_0x1b="@+id/title"
        NOT_FOUND_0x1c="@+id/title"
        style="@style/Label_2_Regular"/>
    <ImageView
        id="@+id/subtitle_icon"
        visibility="2"
        layout_width="@dimen/dp_16"
        android:layout_height="@dimen/dp_16"
        src="@drawable/_2131233141_res_0x7f080975"
        contentDescription="@null"
        layout_marginStart="@dimen/dp_4"
        NOT_FOUND_0x14="@+id/subtitle"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="@+id/subtitle"
        NOT_FOUND_0x1d="@+id/subtitle"
        NOT_FOUND_0x1e="@color/ContentTertiary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
