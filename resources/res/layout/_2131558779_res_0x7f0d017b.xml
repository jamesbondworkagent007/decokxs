<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131230869_res_0x7f080095"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginTop="60dp">
    <FrameLayout
        paddingLeft="@dimen/common_page_edge_space"
        paddingRight="@dimen/common_page_edge_space"
        layout_width="-1"
        android:layout_height="48dp"
        paddingHorizontal="@dimen/common_page_edge_space">
        <o.wYC
            layout_gravity="0x800013"
            id="@+id/backButton"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232719_res_0x7f0807cf"
            tint="@color/ContentContrast"/>
    </FrameLayout>
    <ScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_authlogin_passkey_bttmsheet_header_cant_find"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Headline_4_Bold"/>
            <TextView
                textColor="@color/ContentTertiary"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                text="@string/pr_authlogin_passkey_bttmsheet_desc_cant_find"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Body_2_Regular"/>
            <ImageView
                layout_gravity="0x1"
                id="@+id/crossDeviceImage"
                layout_width="327dp"
                android:layout_height="352dp"
                layout_marginLeft="@dimen/common_page_edge_space"
                layout_marginTop="24dp"
                layout_marginRight="@dimen/common_page_edge_space"
                layout_marginBottom="16dp"
                layout_marginHorizontal="@dimen/common_page_edge_space"/>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        orientation="1"
        paddingLeft="@dimen/common_page_edge_space"
        paddingTop="16dp"
        paddingRight="@dimen/common_page_edge_space"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/common_page_edge_space"
        paddingVertical="16dp">
        <o.C52794wYp
            id="@+id/resetPasskeyButton"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_authlogin_passkey_bttmsheet_btn_reset_passkey"
            NOT_FOUND_0x17="52"
            NOT_FOUND_0x18="0x102"/>
    </LinearLayout>
</LinearLayout>
