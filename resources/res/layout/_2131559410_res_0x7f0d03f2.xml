<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingTop="@dimen/padding_12dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/padding_12dp">
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/trader_avatar"
        layout_width="36dp"
        android:layout_height="36dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/trader_address"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/margin_8dp"
        layout_marginEnd="@dimen/margin_8dp"
        NOT_FOUND_0x16="@+id/pnl_amount"
        NOT_FOUND_0x17="@+id/trader_avatar"
        NOT_FOUND_0x1a="0"
        style="@style/Label_2_Medium"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/trade_info_container"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        NOT_FOUND_0x18="@+id/trader_address"
        NOT_FOUND_0x19="@+id/trader_address">
        <TextView
            gravity="0x11"
            id="@+id/trade_type_indicator"
            paddingLeft="@dimen/padding_4dp"
            paddingTop="@dimen/padding_2dp"
            paddingRight="@dimen/padding_4dp"
            paddingBottom="@dimen/padding_2dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            minWidth="16dp"
            paddingHorizontal="@dimen/padding_4dp"
            paddingVertical="@dimen/padding_2dp"
            style="@style/Label_3_Medium"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/trade_time"
            layout_width="-2"
            android:layout_height="wrap_content"
            includeFontPadding="false"
            layout_marginStart="@dimen/margin_4dp"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <TextView
        id="@+id/pnl_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x1a="0"
        style="@style/Label_2_Medium"/>
    <TextView
        textColor="@color/ContentSecondary"
        id="@+id/position_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        maxLines="1"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="@+id/pnl_amount"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
