<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        gravity="0x11"
        id="@+id/tv_title_name"
        layout_width="-2"
        android:layout_height="32dp"
        text="@string/pr_trade_discover_title_name"
        layout_centerVertical="true"
        layout_marginStart="@dimen/dp24"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        gravity="0x11"
        id="@+id/tv_split_line"
        paddingLeft="8dp"
        paddingRight="8dp"
        layout_width="-2"
        android:layout_height="32dp"
        text="|"
        layout_centerVertical="true"
        paddingHorizontal="8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="@+id/tv_title_name"
        NOT_FOUND_0x11="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        gravity="0x11"
        id="@+id/tv_indicater"
        layout_width="-2"
        android:layout_height="32dp"
        text="@string/pr_trade_colheader_sort_pair"
        layout_centerVertical="true"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="@+id/tv_split_line"
        NOT_FOUND_0x11="0"/>
    <o.C55052xcf
        textSize="12sp"
        id="@+id/time_menu_chip"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/dp24"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@string/pr_trade_discover_cell_today"
        NOT_FOUND_0x13="-5"/>
</merge>
