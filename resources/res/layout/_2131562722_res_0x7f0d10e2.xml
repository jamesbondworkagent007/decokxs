<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    clipChildren="false"
    clipToPadding="false"
    layout_width="-2"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/triangleup"
        background="@drawable/_2131232378_res_0x7f08067a"
        visibility="1"
        layout_width="14dp"
        android:layout_height="5dp"
        layout_marginTop="2dp"
        contentDescription="@null"/>
    <FrameLayout
        orientation="1"
        id="@+id/contentLayout"
        background="@drawable/_2131231516_res_0x7f08031c"
        paddingLeft="6dp"
        paddingTop="6dp"
        paddingRight="6dp"
        paddingBottom="6dp"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="-1px"
        paddingHorizontal="6dp"
        paddingVertical="6dp"/>
    <ImageView
        id="@+id/triangledown"
        background="@drawable/_2131232377_res_0x7f080679"
        visibility="0"
        layout_width="14dp"
        android:layout_height="5dp"
        layout_marginTop="-1px"
        layout_marginBottom="2dp"
        contentDescription="@null"/>
</LinearLayout>
