<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131231798_res_0x7f080436"
    padding="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/dynamic_desc"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1b="0">
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.16SP.Regular"
                textColor="@color/ContentPrimary"
                gravity="0x800015"
                id="@+id/tv_select_mode"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="150dp"
                text="@string/pr_swaptrade_slippage_cell_label_dynamic"
                layout_marginStart="@dimen/margin_16dp"/>
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/iv_chevron"
                layout_width="-2"
                android:layout_height="20dp"
                src="@drawable/_2131231637_res_0x7f080395"
                scaleType="7"
                tint="@color/ContentPrimary"
                contentDescription="web3_dex_slippage_mode_dropdown"
                layout_marginStart="@dimen/margin_4dp"/>
        </LinearLayout>
        <o.C55320xhi
            textAppearance="@style/TextAppearance.Text.16SP.Regular"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_slippage_cell_tips_slippage_tolerance"
            maxLines="1"
            layout_marginEnd="8dp"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x19="@+id/dynamic_desc"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1f="true"
            NOT_FOUND_0x20="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/SemanticNotice"
        gravity="0x800013"
        id="@+id/tv_select_hint"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_swaptrade_slippage_select_dynamic_num"/>
    <FrameLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <o.C55008xbo
            id="@+id/dynamic_input"
            background="@drawable/_2131231828_res_0x7f080454"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"
            hint="@string/pr_swaptrade_slippage_input_unit_3_10"
            inputType="0x2002"
            NOT_FOUND_0x1c="0dp"
            NOT_FOUND_0x1d="48"
            NOT_FOUND_0x1e="8dp"/>
        <LinearLayout
            orientation="1"
            id="@+id/fixed_panel"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/rv_fixed"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/SemanticNotice"
                gravity="0x800013"
                id="@+id/tv_fixed_hint"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"/>
            <o.C55008xbo
                id="@+id/fixed_input"
                background="@drawable/_2131231828_res_0x7f080454"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                hint="5～50"
                inputType="0x2002"
                NOT_FOUND_0x1c="0dp"
                NOT_FOUND_0x1d="48"
                NOT_FOUND_0x1e="8dp"/>
        </LinearLayout>
    </FrameLayout>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/SemanticNotice"
        gravity="0x800013"
        id="@+id/tv_hint"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        contentDescription="web3_dex_slippage_error_label"/>
</LinearLayout>
