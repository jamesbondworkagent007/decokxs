<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/ok_dp_24"
    layout_marginTop="@dimen/dp_8"
    layout_marginRight="@dimen/ok_dp_24"
    layout_marginBottom="32dp"
    layout_marginHorizontal="@dimen/ok_dp_24">
    <ImageView
        id="@+id/iv_group_selection"
        visibility="2"
        layout_width="22dp"
        android:layout_height="match_parent"
        src="@drawable/_2131234264_res_0x7f080dd8"
        importantForAccessibility="2"
        layout_marginEnd="@dimen/ok_dp_16"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_group_item"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <FrameLayout
            id="@+id/ll_token_logo"
            layout_width="@dimen/width_28dp"
            android:layout_height="@dimen/width_28dp"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="0">
            <ImageView
                id="@+id/token_image"
                layout_width="@dimen/ok_dp_24"
                android:layout_height="@dimen/ok_dp_24"
                layout_marginTop="@dimen/margin_2dp"
                layout_marginBottom="@dimen/margin_2dp"
                scaleType="7"
                importantForAccessibility="2"
                layout_marginVertical="@dimen/margin_2dp"/>
            <ImageView
                id="@+id/chain_image"
                background="@drawable/_2131231867_res_0x7f08047b"
                layout_width="@dimen/dp_10"
                android:layout_height="@dimen/dp_10"
                layout_marginTop="@dimen/margin_18dp"
                src="@drawable/_2131231603_res_0x7f080373"
                scaleType="7"
                importantForAccessibility="2"
                layout_marginStart="17dp"
                backgroundTint="@color/line_light"/>
        </FrameLayout>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_token_symbol"
            layout_width="@dimen/width_0dp"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/ok_dp_12"
            layout_marginRight="@dimen/ok_dp_12"
            maxLines="1"
            layout_marginHorizontal="@dimen/ok_dp_12"
            NOT_FOUND_0x19="@+id/tv_alert_count"
            NOT_FOUND_0x1a="@+id/ll_token_logo"
            NOT_FOUND_0x1d="0"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="2"
            id="@+id/tv_token_address"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/ok_dp_12"
            layout_marginRight="@dimen/ok_dp_12"
            maxLines="1"
            layout_marginHorizontal="@dimen/ok_dp_12"
            NOT_FOUND_0x19="@+id/tv_alert_count"
            NOT_FOUND_0x1a="@+id/ll_token_logo"
            NOT_FOUND_0x1c="@+id/tv_token_symbol"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentInverse"
            gravity="0x11"
            id="@+id/tv_alert_count"
            background="@drawable/_2131231847_res_0x7f080467"
            layout_width="@dimen/width_20dp"
            android:layout_height="@dimen/height_14dp"
            layout_marginEnd="@dimen/dp_8"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x19="@+id/iv_expand_card"
            NOT_FOUND_0x1d="0"
            style="@style/Label_4_Medium"/>
        <ImageView
            id="@+id/iv_expand_card"
            layout_width="@dimen/ok_dp_16"
            android:layout_height="@dimen/ok_dp_16"
            src="@drawable/_2131231637_res_0x7f080395"
            importantForAccessibility="2"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1d="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
