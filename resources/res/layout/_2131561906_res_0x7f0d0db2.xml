<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginLeft="@dimen/margin_24dp"
    layout_marginRight="@dimen/margin_24dp"
    layout_marginHorizontal="@dimen/margin_24dp">
    <androidx.core.widget.NestedScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="wrap_content"
        overScrollMode="2">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp">
                <FrameLayout
                    id="@+id/ll_token_logo"
                    layout_width="@dimen/width_32dp"
                    android:layout_height="@dimen/height_32dp"
                    layout_marginEnd="@dimen/dp_12">
                    <ImageView
                        id="@+id/icon"
                        background="@drawable/_2131231884_res_0x7f08048c"
                        layout_width="@dimen/width_32dp"
                        android:layout_height="@dimen/height_32dp"
                        scaleType="7"
                        importantForAccessibility="2"/>
                    <ImageView
                        layout_gravity="0x800055"
                        id="@+id/sub_icon"
                        background="@drawable/_2131231884_res_0x7f08048c"
                        visibility="2"
                        layout_width="@dimen/dp_12"
                        android:layout_height="@dimen/dp_12"
                        src="@drawable/_2131231603_res_0x7f080373"
                        scaleType="7"
                        importantForAccessibility="2"
                        backgroundTint="@color/line_light"/>
                </FrameLayout>
                <TextView
                    textColor="@color/okTradeG900"
                    gravity="0x11"
                    id="@+id/tv_title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    drawablePadding="@dimen/dp_12"
                    NOT_FOUND_0x26="@drawable/_2131232901_res_0x7f080885"
                    style="@style/TextAppearance.Title.16SP.Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="0"
                id="@+id/alertTypeLayout"
                background="@drawable/_2131233477_res_0x7f080ac5"
                layout_width="-1"
                android:layout_height="@dimen/dp_48"
                layout_marginTop="@dimen/dp_16"
                paddingStart="@dimen/dp_12"
                paddingEnd="@dimen/dp_6">
                <TextView
                    textColor="@color/okTradeG900"
                    gravity="0x10"
                    id="@+id/tv_alert_type"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    drawablePadding="5dp"
                    layout_weight="1"
                    style="@style/TextAppearance.Title.16SP.Medium"/>
                <ImageView
                    id="@+id/iv_alert"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    src="@drawable/_2131231588_res_0x7f080364"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="0"
                id="@+id/layout_price"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_16">
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tvType"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_tradechart_price_alert_input_price"
                    style="@style/TextAppearance.Title.14SP.Medium"/>
                <androidx.appcompat.widget.LinearLayoutCompat
                    gravity="0x800015"
                    id="@+id/llPrice"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_weight="1">
                    <TextView
                        textSize="@dimen/text_size_12sp"
                        textColor="@color/ContentContrast"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_trade_mid_placeholder_market_price"
                        layout_marginEnd="8dp"/>
                    <o.C55390xiz
                        textAppearance="@style/TextAppearance.Medium"
                        id="@+id/tv_price"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="--"
                        NOT_FOUND_0x2d="1"/>
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <o.C46693tbw
                id="@+id/marketInputLayout"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"/>
            <o.C46645tbA
                id="@+id/marketIndicatorLayout"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <TextView
                textColor="@color/SemanticNegative"
                id="@+id/tv_price_remind_error"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                layout_marginBottom="@dimen/margin_8dp"
                layout_marginVertical="@dimen/margin_8dp"
                style="@style/TextAppearance.Red.12SP"/>
            <TextView
                textAppearance="@style/TextAppearance.Title.14SP.Medium"
                textColor="@color/ContentPrimary"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_16dp"
                text="@string/pr_trade_input_title_frequency"
                style="@style/TextAppearance.Title.14SP.Medium"/>
            <o.wYX
                id="@+id/frequency_type"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                NOT_FOUND_0x2e="2"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_16dp">
                <com.okinc.uilab.edit.OKEditText
                    textSize="14sp"
                    textColorHint="@color/ContentDisabled"
                    gravity="0x800033"
                    id="@+id/note_edit"
                    background="@drawable/_2131231268_res_0x7f080224"
                    padding="12dp"
                    layout_width="0dp"
                    android:layout_height="80dp"
                    hint="@string/pr_trade_alert_textarea_placeholder_add_note_optional"
                    inputType="0x20001"
                    textCursorDrawable="@drawable/_2131233430_res_0x7f080a96"
                    NOT_FOUND_0x27="0"
                    NOT_FOUND_0x28="0"
                    NOT_FOUND_0x29="0"
                    NOT_FOUND_0x2a="0"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.14SP.Regular"
                    textColor="@color/ContentContrast"
                    id="@+id/word_count"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginBottom="12dp"
                    text="0/40"
                    layout_marginEnd="12dp"
                    NOT_FOUND_0x27="@+id/note_edit"
                    NOT_FOUND_0x28="@+id/note_edit"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="0"
                paddingTop="@dimen/padding_16dp"
                paddingBottom="@dimen/padding_16dp"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_24"
                paddingVertical="@dimen/padding_16dp">
                <o.C52794wYp
                    enabled="false"
                    gravity="0x11"
                    id="@+id/btn_price_remind_delete"
                    layout_width="0dp"
                    android:layout_height="@dimen/height_48dp"
                    text="@string/pr_trade_footer_btn_delete"
                    layout_weight="1"
                    NOT_FOUND_0x2b="48"
                    NOT_FOUND_0x2c="0x102"
                    NOT_FOUND_0x2f="6"/>
                <View
                    id="@+id/spacer"
                    layout_width="@dimen/ok_dp_12"
                    android:layout_height="1dp"/>
                <o.C52794wYp
                    enabled="false"
                    gravity="0x11"
                    id="@+id/btn_price_remind_create"
                    layout_width="0dp"
                    android:layout_height="@dimen/height_48dp"
                    text="@string/pr_trade_header_title_add"
                    layout_weight="1"
                    NOT_FOUND_0x2b="48"
                    NOT_FOUND_0x2c="0x101"
                    NOT_FOUND_0x2f="6"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
