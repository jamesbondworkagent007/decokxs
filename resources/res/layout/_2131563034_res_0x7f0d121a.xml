<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        style="@style/Label_2_Regular"/>
    <LinearLayout
        orientation="1"
        id="@+id/ll_rewards_content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/tv_title">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/cl_reward_first"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp">
            <ImageView
                id="@+id/iv_reward_icon_first"
                layout_width="@dimen/width_24dp"
                android:layout_height="@dimen/height_24dp"
                src="@drawable/_2131231677_res_0x7f0803bd"
                NOT_FOUND_0xc="0"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x11="0"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_reward_amount_first"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_marginStart="@dimen/xxxsm"
                NOT_FOUND_0xc="0"
                NOT_FOUND_0xe="@+id/iv_reward_icon_first"
                NOT_FOUND_0x11="0"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/cl_reward_second"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp">
            <ImageView
                id="@+id/iv_reward_icon_second"
                layout_width="@dimen/width_24dp"
                android:layout_height="@dimen/height_24dp"
                src="@drawable/_2131231677_res_0x7f0803bd"
                NOT_FOUND_0xc="0"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x11="0"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_reward_amount_second"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_marginStart="@dimen/xxxsm"
                NOT_FOUND_0xc="0"
                NOT_FOUND_0xe="@+id/iv_reward_icon_second"
                NOT_FOUND_0x11="0"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
