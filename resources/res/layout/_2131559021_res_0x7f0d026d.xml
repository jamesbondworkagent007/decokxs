<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        gravity="0x11"
        layout_gravity="0x11"
        id="@+id/tv_order_message"
        paddingLeft="24dp"
        paddingTop="8dp"
        paddingRight="24dp"
        paddingBottom="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        lineSpacingExtra="3dp"
        paddingHorizontal="24dp"
        paddingVertical="8dp"/>
    <View
        id="@+id/status_bar_order"
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="1dp"/>
</androidx.appcompat.widget.LinearLayoutCompat>
