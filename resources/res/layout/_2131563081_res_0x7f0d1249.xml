<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131230913_res_0x7f0800c1"
    paddingLeft="@dimen/dp_16"
    paddingTop="@dimen/margin_20dp"
    paddingRight="@dimen/dp_16"
    paddingBottom="@dimen/margin_20dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/dp_16"
    paddingVertical="@dimen/margin_20dp">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/text_size_10sp"
            textColor="@color/okTradeG400"
            layout_gravity="0x10"
            id="@+id/app_widget_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_widgets_header_label_watchlist"
            style="@style/TextAppearance.Text.12SP"/>
        <ImageView
            layout_width="0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
        <ImageView
            layout_gravity="0x800015"
            id="@+id/app_widget_setting"
            background="@drawable/_2131233932_res_0x7f080c8c"
            layout_width="@dimen/dp_16"
            android:layout_height="@dimen/dp_16"
            scaleType="fillCenter"
            layout_marginEnd="8dp"
            backgroundTint="@color/okTradeG400"/>
        <ImageView
            layout_gravity="0x800015"
            background="@mipmap/_2131689474_res_0x7f0f0002"
            layout_width="@dimen/dp_16"
            android:layout_height="@dimen/dp_16"/>
    </LinearLayout>
    <LinearLayout
        layout_gravity="0x30"
        orientation="1"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="@dimen/dp24">
        <ListView
            id="@+id/app_widget_list"
            scrollbars="horizontal"
            layout_width="-1"
            android:layout_height="match_parent"
            divider="@color/LineMuted"
            dividerHeight="0.5dp"/>
    </LinearLayout>
</FrameLayout>
