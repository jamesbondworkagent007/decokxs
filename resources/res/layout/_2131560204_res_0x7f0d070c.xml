<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/fragment_tactics_normal_information_0"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="match_parent"
    fillViewport="true"
    overScrollMode="2">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            orientation="1"
            id="@+id/grid_assets_root_lly"
            background="@drawable/_2131231430_res_0x7f0802c6"
            paddingLeft="16dp"
            paddingTop="@dimen/padding_12dp"
            paddingRight="16dp"
            paddingBottom="@dimen/padding_12dp"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_default"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginRight="@dimen/margin_default"
            layout_marginHorizontal="@dimen/margin_default"
            paddingHorizontal="16dp"
            paddingVertical="@dimen/padding_12dp">
            <o.C55258xgZ
                id="@+id/current_assets"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_strategy_item_current_holding"
                NOT_FOUND_0x17="1"
                NOT_FOUND_0x18="@color/okTradeG400"
                NOT_FOUND_0x19="@dimen/text_size_14sp"
                NOT_FOUND_0x1a="400"
                NOT_FOUND_0x1b="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.Medium"
                textSize="@dimen/text_size_14sp"
                textColor="@color/grey_g900"
                id="@+id/current_assets_number"
                paddingTop="@dimen/padding_4dp"
                paddingBottom="@dimen/padding_16dp"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"/>
            <o.C55258xgZ
                id="@+id/initial_assets"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_strategy_item_total_investment"
                NOT_FOUND_0x17="1"
                NOT_FOUND_0x18="@color/okTradeG400"
                NOT_FOUND_0x19="@dimen/text_size_14sp"
                NOT_FOUND_0x1a="400"
                NOT_FOUND_0x1b="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.Medium"
                textSize="@dimen/text_size_14sp"
                textColor="@color/grey_g900"
                id="@+id/initial_assets_number"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"/>
            <o.C55258xgZ
                id="@+id/tv_earn_holding"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                text="@string/pr_trade_botdetails_subtitle_spot_grid_earn_holdings"
                NOT_FOUND_0x17="1"
                NOT_FOUND_0x18="@color/okTradeG400"
                NOT_FOUND_0x19="@dimen/text_size_14sp"
                NOT_FOUND_0x1a="400"
                NOT_FOUND_0x1b="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.Medium"
                textSize="@dimen/text_size_14sp"
                textColor="@color/grey_g900"
                id="@+id/tv_earn_holding_amt"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/normal_recyclerview"
            paddingLeft="@dimen/margin_default"
            paddingRight="@dimen/margin_default"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_10dp"
            overScrollMode="2"
            paddingHorizontal="@dimen/margin_default"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
