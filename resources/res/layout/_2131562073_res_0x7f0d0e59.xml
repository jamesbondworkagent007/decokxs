<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/dp24"
    paddingTop="@dimen/dp_16"
    paddingRight="@dimen/dp24"
    paddingBottom="@dimen/dp_16"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp24"
    paddingVertical="@dimen/dp_16">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/img_avatar"
        layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        src="@drawable/_2131232465_res_0x7f0806d1"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        lines="1"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x13="true"
        NOT_FOUND_0x16="@+id/tv_followers"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="2"
        NOT_FOUND_0x19="@+id/img_avatar"
        NOT_FOUND_0x1c="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_followers"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x14="@+id/tv_name"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="@+id/tv_name"
        NOT_FOUND_0x1c="@+id/tv_name"
        style="@style/Label_3_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentTertiary"
        ellipsize="3"
        id="@+id/tv_bio"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        maxLines="2"
        includeFontPadding="false"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="@+id/img_avatar"
        NOT_FOUND_0x1b="@+id/tv_name"
        style="@style/Body_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
