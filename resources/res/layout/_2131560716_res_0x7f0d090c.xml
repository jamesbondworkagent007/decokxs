<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingRight="24dp"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp">
    <o.C35893oHp
        id="@+id/iv_avatar"
        layout_width="24dp"
        android:layout_height="24dp"
        scaleType="6"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/username_container"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="8dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/iv_avatar"
        NOT_FOUND_0x1a="0">
        <TextView
            textSize="14sp"
            textColor="@color/ContentContrast"
            id="@+id/tv_username"
            layout_width="-2"
            android:layout_height="wrap_content"
            lines="1"
            layout_marginEnd="4dp"
            style="@style/Label_3_Medium"/>
        <ImageView
            id="@+id/verifiedIcon"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131234290_res_0x7f080df2"
            layout_marginEnd="4dp"
            NOT_FOUND_0x1b="@color/BrandPrimaryAlternative"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_tag"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            lines="1"
            layout_marginEnd="4dp"
            style="@style/TagTextView"/>
        <TextView
            textColor="@color/ContentSecondary"
            id="@+id/tv_role_badge"
            background="@drawable/_2131231414_res_0x7f0802b6"
            paddingLeft="4dp"
            paddingTop="2dp"
            paddingRight="4dp"
            paddingBottom="2dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            lines="1"
            layout_marginEnd="4dp"
            paddingHorizontal="4dp"
            paddingVertical="2dp"
            style="@style/Label_4_Regular"/>
    </LinearLayout>
    <TextView
        textSize="14sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_message_content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        lineSpacingExtra="2dp"
        layout_marginStart="8dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/iv_avatar"
        NOT_FOUND_0x19="@+id/username_container"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
