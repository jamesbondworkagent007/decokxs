<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/Title_1_Bold"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_card_header_trending_collections"
        layout_marginStart="@dimen/margin_24dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="0"/>
    <androidx.recyclerview.widget.RecyclerView
        orientation="0"
        id="@+id/rv_nft_collections"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        overScrollMode="2"
        paddingEnd="@dimen/padding_24dp"
        NOT_FOUND_0xc="androidx.recyclerview.widget.LinearLayoutManager"
        NOT_FOUND_0xe="@+id/tv_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
