<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingTop="4dp"
    paddingBottom="4dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="4dp">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.16SP.Bold"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/tv_slippage"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_modal_dialog_title_slippage"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/ContentSecondary"
        gravity="0x800003"
        id="@+id/tv_slippage_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8"
        text="@string/pr_swaptrade_dialog_subtitle_slippage_refers"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.16SP.Bold"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/tv_dynamic"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_swaptrade_modal_dialog_title_dynamic"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/ContentSecondary"
        gravity="0x800003"
        id="@+id/tv_dynamic_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8"
        text="@string/pr_swaptrade_modal_dialog_desc_well_execute_trade"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.16SP.Bold"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/tv_fixed"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_swaptrade_modal_dialog_title_fixed"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/ContentSecondary"
        gravity="0x800003"
        id="@+id/tv_fixed_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8"
        text="@string/pr_swaptrade_modal_dialog_desc_well_only_execute"/>
</LinearLayout>
