<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP.Semibold"
        id="@+id/tv_position_tier_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        text="@string/pr_trade_kline_header_position_tiers"/>
    <LinearLayout
        orientation="0"
        id="@+id/position_tier_title_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        layout_marginBottom="12dp">
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800033"
            layout_width="0dp"
            android:layout_height="match_parent"
            text="@string/pr_trade_text_trade_info_tier"
            maxLines="3"
            layout_weight="1"
            layout_marginEnd="4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800033"
            id="@+id/tv_max_contracts"
            layout_width="0dp"
            android:layout_height="match_parent"
            text="@string/pr_trade_text_info_size_of_cont"
            maxLines="3"
            layout_weight="1"
            layout_marginEnd="4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800033"
            layout_width="0dp"
            android:layout_height="match_parent"
            text="@string/pr_trade_positiontier_colheader_max_lvg"
            maxLines="3"
            layout_weight="1"
            layout_marginEnd="4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800033"
            layout_width="0dp"
            android:layout_height="match_parent"
            text="@string/pr_trade_text_trade_ui_trade_info_min_imr"
            maxLines="3"
            layout_weight="1"
            layout_marginEnd="4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800035"
            layout_width="0dp"
            android:layout_height="match_parent"
            text="@string/pr_trade_text_info_mmr"
            maxLines="3"
            layout_weight="1"/>
    </LinearLayout>
    <View
        id="@+id/divider"
        background="@color/trade_line_color"
        layout_width="-1"
        android:layout_height="0.5dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/position_tier_recycler_view"
        layout_width="-1"
        android:layout_height="wrap_content"
        overScrollMode="2"
        nestedScrollingEnabled="false"/>
    <o.C55173xeu
        id="@+id/position_tier_empty_view"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_48dp"
        layout_marginBottom="@dimen/margin_48dp"/>
</LinearLayout>
