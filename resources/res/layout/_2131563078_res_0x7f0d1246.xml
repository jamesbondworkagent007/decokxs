<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131230913_res_0x7f0800c1"
    paddingLeft="@dimen/dp_16"
    paddingTop="@dimen/margin_18dp"
    paddingRight="@dimen/dp_16"
    paddingBottom="@dimen/margin_18dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/dp_16"
    paddingVertical="@dimen/margin_18dp">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/text_size_10sp"
            textColor="@color/okTradeG400"
            ellipsize="3"
            layout_gravity="0x10"
            id="@+id/app_widget_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="@dimen/height_72dp"
            text="@string/pr_widgets_header_label_watchlist_crypto"
            singleLine="true"
            style="@style/TextAppearance.Text.10SP"/>
        <ImageView
            layout_width="0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
        <ImageView
            layout_gravity="0x800015"
            id="@+id/app_widget_setting"
            background="@drawable/_2131233932_res_0x7f080c8c"
            layout_width="@dimen/dp_16"
            android:layout_height="@dimen/dp_16"
            scaleType="fillCenter"
            layout_marginEnd="8dp"
            backgroundTint="@color/okTradeG400"/>
        <ImageView
            layout_gravity="0x800015"
            background="@mipmap/_2131689474_res_0x7f0f0002"
            layout_width="@dimen/dp_16"
            android:layout_height="@dimen/dp_16"
            scaleType="fillCenter"/>
    </LinearLayout>
    <RelativeLayout
        id="@+id/app_widget_item_layout"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="24dp">
        <LinearLayout
            orientation="1"
            id="@+id/inner_price"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_alignParentBottom="true">
            <TextView
                textSize="@dimen/sp_12"
                textColor="@color/positive"
                id="@+id/app_widget_change_percent"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Title.12SP.Semibold"/>
            <LinearLayout
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textSize="@dimen/sp_16"
                    textStyle="0x1"
                    textColor="@color/positive"
                    id="@+id/app_widget_price"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    singleLine="true"
                    style="@style/TextAppearance.Title.16SP.Semibold"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            id="@+id/app_widget_icon"
            layout_width="@dimen/dp_32"
            android:layout_height="@dimen/dp_32"
            layout_marginBottom="@dimen/ok_dp_12"
            scaleType="fillCenter"
            layout_above="@+id/inner_price"
            contentDescription=""/>
    </RelativeLayout>
</FrameLayout>
