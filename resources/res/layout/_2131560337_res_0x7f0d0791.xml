<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/content"
    background="@color/BasePrimary"
    paddingLeft="@dimen/margin_default"
    paddingTop="16dp"
    paddingRight="@dimen/margin_default"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default">
    <RelativeLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP.Medium"
            ellipsize="3"
            id="@+id/tv_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="2"
            drawablePadding="@dimen/padding_6dp"/>
        <ImageView
            gravity="0x11"
            id="@+id/iv_edit_share"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131232894_res_0x7f08087e"
            layout_marginStart="8dp"
            layout_alignParentEnd="true"
            NOT_FOUND_0x14="@color/grey_g900"/>
    </RelativeLayout>
    <o.C55372xih
        orientation="0"
        id="@+id/ll_contract"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x12="6dp"
        NOT_FOUND_0x13="6dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcv_content"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <View
        id="@+id/divider"
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="16dp"/>
</LinearLayout>
