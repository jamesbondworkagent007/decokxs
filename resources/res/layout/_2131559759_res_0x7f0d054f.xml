                layout_marginBottom="8dp"
                src="@drawable/_2131234286_res_0x7f080dee"
                layout_marginEnd="@dimen/margin_default"
                layout_marginVertical="8dp"
                NOT_FOUND_0x1f="@color/ContentPrimary"/>
        </LinearLayout>
        <o.C57597ylS
            id="@+id/activity_header_appbar"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x11="@string/pr_swaptrade_market_tab_title_tracker"
            NOT_FOUND_0x12="@color/ContentPrimary"
            NOT_FOUND_0x13="@drawable/_2131231642_res_0x7f08039a"
            NOT_FOUND_0x14="false"
            NOT_FOUND_0x15="@drawable/_2131234286_res_0x7f080dee"
            NOT_FOUND_0x16="true"
            NOT_FOUND_0x17="true"/>
        <o.C55254xgV
            theme="@style/OKUITheme.Alternative.Web3"
            id="@+id/tabs"
            layout_width="-1"
            android:layout_height="wrap_content"
            elevation="0dp"
            NOT_FOUND_0x18="true"
            NOT_FOUND_0x19="44"
            NOT_FOUND_0x1a="2"
            NOT_FOUND_0x1b="@dimen/height_2dp"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="?attr/horizontalPaddingDimension"
            NOT_FOUND_0x1e="?attr/horizontalPaddingDimension"/>
