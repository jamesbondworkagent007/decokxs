<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/item_root_layout"
    tag="layout/item_group_notification_message_0"
    paddingTop="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    baselineAligned="false">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_unread_divider"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/xsm"
        layout_marginRight="@dimen/xsm"
        layout_marginBottom="@dimen/margin_16dp"
        layout_marginHorizontal="@dimen/xsm">
        <View
            background="@color/BorderPrimary"
            layout_width="0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
        <TextView
            textColor="@color/ContentContrast"
            layout_gravity="0x1"
            id="@+id/unread_message_indicator"
            paddingLeft="@dimen/padding_12dp"
            paddingRight="@dimen/padding_12dp"
            visibility="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingHorizontal="@dimen/padding_12dp"
            style="@style/Label_3_Regular"/>
        <View
            background="@color/BorderPrimary"
            layout_width="0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
    </LinearLayout>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        layout_gravity="0x1"
        id="@+id/tv_message_interval_time"
        visibility="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        layout_marginBottom="@dimen/margin_20dp"
        layout_marginStart="@dimen/common_page_edge_space"
        layout_marginEnd="@dimen/common_page_edge_space"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        gravity="0x11"
        id="@+id/tv_message"
        layout_width="-1"
        android:layout_height="wrap_content"
        includeFontPadding="false"
        paddingStart="@dimen/common_page_edge_space"
        paddingEnd="@dimen/common_page_edge_space"
        breakStrategy="0"/>
</LinearLayout>
