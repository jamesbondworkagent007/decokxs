<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/SurfaceSecondary"
    layout_width="375dp"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/iv_share_bg_line_top"
        layout_width="-1"
        android:layout_height="161dp"
        src="@drawable/_2131234445_res_0x7f080e8d"
        contentDescription="@null"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x20="0"/>
    <ImageView
        id="@+id/iv_share_bg_diamond_top"
        layout_width="152dp"
        android:layout_height="328dp"
        layout_marginTop="-98dp"
        src="@drawable/_2131234448_res_0x7f080e90"
        contentDescription="@null"
        layout_marginEnd="-51dp"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x20="0"/>
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="60sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="24dp"
        layout_marginRight="24dp"
        layout_marginHorizontal="24dp"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/iv_share_bg_line_top"/>
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="20sp"
        textColor="@color/whole_sale_revamp_des_color"
        ellipsize="3"
        id="@+id/tv_sub_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="8dp"
        layout_marginRight="24dp"
        maxLines="4"
        lineSpacingExtra="4dp"
        layout_marginHorizontal="24dp"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/tv_title"/>
    <View
        id="@+id/view_empty"
        layout_width="-1"
        android:layout_height="56dp"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/tv_sub_title"/>
    <ImageView
        id="@+id/iv_share_bg_line_bottom"
        layout_width="-1"
        android:layout_height="0dp"
        src="@drawable/_2131234446_res_0x7f080e8e"
        scaleType="6"
        minHeight="148dp"
        contentDescription="@null"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/view_empty"/>
    <LinearLayout
        orientation="0"
        id="@+id/ll_share_bottom"
        background="@drawable/_2131231532_res_0x7f08032c"
        padding="20dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="24dp"
        layout_marginRight="24dp"
        layout_marginBottom="24dp"
        baselineAligned="false"
        layout_marginHorizontal="24dp"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/view_empty">
        <LinearLayout
            layout_gravity="0x10"
            orientation="1"
            id="@+id/ll_share_bottom_content"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textAppearance="@style/TextAppearance"
                    textSize="16sp"
                    ellipsize="3"
                    id="@+id/tv_bottom_title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"/>
                <View
                    layout_gravity="0x10"
                    id="@+id/view_bottom_vip_line"
                    background="@color/whole_sale_revamp_des_color"
                    layout_width="1dp"
                    android:layout_height="12dp"
                    layout_marginStart="6dp"/>
                <ImageView
                    layout_gravity="0x10"
                    id="@+id/iv_bottom_vip_logo"
                    layout_width="12dp"
                    android:layout_height="12dp"
                    src="@drawable/_2131234447_res_0x7f080e8f"
                    contentDescription="@null"
                    layout_marginStart="6dp"/>
                <TextView
                    textAppearance="@style/TextAppearance"
                    textSize="16sp"
                    textColor="@color/whole_sale_revamp_des_color"
                    id="@+id/tv_bottom_vip_dec"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    layout_marginStart="6dp"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                id="@+id/ll_bottom_vip_long_case"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content">
                <ImageView
                    layout_gravity="0x10"
                    layout_width="12dp"
                    android:layout_height="12dp"
                    src="@drawable/_2131234447_res_0x7f080e8f"
                    contentDescription="@null"/>
                <TextView
                    textAppearance="@style/TextAppearance"
                    textSize="16sp"
                    textColor="@color/whole_sale_revamp_des_color"
                    ellipsize="3"
                    id="@+id/tv_bottom_vip_dec_ano"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    layout_marginStart="6dp"/>
            </LinearLayout>
            <TextView
                textSize="@dimen/sp_14"
                ellipsize="3"
                id="@+id/tv_bottom_sub_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                maxLines="3"/>
        </LinearLayout>
        <FrameLayout
            layout_gravity="0x10"
            id="@+id/fl_bottom_qr_code"
            background="@drawable/_2131231462_res_0x7f0802e6"
            padding="3dp"
            layout_width="60dp"
            android:layout_height="60dp"
            layout_marginStart="12dp">
            <o.C6995aZr
                id="@+id/qr_code_view"
                layout_width="-1"
                android:layout_height="match_parent"
                NOT_FOUND_0x1b="0dp"/>
        </FrameLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
