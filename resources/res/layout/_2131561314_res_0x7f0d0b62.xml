<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/iv_pic"
        layout_width="@dimen/height_56dp"
        android:layout_height="@dimen/height_56dp"
        layout_marginTop="@dimen/xxxsm"
        src="@drawable/_2131234330_res_0x7f080e1a"
        scaleType="fitStart"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@color/grey_g900"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x11"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/sm"
        layout_marginTop="@dimen/margin_24dp"
        layout_marginRight="@dimen/sm"
        text="@string/pr_invest_placeorder_card_title_txloss_details"
        layout_marginHorizontal="@dimen/sm"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/iv_pic"
        style="@style/Title_2_Bold"/>
    <TextView
        textColor="@color/ContentSecondary"
        gravity="0x11"
        id="@+id/tv_transaction_loss_description"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/sm"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginRight="@dimen/sm"
        text="@string/pr_investdeposit_bot_text_1day_clear_loss"
        lineSpacingExtra="4sp"
        layout_marginHorizontal="@dimen/sm"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/tv_title"
        style="@style/Body_3_Regular"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/transaction_loss_container"
        background="@drawable/_2131231196_res_0x7f0801dc"
        padding="@dimen/padding_20dp"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/sm"
        layout_marginTop="@dimen/margin_24dp"
        layout_marginRight="@dimen/sm"
        layout_marginHorizontal="@dimen/sm"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/tv_transaction_loss_description">
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP"
            textColor="@color/text_secondary"
            id="@+id/tv_network_fee"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_investdeposit_bot_title_network_fee"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x14="0"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            textColor="@color/text_amplified"
            id="@+id/network_fee_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="$38.85"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x14="0"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP"
            textColor="@color/text_secondary"
            id="@+id/tv_swap_loss"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="@string/pr_investdeposit_bot_title_swap_loss"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="@+id/tv_network_fee"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            textColor="@color/text_amplified"
            id="@+id/swap_loss_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="$5.85"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x13="@+id/network_fee_value"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP"
            textColor="@color/text_secondary"
            id="@+id/tv_total_transaction_loss"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="@string/pr_invest_placeorder_card_label_total_txloss"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="@+id/tv_swap_loss"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            textColor="@color/text_amplified"
            id="@+id/total_transaction_loss_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="$44.85"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x13="@+id/swap_loss_value"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
