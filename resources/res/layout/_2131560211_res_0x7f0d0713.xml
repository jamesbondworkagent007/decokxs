<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x1"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        layout_marginBottom="12dp"
        fillViewport="true"
        layout_weight="1">
        <LinearLayout
            gravity="0x1"
            orientation="1"
            layout_width="-1"
            android:layout_height="match_parent">
            <ImageView
                id="@+id/image_top"
                layout_width="100dp"
                android:layout_height="100dp"/>
            <TextView
                textAppearance="@style/Headline_4_Bold"
                textColor="@color/ContentPrimary"
                gravity="0x11"
                id="@+id/tv_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="@dimen/margin_8dp"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp"/>
            <LinearLayout
                orientation="1"
                id="@+id/tip_group"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_12dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <o.C52794wYp
        textSize="16sp"
        id="@+id/btn"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="16dp"
        layout_marginRight="24dp"
        layout_marginBottom="16dp"
        text="@string/pr_commonall_text_btn_ok_passive"
        layout_marginHorizontal="24dp"
        layout_marginVertical="16dp"
        NOT_FOUND_0x12="52"
        NOT_FOUND_0x13="0x101"/>
</LinearLayout>
