<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    padding="16dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideline"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="0.5"/>
    <TextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/ContentTertiary"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x8="0"
        NOT_FOUND_0xa="@+id/guideline"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="0"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        gravity="0x800005"
        id="@+id/content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x8="0"
        NOT_FOUND_0xa="@+id/icon"
        NOT_FOUND_0xc="@+id/guideline"
        NOT_FOUND_0xd="0"/>
    <ImageView
        id="@+id/icon"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x8="@+id/content"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xd="@+id/content"/>
</merge>
