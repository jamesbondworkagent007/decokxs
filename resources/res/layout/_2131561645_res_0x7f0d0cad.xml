<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x11"
        layout_gravity="0x11"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="@dimen/dp_44"
        text="@string/pr_trade_favorites_bttmsheet_header_edit_group"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        style="@style/Label_1_Bold"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_option_edit_name"
        background="?attr/selectableItemBackground"
        paddingTop="@dimen/padding_18dp"
        paddingBottom="@dimen/padding_18dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_trade_favorites_bttmsheet_option_edit_group_name"
        drawablePadding="@dimen/dp_12"
        drawableStart="@drawable/_2131233452_res_0x7f080aac"
        paddingStart="@dimen/dp24"
        paddingEnd="0dp"
        drawableTint="@color/ContentPrimary"
        paddingVertical="@dimen/padding_18dp"
        NOT_FOUND_0x15="@color/ContentPrimary"
        NOT_FOUND_0x19="@+id/tv_title"
        style="@style/Label_1_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232355_res_0x7f080663"
        layout_marginEnd="24dp"
        NOT_FOUND_0x16="@+id/tv_option_edit_name"
        NOT_FOUND_0x17="@+id/tv_option_edit_name"
        NOT_FOUND_0x1a="@+id/tv_option_edit_name"
        NOT_FOUND_0x1b="@color/ContentContrast"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_option_delete"
        background="?attr/selectableItemBackground"
        paddingTop="@dimen/padding_18dp"
        paddingBottom="@dimen/padding_18dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="@dimen/dp_34"
        text="@string/pr_trade_favorites_bttmsheet_option_delete_group"
        drawablePadding="@dimen/dp_12"
        drawableStart="@drawable/_2131233450_res_0x7f080aaa"
        paddingStart="@dimen/dp24"
        paddingEnd="0dp"
        drawableTint="@color/ContentPrimary"
        paddingVertical="@dimen/padding_18dp"
        NOT_FOUND_0x15="@color/ContentPrimary"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x19="@+id/tv_option_edit_name"
        style="@style/Label_1_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232355_res_0x7f080663"
        layout_marginEnd="24dp"
        NOT_FOUND_0x16="@+id/tv_option_delete"
        NOT_FOUND_0x17="@+id/tv_option_delete"
        NOT_FOUND_0x1a="@+id/tv_option_delete"
        NOT_FOUND_0x1b="@color/ContentContrast"/>
</androidx.constraintlayout.widget.ConstraintLayout>
