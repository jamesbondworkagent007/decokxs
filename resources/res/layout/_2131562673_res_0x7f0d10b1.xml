<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/background_lv2"
    padding="12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        id="@+id/ll_total"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/iv_style"
            layout_width="16dp"
            android:layout_height="16dp"
            layout_marginTop="2dp"
            layout_marginEnd="8dp"/>
        <LinearLayout
            layout_gravity="0x800013"
            orientation="1"
            id="@+id/ll_content"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginEnd="28dp">
            <TextView
                textAppearance="@style/TextAppearance.White.14SP.Medium"
                textColor="@color/grey_g900"
                gravity="0x10"
                layout_gravity="0x800003"
                id="@+id/tv_header"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="4dp"
                minHeight="20dp"
                breakStrategy="0"/>
            <TextView
                textColor="@color/grey_g600"
                gravity="0x10"
                layout_gravity="0x800003"
                id="@+id/tv_body"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                minHeight="20dp"
                breakStrategy="0"
                style="@style/Label_3_Regular"/>
            <RelativeLayout
                id="@+id/rl_custom"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"/>
            <RelativeLayout
                id="@+id/rl_extra"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <o.C55317xhf
                    id="@+id/hyperlink"
                    layout_width="-2"
                    android:layout_height="20dp"
                    layout_marginEnd="4dp"
                    layout_alignParentEnd="true"
                    NOT_FOUND_0x19="@color/okc_gray_90_light"
                    NOT_FOUND_0x1a="Content"/>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        id="@+id/functionContainer"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_below="@+id/ll_total"
        layout_marginStart="4dp">
        <LinearLayout
            orientation="0"
            id="@+id/ll_action"
            layout_width="-2"
            android:layout_height="wrap_content">
            <o.C52794wYp
                id="@+id/primary"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                NOT_FOUND_0x17="28"
                NOT_FOUND_0x18="0x31"/>
            <o.C52794wYp
                id="@+id/secondary"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                layout_marginStart="8dp"
                NOT_FOUND_0x17="28"
                NOT_FOUND_0x18="0x31"/>
        </LinearLayout>
        <o.C55317xhf
            textSize="12sp"
            textColor="@color/blue_lv1"
            id="@+id/hyperlinkAction"
            paddingTop="4dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            layout_below="@+id/ll_action"
            layout_marginStart="16dp"
            textFontWeight="500"
            NOT_FOUND_0x1b="0"/>
    </RelativeLayout>
    <ImageView
        id="@+id/iv_close"
        background="@drawable/_2131232489_res_0x7f0806e9"
        layout_width="@dimen/width_20dp"
        android:layout_height="@dimen/width_20dp"
        layout_alignParentEnd="true"
        NOT_FOUND_0x1c="@color/color_content_static_subtle"/>
</RelativeLayout>
