<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-2"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        id="@+id/ll_label_container"
        tag="layout/okim_common_reference_view_0"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="true"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="@+id/media_container"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="1"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="-2">
        <TextView
            textColor="@color/ContentTertiary"
            ellipsize="3"
            gravity="0x10"
            id="@+id/okim_reference_sender_name"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"
            style="@style/Label_3_Bold"/>
        <TextView
            textColor="@color/ContentTertiary"
            ellipsize="3"
            gravity="0x10"
            id="@+id/okim_reference_content"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxxsm"
            singleLine="true"
            drawablePadding="@dimen/xxxxsm"
            NOT_FOUND_0x14="@drawable/_2131233593_res_0x7f080b39"
            NOT_FOUND_0x15="@color/ContentTertiary"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <FrameLayout
        id="@+id/media_container"
        tag="layout/okim_common_reference_view_1"
        visibility="2"
        layout_width="@dimen/height_36dp"
        android:layout_height="@dimen/height_36dp"
        layout_marginStart="@dimen/xxsm"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1c="@+id/ll_label_container"
        NOT_FOUND_0x1e="0">
        <androidx.cardview.widget.CardView
            id="@+id/reference_thumbnail_card_view"
            background="@color/grey_70"
            visibility="2"
            layout_width="-1"
            android:layout_height="match_parent"
            NOT_FOUND_0x12="1.5dp"
            NOT_FOUND_0x13="0dp">
            <ImageView
                id="@+id/reference_content_thumbnail"
                layout_width="-1"
                android:layout_height="match_parent"
                src="@drawable/_2131233600_res_0x7f080b40"
                scaleType="6"
                importantForAccessibility="2"/>
        </androidx.cardview.widget.CardView>
        <FrameLayout
            id="@+id/coin_panel"
            visibility="2"
            layout_width="-1"
            android:layout_height="match_parent">
            <ImageView
                layout_gravity="0x11"
                id="@+id/token_iv"
                background="@drawable/_2131231261_res_0x7f08021d"
                layout_width="@dimen/height_36dp"
                android:layout_height="@dimen/height_36dp"
                src="@drawable/_2131231718_res_0x7f0803e6"
                scaleType="7"/>
            <ImageView
                layout_gravity="0x800055"
                id="@+id/iv_chain_logo"
                background="@drawable/_2131231340_res_0x7f08026c"
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131232091_res_0x7f08055b"
                scaleType="7"/>
        </FrameLayout>
    </FrameLayout>
</merge>
