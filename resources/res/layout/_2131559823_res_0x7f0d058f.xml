<?xml version="1.0" encoding="utf-8"?>
<android.widget.LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        background="@drawable/_2131231033_res_0x7f080139"
        paddingLeft="24dp"
        paddingTop="14dp"
        paddingRight="24dp"
        paddingBottom="14dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="24dp"
        paddingVertical="14dp">
        <TextView
            textSize="@dimen/text_size_16sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x11"
            id="@+id/toolbar_title"
            layout_width="-1"
            android:layout_height="24dp"
            maxLines="1"
            fontFamily="@font/harmony_sans_bold"
            layout_marginStart="24dp"
            layout_marginEnd="36dp"/>
        <ImageView
            gravity="0x11"
            layout_gravity="0x800005"
            id="@+id/close_button"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131232722_res_0x7f0807d2"
            scaleType="fitStart"
            contentDescription="@null"/>
    </FrameLayout>
    <androidx.fragment.app.FragmentContainerView
        id="@+id/section_message_list"
        layout_width="-1"
        android:layout_height="match_parent"/>
</android.widget.LinearLayout>
