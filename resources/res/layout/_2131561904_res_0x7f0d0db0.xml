<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/BasePrimary"
    paddingLeft="16dp"
    paddingRight="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="16dp">
    <TextView
        textAppearance="@style/TextAppearance.Text.Bold"
        textSize="16sp"
        textColor="@color/grey_g900"
        id="@+id/param_detail"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_20dp"
        text="@string/pr_marketplace_botdetails_title_bot_details"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcv_info"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_28dp"
        overScrollMode="2"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/param_detail"/>
    <TextView
        textAppearance="@style/TextAppearance.Blue.14SP.Medium"
        textColor="@color/grey_g900"
        id="@+id/tv_custom_param"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginBottom="24dp"
        text="@string/pr_marketplace_botdetails_modaltitle_custom_parameter"
        NOT_FOUND_0x13="@drawable/_2131231648_res_0x7f0803a0"
        NOT_FOUND_0x14="@color/grey_g900"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/rcv_info"/>
    <ImageView
        id="@+id/hide_or_show"
        paddingTop="@dimen/margin_12dp"
        paddingBottom="@dimen/padding_24dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        src="@drawable/_2131234176_res_0x7f080d80"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/tv_custom_param"
        NOT_FOUND_0x19="@color/ContentPrimary"/>
    <View
        id="@+id/space"
        layout_width="-1"
        android:layout_height="1dp"
        NOT_FOUND_0x16="@+id/hide_or_show"
        NOT_FOUND_0x18="@dimen/margin_24dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
