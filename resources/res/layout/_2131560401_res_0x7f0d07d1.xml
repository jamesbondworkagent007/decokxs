<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    layout_gravity="0x10"
    id="@+id/item_root_layout"
    background="?attr/selectableItemBackground"
    layout_width="-1"
    android:layout_height="wrap_content"
    baselineAligned="true"
    minHeight="64dp"
    paddingStart="@dimen/common_page_edge_space"
    paddingEnd="@dimen/common_page_edge_space">
    <ImageView
        id="@+id/iv_icon"
        visibility="2"
        layout_width="32dp"
        android:layout_height="32dp"
        scaleType="fitStart"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
    <TextView
        textColor="@color/okTradeG900"
        gravity="0x800013"
        id="@+id/tv_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="2dp"
        includeFontPadding="false"
        layout_marginStart="8dp"
        NOT_FOUND_0x15="@+id/tv_full_name"
        NOT_FOUND_0x17="@+id/iv_icon"
        NOT_FOUND_0x1a="@+id/iv_icon"
        style="@style/TextAppearance.Title.15SP.Medium"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/okTradeG400"
        gravity="0x800013"
        id="@+id/tv_full_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        includeFontPadding="false"
        paddingStart="0dp"
        NOT_FOUND_0x14="@+id/iv_icon"
        NOT_FOUND_0x18="@+id/tv_name"
        NOT_FOUND_0x19="@+id/tv_name"/>
    <TextView
        gravity="0x800005"
        id="@+id/tv_price"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginEnd="104dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tv_full_name"
        NOT_FOUND_0x1a="0"
        style="@style/TextAppearance.Title.16SP"/>
    <o.C42920rfX
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        gravity="0x11"
        id="@+id/tv_change_percent"
        layout_width="80dp"
        android:layout_height="32dp"
        minWidth="80dp"
        paddingStart="5dp"
        paddingEnd="5dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="0"
        style="@style/TextAppearance.White.14SP"/>
</androidx.constraintlayout.widget.ConstraintLayout>
