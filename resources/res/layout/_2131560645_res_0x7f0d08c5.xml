<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/input_select_layout"
    tag="layout/item_inputselect_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <o.C55008xbo
        id="@+id/input_select_input_field"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textColor="@color/grey_g400"
        id="@+id/tv_helper"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcy_pictures"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        overScrollMode="2"/>
    <RelativeLayout
        id="@+id/rl_reminder"
        background="@drawable/_2131231154_res_0x7f0801b2"
        paddingLeft="@dimen/padding_16dp"
        paddingTop="@dimen/padding_12dp"
        paddingRight="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_12dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_28dp"
        paddingHorizontal="@dimen/padding_16dp"
        paddingVertical="@dimen/padding_12dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Bold"
            textColor="@color/primary_white"
            id="@+id/tv_reminder_title"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP"
            textColor="@color/primary_white"
            id="@+id/tv_reminder_message"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            layout_below="@+id/tv_reminder_title"
            lineHeight="18dp"/>
    </RelativeLayout>
</LinearLayout>
