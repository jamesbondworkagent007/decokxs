<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="@dimen/planet_spotlight_item_width"
    android:layout_height="176dp"
    layout_marginStart="12dp"
    NOT_FOUND_0x1d="@color/SurfacePrimary"
    NOT_FOUND_0x1e="20dp"
    NOT_FOUND_0x1f="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        paddingLeft="16dp"
        paddingTop="16dp"
        paddingRight="16dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="match_parent"
        paddingHorizontal="16dp"
        paddingVertical="16dp">
        <ImageView
            id="@+id/ivAvatar"
            layout_width="24dp"
            android:layout_height="24dp"
            NOT_FOUND_0x25="@+id/tvName"
            NOT_FOUND_0x26="0"
            NOT_FOUND_0x27="2"
            NOT_FOUND_0x29="0"
            NOT_FOUND_0x2b="0"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tvName"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="8dp"
            NOT_FOUND_0x21="true"
            NOT_FOUND_0x22="@+id/ivAvatar"
            NOT_FOUND_0x25="@+id/ivVerified"
            NOT_FOUND_0x28="@+id/ivAvatar"
            NOT_FOUND_0x2b="@+id/ivAvatar"
            style="@style/Title_2_Medium"/>
        <androidx.constraintlayout.widget.Barrier
            id="@+id/barrierRight"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1c="5"
            NOT_FOUND_0x20="ivVerified"
            NOT_FOUND_0x24="0"/>
        <ImageView
            id="@+id/ivVerified"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131232809_res_0x7f080829"
            layout_marginStart="4dp"
            NOT_FOUND_0x22="@+id/ivAvatar"
            NOT_FOUND_0x25="@+id/tvTime"
            NOT_FOUND_0x28="@+id/tvName"
            NOT_FOUND_0x2b="@+id/ivAvatar"/>
        <TextView
            textSize="14sp"
            textColor="@color/ContentContrast"
            id="@+id/tvTime"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="8dp"
            NOT_FOUND_0x22="@+id/ivAvatar"
            NOT_FOUND_0x24="0"
            NOT_FOUND_0x28="@+id/ivVerified"
            NOT_FOUND_0x2b="@+id/ivAvatar"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentSecondary"
            ellipsize="3"
            id="@+id/tvContent"
            layout_width="0dp"
            android:layout_height="wrap_content"
            lines="3"
            includeFontPadding="false"
            lineHeight="22sp"
            NOT_FOUND_0x23="@+id/bottomContainer"
            NOT_FOUND_0x25="@+id/imageContainer"
            NOT_FOUND_0x29="0"
            NOT_FOUND_0x2a="@+id/ivAvatar"
            NOT_FOUND_0x2c="0.4"
            NOT_FOUND_0x2d="22sp"
            style="@style/Body_2_Regular"/>
        <FrameLayout
            id="@+id/imageContainer"
            background="@drawable/_2131231388_res_0x7f08029c"
            padding="@dimen/dp_0.5"
            visibility="2"
            layout_width="60dp"
            android:layout_height="60dp"
            layout_marginStart="8dp"
            NOT_FOUND_0x22="@+id/tvContent"
            NOT_FOUND_0x24="0"
            NOT_FOUND_0x28="@+id/tvContent"
            NOT_FOUND_0x2b="@+id/tvContent">
            <ImageView
                id="@+id/ivImage"
                layout_width="-1"
                android:layout_height="match_parent"
                scaleType="6"/>
            <TextView
                textColor="@color/color_content_static_default"
                layout_gravity="0x800055"
                id="@+id/tvImageCount"
                background="@drawable/_2131231389_res_0x7f08029d"
                paddingLeft="4dp"
                paddingTop="2dp"
                paddingRight="4dp"
                paddingBottom="2dp"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="4dp"
                layout_marginEnd="4dp"
                paddingHorizontal="4dp"
                paddingVertical="2dp"
                style="@style/Label_4_Regular"/>
        </FrameLayout>
        <LinearLayout
            gravity="0x10"
            id="@+id/bottomContainer"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x22="0">
            <LinearLayout
                orientation="0"
                id="@+id/tokenContainer"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content">
                <include
                    id="@+id/tokenTag"
                    layout="@layout/_2131562145_res_0x7f0d0ea1"/>
            </LinearLayout>
            <View
                layout_width="0dp"
                android:layout_height="0dp"
                layout_weight="1"/>
            <LinearLayout
                gravity="0x10"
                orientation="0"
                id="@+id/statsContainer"
                paddingTop="3dp"
                paddingBottom="3dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingVertical="3dp">
                <ImageView
                    id="@+id/ivLike"
                    layout_width="20dp"
                    android:layout_height="20dp"
                    src="@drawable/_2131233323_res_0x7f080a2b"
                    NOT_FOUND_0x2e="@color/ContentContrast"/>
                <TextView
                    textSize="14sp"
                    textColor="@color/ContentContrast"
                    id="@+id/tvLikeCount"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="2dp"
                    style="@style/Label_3_Regular"/>
                <ImageView
                    id="@+id/ivView"
                    layout_width="20dp"
                    android:layout_height="20dp"
                    src="@drawable/_2131232199_res_0x7f0805c7"
                    layout_marginStart="8dp"
                    NOT_FOUND_0x2e="@color/ContentContrast"/>
                <TextView
                    textSize="14sp"
                    textColor="@color/ContentContrast"
                    id="@+id/tvViewCount"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="2dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
