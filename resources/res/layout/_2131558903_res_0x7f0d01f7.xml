                ellipsize="2"
                gravity="0x10"
                id="@+id/price_percentage"
                tag="binding_1"
                layout_width="-2"
                android:layout_height="wrap_content"
                lines="1"
                autoSizeTextType="uniform"
                autoSizeStepGranularity="@dimen/text_size_2sp"
                autoSizeMinTextSize="@dimen/text_size_10sp"
                autoSizeMaxTextSize="@dimen/text_size_16sp"
                NOT_FOUND_0x15="true"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="1"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"
                style="@style/Label_1_Medium"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
