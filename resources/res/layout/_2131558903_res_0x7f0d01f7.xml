<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/component_okcr_card_horizontal_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/pressed_background"
        focusable="false"
        focusableInTouchMode="false"
        layout_width="-1"
        android:layout_height="match_parent"
        alpha="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/content_view"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/token_layout"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_8"
            layout_marginBottom="@dimen/dp_8"
            layout_marginStart="@dimen/dp_12"
            layout_marginVertical="@dimen/dp_8"
            NOT_FOUND_0x15="true"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="@+id/percentage_layout"
            NOT_FOUND_0x1a="1"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="0">
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/token_detail_layout"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x18="@+id/price_layout"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0">
                <ImageView
                    id="@+id/token_img"
                    layout_width="@dimen/dp_24"
                    android:layout_height="@dimen/dp_24"
                    contentDescription="@null"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x18="@+id/token_name"
                    NOT_FOUND_0x1c="0"
                    NOT_FOUND_0x1d="0"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    gravity="0x10"
                    id="@+id/token_name"
                    layout_width="@dimen/dp_70"
                    android:layout_height="wrap_content"
                    lines="1"
                    layout_marginStart="@dimen/dp_8"
                    autoSizeTextType="uniform"
                    autoSizeStepGranularity="@dimen/text_size_2sp"
                    autoSizeMinTextSize="@dimen/text_size_10sp"
                    autoSizeMaxTextSize="@dimen/text_size_16sp"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x17="0"
                    NOT_FOUND_0x1b="@+id/token_img"
                    NOT_FOUND_0x1d="0"
                    style="@style/Label_1_Bold"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/price_layout"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_12"
                layout_marginBottom="@dimen/dp_12"
                layout_marginStart="@dimen/dp_8"
                layout_marginEnd="@dimen/dp_4"
                layout_marginVertical="@dimen/dp_12"
                NOT_FOUND_0x15="true"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1b="@+id/token_detail_layout"
                NOT_FOUND_0x1d="0">
                <TextView
                    textColor="@color/ContentSecondary"
                    ellipsize="2"
                    gravity="0x10"
                    id="@+id/price"
                    layout_width="-2"
                    android:layout_height="@dimen/dp_24"
                    lines="1"
                    autoSizeTextType="uniform"
                    autoSizeStepGranularity="0.1sp"
                    autoSizeMinTextSize="@dimen/text_size_10sp"
                    autoSizeMaxTextSize="@dimen/text_size_16sp"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x17="0"
                    NOT_FOUND_0x1c="0"
                    NOT_FOUND_0x1d="0"
                    style="@style/Label_1_Regular"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/percentage_layout"
            layout_width="@dimen/dp_84"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_8"
            layout_marginBottom="@dimen/dp_8"
            layout_marginStart="@dimen/dp_10"
            layout_marginEnd="@dimen/dp_12"
            layout_marginVertical="@dimen/dp_8"
            NOT_FOUND_0x15="true"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x1b="@+id/token_layout"
            NOT_FOUND_0x1d="0">
