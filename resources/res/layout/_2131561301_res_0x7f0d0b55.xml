<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/layout_invest_redeem_process_dialog_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.core.widget.NestedScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="@dimen/margin_20dp">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                orientation="1"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/sm"
                layout_marginTop="@dimen/margin_16dp"
                layout_marginRight="@dimen/sm"
                layout_marginHorizontal="@dimen/sm">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tv_investwith_title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_invest_placeorder_details_label_redeemed_from"
                    style="@style/Label_2_Regular"/>
                <androidx.constraintlayout.widget.ConstraintLayout
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="22dp">
                    <ImageView
                        id="@+id/invest_platform_img"
                        layout_width="@dimen/width_32dp"
                        android:layout_height="@dimen/width_32dp"
                        NOT_FOUND_0x29="0"
                        NOT_FOUND_0x2d="0"
                        NOT_FOUND_0x2e="0"/>
                    <TextView
                        textColor="@color/ContentSecondary"
                        gravity="0x800013"
                        id="@+id/invest_platform_name"
                        layout_width="0dp"
                        android:layout_height="wrap_content"
                        maxLines="1"
                        includeFontPadding="false"
                        textAlignment="5"
                        layout_marginStart="@dimen/margin_12dp"
                        layout_marginEnd="@dimen/margin_14dp"
                        NOT_FOUND_0x24="20sp"
                        NOT_FOUND_0x25="2sp"
                        NOT_FOUND_0x26="2sp"
                        NOT_FOUND_0x27="1"
                        NOT_FOUND_0x29="@+id/invest_platform_img"
                        NOT_FOUND_0x2b="@+id/invest_platform_text"
                        NOT_FOUND_0x2c="@+id/invest_platform_img"
                        NOT_FOUND_0x2e="@+id/invest_platform_img"
                        style="@style/Label_1_Medium"/>
                    <TextView
                        textColor="@color/ContentSecondary"
                        id="@+id/invest_platform_text"
                        background="@drawable/_2131231216_res_0x7f0801f0"
                        paddingLeft="@dimen/padding_8dp"
                        paddingTop="@dimen/padding_4dp"
                        paddingRight="@dimen/padding_8dp"
                        paddingBottom="@dimen/padding_4dp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_investredeem_midpopprocess_text_platform"
                        includeFontPadding="false"
                        paddingHorizontal="@dimen/padding_8dp"
                        paddingVertical="@dimen/padding_4dp"
                        NOT_FOUND_0x29="@+id/invest_platform_name"
                        NOT_FOUND_0x2a="0"
                        NOT_FOUND_0x2e="@+id/invest_platform_name"
                        style="@style/Label_3_Regular"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
            <LinearLayout
                orientation="1"
                id="@+id/invest_receive_content"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/sm"
                layout_marginTop="@dimen/dp_32"
                layout_marginRight="@dimen/sm"
                layout_marginHorizontal="@dimen/sm">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tv_receive_title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_invest_placeorder_details_label_get_back"
                    style="@style/Label_2_Regular"/>
                <LinearLayout
                    orientation="1"
                    id="@+id/invest_receive_list"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_20dp"
                    divider="@drawable/_2131231219_res_0x7f0801f3"
                    showDividers="middle"/>
            </LinearLayout>
            <LinearLayout
                orientation="1"
                id="@+id/invest_swapfrom_container"
                paddingTop="@dimen/padding_20dp"
                paddingBottom="@dimen/padding_20dp"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/sm"
                layout_marginTop="@dimen/xxsm"
                layout_marginRight="@dimen/sm"
                layout_marginHorizontal="@dimen/sm"
                paddingVertical="@dimen/padding_20dp">
                <LinearLayout
                    gravity="0x800013"
                    orientation="0"
                    id="@+id/invest_swapfrom_tips"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <ImageView
                        id="@+id/cross_middle_line"
                        layout_width="20dp"
                        android:layout_height="20dp"
                        src="@drawable/_2131232676_res_0x7f0807a4"
                        scaleType="fitStart"/>
                    <TextView
                        textColor="@color/ContentContrast"
                        id="@+id/tv_invest_swapfrom"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_invest_placeorder_details_label_swapped_into"
                        includeFontPadding="false"
                        layout_marginStart="@dimen/margin_12dp"
                        style="@style/Label_2_Regular"/>
                </LinearLayout>
                <LinearLayout
                    orientation="1"
                    id="@+id/invest_swapfrom_content"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_20dp"
                    divider="@drawable/_2131231219_res_0x7f0801f3"
                    showDividers="middle"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.12SP.Medium"
                    textColor="@color/ContentPrimary"
                    gravity="0x11"
                    layout_gravity="0x1"
                    id="@+id/tv_more"
                    paddingTop="@dimen/padding_2dp"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_8dp"
                    drawablePadding="@dimen/padding_4dp"
                    paddingStart="@dimen/padding_6dp"
                    paddingEnd="@dimen/padding_6dp"
                    NOT_FOUND_0x28="@color/ContentPrimary"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
