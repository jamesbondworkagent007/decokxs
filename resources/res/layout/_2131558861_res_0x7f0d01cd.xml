    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_16dp">
    <ImageView
        id="@+id/iv_payment_icon"
        layout_width="48dp"
        android:layout_height="48dp"
        layout_marginTop="@dimen/margin_8dp"
        contentDescription="@null"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <TextView
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0xf="@+id/tv_payment_identifier"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/iv_payment_icon"
        style="@style/Title_2_Bold"/>
    <TextView
        id="@+id/tv_payment_identifier"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
