<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="18dp"
    paddingBottom="18dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="18dp">
    <ImageView
        id="@+id/icon"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textColor="@color/grey_g900"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_10dp"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xc="@+id/right_icon"
        NOT_FOUND_0xd="@+id/icon"
        NOT_FOUND_0xf="0"/>
    <ImageView
        id="@+id/right_icon"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131234178_res_0x7f080d82"
        layout_marginStart="16dp"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xd="@+id/title"
        NOT_FOUND_0xf="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
