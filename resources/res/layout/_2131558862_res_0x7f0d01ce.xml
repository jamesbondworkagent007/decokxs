<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/bottomsheet_buy_sell_order_detail_security_hold_0"
    paddingLeft="@dimen/padding_24dp"
    paddingRight="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp">
    <TextView
        id="@+id/security_hold_info_title"
        paddingTop="@dimen/padding_12dp"
        paddingBottom="@dimen/padding_12dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/lt_unipay_orderdetails_title_security_hold"
        paddingVertical="@dimen/padding_12dp"
        NOT_FOUND_0x11="@+id/security_hold_info_body"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        style="@style/Label_1_Bold"/>
    <TextView
        id="@+id/security_hold_info_body"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/lt_unipay_orderdetails_body_buy_security_hold"
        NOT_FOUND_0x11="@+id/withdraw_available_info_container"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/security_hold_info_title"
        style="@style/Body_3_Regular"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/withdraw_available_info_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/security_hold_info_body">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/cash_withdrawal_info_container"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            layout_marginBottom="@dimen/margin_12dp"
            layout_marginVertical="@dimen/margin_12dp"
            NOT_FOUND_0x11="@+id/crypto_withdrawal_info_container"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0">
            <TextView
                id="@+id/cash_withdrawal_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/lt_unipay_orderdetails_label_cashwithdraw"
                NOT_FOUND_0x11="@+id/cash_withdrawal_time"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x15="0"
                style="@style/Label_1_Regular"/>
            <TextView
                id="@+id/cash_withdrawal_date"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/margin_12dp"
                NOT_FOUND_0x11="@+id/cash_withdrawal_time"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x15="@+id/cash_withdrawal_title"
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/cash_withdrawal_time"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x14="@+id/cash_withdrawal_date"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/crypto_withdrawal_info_container"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            layout_marginBottom="@dimen/margin_12dp"
            layout_marginVertical="@dimen/margin_12dp"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="@+id/cash_withdrawal_info_container">
            <TextView
                id="@+id/crypto_withdrawal_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/lt_unipay_orderdetails_label_cryptowithdraw"
                NOT_FOUND_0x11="@+id/crypto_withdrawal_time"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x15="0"
                style="@style/Label_1_Regular"/>
            <TextView
                id="@+id/crypto_withdrawal_date"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/margin_12dp"
                NOT_FOUND_0x11="@+id/crypto_withdrawal_time"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x15="@+id/crypto_withdrawal_title"
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/crypto_withdrawal_time"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x14="@+id/crypto_withdrawal_date"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
