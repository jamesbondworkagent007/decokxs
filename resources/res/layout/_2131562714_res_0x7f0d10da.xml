<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textSize="12sp"
        textColor="@color/grey_g400"
        ellipsize="3"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_subtitle_arbiltrage_margin_lever"/>
    <LinearLayout
        orientation="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp">
        <TextView
            textSize="12sp"
            textColor="@color/grey_g900"
            ellipsize="3"
            id="@+id/tv_cross"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="--"
            singleLine="true"
            layout_marginEnd="8dp"/>
        <TextView
            textColor="@color/grey_g200"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="|"/>
        <TextView
            textSize="12sp"
            textColor="@color/grey_g900"
            ellipsize="3"
            id="@+id/tv_leverage"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="--"
            singleLine="true"
            layout_marginStart="8dp"/>
    </LinearLayout>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g400"
        ellipsize="3"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="14dp"
        text="@string/pr_demotrade_colheader_side"
        singleLine="true"/>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/tv_order_type"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        text="--"
        singleLine="true"/>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g400"
        ellipsize="3"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="14dp"
        text="@string/pr_trade_input_price"
        singleLine="true"/>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/tv_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        text="--"
        singleLine="true"/>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g400"
        ellipsize="3"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="14dp"
        text="@string/pr_trade_input_amt"
        singleLine="true"/>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/tv_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        text="--"
        singleLine="true"/>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g400"
        ellipsize="3"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="14dp"
        text="@string/pr_trade_input_total"
        singleLine="true"/>
    <TextView
        textSize="12sp"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/tv_sum"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        text="--"
        singleLine="true"/>
</merge>
