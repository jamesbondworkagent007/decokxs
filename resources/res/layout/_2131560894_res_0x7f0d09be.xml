<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/cl_stop"
    tag="layout/item_stop_strategy_0"
    background="@drawable/_2131234177_res_0x7f080d81"
    paddingLeft="12dp"
    paddingTop="14dp"
    paddingRight="12dp"
    paddingBottom="14dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="12dp"
    paddingVertical="14dp">
    <ImageView
        id="@+id/okrb_check"
        layout_width="14dp"
        android:layout_height="14dp"
        src="@drawable/_2131234178_res_0x7f080d82"
        NOT_FOUND_0x16="@+id/tv_title"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="@+id/tv_title"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP.Medium"
        textColor="@color/grey_g900"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_bot_radio_stop_selltitle"
        includeFontPadding="false"
        paddingStart="@dimen/padding_8dp"
        paddingEnd="@dimen/padding_2dp"
        layout_marginStart="6dp"
        layout_marginEnd="@dimen/margin_1dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/okrb_check"
        NOT_FOUND_0x1b="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        id="@+id/tv_first_desc"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="@string/pr_trade_bot_radio_stop_selltitle"
        paddingStart="@dimen/padding_8dp"
        paddingEnd="@dimen/padding_8dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="@+id/tv_title"
        NOT_FOUND_0x1a="@+id/tv_title"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        id="@+id/tv_second_desc"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="@string/pr_trade_bot_radio_stop_selltitle"
        paddingStart="@dimen/padding_8dp"
        paddingEnd="@dimen/padding_8dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="@+id/tv_title"
        NOT_FOUND_0x1a="@+id/tv_first_desc"/>
</androidx.constraintlayout.widget.ConstraintLayout>
