<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="?attr/horizontalPaddingDimension"
    paddingRight="?attr/horizontalPaddingDimension"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="?attr/horizontalPaddingDimension">
    <androidx.appcompat.widget.LinearLayoutCompat
        layout_width="-1"
        android:layout_height="@dimen/xlg">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/txHistoryConstraintLayout"
            layout_width="108dp"
            android:layout_height="match_parent">
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/liquidityPoolListingTokenImage"
                layout_width="@dimen/width_24dp"
                android:layout_height="24dp"
                src="@drawable/_2131231887_res_0x7f08048f"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1f="0"/>
            <View
                id="@+id/centerViewAnchor"
                layout_width="-2"
                android:layout_height="4dp"
                layout_marginStart="@dimen/margin_8dp"
                NOT_FOUND_0x19="@+id/liquidityPoolListingTokenImage"
                NOT_FOUND_0x1c="@+id/liquidityPoolListingTokenImage"
                NOT_FOUND_0x1f="@+id/liquidityPoolListingTokenImage"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                gravity="0x10"
                id="@+id/liquidityPoolChangeTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x15="14sp"
                NOT_FOUND_0x16="10sp"
                NOT_FOUND_0x17="1sp"
                NOT_FOUND_0x18="1"
                NOT_FOUND_0x1a="@+id/centerViewAnchor"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1d="@+id/centerViewAnchor"
                style="@style/Label_2_Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                gravity="0x10"
                id="@+id/txHistoryTimeTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x15="14sp"
                NOT_FOUND_0x16="10sp"
                NOT_FOUND_0x17="1sp"
                NOT_FOUND_0x18="1"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1d="@+id/centerViewAnchor"
                NOT_FOUND_0x1e="@+id/centerViewAnchor"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x800015"
            layout_gravity="0x11"
            orientation="1"
            id="@+id/lpHistoryChangePriceLyaoutRoot"
            layout_width="-2"
            android:layout_height="match_parent"
            layout_weight="0.4"
            layout_marginStart="@dimen/dp_8"
            layout_marginEnd="@dimen/margin_8dp">
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                gravity="0x800015"
                id="@+id/liquidityPoolFirstTokenNameTv"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="@dimen/margin_2dp"
                maxLines="1"
                NOT_FOUND_0x15="14sp"
                NOT_FOUND_0x16="10sp"
                NOT_FOUND_0x17="1sp"
                NOT_FOUND_0x18="1"
                style="@style/Label_2_Regular"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                gravity="0x800015"
                id="@+id/liquidityPoolSecondTokenNameTv"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="@dimen/margin_2dp"
                maxLines="1"
                NOT_FOUND_0x15="14sp"
                NOT_FOUND_0x16="10sp"
                NOT_FOUND_0x17="1sp"
                NOT_FOUND_0x18="1"
                style="@style/Label_2_Regular"/>
            <ImageView
                layout_gravity="0x800055"
                id="@+id/liquidityPoolMoreTokensTV"
                background="@color/BaseSecondary"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                src="@drawable/_2131231971_res_0x7f0804e3"
                includeFontPadding="false"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            gravity="0x800015"
            layout_gravity="0x10"
            id="@+id/liquidityPoolTokenValue"
            layout_width="72dp"
            android:layout_height="wrap_content"
            maxLines="2"
            NOT_FOUND_0x15="14sp"
            NOT_FOUND_0x16="8sp"
            NOT_FOUND_0x17="1sp"
            NOT_FOUND_0x18="1"
            style="@style/Label_2_Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
