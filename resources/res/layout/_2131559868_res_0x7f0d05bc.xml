<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    background="@color/ContainerSecondary"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="44dp"
    paddingEnd="@dimen/padding_16dp">
    <LinearLayout
        gravity="0x10"
        paddingTop="12dp"
        paddingBottom="12dp"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1"
        paddingStart="@dimen/padding_16dp"
        paddingVertical="12dp">
        <FrameLayout
            id="@+id/coin_panel"
            layout_width="28dp"
            android:layout_height="28dp"
            layout_marginEnd="8dp"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="0">
            <ImageView
                layout_gravity="0x11"
                id="@+id/token_iv"
                background="@drawable/_2131231261_res_0x7f08021d"
                layout_width="28dp"
                android:layout_height="28dp"
                src="@drawable/_2131231718_res_0x7f0803e6"
                scaleType="7"/>
            <ImageView
                layout_gravity="0x800055"
                id="@+id/iv_chain_logo"
                background="@drawable/_2131231340_res_0x7f08026c"
                layout_width="10dp"
                android:layout_height="10dp"
                src="@drawable/_2131232091_res_0x7f08055b"
                scaleType="7"/>
        </FrameLayout>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="1"
            id="@+id/okt_dex_search_coin_ll"
            layout_width="-2"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="0"
                id="@+id/okt_dex_search_coin"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="@dimen/padding_4dp">
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    gravity="0x800013"
                    id="@+id/token_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    includeFontPadding="false"
                    NOT_FOUND_0x1c="1sp"
                    style="@style/Label_2_Medium"/>
                <o.C55251xgS
                    gravity="0x10"
                    id="@+id/okte_dex_token_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_cedefi_title_dex"
                    layout_marginStart="@dimen/margin_4dp"
                    NOT_FOUND_0x20="-6"
                    NOT_FOUND_0x21="6"/>
                <o.oIV
                    id="@+id/icon_list"
                    visibility="2"
                    layout_width="16dp"
                    android:layout_height="16dp"
                    importantForAccessibility="2"
                    layout_marginStart="3dp"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                orientation="0"
                id="@+id/ll_address"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentContrast"
                    layout_gravity="0x800013"
                    id="@+id/token_address"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    textDirection="5"
                    textAlignment="5"
                    style="@style/Label_4_Regular"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </LinearLayout>
    <LinearLayout
        gravity="0x800015"
        id="@+id/ll_right"
        layout_width="-2"
        android:layout_height="match_parent">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_token_price"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
</LinearLayout>
