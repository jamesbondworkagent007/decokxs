<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp">
        <View
            background="@color/ContentSecondary"
            layout_width="1dp"
            android:layout_height="match_parent"
            layout_marginEnd="12dp"/>
        <TextView
            textColor="@color/ContentSecondary"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_spotgrid_botdetails_tooltips_title_in_simple_earn_product"
            layout_weight="1"
            style="@style/Body_4"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/tvEarnActiveSimpleAmount"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="--"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <View
            background="@color/ContentSecondary"
            layout_width="1dp"
            android:layout_height="match_parent"
            layout_marginEnd="12dp"/>
        <TextView
            textColor="@color/ContentSecondary"
            paddingTop="12dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_spotgrid_botdetails_tooltips_title_in_auto_earn"
            layout_weight="1"
            style="@style/Body_4"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/tvEarnActiveAutoAmount"
            paddingTop="12dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="--"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
</LinearLayout>
