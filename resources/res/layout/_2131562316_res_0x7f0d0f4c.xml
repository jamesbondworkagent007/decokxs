<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingTop="@dimen/margin_16dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingStart="@dimen/margin_8dp"
    paddingEnd="@dimen/margin_8dp">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/group1"
        paddingBottom="@dimen/margin_5dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0">
        <ImageView
            id="@+id/ivSelectPoint"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231515_res_0x7f08031b"
            scaleType="6"
            layout_marginEnd="8dp"/>
        <ImageView
            id="@+id/ivAvatar"
            background="@drawable/_2131234215_res_0x7f080da7"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231099_res_0x7f08017b"
            scaleType="6"
            layout_marginEnd="8dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tvDescription"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="Earned +533 USDT via Smart arbitrage!"
            style="@style/TextAppearance.Text.14SP.Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/group2"
        paddingTop="@dimen/margin_5dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/group1">
        <ImageView
            id="@+id/ivSelectPoint2"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231515_res_0x7f08031b"
            scaleType="6"
            layout_marginEnd="8dp"/>
        <ImageView
            id="@+id/ivAvatar2"
            background="@drawable/_2131234215_res_0x7f080da7"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231099_res_0x7f08017b"
            scaleType="6"
            layout_marginEnd="8dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tvDescription2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="Earned +533 USDT via Smart arbitrage!"
            style="@style/TextAppearance.Text.14SP.Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.constraintlayout.widget.ConstraintLayout>
