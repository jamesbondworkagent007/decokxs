<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x800003"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Semibold"
        textColor="@color/grey_g900"
        gravity="0x800003"
        id="@+id/tv_content"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_swap_buttomsheet_crosschain_confirm"
        includeFontPadding="false"/>
    <TextView
        textSize="14sp"
        textColor="@color/grey_g900"
        gravity="0x800003"
        id="@+id/sub_content"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        lineSpacingExtra="2.5dp"
        fontFamily="@font/font_alpha_regular"/>
    <o.wYK
        gravity="0x800003"
        id="@+id/select_checkbox"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_20dp"
        text="@string/pr_swaptrade_swap_buttomsheet_not_showagain"/>
</LinearLayout>
