<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textSize="@dimen/text_size_18sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title_new_address"
        paddingTop="@dimen/padding_12dp"
        paddingBottom="@dimen/padding_12dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_escape_header_new_owner_address_cdf"
        layout_marginStart="@dimen/margin_24dp"
        paddingVertical="@dimen/padding_12dp"
        NOT_FOUND_0x12="@+id/iv_new_address_info"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="2"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        style="@style/Title_2_Bold"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_new_address_info"
        layout_width="@dimen/width_16dp"
        android:layout_height="@dimen/height_16dp"
        src="@drawable/_2131233141_res_0x7f080975"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0xf="@+id/tv_title_new_address"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x15="@+id/tv_title_new_address"
        NOT_FOUND_0x18="@+id/tv_title_new_address"
        NOT_FOUND_0x1b="@color/ContentContrast"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentTertiary"
        id="@+id/tv_new_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0x12="@+id/iv_copy_new_address"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tv_title_new_address"
        style="@style/Body_2_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_copy_new_address"
        layout_width="@dimen/width_20dp"
        android:layout_height="@dimen/height_20dp"
        src="@drawable/_2131234345_res_0x7f080e29"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x18="@+id/tv_new_address"
        NOT_FOUND_0x1b="@color/ContentTertiary"/>
    <TextView
        textSize="@dimen/text_size_18sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title_dex_address"
        paddingTop="@dimen/padding_12dp"
        paddingBottom="@dimen/padding_12dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_wallet_escape_header_dex_trading_address_cf"
        layout_marginStart="@dimen/margin_24dp"
        paddingVertical="@dimen/padding_12dp"
        NOT_FOUND_0x12="@+id/iv_dex_address_info"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="2"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tv_new_address"
        style="@style/Title_2_Bold"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_dex_address_info"
        layout_width="@dimen/width_16dp"
        android:layout_height="@dimen/height_16dp"
        src="@drawable/_2131233141_res_0x7f080975"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0xf="@+id/tv_title_dex_address"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x15="@+id/tv_title_dex_address"
        NOT_FOUND_0x18="@+id/tv_title_dex_address"
        NOT_FOUND_0x1b="@color/ContentContrast"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentTertiary"
        id="@+id/tv_title_storage_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="@dimen/margin_4dp"
        text="@string/pr_wallet_escape_title_storage_address"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0x10="@+id/tv_content_storage_address"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tv_title_dex_address"
        NOT_FOUND_0x19="2"
        style="@style/Body_2_Regular"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentTertiary"
        id="@+id/tv_content_storage_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0x10="@+id/tv_title_control_address"
        NOT_FOUND_0x12="@+id/iv_copy_storage_address"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tv_title_storage_address"
        style="@style/Body_2_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_copy_storage_address"
        layout_width="@dimen/width_20dp"
        android:layout_height="@dimen/height_20dp"
        src="@drawable/_2131234345_res_0x7f080e29"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x18="@+id/tv_content_storage_address"
        NOT_FOUND_0x1b="@color/ContentTertiary"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentTertiary"
        id="@+id/tv_title_control_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        text="@string/pr_wallet_escape_title_control_address"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0x10="@+id/tv_content_control_address"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tv_content_storage_address"
        style="@style/Body_2_Regular"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentTertiary"
        id="@+id/tv_content_control_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0x12="@+id/iv_copy_control_address"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tv_title_control_address"
        NOT_FOUND_0x1a="0dp"
        style="@style/Body_2_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_copy_control_address"
        layout_width="@dimen/width_20dp"
        android:layout_height="@dimen/height_20dp"
        src="@drawable/_2131234345_res_0x7f080e29"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x18="@+id/tv_content_control_address"
        NOT_FOUND_0x1b="@color/ContentTertiary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
