<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root_view"
    tag="layout/dialog_state_notification_0"
    background="@color/background_lv1_lv2"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="0"
            clickable="false"
            layout_width="-1"
            android:layout_height="wrap_content">
            <ImageView
                id="@+id/iv_state"
                visibility="2"
                clickable="false"
                layout_width="19dp"
                android:layout_height="19dp"
                layout_marginEnd="10dp"
                NOT_FOUND_0x11="0"/>
            <LinearLayout
                orientation="1"
                clickable="false"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginEnd="30dp">
                <TextView
                    textAppearance="@style/TextAppearance.Title.16SP.Medium"
                    textColor="@color/grey_g900"
                    id="@+id/tv_title"
                    clickable="false"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    includeFontPadding="false"
                    breakStrategy="0"/>
                <TextView
                    textAppearance="@style/TextAppearance.Title.14SP"
                    textColor="@color/grey_g600"
                    id="@+id/tv_content"
                    clickable="false"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="8dp"
                    includeFontPadding="false"
                    breakStrategy="0"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            orientation="0"
            id="@+id/action_group"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="18dp"
            layout_marginStart="29dp">
            <TextView
                textAppearance="@style/TextAppearance.Blue.14SP.Medium"
                textColor="@color/blue_lv1"
                id="@+id/tv_action"
                layout_width="-2"
                android:layout_height="wrap_content"/>
            <TextView
                textAppearance="@style/TextAppearance.Blue.14SP.Medium"
                textColor="@color/blue_lv1"
                id="@+id/tv_action1"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="16dp"/>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        layout_gravity="0x800005"
        id="@+id/iv_close"
        layout_width="@dimen/margin_20dp"
        android:layout_height="@dimen/margin_20dp"
        src="@drawable/_2131232722_res_0x7f0807d2"/>
</FrameLayout>
