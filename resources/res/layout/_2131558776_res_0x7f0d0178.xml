<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="0"
    background="@drawable/_2131230928_res_0x7f0800d0"
    paddingLeft="16dp"
    paddingTop="20dp"
    paddingRight="16dp"
    paddingBottom="20dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="16dp"
    paddingVertical="20dp">
    <ImageView
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131233507_res_0x7f080ae3"/>
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginStart="12dp">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_1_Bold"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/date"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
</LinearLayout>
