<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        paddingTop="8dp"
        paddingBottom="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="8dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            gravity="0x800013"
            id="@+id/tv_exchange"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginEnd="4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            gravity="0x800013"
            id="@+id/tv_currency"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginEnd="4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            gravity="0x800013"
            id="@+id/tv_price"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginEnd="4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            gravity="0x800015"
            id="@+id/tv_weight"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
