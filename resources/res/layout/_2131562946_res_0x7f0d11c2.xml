<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/xsm"
    layout_marginBottom="@dimen/xsm"
    layout_marginVertical="@dimen/xsm"
    paddingHorizontal="24dp">
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/token_logo"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginTop="2dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@style/CircleStyle"/>
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/network_logo"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginTop="22dp"
        layout_marginStart="20dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@style/CircleStyle"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/container_token_info"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="@+id/network_logo"
        NOT_FOUND_0x1d="0">
        <androidx.legacy.widget.Space
            id="@+id/space_center"
            layout_width="@dimen/margin_1dp"
            android:layout_height="@dimen/margin_1dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="0"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_token_name"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            autoSizeTextType="uniform"
            autoSizeMinTextSize="12sp"
            autoSizeMaxTextSize="16sp"
            NOT_FOUND_0x14="true"
            NOT_FOUND_0x17="@+id/iv_community"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="2"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="0"
            style="@style/Label_1_Medium"/>
        <ImageView
            id="@+id/iv_community"
            visibility="2"
            layout_width="12dp"
            android:layout_height="12dp"
            src="@drawable/_2131233096_res_0x7f080948"
            layout_marginStart="4dp"
            NOT_FOUND_0x15="@+id/tv_token_name"
            NOT_FOUND_0x17="@+id/space_center"
            NOT_FOUND_0x19="2"
            NOT_FOUND_0x1a="@+id/tv_token_name"
            NOT_FOUND_0x1d="@+id/tv_token_name"
            NOT_FOUND_0x1f="@color/BrandPrimaryAlternative"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_liquidity"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            maxLines="1"
            autoSizeTextType="uniform"
            autoSizeMinTextSize="12sp"
            autoSizeMaxTextSize="16sp"
            NOT_FOUND_0x14="true"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/space_center"
            NOT_FOUND_0x1b="@+id/tv_token_name"
            NOT_FOUND_0x1c="@+id/tv_token_name"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            layout_gravity="0x800005"
            id="@+id/tv_price"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="@dimen/xxxsm"
            autoSizeTextType="uniform"
            autoSizeMinTextSize="12sp"
            autoSizeMaxTextSize="16sp"
            NOT_FOUND_0x14="true"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="1"
            NOT_FOUND_0x1a="@+id/space_center"
            NOT_FOUND_0x1d="0"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="?attr/tradeRiseDefault"
            ellipsize="3"
            gravity="0x800005"
            layout_gravity="0x800005"
            id="@+id/tv_price_change"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            maxLines="1"
            layout_marginStart="@dimen/xxxsm"
            autoSizeTextType="uniform"
            autoSizeMinTextSize="12sp"
            autoSizeMaxTextSize="16sp"
            NOT_FOUND_0x14="true"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="1"
            NOT_FOUND_0x1a="@+id/space_center"
            NOT_FOUND_0x1c="@+id/tv_price"
            style="@style/Label_3_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
