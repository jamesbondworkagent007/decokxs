<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    layout_width="-1"
    android:layout_height="44dp">
    <ImageView
        layout_gravity="0x10"
        id="@+id/iv_coin_img"
        layout_width="28dp"
        android:layout_height="28dp"
        scaleType="fillCenter"/>
    <LinearLayout
        layout_gravity="0x10"
        orientation="0"
        id="@+id/select_view"
        layout_width="-2"
        android:layout_height="match_parent"
        layout_marginStart="6dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP.Medium"
            textSize="20sp"
            textStyle="0x1"
            textColor="@color/okTradeG900"
            layout_gravity="0x10"
            id="@+id/coin_name"
            layout_width="-2"
            android:layout_height="wrap_content"
            text=""/>
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP.Medium"
            textSize="16sp"
            textColor="@color/okTradeG400"
            gravity="0x10"
            layout_gravity="0x10"
            id="@+id/coin_type"
            layout_width="-2"
            android:layout_height="wrap_content"
            text=""
            hint="etherem"
            maxLines="1"
            layout_marginStart="@dimen/dp_4"
            layout_marginEnd="@dimen/ok_dp_16"
            autoSizeTextType="uniform"
            autoSizeMinTextSize="@dimen/text_size_10sp"/>
    </LinearLayout>
</LinearLayout>
