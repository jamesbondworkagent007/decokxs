<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_8dp"
    paddingTop="@dimen/common_page_edge_space"
    paddingRight="@dimen/padding_8dp"
    paddingBottom="@dimen/common_page_edge_space"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_8dp"
    paddingVertical="@dimen/common_page_edge_space">
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        ellipsize="3"
        gravity="0x10"
        id="@+id/date"
        layout_width="80dp"
        android:layout_height="0dp"
        maxLines="1"
        NOT_FOUND_0x15="@+id/status"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="@+id/status"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.12SP.Medium"
        ellipsize="3"
        gravity="0x10"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="0dp"
        maxLines="2"
        layout_marginStart="@dimen/xxsm"
        NOT_FOUND_0x15="@+id/status"
        NOT_FOUND_0x17="@+id/status"
        NOT_FOUND_0x18="@+id/date"
        NOT_FOUND_0x1b="@+id/status"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        ellipsize="3"
        gravity="0x800015"
        id="@+id/status"
        layout_width="76dp"
        android:layout_height="wrap_content"
        maxLines="2"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1b="0"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/action_layout"
        background="@drawable/_2131233965_res_0x7f080cad"
        padding="@dimen/padding_8dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xsm"
        NOT_FOUND_0x1a="@+id/date">
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP.Medium"
            id="@+id/validation_redeem_reward"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"/>
        <o.C52794wYp
            id="@+id/reject"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_text_history_list_reject"
            layout_marginStart="@dimen/margin_8dp"
            NOT_FOUND_0x1c="-2"
            NOT_FOUND_0x1d="28"
            NOT_FOUND_0x1e="0x102"/>
        <o.C52794wYp
            id="@+id/approve"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_tab_history_list_approve"
            layout_marginStart="@dimen/margin_8dp"
            NOT_FOUND_0x1c="-2"
            NOT_FOUND_0x1d="28"
            NOT_FOUND_0x1e="0x101"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
