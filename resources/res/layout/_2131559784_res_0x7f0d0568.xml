<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp">
        <TextView
            textAppearance="@style/TextAppearance.Text.16SP.Medium"
            textColor="@color/grey_g900"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_nft_title_mediapicker_file"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP"
            textColor="@color/grey_g400"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_nft_subtitle_mediapicker_file"/>
    </LinearLayout>
    <FrameLayout
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="@dimen/margin_16dp">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/nft_mediapicker_file_list"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginLeft="@dimen/margin_16dp"
            layout_marginRight="@dimen/margin_16dp"
            overScrollMode="2"/>
        <o.C55113xdn
            layout_gravity="0x11"
            id="@+id/nft_mediapicker_file_loadingView"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x10="true"/>
        <TextView
            textColor="@color/grey_g900"
            gravity="0x1"
            layout_gravity="0x1"
            id="@+id/nft_mediapicker_file_emptyview"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="56dp"
            text="@string/pr_nft_mediapicker_tip_file_empty"
            drawableTop="@drawable/_2131232474_res_0x7f0806da"
            drawablePadding="4dp"
            style="@style/TextAppearance.Text.16SP.Medium"/>
    </FrameLayout>
</LinearLayout>
