        src="@drawable/_2131234381_res_0x7f080e4d"
        tint="@color/ContentPrimary"
        layout_marginEnd="24dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
