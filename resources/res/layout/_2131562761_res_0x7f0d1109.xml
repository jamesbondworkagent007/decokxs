<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="16dp"
    clipToPadding="false"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/contentLayout"
        background="@drawable/_2131231109_res_0x7f080185"
        paddingTop="16dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        paddingStart="12dp"
        paddingEnd="16dp"
        elevation="12dp"
        layout_marginHorizontal="16dp"
        paddingVertical="16dp"
        NOT_FOUND_0x17="0">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/warningIcon"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232472_res_0x7f0806d8"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_1_Bold"
            textColor="@color/ContentSecondary"
            id="@+id/title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_metax_wallet_home_notiy_walletnotbackup"
            layout_marginStart="8dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="@+id/warningIcon"
            NOT_FOUND_0x1c="@+id/warningIcon"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_3_Regular"
            textColor="@color/ContentContrast"
            id="@+id/desc"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="@string/pr_metax_wallet_home_textbtn_backupcontent"
            layout_marginStart="8dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="@+id/warningIcon"
            NOT_FOUND_0x1b="@+id/title"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_2_Medium"
            textColor="@color/okTradeBlue700"
            id="@+id/backUp"
            background="@drawable/_2131233936_res_0x7f080c90"
            paddingLeft="24dp"
            paddingTop="8dp"
            paddingRight="24dp"
            paddingBottom="8dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            text="@string/pr_metax_wallet_home_textbtn_backup"
            layout_marginStart="8dp"
            paddingHorizontal="24dp"
            paddingVertical="8dp"
            NOT_FOUND_0x19="@+id/warningIcon"
            NOT_FOUND_0x1b="@+id/desc"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
