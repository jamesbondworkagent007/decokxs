<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/cl_question_and_answer"
    tag="layout/item_multi_send_board_question_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        id="@+id/ll_question_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0">
        <TextView
            textSize="@dimen/text_size_16sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_question"
            paddingTop="@dimen/padding_12dp"
            paddingBottom="@dimen/padding_12dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            paddingVertical="@dimen/padding_12dp"
            style="@style/Label_1_Bold"/>
        <androidx.appcompat.widget.AppCompatImageView
            layout_gravity="0x10"
            id="@+id/iv_arrow"
            layout_width="@dimen/width_24dp"
            android:layout_height="@dimen/height_24dp"
            src="@drawable/_2131231654_res_0x7f0803a6"
            tint="@color/ContentPrimary"
            layout_marginStart="@dimen/margin_16dp"/>
    </LinearLayout>
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_answer"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="@+id/question_divider"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/ll_question_title"
        style="@style/Body_3_Regular"/>
    <View
        id="@+id/question_divider"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="@dimen/height_0.5dp"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_16dp"
        layout_marginVertical="@dimen/margin_16dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/tv_answer"/>
</androidx.constraintlayout.widget.ConstraintLayout>
