<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/fragment_market_place_copy_create_order_0"
    paddingBottom="20dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.core.widget.NestedScrollView
        id="@+id/nsv_content"
        paddingBottom="@dimen/padding_24dp"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"
        overScrollMode="2"
        NOT_FOUND_0x1f="@+id/btn_create"
        NOT_FOUND_0x20="@+id/headerLayout">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <FrameLayout
                id="@+id/ll_order"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_default"
                layout_marginRight="@dimen/margin_default"
                minHeight="70dp"
                layout_marginHorizontal="@dimen/margin_default"/>
            <View
                id="@+id/bot_copy_tip_line"
                background="@color/okTradeG100"
                visibility="2"
                layout_width="-1"
                android:layout_height="0.5dp"
                layout_marginLeft="@dimen/margin_default"
                layout_marginTop="@dimen/margin_16dp"
                layout_marginRight="@dimen/margin_default"
                layout_marginHorizontal="@dimen/margin_default"/>
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.12SP"
                textColor="@color/grey_g400"
                id="@+id/bot_copy_tip"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_default"
                layout_marginTop="@dimen/margin_16dp"
                layout_marginRight="@dimen/margin_default"
                layout_marginBottom="@dimen/margin_16dp"
                layout_marginHorizontal="@dimen/margin_default"
                layout_marginVertical="@dimen/margin_16dp"
                lineHeight="20dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.12SP"
                textColor="@color/grey_g400"
                id="@+id/bot_copy_sub_tip"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_default"
                layout_marginTop="-4dp"
                layout_marginRight="@dimen/margin_default"
                layout_marginBottom="@dimen/margin_16dp"
                layout_marginHorizontal="@dimen/margin_default"
                lineHeight="20dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.12SP"
                textColor="@color/grey_g400"
                id="@+id/orderTip"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_default"
                layout_marginTop="@dimen/margin_12dp"
                layout_marginRight="@dimen/margin_default"
                layout_marginHorizontal="@dimen/margin_default"
                lineHeight="20dp"/>
            <LinearLayout
                orientation="0"
                id="@+id/space_view"
                background="@color/grey_g50"
                layout_width="-1"
                android:layout_height="8dp"
                layout_marginTop="20dp"/>
            <LinearLayout
                orientation="0"
                id="@+id/bot_details_layout"
                layout_width="-1"
                android:layout_height="wrap_content"
                paddingStart="@dimen/margin_default">
                <TextView
                    textAppearance="@style/TextAppearance.Title.16SP.Semibold"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="16dp"
                    layout_marginBottom="16dp"
                    text="@string/pr_marketplace_botdetails_title_bot_details"
                    layout_weight="1"
                    layout_marginVertical="16dp"/>
                <ImageView
                    layout_gravity="0x10"
                    id="@+id/iv_show"
                    paddingLeft="16dp"
                    paddingTop="8dp"
                    paddingRight="16dp"
                    paddingBottom="8dp"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    src="@drawable/_2131231637_res_0x7f080395"
                    layout_marginEnd="8dp"
                    paddingHorizontal="16dp"
                    paddingVertical="8dp"
                    NOT_FOUND_0x23="@color/ContentSecondary"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/rcv_info"
                paddingLeft="@dimen/margin_default"
                paddingRight="@dimen/margin_default"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                overScrollMode="2"
                paddingHorizontal="@dimen/margin_default"/>
            <View
                id="@+id/v_bottom_line"
                background="@color/okTradeG100"
                layout_width="-1"
                android:layout_height="0.5dp"
                layout_marginLeft="@dimen/margin_default"
                layout_marginTop="16dp"
                layout_marginRight="@dimen/margin_default"
                layout_marginHorizontal="@dimen/margin_default"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP"
                id="@+id/tv_hint"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_default"
                layout_marginTop="16dp"
                layout_marginRight="@dimen/margin_default"
                text="@string/pr_marketplace_placeorder_notif_bot_individual_earn"
                layout_marginHorizontal="@dimen/margin_default"/>
