    </androidx.core.widget.NestedScrollView>
    <o.C52794wYp
        gravity="0x11"
        id="@+id/btn_create"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/dp_16"
        layout_marginRight="@dimen/dp_16"
        layout_marginHorizontal="@dimen/dp_16"
        NOT_FOUND_0x20="@+id/confirm_scroll_view"
        NOT_FOUND_0x21="52"
        NOT_FOUND_0x22="0x103"/>
</LinearLayout>
