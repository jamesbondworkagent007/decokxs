<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/drawer_layout"
    layout_width="-1"
    android:layout_height="match_parent">
    <RelativeLayout
        layout_width="-1"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/landscape_main_content"
            background="@color/okTradeBackground1"
            clipChildren="true"
            layout_width="-1"
            android:layout_height="match_parent">
            <o.C39816pzV
                id="@+id/time_select_landscape"
                layout_width="0dp"
                android:layout_height="32dp"
                layout_marginStart="@dimen/padding_16dp"
                NOT_FOUND_0x1e="@+id/market_cap"
                NOT_FOUND_0x23="0"
                NOT_FOUND_0x25="0"
                NOT_FOUND_0x26="1"/>
            <androidx.appcompat.widget.AppCompatTextView
                textSize="@dimen/text_size_12sp"
                id="@+id/market_cap"
                background="@drawable/_2131233867_res_0x7f080c4b"
                paddingLeft="@dimen/padding_8dp"
                paddingTop="@dimen/padding_4dp"
                paddingRight="@dimen/padding_8dp"
                paddingBottom="@dimen/padding_4dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_function_tab_mcap"
                includeFontPadding="false"
                layout_marginStart="@dimen/margin_4dp"
                layout_marginEnd="@dimen/margin_16dp"
                paddingHorizontal="@dimen/padding_8dp"
                paddingVertical="@dimen/padding_4dp"
                NOT_FOUND_0x1c="@+id/time_select_landscape"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x22="@+id/time_select_landscape"
                NOT_FOUND_0x25="@+id/time_select_landscape"/>
            <View
                id="@+id/viewLine"
                background="@color/oktemp_widget_border_color"
                layout_width="-1"
                android:layout_height="1px"
                NOT_FOUND_0x24="@+id/time_select_landscape"/>
            <RelativeLayout
                id="@+id/mRlRightTool"
                layout_width="48dp"
                android:layout_height="0dp"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x21="0"
                NOT_FOUND_0x24="@+id/viewLine">
                <LinearLayout
                    gravity="0x1"
                    orientation="1"
                    id="@+id/mLlMarketTool"
                    layout_width="48dp"
                    android:layout_height="match_parent">
                    <RelativeLayout
                        id="@+id/mRlLandLineTools"
                        layout_width="-1"
                        android:layout_height="36dp">
                        <ImageView
                            background="@drawable/_2131233334_res_0x7f080a36"
                            layout_width="18dp"
                            android:layout_height="18dp"
                            layout_centerInParent="true"/>
                    </RelativeLayout>
                    <View
                        background="@color/okTradeG200"
                        layout_width="36dp"
                        android:layout_height="1px"/>
                    <o.C39756pyO
                        id="@+id/mLandIndexSelectView"
                        layout_width="48dp"
                        android:layout_height="0dp"
                        layout_weight="1"
                        NOT_FOUND_0x1b="false"/>
                    <View
                        background="@color/okTradeG200"
                        layout_width="36dp"
                        android:layout_height="1px"/>
                    <RelativeLayout
                        id="@+id/mRLLandMarketSetting"
                        layout_width="-1"
                        android:layout_height="32dp">
                        <ImageView
                            background="@drawable/_2131232294_res_0x7f080626"
                            layout_width="18dp"
                            android:layout_height="18dp"
                            layout_centerInParent="true"/>
                    </RelativeLayout>
                </LinearLayout>
                <o.ViewOnClickListenerC39746pyE
                    id="@+id/mDrawLineToolsView"
                    visibility="2"
                    layout_width="48dp"
                    android:layout_height="match_parent"/>
                <View
                    background="@color/oktemp_widget_border_color"
                    layout_width="1px"
                    android:layout_height="match_parent"/>
            </RelativeLayout>
            <o.C39835pzo
                id="@+id/mNestedScrollView"
                clipChildren="false"
                layout_width="0dp"
                android:layout_height="0dp"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="@+id/mRlRightTool"
                NOT_FOUND_0x24="@+id/viewLine">
                <RelativeLayout
                    clipChildren="false"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <o.C36250oUv
                        id="@+id/mLandMarketChart"
                        layout_width="-1"
                        android:layout_height="wrap_content"/>
                    <o.C39805pzK
                        id="@+id/magnifier"
                        background="@color/transparent"
                        visibility="2"
                        layout_width="@dimen/width_100dp"
                        android:layout_height="@dimen/height_100dp"/>
                </RelativeLayout>
            </o.C39835pzo>
            <o.ViewOnClickListenerC39742pyA
                id="@+id/draw_box"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="10dp"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x23="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <ImageView
            id="@+id/mIvLandClose"
            padding="@dimen/padding_14dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232980_res_0x7f0808d4"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
    <FrameLayout
        layout_gravity="0x5"
        id="@+id/drawer_right"
        background="@color/okTradeBackground1"
        clickable="true"
        layout_width="375dp"
        android:layout_height="match_parent"/>
    <FrameLayout
        layout_gravity="0x3"
        id="@+id/drawer_left"
        background="@color/okTradeBackground1"
        clickable="true"
        layout_width="375dp"
        android:layout_height="match_parent"/>
</androidx.drawerlayout.widget.DrawerLayout>
