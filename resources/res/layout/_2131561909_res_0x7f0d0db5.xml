<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="@dimen/dp_24"
    paddingRight="@dimen/dp_24"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/dp_24">
    <LinearLayout
        orientation="1"
        id="@+id/content"
        paddingTop="@dimen/padding_20dp"
        paddingBottom="@dimen/padding_20dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/padding_20dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            minHeight="@dimen/height_48dp">
            <TextView
                textColor="@color/okTradeG900"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_trade_modal_input_price_reach"
                includeFontPadding="false"
                style="@style/TextAppearance.Title.16SP.Semibold"/>
            <TextView
                textColor="@color/okTradeG400"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_modal_text_equal"
                includeFontPadding="false"
                style="@style/LiteTextAppearance.TextBlack.14SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_24"
            minHeight="@dimen/height_48dp">
            <TextView
                textColor="@color/okTradeG900"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_trade_modal_input_price_rise"
                includeFontPadding="false"
                style="@style/TextAppearance.Title.16SP.Semibold"/>
            <TextView
                textColor="@color/okTradeG400"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_modal_text_greater"
                includeFontPadding="false"
                style="@style/LiteTextAppearance.TextBlack.14SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_24"
            minHeight="@dimen/height_48dp">
            <TextView
                textColor="@color/okTradeG900"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_trade_modal_input_price_fall"
                includeFontPadding="false"
                style="@style/TextAppearance.Title.16SP.Semibold"/>
            <TextView
                textColor="@color/okTradeG400"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_modal_text_less"
                includeFontPadding="false"
                style="@style/LiteTextAppearance.TextBlack.14SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_24"
            minHeight="@dimen/height_48dp">
            <TextView
                textColor="@color/okTradeG900"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_trade_settings_alert_label_price_gain_exceeds"
                includeFontPadding="false"
                style="@style/TextAppearance.Title.16SP.Semibold"/>
            <TextView
                textColor="@color/okTradeG400"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_settings_alert_desc_price_gain_exceeds"
                maxLines="3"
                includeFontPadding="false"
                style="@style/LiteTextAppearance.TextBlack.14SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_24"
            minHeight="@dimen/height_48dp">
            <TextView
                textColor="@color/okTradeG900"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_trade_settings_alert_label_price_loss_exceeds"
                includeFontPadding="false"
                style="@style/TextAppearance.Title.16SP.Semibold"/>
            <TextView
                textColor="@color/okTradeG400"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_settings_alert_desc_price_loss_exceeds"
                includeFontPadding="false"
                style="@style/LiteTextAppearance.TextBlack.14SP.Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/layout_ma"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_24"
            minHeight="48dp">
            <TextView
                textColor="@color/okTradeG900"
                id="@+id/tv_ma_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_trade_alert_input_moving_average"
                includeFontPadding="false"
                NOT_FOUND_0x15="@+id/tv_ma_desc"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1b="2"
                style="@style/TextAppearance.Title.16SP.Semibold"/>
            <TextView
                textColor="@color/okTradeG400"
                id="@+id/tv_ma_desc"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_alert_tooltips_desc_moving_average"
                includeFontPadding="false"
                layout_marginEnd="@dimen/margin_8dp"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x17="@+id/ma_red_pot"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="@+id/tv_ma_title"
                NOT_FOUND_0x1c="0dp"
                style="@style/LiteTextAppearance.TextBlack.14SP.Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                id="@+id/ma_red_pot"
                background="@drawable/_2131232046_res_0x7f08052e"
                visibility="2"
                layout_width="8dp"
                android:layout_height="8dp"
                layout_marginEnd="@dimen/margin_2dp"
                backgroundTint="@color/SemanticNegative"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x1a="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
