<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/avatarContainer"
    layout_width="-2"
    android:layout_height="wrap_content">
    <FrameLayout
        id="@+id/contentContainer"
        background="@color/color_surface_structural_layer_2"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_margin="4dp">
        <com.airbnb.lottie.LottieAnimationView
            id="@+id/avatarImage"
            visibility="2"
            layout_width="-1"
            android:layout_height="match_parent"
            scaleType="6"/>
        <TextView
            textStyle="0x1"
            textColor="#5e5e5e"
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/avatarTextView"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <ImageView
            layout_gravity="0x11"
            id="@+id/avatarIcon"
            visibility="2"
            layout_width="-1"
            android:layout_height="match_parent"
            scaleType="7"/>
        <View
            id="@+id/avatarOutline"
            visibility="2"
            layout_width="-1"
            android:layout_height="match_parent"/>
    </FrameLayout>
    <View
        id="@+id/avatarNotificationRing"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"/>
</FrameLayout>
