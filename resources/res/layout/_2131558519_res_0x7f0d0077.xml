<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    background="#fff"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x11"
        orientation="1"
        paddingLeft="32dp"
        paddingRight="32dp"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="44dp"
        layout_marginBottom="84dp">
        <ImageView
            layout_gravity="0x1"
            id="@+id/iv_icon"
            layout_width="90dp"
            android:layout_height="90dp"
            layout_marginTop="20dp"
            src="@drawable/_2131232752_res_0x7f0807f0"/>
        <TextView
            textSize="24sp"
            textColor="#000"
            layout_gravity="0x1"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"
            text="@string/pr_safemode_home_title_safe_mode"/>
        <TextView
            textSize="14sp"
            textStyle="0x1"
            textColor="#545454"
            gravity="0x11"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            text="@string/pr_safemode_home_subtitle_crash_and_resolve"/>
    </LinearLayout>
    <Button
        textColor="@color/safe_mode_btn_color_selector"
        background="@drawable/_2131233825_res_0x7f080c21"
        focusable="true"
        clickable="true"
        layout_width="-1"
        android:layout_height="52dp"
        layout_marginLeft="16dp"
        layout_marginTop="12dp"
        layout_marginRight="16dp"
        layout_marginBottom="20dp"
        text="@string/pr_safemode_home_btn_export_log"
        layout_alignParentBottom="true"
        onClick="exportLog"/>
</RelativeLayout>
