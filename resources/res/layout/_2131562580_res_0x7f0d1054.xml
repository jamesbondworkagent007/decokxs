<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="16dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        gravity="0x11"
        layout_gravity="0x11"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        drawablePadding="6dp"
        layout_centerVertical="true"
        layout_marginStart="@dimen/common_page_edge_space"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Hint.12SP"
        gravity="0x11"
        id="@+id/tv_status"
        layout_width="-2"
        android:layout_height="0dp"
        text="@string/pr_trade_history_text_buyorder_status"
        drawablePadding="4dp"
        drawableEnd="@drawable/_2131231649_res_0x7f0803a1"
        paddingEnd="@dimen/common_page_edge_space"
        drawableTint="@color/ContentDisabled"
        NOT_FOUND_0x17="@+id/tv_title"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="@+id/tv_title"/>
    <TextView
        textAppearance="@style/TextAppearance.Red.12SP"
        id="@+id/tv_trade_type"
        background="@drawable/_2131231484_res_0x7f0802fc"
        paddingLeft="2dp"
        paddingRight="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        backgroundTint="@color/okTradeRed50"
        paddingHorizontal="2dp"
        NOT_FOUND_0x1b="@+id/tv_title"
        NOT_FOUND_0x1c="@+id/tv_title"/>
    <TextView
        textAppearance="@style/TextAppearance.Hint.12SP"
        gravity="0x10"
        id="@+id/tv_time"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginStart="6dp"
        NOT_FOUND_0x17="@+id/tv_trade_type"
        NOT_FOUND_0x1a="@+id/tv_trade_type"
        NOT_FOUND_0x1d="@+id/tv_trade_type"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcv_view"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        layout_marginStart="@dimen/common_page_edge_space"
        layout_marginEnd="@dimen/common_page_edge_space"
        touchscreenBlocksFocus="false"
        NOT_FOUND_0x16="true"
        NOT_FOUND_0x18="@+id/view_line"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="@+id/tv_trade_type"
        NOT_FOUND_0x1e="0"/>
    <View
        id="@+id/view_line"
        layout_marginTop="17dp"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="@+id/rcv_view"
        NOT_FOUND_0x1f="0.3"
        style="@style/WidgetDivisionLine"/>
</androidx.constraintlayout.widget.ConstraintLayout>
