<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/view_line"
        layout_marginTop="16dp"
        style="@style/WidgetDivisionLine"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        id="@+id/tv_tip1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_trade_bot_recurring_tactics_confirm_tip1"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        id="@+id/tv_tip2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_trade_bots_recurring_modal_confirm2"/>
    <TextView
        textAppearance="@style/TextAppearance.Blue.12SP"
        id="@+id/tv_expand"
        visibility="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_trade_strategy_header_view_less"/>
</LinearLayout>
