<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/root_layout"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        id="@+id/title_layout"
        background="?attr/selectableItemWhiteBackgroundWithDivider"
        layout_width="0dp"
        android:layout_height="@dimen/appbar_height"
        NOT_FOUND_0x10="@+id/rv_list"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0">
        <TextView
            textSize="16sp"
            gravity="0x11"
            id="@+id/tv_title"
            layout_width="-2"
            android:layout_height="match_parent"
            layout_weight="1"
            fontFamily="sans-serif-medium"
            layout_marginStart="@dimen/common_page_edge_space"
            style="@style/TextAppearance.Title"/>
        <ImageView
            id="@+id/btn_close"
            background="?attr/selectableItemBackgroundBorderless"
            layout_width="@dimen/appbar_height"
            android:layout_height="@dimen/appbar_height"
            src="@drawable/_2131232489_res_0x7f0806e9"
            scaleType="fitEnd"
            NOT_FOUND_0x16="#5c5e66"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_list"
        background="@color/white_background_color"
        layout_width="0dp"
        android:layout_height="0dp"
        NOT_FOUND_0x10="@+id/divider"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="1"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/title_layout"/>
    <View
        id="@+id/divider"
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="0.5dp"
        NOT_FOUND_0x10="@+id/btn_cancel"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/rv_list"/>
    <TextView
        textAppearance="@style/TextAppearance.Subtitle"
        textSize="16sp"
        gravity="0x11"
        id="@+id/btn_cancel"
        background="@color/white_background_color"
        layout_width="0dp"
        android:layout_height="@dimen/height_56dp"
        text="@android:string/cancel"
        textAllCaps="true"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
