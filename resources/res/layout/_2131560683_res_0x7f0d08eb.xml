<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="16dp"
    paddingRight="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="16dp">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <o.C33608mzf
            id="@+id/thumbnail"
            layout_width="72dp"
            android:layout_height="72dp"
            NOT_FOUND_0x17="36dp"
            NOT_FOUND_0x18="36dp"
            NOT_FOUND_0x19="36dp"
            NOT_FOUND_0x1a="36dp"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="8dp">
            <TextView
                textAppearance="@style/Label_1_Bold"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/name"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="2"/>
            <o.C55251xgS
                id="@+id/tag"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="@string/pr_investutxo_mid_text_no_value_nft"
                NOT_FOUND_0x14="-2"
                NOT_FOUND_0x15="-4"
                NOT_FOUND_0x16="0"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <TextView
            textColor="@color/ContentContrast"
            gravity="0x800005"
            id="@+id/tv_fiat_amount"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="150dp"
            layout_marginStart="16dp"
            style="@style/Label_3_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <View
        id="@+id/divider"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="24dp"
        layout_marginBottom="24dp"/>
</androidx.appcompat.widget.LinearLayoutCompat>
