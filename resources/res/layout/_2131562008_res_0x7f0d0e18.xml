<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/status_bar_latest_event_content"
    layout_width="-1"
    android:layout_height="128dp">
    <ImageView
        id="@+id/icon"
        layout_width="128dp"
        android:layout_height="128dp"
        scaleType="6"/>
    <include
        layout_width="48dp"
        android:layout_height="48dp"
        layout_marginLeft="2dp"
        layout_marginRight="2dp"
        layout_alignParentRight="true"
        layout_alignParentEnd="true"
        layout="@layout/_2131562003_res_0x7f0d0e13"/>
    <LinearLayout
        orientation="0"
        id="@+id/notification_main_column_container"
        paddingTop="@dimen/notification_main_column_padding_top"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="128dp"
        minHeight="@dimen/notification_large_icon_height"
        layout_toLeftOf="@+id/cancel_action"
        layout_marginStart="128dp"
        layout_toStartOf="@+id/cancel_action">
        <FrameLayout
            id="@+id/notification_main_column"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/notification_media_narrow_margin"
            layout_marginRight="8dp"
            layout_marginBottom="8dp"
            layout_weight="1"
            layout_marginStart="@dimen/notification_media_narrow_margin"
            layout_marginEnd="8dp"/>
        <FrameLayout
            id="@+id/right_side"
            paddingTop="@dimen/notification_right_side_padding_top"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginRight="8dp"
            layout_marginEnd="8dp">
            <DateTimeView
                textAppearance="@style/TextAppearance.Compat.Notification.Time.Media"
                layout_gravity="0x800035"
                id="@+id/time"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"/>
            <Chronometer
                textAppearance="@style/TextAppearance.Compat.Notification.Time.Media"
                layout_gravity="0x800035"
                id="@+id/chronometer"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"/>
            <TextView
                textAppearance="@style/TextAppearance.Compat.Notification.Info.Media"
                layout_gravity="0x800055"
                id="@+id/info"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="20dp"
                singleLine="true"/>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        id="@+id/media_actions"
        layout_width="-1"
        android:layout_height="48dp"
        layout_marginLeft="12dp"
        layout_marginRight="12dp"
        layout_toRightOf="@+id/icon"
        layout_alignParentBottom="true"
        layoutDirection="0"
        layout_toEndOf="@+id/icon"/>
    <ImageView
        id="@+id/action_divider"
        background="?android:attr/dividerHorizontal"
        layout_width="-1"
        android:layout_height="1dp"
        layout_toRightOf="@+id/icon"
        layout_above="@+id/media_actions"
        layout_toEndOf="@+id/icon"/>
</RelativeLayout>
