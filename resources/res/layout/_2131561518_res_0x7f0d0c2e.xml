<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root"
    background="@android:color/black"
    layout_width="-1"
    android:layout_height="match_parent">
    <RelativeLayout
        layout_width="-1"
        android:layout_height="match_parent">
        <FrameLayout
            id="@+id/surface_container"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <FrameLayout
            id="@+id/mask"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <ImageView
            id="@+id/poster"
            background="#000000"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_centerInParent="true"/>
        <RelativeLayout
            id="@+id/layout_top"
            visibility="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="10dp"
            layout_alignParentTop="true"
            layout_alignParentStart="true">
            <ImageView
                id="@+id/back"
                padding="@dimen/dp_10"
                layout_width="46dp"
                android:layout_height="46dp"
                layout_marginTop="@dimen/margin_20dp"
                src="@drawable/_2131233218_res_0x7f0809c2"
                scaleType="7"
                layout_alignParentTop="true"
                layout_marginStart="@dimen/margin_20dp"
                layout_alignParentStart="true"/>
        </RelativeLayout>
        <ProgressBar
            id="@+id/loading"
            visibility="1"
            layout_width="@dimen/jz_start_button_w_h_normal"
            android:layout_height="@dimen/jz_start_button_w_h_normal"
            indeterminateDrawable="@drawable/_2131233229_res_0x7f0809cd"
            layout_centerHorizontal="true"
            layout_centerVertical="true"/>
        <ImageView
            id="@+id/start"
            layout_width="65dp"
            android:layout_height="65dp"
            src="@drawable/_2131233685_res_0x7f080b95"
            layout_centerInParent="true"/>
        <LinearLayout
            gravity="0x1"
            orientation="1"
            id="@+id/retry_layout"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_centerHorizontal="true"
            layout_centerVertical="true">
            <TextView
                textSize="16sp"
                textColor="@android:color/white"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_metax_nft_playvideo_notif_playfail"
                style="@style/TextAppearance.Text.16SP"/>
            <TextView
                textSize="14sp"
                textColor="@android:color/white"
                id="@+id/retry_btn"
                background="@drawable/_2131231455_res_0x7f0802df"
                paddingTop="10dp"
                paddingBottom="10dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="15dp"
                text="@string/pr_metax_nft_playvideo_link_retry"
                paddingStart="24dp"
                paddingEnd="24dp"
                style="@style/TextAppearance.Text.14SP.Medium"/>
        </LinearLayout>
    </RelativeLayout>
    <RelativeLayout
        gravity="0x10"
        layout_gravity="0x50"
        orientation="0"
        id="@+id/layout_bottom"
        background="@drawable/_2131234296_res_0x7f080df8"
        visibility="1"
        layout_width="-1"
        android:layout_height="56dp"
        NOT_FOUND_0x24="0">
        <ImageView
            id="@+id/control_iv"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131233686_res_0x7f080b96"
            layout_centerVertical="true"
            layout_marginStart="21dp"/>
        <ImageView
            id="@+id/fullscreen"
            layout_width="@dimen/ok_dp_24"
            android:layout_height="@dimen/ok_dp_24"
            src="@drawable/_2131234297_res_0x7f080df9"
            layout_centerVertical="true"
            layout_marginEnd="19dp"
            layout_alignParentEnd="true"/>
        <TextView
            textSize="@dimen/height_14dp"
            textColor="@color/okTradeW900"
            id="@+id/current"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="00:00"
            layout_centerVertical="true"
            layout_marginStart="@dimen/ok_dp_12"
            layout_toEndOf="@+id/control_iv"
            style="@style/TextAppearance.Text.14SP.Medium"/>
        <TextView
            textSize="@dimen/height_14dp"
            textColor="@color/okTradeW900"
            id="@+id/total"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="00:00"
            layout_centerVertical="true"
            layout_marginEnd="@dimen/margin_9dp"
            layout_toStartOf="@+id/fullscreen"
            style="@style/TextAppearance.Text.14SP.Medium"/>
        <SeekBar
            layout_gravity="0x10"
            id="@+id/bottom_seek_progress"
            background="@null"
            padding="8dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxHeight="1dp"
            max="100"
            progress="50"
            progressDrawable="@drawable/_2131234303_res_0x7f080dff"
            minHeight="1dp"
            thumb="@drawable/_2131233214_res_0x7f0809be"
            layout_centerVertical="true"
            layout_toStartOf="@+id/total"
            layout_toEndOf="@+id/current"/>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
