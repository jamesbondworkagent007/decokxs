<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131231350_res_0x7f080276"
    paddingLeft="@dimen/margin_16dp"
    paddingTop="@dimen/margin_14dp"
    paddingRight="@dimen/margin_16dp"
    paddingBottom="@dimen/margin_14dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="48dp"
    paddingHorizontal="@dimen/margin_16dp"
    paddingVertical="@dimen/margin_14dp">
    <LinearLayout
        orientation="0"
        id="@+id/scanItemHeader"
        focusable="true"
        clickable="true"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            layout_gravity="0x11"
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textAppearance="@style/Label_1_Medium"
                textSize="@dimen/text_size_16sp"
                textColor="@color/ContentPrimary"
                id="@+id/tv_itemTitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="扫描类型"
                maxLines="1"
                NOT_FOUND_0x1a="@drawable/_2131231589_res_0x7f080365"/>
            <TextView
                textAppearance="@style/Label_3_Regular"
                textSize="@dimen/text_size_12sp"
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_itemInfo"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_4"
                text="正在检测..."
                maxLines="3"
                layout_marginEnd="12dp"/>
        </LinearLayout>
        <com.airbnb.lottie.LottieAnimationView
            layout_gravity="0x11"
            id="@+id/iv_progressIcon"
            layout_width="20dp"
            android:layout_height="20dp"
            NOT_FOUND_0x1b="false"
            NOT_FOUND_0x1c="true"
            NOT_FOUND_0x1d="@raw/_2131886112_res_0x7f120020"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_scanResults"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        nestedScrollingEnabled="false"/>
</LinearLayout>
