<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent"
    fillViewport="true">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        layout_marginBottom="16dp"
        layout_marginHorizontal="16dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP.Semibold"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="8dp"
            layout_marginRight="16dp"
            text="Footer Theme Test"
            layout_marginHorizontal="16dp"/>
        <Spinner
            id="@+id/sp_themes"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            layout_marginBottom="16dp"
            minHeight="36dp"/>
        <o.C49352umt
            id="@+id/fv_unspecified"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="apitest"
            NOT_FOUND_0x13="Unspecified theme"/>
        <o.C49352umt
            theme="@style/FootViewFollowTheme"
            id="@+id/fv_follow_app"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="apitest"
            NOT_FOUND_0x13="Follow App"/>
        <o.C49352umt
            theme="@style/FootViewFixedTheme"
            id="@+id/fv_fixed_light"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="apitest"
            NOT_FOUND_0x13="Light"/>
        <o.C49352umt
            theme="@style/FootViewFixedTheme.Inverse"
            id="@+id/fv_fixed_dark"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="apitest"
            NOT_FOUND_0x13="Dark"/>
        <o.C49352umt
            theme="@style/FootViewFixedTheme.VIP"
            id="@+id/fv_fixed_vip"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="apitest"
            NOT_FOUND_0x13="VIP"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP.Semibold"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="16dp"
            layout_marginRight="16dp"
            text="Footer with default data"
            layout_marginHorizontal="16dp"/>
        <LinearLayout
            orientation="1"
            id="@+id/ll_default_data"
            layout_width="-1"
            android:layout_height="wrap_content">
            <ImageView
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginBottom="4dp"
                src="@drawable/_2131234041_res_0x7f080cf9"
                scaleType="6"/>
            <o.C49352umt
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0x12="apitest"/>
        </LinearLayout>
        <o.C52794wYp
            id="@+id/btn_share_default_data"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="Share Footer default data"
            NOT_FOUND_0x15="52"
            NOT_FOUND_0x16="0x101"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP.Semibold"
            id="@+id/tv_decode_short_code"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"
            text="Decode Share Short Link"/>
        <com.okinc.uilab.edit.OKEditText
            id="@+id/et_short_code"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            hint="please input share shortcode"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.10SP"
            id="@+id/tv_code_hint"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            text="eg:(https://okx.com/ul/FKDJPoC),input FKDJPoC"
            textIsSelectable="true"/>
        <o.C52794wYp
            id="@+id/btn_decode"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="Decode Short Link"
            NOT_FOUND_0x15="52"
            NOT_FOUND_0x16="0x101"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP.Semibold"
            id="@+id/tv_qrcode_link"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"
            text="original link for FooterView of below"/>
        <com.okinc.uilab.edit.OKEditText
            id="@+id/et_qrcode_link"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            hint="please input original link for create short link of FooterView below"/>
        <o.C52794wYp
            id="@+id/btn_share_footer_v1_src_from"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            text="Show Share Footer(SetSrcFrom)"
            NOT_FOUND_0x15="52"
            NOT_FOUND_0x16="0x101"/>
        <o.C52794wYp
            id="@+id/btn_share_footer_V1_create_short_link"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            text="Show Share Footer(Create Short Link)"
            NOT_FOUND_0x15="52"
            NOT_FOUND_0x16="0x101"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP.Semibold"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="24dp"
            layout_marginRight="16dp"
            text="Create Short Link By Parameters"
            layout_marginHorizontal="16dp"/>
        <com.google.android.material.textfield.TextInputLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginRight="16dp"
            layout_marginHorizontal="16dp"
            NOT_FOUND_0x14="true">
            <com.google.android.material.textfield.TextInputEditText
                id="@+id/et_original_link"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="https://okx.com/join/12345"
                hint="Original Link"/>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginRight="16dp"
            layout_marginHorizontal="16dp"
            NOT_FOUND_0x14="true">
            <com.google.android.material.textfield.TextInputEditText
                id="@+id/et_deep_link"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="okx://pro/home"
                hint="Deeplink"/>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="8dp"
            layout_marginRight="16dp"
            layout_marginHorizontal="16dp"
            NOT_FOUND_0x14="true">
            <com.google.android.material.textfield.TextInputEditText
                id="@+id/et_share_from"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="apitest"
                hint="Content scene(share from)"/>
        </com.google.android.material.textfield.TextInputLayout>
        <o.wYK
            textAppearance="@style/TextAppearance.Title.12SP"
            id="@+id/cb_channel_code"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="8dp"
            layout_marginRight="16dp"
            text="Attach Channel Code"
            layout_marginHorizontal="16dp"/>
        <o.wYK
            textAppearance="@style/TextAppearance.Title.12SP"
            id="@+id/cb_direct_goto_bizpage"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="8dp"
            layout_marginRight="16dp"
            text="Direct goto biz page(ignore deeplink)"
            layout_marginHorizontal="16dp"/>
        <o.C52794wYp
            id="@+id/btn_create_short_link"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginRight="16dp"
            text="Create and Preview Short Link"
            layout_marginHorizontal="16dp"
            NOT_FOUND_0x15="52"
            NOT_FOUND_0x16="0x101"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP.Semibold"
            id="@+id/tv_created_short_link"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginTop="8dp"
            layout_marginRight="16dp"
            layout_marginBottom="16dp"
            text="show links here after created"
            textIsSelectable="true"
            layout_marginHorizontal="16dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
