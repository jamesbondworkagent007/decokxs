                textColor="@color/ContentPrimary"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_volume_content"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginLeft="12dp"
                layout_marginTop="2dp"
                layout_marginRight="12dp"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeMinTextSize="10sp"
                layout_marginHorizontal="12dp"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="@+id/tv_volume_title"
                style="@style/Label_1_Medium"/>
            <TextView
                textSize="10sp"
                layout_gravity="0x10"
                id="@+id/tv_volume_percent"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginLeft="12dp"
                layout_marginTop="2dp"
                layout_marginRight="12dp"
                layout_marginHorizontal="12dp"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="@+id/tv_volume_content"
                style="@style/Label_4_Regular"/>
            <o.C41084qkD
                id="@+id/volume_chart"
                visibility="1"
                layout_width="-1"
                android:layout_height="40dp"
                layout_marginLeft="0.5dp"
                layout_marginRight="0.5dp"
                layout_marginBottom="0.5dp"
                layout_marginHorizontal="0.5dp"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1d="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/cl_end"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginStart="8dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1c="@+id/cl_mid"
            NOT_FOUND_0x1f="0">
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/cl_24h_change"
                background="@drawable/_2131231483_res_0x7f0802fb"
                padding="8dp"
                layout_width="-1"
                android:layout_height="wrap_content"
                backgroundTint="@color/SurfaceSecondary"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1f="0">
                <TextView
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    layout_gravity="0x10"
                    id="@+id/tv_24h_change_title"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_discover_title_24h_change"
                    maxLines="1"
                    autoSizeTextType="uniform"
                    autoSizeMinTextSize="10sp"
                    NOT_FOUND_0x19="0"
                    NOT_FOUND_0x1d="0"
                    NOT_FOUND_0x1f="0"
                    style="@style/Label_3_Regular"/>
