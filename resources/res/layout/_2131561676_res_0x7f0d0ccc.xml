                autoSizeMinTextSize="10sp"
                layout_marginHorizontal="12dp"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1f="0"
                style="@style/Label_3_Regular"/>
            <TextView
