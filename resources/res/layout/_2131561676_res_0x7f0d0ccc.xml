                    layout_gravity="0x10"
                    id="@+id/tv_24h_change_percent"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    NOT_FOUND_0x19="0"
                    NOT_FOUND_0x1d="0"
                    NOT_FOUND_0x1e="@+id/tv_24h_change_title"
                    style="@style/Body_3"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                background="@drawable/_2131231483_res_0x7f0802fb"
                padding="8dp"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                backgroundTint="@color/SurfaceSecondary"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="@+id/cl_24h_change">
                <TextView
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    layout_gravity="0x10"
                    id="@+id/tv_total_mentions_title"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_discover_title_total_mentions"
                    maxLines="1"
                    autoSizeTextType="uniform"
                    autoSizeMinTextSize="10sp"
                    NOT_FOUND_0x19="0"
                    NOT_FOUND_0x1d="0"
                    NOT_FOUND_0x1f="0"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textStyle="0x1"
                    textColor="@color/ContentPrimary"
                    layout_gravity="0x10"
                    id="@+id/tv_total_mentions_cap"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    NOT_FOUND_0x1d="0"
                    NOT_FOUND_0x1e="@+id/tv_total_mentions_title"
                    style="@style/Label_2_Bold"/>
                <TextView
                    textStyle="0x1"
                    ellipsize="3"
                    gravity="0x800013"
                    layout_gravity="0x10"
                    id="@+id/tv_total_mentions_percent"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    maxLines="1"
                    layout_marginStart="4dp"
                    autoSizeTextType="uniform"
                    autoSizeMinTextSize="10sp"
                    NOT_FOUND_0x19="0"
                    NOT_FOUND_0x1c="@+id/tv_total_mentions_cap"
                    NOT_FOUND_0x1e="@+id/tv_total_mentions_title"
                    style="@style/Label_2_Medium"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        textColor="@color/ContentSecondary"
        id="@+id/tv_category_desc"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@+id/cl_category_header"
        style="@style/Body_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
