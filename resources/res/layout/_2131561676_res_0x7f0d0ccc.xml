<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/cl_category_detail"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="24dp"
    layout_marginTop="24dp"
    layout_marginRight="24dp"
    layout_marginHorizontal="24dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_category_header"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/cl_start"
            background="@drawable/_2131231483_res_0x7f0802fb"
            layout_width="0dp"
            android:layout_height="0dp"
            backgroundTint="@color/SurfaceSecondary"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="@+id/cl_mid"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1f="0">
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_cap_title"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginLeft="12dp"
                layout_marginTop="12dp"
                layout_marginRight="12dp"
                text="@string/pr_trade_discover_title_market_cap"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeMinTextSize="10sp"
                layout_marginHorizontal="12dp"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1f="0"
                style="@style/Label_3_Regular"/>
            <TextView
                textStyle="0x1"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_cap_content"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginLeft="12dp"
                layout_marginTop="2dp"
                layout_marginRight="12dp"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeMinTextSize="10sp"
                layout_marginHorizontal="12dp"
                NOT_FOUND_0x17="true"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="@+id/tv_cap_title"
                style="@style/Label_1_Medium"/>
            <TextView
                textSize="10sp"
                layout_gravity="0x10"
                id="@+id/tv_cap_percent"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginLeft="12dp"
                layout_marginTop="2dp"
                layout_marginRight="12dp"
                layout_marginHorizontal="12dp"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="@+id/tv_cap_content"
                style="@style/Label_4_Regular"/>
            <o.C41084qkD
                id="@+id/market_cap_chart"
                visibility="1"
                layout_width="-1"
                android:layout_height="40dp"
                layout_marginLeft="0.5dp"
                layout_marginRight="0.5dp"
                layout_marginBottom="0.5dp"
                layout_marginHorizontal="0.5dp"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1d="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/cl_mid"
            background="@drawable/_2131231483_res_0x7f0802fb"
            layout_width="0dp"
            android:layout_height="0dp"
            layout_marginStart="8dp"
            backgroundTint="@color/SurfaceSecondary"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="@+id/cl_end"
            NOT_FOUND_0x1c="@+id/cl_start"
            NOT_FOUND_0x1f="0">
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_volume_title"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginLeft="12dp"
                layout_marginTop="12dp"
                layout_marginRight="12dp"
