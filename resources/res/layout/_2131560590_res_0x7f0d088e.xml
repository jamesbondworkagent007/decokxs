<?xml version="1.0" encoding="utf-8"?>
<android.widget.LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    id="@+id/pay_card"
    tag="layout/item_im_pay_message_0"
    background="@drawable/_2131231486_res_0x7f0802fe"
    paddingLeft="@dimen/padding_8dp"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/padding_8dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="92dp"
    paddingHorizontal="@dimen/padding_8dp"
    paddingVertical="@dimen/padding_12dp">
    <ImageView
        layout_gravity="0x11"
        id="@+id/iv_image"
        padding="@dimen/dp_4"
        layout_width="@dimen/height_40dp"
        android:layout_height="@dimen/height_40dp"
        scaleType="fitStart"
        importantForAccessibility="2"/>
    <android.widget.LinearLayout
        layout_gravity="0x11"
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_weight="1"
        layout_marginStart="@dimen/xsm"
        layout_marginEnd="@dimen/xxxxsm">
        <TextView
            id="@+id/status"
            layout_width="-1"
            android:layout_height="wrap_content"
            style="@style/Label_3_Medium"/>
        <TextView
            ellipsize="3"
            id="@+id/currency"
            paddingTop="@dimen/dp_4"
            paddingBottom="@dimen/dp_4"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            paddingVertical="@dimen/dp_4"
            style="@style/Title_1_Bold"/>
        <TextView
            id="@+id/network"
            layout_width="-1"
            android:layout_height="wrap_content"
            style="@style/Label_4_Regular"/>
    </android.widget.LinearLayout>
</android.widget.LinearLayout>
