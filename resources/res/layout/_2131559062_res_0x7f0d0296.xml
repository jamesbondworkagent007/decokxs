<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <o.C55254xgV
        id="@+id/tabs"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x13="0"/>
    <androidx.viewpager2.widget.ViewPager2
        id="@+id/view_pager"
        layout_width="-1"
        android:layout_height="0dp"
        NOT_FOUND_0x11="@+id/divider_footer"
        NOT_FOUND_0x12="@+id/tabs"/>
    <View
        id="@+id/divider_footer"
        background="@drawable/_2131231808_res_0x7f080440"
        layout_width="-1"
        android:layout_height="0.5dp"
        NOT_FOUND_0x11="@+id/ll_mcap_section"/>
    <LinearLayout
        orientation="0"
        id="@+id/ll_mcap_section"
        paddingLeft="@dimen/margin_default"
        paddingTop="@dimen/xxsm"
        paddingRight="@dimen/margin_default"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_default"
        NOT_FOUND_0x10="0">
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentTertiary"
                    id="@+id/tv_mcap_label"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_3_Regular"/>
                <ImageView
                    layout_width="14dp"
                    android:layout_height="14dp"
                    src="@drawable/_2131231647_res_0x7f08039f"
                    layout_marginStart="4dp"
                    NOT_FOUND_0x14="@color/ContentTertiary"/>
            </LinearLayout>
            <TextView
                id="@+id/tv_mcap_value"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxxsm"
                style="@style/Label_1_Medium"/>
        </LinearLayout>
        <com.github.mikephil.charting.charts.LineChart
            layout_gravity="0x10"
            id="@+id/kline_chart"
            layout_width="@dimen/height_64dp"
            android:layout_height="match_parent"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
