<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.helper.widget.Flow
        id="@+id/flow_1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        NOT_FOUND_0xa="grid_1,grid_2,grid_3"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="8dp"
        NOT_FOUND_0xf="3"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="1"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"/>
    <o.C46466tVj
        id="@+id/grid_1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="@style/TextAppearance.Text.Medium.14SP"/>
    <o.C46466tVj
        id="@+id/grid_2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="@style/TextAppearance.Text.Medium.14SP"/>
    <o.C46466tVj
        id="@+id/grid_3"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="@style/TextAppearance.Text.Medium.14SP"
        NOT_FOUND_0x13="true"/>
    <androidx.constraintlayout.helper.widget.Flow
        id="@+id/flow_2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        NOT_FOUND_0xa="grid_4,grid_5,grid_6"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="8dp"
        NOT_FOUND_0xf="3"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="1"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@+id/flow_1"/>
    <o.C46466tVj
        id="@+id/grid_4"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="@style/TextAppearance.Text.Medium.14SP"/>
    <o.C46466tVj
        id="@+id/grid_5"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="@style/TextAppearance.Text.Medium.14SP"/>
    <o.C46466tVj
        id="@+id/grid_6"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="@style/TextAppearance.Text.Medium.14SP"
        NOT_FOUND_0x13="true"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/grey_g400"
        id="@+id/open_pos_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        text="@string/pr_copytrade_profile_title_bought"
        NOT_FOUND_0x16="@+id/open_pos_time"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@+id/flow_2"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/grey_g400"
        gravity="0x800005"
        id="@+id/open_pos_time"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="8dp"
        NOT_FOUND_0x14="@+id/open_pos_title"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="1"
        NOT_FOUND_0x18="@+id/open_pos_title"
        NOT_FOUND_0x1b="@+id/open_pos_title"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/grey_g400"
        id="@+id/close_pos_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="@string/pr_copytrade_profile_title_sold"
        NOT_FOUND_0x16="@+id/close_pos_time"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@+id/open_pos_title"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/grey_g400"
        gravity="0x800005"
        id="@+id/close_pos_time"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="8dp"
        NOT_FOUND_0x14="@+id/close_pos_title"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="1"
        NOT_FOUND_0x18="@+id/close_pos_title"
        NOT_FOUND_0x1b="@+id/close_pos_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
