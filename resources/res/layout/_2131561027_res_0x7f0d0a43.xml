<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="0"
        layout_width="-1"
        android:layout_height="@dimen/height_72dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/position_activity_layout"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="0.8">
            <View
                id="@+id/centerViewAnchor"
                layout_width="-2"
                android:layout_height="4dp"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="0"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                gravity="0x10"
                id="@+id/position_activity_tv"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0xe="14sp"
                NOT_FOUND_0xf="10sp"
                NOT_FOUND_0x10="1sp"
                NOT_FOUND_0x11="1"
                NOT_FOUND_0x13="@+id/centerViewAnchor"
                NOT_FOUND_0x15="@+id/centerViewAnchor"
                style="@style/TextAppearance.Text.14SP.Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                gravity="0x10"
                id="@+id/position_timestamp_tv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0xe="12sp"
                NOT_FOUND_0xf="8sp"
                NOT_FOUND_0x10="1sp"
                NOT_FOUND_0x11="1"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x15="@+id/centerViewAnchor"
                NOT_FOUND_0x16="@+id/centerViewAnchor"
                style="@style/TextAppearance.Text.12SP"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x11"
            layout_gravity="0x11"
            orientation="1"
            id="@+id/amountLayoutRoot"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginStart="@dimen/dp_8"
            layout_marginEnd="@dimen/margin_8dp">
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x800005"
                layout_gravity="0x11"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginBottom="@dimen/margin_2dp">
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="?attr/defaultProfit"
                    ellipsize="3"
                    gravity="0x800015"
                    id="@+id/position_amount_tv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    layout_weight="0.5"
                    NOT_FOUND_0xe="14sp"
                    NOT_FOUND_0xf="10sp"
                    NOT_FOUND_0x10="1sp"
                    NOT_FOUND_0x11="1"
                    style="@style/TextAppearance.Text.14SP.Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x800015"
            orientation="1"
            layout_width="@dimen/width_0dp"
            android:layout_height="match_parent"
            layout_weight="0.8">
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentPrimary"
                gravity="0x800015"
                layout_gravity="0x10"
                id="@+id/positionTokenValue"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0xe="14sp"
                NOT_FOUND_0xf="10sp"
                NOT_FOUND_0x10="1sp"
                NOT_FOUND_0x11="1"
                style="@style/TextAppearance.Text.14SP.Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                gravity="0x800015"
                layout_gravity="0x10"
                id="@+id/tokenPrice_tv"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                maxLines="1"
                NOT_FOUND_0xe="12sp"
                NOT_FOUND_0xf="8sp"
                NOT_FOUND_0x10="1sp"
                NOT_FOUND_0x11="1"
                style="@style/TextAppearance.Text.12SP"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
