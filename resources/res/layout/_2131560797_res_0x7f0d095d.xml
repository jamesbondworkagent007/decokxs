<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <o.C31909mIk
        orientation="1"
        id="@+id/market_alert_item_swip_layout"
        paddingTop="12dp"
        paddingBottom="12dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="12dp"
        NOT_FOUND_0x29="1">
        <LinearLayout
            gravity="0x11"
            layout_gravity="0x10"
            orientation="1"
            id="@+id/market_alert_delete_container"
            layout_width="-2"
            android:layout_height="match_parent">
            <TextView
                textSize="@dimen/sp_14"
                textColor="#ffffff"
                gravity="0x11"
                id="@+id/market_alert_delete_tv"
                background="@color/SemanticNegative"
                layout_width="-2"
                android:layout_height="match_parent"
                minWidth="72dp"
                text="@string/pr_trade_footer_btn_delete"
                contentDescription="@null"/>
        </LinearLayout>
        <LinearLayout
            orientation="1"
            id="@+id/market_alert_item_container"
            layout_width="-1"
            android:layout_height="wrap_content">
            <RelativeLayout
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <o.wYK
                    id="@+id/checkbox"
                    background="@drawable/_2131232409_res_0x7f080699"
                    visibility="0"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    checked="false"
                    button="@color/transparent"
                    layout_centerVertical="true"
                    drawableStart="@color/transparent"
                    layout_marginEnd="@dimen/dp_10"
                    NOT_FOUND_0x27="@drawable/_2131232409_res_0x7f080699"
                    NOT_FOUND_0x28="-5"/>
                <RelativeLayout
                    background="@drawable/_2131233720_res_0x7f080bb8"
                    paddingLeft="@dimen/dp_12"
                    paddingTop="@dimen/dp_16"
                    paddingRight="@dimen/dp_12"
                    paddingBottom="@dimen/dp_16"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_centerVertical="true"
                    layout_toEndOf="@+id/checkbox"
                    paddingHorizontal="@dimen/dp_12"
                    paddingVertical="@dimen/dp_16">
                    <ImageView
                        id="@+id/icon"
                        background="@color/transparent"
                        visibility="0"
                        layout_width="@dimen/dp_16"
                        android:layout_height="@dimen/dp_16"
                        layout_marginTop="3dp"
                        scaleType="fillCenter"
                        layout_alignTop="@+id/ll_title"/>
                    <LinearLayout
                        gravity="0x10"
                        orientation="0"
                        id="@+id/ll_title"
                        layout_width="-1"
                        android:layout_height="wrap_content"
                        layout_marginStart="@dimen/dp_8"
                        layout_marginEnd="78dp"
                        layout_toEndOf="@+id/icon">
                        <TextView
                            textAppearance="@style/TextAppearance.Text.14SP.Medium"
                            textSize="@dimen/text_size_15sp"
                            textColor="@color/okTradeG900"
                            ellipsize="3"
                            id="@+id/tv_title"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            maxLines="2"
                            style="@style/TextAppearance.Text.14SP.Medium"/>
                        <TextView
                            textSize="@dimen/text_size_15sp"
                            id="@+id/tv_local_price"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            layout_marginStart="5dp"
                            style="@style/TextAppearance.Text"/>
                    </LinearLayout>
                    <TextView
                        textColor="@color/ContentSecondary"
                        id="@+id/tv_custom_msg"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        layout_marginTop="@dimen/margin_4dp"
                        maxLines="2"
                        layout_below="@+id/ll_title"
                        layout_marginStart="@dimen/dp_8"
                        layout_marginEnd="60dp"
                        layout_toEndOf="@+id/icon"
                        style="@style/TextAppearance.Text.12SP.Regular"/>
                    <TextView
                        id="@+id/tv_remind_times"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        layout_marginTop="@dimen/margin_4dp"
                        layout_below="@+id/tv_custom_msg"
                        layout_marginStart="@dimen/dp_8"
                        layout_toEndOf="@+id/icon"
                        style="@style/TextAppearance.Text.12SP"/>
                </RelativeLayout>
                <o.C55239xgG
                    id="@+id/item_switch"
                    background="@drawable/_2131233716_res_0x7f080bb4"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_centerVertical="true"
                    layout_marginEnd="@dimen/ok_dp_12"
                    layout_alignParentEnd="true"
                    NOT_FOUND_0x2a="@color/transparent"
                    NOT_FOUND_0x2b="@color/transparent"/>
            </RelativeLayout>
        </LinearLayout>
    </o.C31909mIk>
    <LinearLayout
        id="@+id/market_alert_item_emptyview_container"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_24"
        layout_marginBottom="@dimen/dp_24"
        layout_marginVertical="@dimen/dp_24">
        <TextView
            textSize="@dimen/text_size_12sp"
            textColor="@color/ContentContrast"
            gravity="0x11"
            layout_gravity="0x11"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_trade_alerts_textarea_no_alerts"/>
    </LinearLayout>
</FrameLayout>
