<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        id="@+id/chain_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        style="@style/Title_2_Bold"/>
    <com.google.android.material.card.MaterialCardView
        id="@+id/address_input_card"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        minHeight="136dp"
        NOT_FOUND_0x14="@color/SurfacePrimary"
        NOT_FOUND_0x15="16dp"
        NOT_FOUND_0x16="0dp"
        NOT_FOUND_0x1e="@android:color/transparent"
        NOT_FOUND_0x1f="1dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            padding="@dimen/padding_24dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            minHeight="136dp">
            <EditText
                textColorHint="@color/ContentDisabled"
                gravity="0x800033"
                id="@+id/etAddress"
                paddingBottom="@dimen/padding_12dp"
                scrollbars="horizontal"
                layout_width="-1"
                android:layout_height="wrap_content"
                minHeight="@dimen/height_40dp"
                hint="@string/pr_wallet_escape_input_placeholder_enter_wallet_address_cdf"
                maxLines="100"
                includeFontPadding="true"
                maxLength="1000000"
                inputType="0xa0001"
                overScrollMode="2"
                NOT_FOUND_0x17="@+id/btnClearOrPaste"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1b="0"
                style="@style/NoUnderlineEditText"/>
            <o.C52794wYp
                id="@+id/btnClearOrPaste"
                layout_width="-2"
                android:layout_height="36dp"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1a="@+id/etAddress"
                NOT_FOUND_0x1c="36"
                NOT_FOUND_0x1d="0x104"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/color_content_danger_default"
        id="@+id/error_tip"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        style="@style/Label_2_Regular"/>
</LinearLayout>
