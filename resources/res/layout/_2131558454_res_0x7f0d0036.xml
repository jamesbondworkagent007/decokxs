    <o.C55055xci
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/grey_g900"
                gravity="0x10"
                background="@color/grey_g200"
                layout_width="-1"
                android:layout_height="24dp"
                text="埋点调试(analytics debugging)"
                drawablePadding="6dp"
                paddingStart="15dp"
                NOT_FOUND_0x16="16dp"
                NOT_FOUND_0x17="16dp"
                style="@style/TextAppearance.Text.12SP"/>
            <RelativeLayout
                layout_width="-1"
                android:layout_height="48dp"
                layout_marginTop="10dp">
                <TextView
