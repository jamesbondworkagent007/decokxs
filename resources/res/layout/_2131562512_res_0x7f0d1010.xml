<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/trade_ui_dialog_spot_dca_make_order_confirm_content_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1">
        <androidx.constraintlayout.widget.ConstraintLayout
            paddingLeft="@dimen/ok_dp_16"
            paddingTop="@dimen/padding_20dp"
            paddingRight="@dimen/ok_dp_16"
            paddingBottom="@dimen/padding_20dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="@dimen/ok_dp_16"
            paddingVertical="@dimen/padding_20dp">
            <TextView
                textAppearance="@style/TextAppearance.Title.14SP.Medium"
                id="@+id/instId"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x22="0"/>
            <TextView
                textSize="@dimen/text_size_12sp"
                textColor="@color/grey_g700"
                id="@+id/type"
                background="@drawable/_2131231013_res_0x7f080125"
                paddingLeft="4dp"
                paddingTop="2dp"
                paddingRight="4dp"
                paddingBottom="2dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_bot_title_spot_dca"
                backgroundTint="@color/background_lv3"
                paddingHorizontal="4dp"
                paddingVertical="2dp"/>
            <TextView
                textSize="@dimen/text_size_12sp"
                textColor="@color/grey_g700"
                id="@+id/reserveFundsFlag"
                background="@drawable/_2131231013_res_0x7f080125"
                paddingLeft="4dp"
                paddingTop="2dp"
                paddingRight="4dp"
                paddingBottom="2dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                backgroundTint="@color/background_lv3"
                paddingHorizontal="4dp"
                paddingVertical="2dp"/>
            <androidx.constraintlayout.helper.widget.Flow
                id="@+id/botTagFlow"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                NOT_FOUND_0x1a="type, reserveFundsFlag"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="@dimen/padding_6dp"
                NOT_FOUND_0x1d="2"
                NOT_FOUND_0x1e="@dimen/padding_4dp"
                NOT_FOUND_0x1f="1"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x21="@+id/instId"/>
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/contentRv"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_20dp"
                overScrollMode="2"
                NOT_FOUND_0x21="@+id/botTagFlow"/>
            <LinearLayout
                orientation="1"
                id="@+id/reminderLay"
                layout_width="-1"
                android:layout_height="wrap_content"
                showDividers="middle"
                NOT_FOUND_0x21="@+id/contentRv">
                <View
                    id="@+id/view_line"
                    layout_marginTop="11dp"
                    style="@style/WidgetDivisionLine"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.12SP"
                    textColor="@color/okTradeG400"
                    ellipsize="3"
                    id="@+id/fundNotice"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="16dp"
                    text="@string/pr_dcabot_orderconfirm_modal_funds_notice"
                    maxLines="2"
                    lineSpacingExtra="2dp"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.12SP"
                    textColor="@color/okTradeG400"
                    id="@+id/riskNotice"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="16dp"
                    text="@string/pr_dcabot_orderconfirm_modal_risks_notice"
                    lineSpacingExtra="2dp"/>
                <TextView
                    textAppearance="@style/TextAppearance.Blue.12SP"
                    id="@+id/expand"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="8dp"
                    text="@string/pr_trade_strategy_header_view_more"/>
            </LinearLayout>
            <o.wYK
                theme="@style/OKUITheme"
                textColor="@color/okTradeG900"
                id="@+id/check_no_show"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="14dp"
                text="@string/pr_options_alert_not_tips"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x21="@+id/reminderLay"
                NOT_FOUND_0x23="-4"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
