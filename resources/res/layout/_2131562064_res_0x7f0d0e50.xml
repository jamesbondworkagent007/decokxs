<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="32dp"
    paddingStart="@dimen/dp24"
    paddingEnd="@dimen/dp24">
    <TextView
        textAppearance="@style/TextAppearance.Hint.12SP"
        id="@+id/strike"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="2"
        drawablePadding="5dp"
        drawableEnd="@drawable/_2131232756_res_0x7f0807f4"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="80dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginStart="86dp"
        layout_marginEnd="100dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/strike"
        NOT_FOUND_0x11="0">
        <FrameLayout
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0xe="0"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x13="0.48">
            <TextView
                textAppearance="@style/TextAppearance.Hint.12SP"
                id="@+id/type"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="2"
                drawablePadding="5dp"
                drawableEnd="@drawable/_2131232756_res_0x7f0807f4"/>
        </FrameLayout>
        <com.okinc.core.widget.SortTextView
            textAppearance="@style/TextAppearance.Hint.12SP"
            gravity="0x800005"
            id="@+id/price"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxWidth="@dimen/width_100dp"
            maxLines="2"
            NOT_FOUND_0xe="0"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x13="0.48"
            NOT_FOUND_0x14="0"
            style="@style/SortTextView"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.okinc.core.widget.SortTextView
        textAppearance="@style/TextAppearance.Hint.12SP"
        id="@+id/change"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="2"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="84dp"
        NOT_FOUND_0x14="0"
        style="@style/SortTextView"/>
</androidx.constraintlayout.widget.ConstraintLayout>
