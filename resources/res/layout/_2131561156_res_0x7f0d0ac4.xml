<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/bs_item_layout"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="?attr/bottomSheetItemHeaderTextColor"
        id="@+id/bs_header_text"
        paddingTop="16dp"
        paddingBottom="16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="?attr/dialogPageMargin"
        layout_marginRight="?attr/dialogPageMargin"
        layout_marginHorizontal="?attr/dialogPageMargin"
        paddingVertical="16dp"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0"
        style="@style/TextAppearance.Text.Medium.14SP"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        id="@+id/bs_content_layout"
        paddingTop="16dp"
        paddingBottom="16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="?attr/dialogPageMargin"
        layout_marginRight="?attr/dialogPageMargin"
        minHeight="@dimen/height_56dp"
        layout_marginHorizontal="?attr/dialogPageMargin"
        paddingVertical="16dp"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0">
        <ImageView
            id="@+id/bs_content_thumbnail"
            visibility="2"
            layout_width="62dp"
            android:layout_height="40dp"
            src="@drawable/_2131232579_res_0x7f080743"
            layout_marginEnd="@dimen/margin_16dp"/>
        <o.C42513rVq
            id="@+id/bs_content_country_flag"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginEnd="@dimen/dp_8"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_gravity="0x10"
            id="@+id/bs_content_sublayout"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <o.C55251xgS
                ellipsize="3"
                id="@+id/bs_content_badge"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x18="true"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="0dp"
                NOT_FOUND_0x22="?attr/tag_positiveFillBackgroundTint"
                NOT_FOUND_0x23="1"
                NOT_FOUND_0x24="7"/>
            <TextView
                textColor="?attr/primaryTextColor"
                id="@+id/bs_content_text"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                NOT_FOUND_0x18="true"
                NOT_FOUND_0x1a="@+id/bs_content_tip"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="@+id/bs_content_badge"
                NOT_FOUND_0x20="0dp"
                NOT_FOUND_0x21="0dp"
                style="@style/TextAppearance.Text.16SP"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/bs_content_tip"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                NOT_FOUND_0x18="true"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="@+id/bs_content_text"
                NOT_FOUND_0x20="0dp"
                NOT_FOUND_0x21="0dp"
                style="@style/TextAppearance.Text.12SP"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <ImageView
            layout_gravity="0x10"
            id="@+id/bs_content_selected_icon"
            visibility="2"
            layout_width="18dp"
            android:layout_height="18dp"
            src="@drawable/_2131232680_res_0x7f0807a8"
            layout_marginStart="@dimen/margin_16dp"/>
        <ImageView
            layout_gravity="0x10"
            id="@+id/bs_content_arrow"
            visibility="2"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131232355_res_0x7f080663"
            layout_marginStart="@dimen/margin_16dp"
            NOT_FOUND_0x25="@color/ContentContrast"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <LinearLayout
        orientation="1"
        id="@+id/ll_add_exchange"
        paddingBottom="14dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="?attr/dialogPageMargin"
        layout_marginRight="?attr/dialogPageMargin"
        layout_marginHorizontal="?attr/dialogPageMargin"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0">
        <TextView
            textSize="@dimen/sp_14"
            textColor="@color/grey_g400"
            id="@+id/tv_add_code_title"
            paddingBottom="@dimen/padding_8dp"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <TextView
            textSize="@dimen/text_size_16sp"
            textColor="@color/grey_g900"
            id="@+id/tv_add_code"
            paddingTop="@dimen/padding_16dp"
            paddingBottom="@dimen/padding_16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingVertical="@dimen/padding_16dp"/>
        <View
            id="@+id/line_code"
            background="@color/grey_g100"
            layout_width="-2"
            android:layout_height="@dimen/height_0.5dp"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginBottom="@dimen/margin_10dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
