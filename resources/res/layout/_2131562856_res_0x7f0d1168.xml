<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/contentContainer"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="24dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/coinName">
        <o.C21260gwR
            textSize="36sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/coinCount"
            paddingLeft="0dp"
            paddingRight="0dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            includeFontPadding="false"
            paddingHorizontal="0dp"
            NOT_FOUND_0x19="false"
            NOT_FOUND_0x1a="250"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/valuation"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            includeFontPadding="false"/>
        <androidx.constraintlayout.helper.widget.Flow
            id="@+id/flow"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0xd="coinCount,valuation"
            NOT_FOUND_0xe="0"
            NOT_FOUND_0xf="8dp"
            NOT_FOUND_0x10="2"
            NOT_FOUND_0x11="2"
            NOT_FOUND_0x12="4dp"
            NOT_FOUND_0x13="1"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
