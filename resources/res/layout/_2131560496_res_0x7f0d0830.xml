<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/content_constraint_layout"
    tag="layout/item_edit_card_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        visibility="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <FrameLayout
            id="@+id/icon_layout"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginEnd="@dimen/margin_16dp">
            <ImageView
                id="@+id/content_icon"
                visibility="2"
                layout_width="24dp"
                android:layout_height="@dimen/height_24dp"
                src="@drawable/_2131232836_res_0x7f080844"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP.Medium"
                textColor="@color/primary_black"
                gravity="0x11"
                id="@+id/content_step"
                background="@drawable/_2131234013_res_0x7f080cdd"
                visibility="2"
                layout_width="-2"
                android:layout_height="24dp"
                minWidth="24dp"/>
        </FrameLayout>
        <LinearLayout
            orientation="1"
            id="@+id/container"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"/>
        <ImageView
            layout_gravity="0x10"
            id="@+id/arrow"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/dp24"
            src="@drawable/_2131232354_res_0x7f080662"/>
        <LinearLayout
            layout_gravity="0x10"
            orientation="0"
            id="@+id/right_cta_container"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/dp24"/>
    </LinearLayout>
    <LinearLayout
        layout_gravity="0x10"
        orientation="0"
        id="@+id/bottom_cta_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"/>
    <TextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/color_content_danger_default"
        id="@+id/errorText"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="14sp"/>
</LinearLayout>
