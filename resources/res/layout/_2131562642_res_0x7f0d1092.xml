<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-2"
    android:layout_height="wrap_content"
    contentDescription="OKCoachMark">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/totalContentView"
        paddingLeft="4dp"
        paddingTop="8dp"
        paddingRight="4dp"
        paddingBottom="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="4dp"
        paddingVertical="8dp">
        <LinearLayout
            id="@+id/contentView"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="218dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/bodyContent"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textAppearance="@style/OKTextFont.Bold"
                    textSize="16sp"
                    textColor="@color/color_content_static_default"
                    id="@+id/tv_title"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    textAlignment="5"
                    NOT_FOUND_0x18="0"
                    NOT_FOUND_0x19="0"
                    NOT_FOUND_0x1b="0"/>
                <ImageView
                    id="@+id/iv_dismiss"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    src="@drawable/_2131231675_res_0x7f0803bb"
                    contentDescription="OKCoachMarkBtnClose"
                    layout_alignParentEnd="true"
                    NOT_FOUND_0x18="0"
                    NOT_FOUND_0x1b="0"
                    NOT_FOUND_0x1f="@color/ContentTertiary"/>
                <TextView
                    textAppearance="@style/OKTextFont.Regular"
                    textSize="14sp"
                    textColor="@color/color_content_static_default"
                    id="@+id/tv_content"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="8dp"
                    textAlignment="5"
                    lineHeight="22dp"
                    NOT_FOUND_0x19="0"
                    NOT_FOUND_0x1a="@+id/tv_title"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
        <RelativeLayout
            id="@+id/rl_action"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="@+id/contentView"
            NOT_FOUND_0x1c="218dp">
            <TextView
                textAppearance="@style/OKTextFont.Regular"
                textSize="@dimen/text_size_14sp"
                textColor="@color/color_content_static_subtle"
                id="@+id/tv_step"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_alignParentStart="true"/>
            <o.C52794wYp
                id="@+id/btn_secondary"
                padding="5dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                contentDescription="OKCoachMarkBtnSecondary"
                layout_marginEnd="10dp"
                layout_toStartOf="@+id/btn_primary"
                NOT_FOUND_0x1d="28"
                NOT_FOUND_0x1e="0x104"/>
            <o.C52794wYp
                id="@+id/btn_primary"
                padding="5dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                contentDescription="OKCoachMarkBtnPrimary"
                layout_alignParentEnd="true"
                NOT_FOUND_0x1d="28"
                NOT_FOUND_0x1e="0x103"/>
        </RelativeLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
