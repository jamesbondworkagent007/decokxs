<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/tactics_recurring_price_range_item_0"
    paddingTop="12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/title_left_ll"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="true"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/title_gap"
            NOT_FOUND_0x18="1"
            NOT_FOUND_0x19="1"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="0">
            <ImageView
                id="@+id/iv_coin"
                layout_width="20dp"
                android:layout_height="20dp"
                scaleType="fillCenter"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0"/>
            <TextView
                textAppearance="@style/Body_3"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/coin_tv"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_marginStart="4dp"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x1a="@+id/iv_coin"
                NOT_FOUND_0x1c="0"/>
        </LinearLayout>
        <TextView
            textAppearance="@style/Body_2"
            gravity="0x11"
            id="@+id/title_gap"
            layout_width="16dp"
            android:layout_height="wrap_content"
            layout_marginLeft="12dp"
            layout_marginRight="12dp"
            layout_marginHorizontal="12dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/title_left_ll"
            NOT_FOUND_0x1a="@+id/tv_coin_price"
            NOT_FOUND_0x1c="0"/>
        <TextView
            textAppearance="@style/Body_3"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_coin_price"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            singleLine="true"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x19="1"
            NOT_FOUND_0x1a="@+id/title_gap"
            NOT_FOUND_0x1c="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp">
        <o.C47988uAv
            id="@+id/min_price_input"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/price_gap"
            NOT_FOUND_0x18="1"
            NOT_FOUND_0x19="1"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="1"/>
        <TextView
            textAppearance="@style/Body_2"
            gravity="0x11"
            id="@+id/price_gap"
            layout_width="8dp"
            android:layout_height="wrap_content"
            layout_marginLeft="12dp"
            layout_marginRight="12dp"
            text="-"
            layout_marginHorizontal="12dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="@+id/max_price_input"
            NOT_FOUND_0x1a="@+id/min_price_input"
            NOT_FOUND_0x1c="0"/>
        <o.C47988uAv
            id="@+id/max_price_input"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x19="1"
            NOT_FOUND_0x1a="@+id/price_gap"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        textAppearance="@style/Body_4"
        textColor="@color/SemanticNegative"
        gravity="0x11"
        id="@+id/err_tips"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_recurbot_placeorder_errortext_upper_limit_price_must"/>
</LinearLayout>
