<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        textAppearance="@style/TextAppearance.Text.16SP"
        gravity="0x11"
        orientation="1"
        id="@+id/group_invalid_input_state_banner"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <View
            background="@color/grey_g100"
            layout_width="-1"
            android:layout_height="@dimen/height_0.5dp"/>
        <TextView
            gravity="0x11"
            id="@+id/tv_group_invalid_input_state_banner"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            layout_marginBottom="12dp"
            minHeight="44dp"
            text="@string/pr_message_group_textarea_no_longer_member"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
    <LinearLayout
        textAppearance="@style/TextAppearance.Text.16SP"
        gravity="0x11"
        orientation="1"
        id="@+id/group_muted_input_state_banner"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <View
            background="@color/grey_g100"
            layout_width="-1"
            android:layout_height="@dimen/height_0.5dp"/>
        <TextView
            gravity="0x11"
            id="@+id/group_muted_banner"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            layout_marginBottom="12dp"
            minHeight="44dp"
            text="@string/pr_message_vip_warning_text_no_longer_send_msg"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
</FrameLayout>
