<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/okTradeG900"
        id="@+id/tv_cycle"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/common_page_edge_space"
        NOT_FOUND_0x24="0"
        NOT_FOUND_0x26="0"/>
    <o.C49946uyD
        id="@+id/adl"
        layout_width="24dp"
        android:layout_height="20dp"
        layout_marginStart="@dimen/common_page_edge_space"
        NOT_FOUND_0x18="@{positionsItem.adl}"
        NOT_FOUND_0x19="@color/okTradeG100"
        NOT_FOUND_0x1a="8dp"
        NOT_FOUND_0x1b="@color/SemanticNegative"
        NOT_FOUND_0x1c="@color/SemanticPositive"
        NOT_FOUND_0x1d="2dp"
        NOT_FOUND_0x1e="@color/SemanticNotice"
        NOT_FOUND_0x1f="2dp"
        NOT_FOUND_0x20="5"
        NOT_FOUND_0x22="@+id/rcv_view"
        NOT_FOUND_0x24="0"
        NOT_FOUND_0x25="@+id/tv_cycle"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcv_view"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/common_page_edge_space"
        layout_marginRight="@dimen/common_page_edge_space"
        layout_marginBottom="12dp"
        touchscreenBlocksFocus="false"
        layout_marginHorizontal="@dimen/common_page_edge_space"
        NOT_FOUND_0x21="true"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x24="0"
        NOT_FOUND_0x25="@+id/adl"
        NOT_FOUND_0x27="0"/>
    <LinearLayout
        orientation="0"
        id="@+id/ll_button"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/common_page_edge_space"
        layout_marginTop="16dp"
        layout_marginRight="@dimen/common_page_edge_space"
        layout_marginHorizontal="@dimen/common_page_edge_space"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x24="0"
        NOT_FOUND_0x25="@+id/rcv_view">
        <o.C52794wYp
            textSize="@dimen/sp_14"
            ellipsize="3"
            gravity="0x11"
            id="@+id/btn_close"
            paddingLeft="8dp"
            paddingRight="8dp"
            visibility="0"
            layout_width="0dp"
            android:layout_height="match_parent"
            text="@string/pr_trade_futuresgrid_btn_close"
            maxLines="2"
            layout_weight="1"
            paddingHorizontal="8dp"
            NOT_FOUND_0x28="-1"
            NOT_FOUND_0x29="28"
            NOT_FOUND_0x2a="0x104"/>
        <o.C52794wYp
            textSize="@dimen/sp_14"
            ellipsize="3"
            gravity="0x11"
            id="@+id/btn_close_all"
            paddingLeft="8dp"
            paddingRight="8dp"
            visibility="0"
            layout_width="0dp"
            android:layout_height="match_parent"
            text="@string/pr_trade_futuresgrid_btn_close_all"
            maxLines="2"
            layout_weight="1"
            layout_marginStart="8dp"
            paddingHorizontal="8dp"
            NOT_FOUND_0x28="-1"
            NOT_FOUND_0x29="28"
            NOT_FOUND_0x2a="0x104"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
