<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="1"
    paddingTop="@dimen/padding_8dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        id="@+id/explain_item_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        textAlignment="5"
        style="@style/Label_1_Bold"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentTertiary"
        id="@+id/explain_item_content"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        textAlignment="5"
        style="@style/Body_3_Regular"/>
</LinearLayout>
