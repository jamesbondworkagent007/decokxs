<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="12dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="match_parent"
    fillViewport="true"
    paddingVertical="12dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-2"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            layout_width="-1"
            android:layout_height="match_parent"
            fillViewport="true"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0">
            <TableLayout
                orientation="1"
                id="@+id/tableLayout"
                layout_width="-2"
                android:layout_height="match_parent"
                layout_marginLeft="@dimen/margin_default"
                layout_marginRight="@dimen/margin_default"
                layout_marginHorizontal="@dimen/margin_default">
                <TableRow
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    divider="@drawable/_2131231434_res_0x7f0802ca"
                    showDividers="middle"
                    NOT_FOUND_0x13="0"
                    NOT_FOUND_0x14="0"
                    NOT_FOUND_0x15="0">
                    <TextView
                        textAppearance="@style/TextAppearance.Text.12SP.Regular"
                        textColor="@color/ContentContrast"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxWidth="80dp"
                        text="@string/pr_dcabot_orderdetails_header_order_type"/>
                    <o.C55258xgZ
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxWidth="145dp"
                        NOT_FOUND_0x16="1"
                        NOT_FOUND_0x17="@color/ContentContrast"
                        NOT_FOUND_0x18="@string/pr_dcabot_orderdetails_header_order_price_n_deviation"
                        NOT_FOUND_0x19="@style/TextAppearance.Text.12SP.Regular"
                        NOT_FOUND_0x1a="0"/>
                    <o.C55258xgZ
                        id="@+id/orderAmountTitleLabel"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxWidth="80dp"
                        NOT_FOUND_0x16="1"
                        NOT_FOUND_0x17="@color/ContentContrast"
                        NOT_FOUND_0x18="@string/pr_dcabot_orderdetails_title_order_amount"
                        NOT_FOUND_0x19="@style/TextAppearance.Text.12SP.Regular"
                        NOT_FOUND_0x1a="0"/>
                    <TextView
                        textAppearance="@style/TextAppearance.Text.12SP.Regular"
                        textColor="@color/ContentContrast"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxWidth="80dp"
                        text="@string/pr_dcabot_orderdetail_colheader_avg_cost"/>
                    <o.C55258xgZ
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxWidth="80dp"
                        NOT_FOUND_0x16="1"
                        NOT_FOUND_0x17="@color/ContentContrast"
                        NOT_FOUND_0x18="@string/pr_dcabot_placeorder_title_take_profit_setting"
                        NOT_FOUND_0x19="@style/TextAppearance.Text.12SP.Regular"
                        NOT_FOUND_0x1a="0"/>
                    <TextView
                        textAppearance="@style/TextAppearance.Text.12SP.Regular"
                        textColor="@color/ContentContrast"
                        id="@+id/liqPriceTv"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxWidth="145dp"
                        text="@string/pr_trade_botdetails_colheader_est_liq_price"/>
                    <TextView
                        textAppearance="@style/TextAppearance.Text.12SP.Regular"
                        textColor="@color/ContentContrast"
                        id="@+id/leverTv"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxWidth="145dp"
                        text="@string/pr_fdcabot_orderdetail_item_actual_leverage"/>
                    <TextView
                        textAppearance="@style/TextAppearance.Text.12SP.Regular"
                        textColor="@color/ContentContrast"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxWidth="145dp"
                        text="@string/pr_dcabot_orderdetails_header_change_pct_tp"/>
                </TableRow>
            </TableLayout>
        </androidx.core.widget.NestedScrollView>
        <LinearLayout
            id="@+id/headerRow"
            background="@color/background_BasePrimary_BaseSecondary"
            paddingBottom="12dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            divider="@drawable/_2131231434_res_0x7f0802ca"
            showDividers="middle"
            layout_marginStart="@dimen/margin_default"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0">
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="80dp"
                text="@string/pr_dcabot_orderdetails_header_order_type"/>
            <o.C55258xgZ
                id="@+id/orderPriceNDeviationLabel"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="145dp"
                NOT_FOUND_0x16="1"
                NOT_FOUND_0x17="@color/ContentContrast"
                NOT_FOUND_0x18="@string/pr_dcabot_orderdetails_header_order_price_n_deviation"
                NOT_FOUND_0x19="@style/TextAppearance.Text.12SP.Regular"
                NOT_FOUND_0x1a="0"/>
            <o.C55258xgZ
                id="@+id/orderAmountLabel"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="80dp"
                NOT_FOUND_0x16="1"
                NOT_FOUND_0x17="@color/ContentContrast"
                NOT_FOUND_0x18="@string/pr_dcabot_orderdetails_title_order_amount"
                NOT_FOUND_0x19="@style/TextAppearance.Text.12SP.Regular"
                NOT_FOUND_0x1a="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="80dp"
                text="@string/pr_dcabot_orderdetail_colheader_avg_cost"/>
            <o.C55258xgZ
                id="@+id/tpPriceLabel"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="80dp"
                NOT_FOUND_0x16="1"
                NOT_FOUND_0x17="@color/ContentContrast"
                NOT_FOUND_0x18="@string/pr_dcabot_placeorder_title_take_profit_setting"
                NOT_FOUND_0x19="@style/TextAppearance.Text.12SP.Regular"
                NOT_FOUND_0x1a="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="145dp"
                text="@string/pr_trade_botdetails_colheader_est_liq_price"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="145dp"
                text="@string/pr_fdcabot_orderdetail_item_actual_leverage"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="145dp"
                text="@string/pr_dcabot_orderdetails_header_change_pct_tp"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</HorizontalScrollView>
