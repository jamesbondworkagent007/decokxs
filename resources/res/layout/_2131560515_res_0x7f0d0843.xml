<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="66dp">
    <TextView
        textAppearance="@style/TextAppearance.TitleWhite.12SP.Medium"
        gravity="0x11"
        id="@+id/head"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <o.C45607stI
        id="@+id/line_dash"
        layout_width="1dp"
        android:layout_height="0dp"
        layerType="1"
        NOT_FOUND_0xa="4dp"
        NOT_FOUND_0xb="4dp"
        NOT_FOUND_0xc="1dp"
        NOT_FOUND_0xd="@color/grey_g300"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/head"
        NOT_FOUND_0x12="@+id/head"
        NOT_FOUND_0x13="@+id/head"/>
    <View
        id="@+id/line_solid"
        background="@drawable/_2131232214_res_0x7f0805d6"
        layout_width="1dp"
        android:layout_height="0dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/head"
        NOT_FOUND_0x12="@+id/head"
        NOT_FOUND_0x13="@+id/head"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        id="@+id/status"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/common_page_edge_space"
        NOT_FOUND_0x11="@+id/head"
        NOT_FOUND_0x14="@+id/head"/>
    <TextView
        textAppearance="@style/TextAppearance.Hint.12SP"
        id="@+id/time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_6dp"
        NOT_FOUND_0x12="@+id/status"
        NOT_FOUND_0x13="@+id/status"/>
</androidx.constraintlayout.widget.ConstraintLayout>
