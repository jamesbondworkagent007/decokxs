<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <o.C33537myN
        id="@+id/app_bar"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <ScrollView
        layout_width="-1"
        android:layout_height="0dp"
        fillViewport="true"
        layout_weight="1">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textAppearance="@style/Headline_4_Bold"
                textColor="@color/ContentPrimary"
                id="@+id/tv_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="24dp"
                layout_marginTop="12dp"
                layout_marginRight="24dp"
                text="@string/pr_trade_cedefi_header_authorize_with_old_passkey"
                layout_marginHorizontal="24dp"
                NOT_FOUND_0x12="0"/>
            <TextView
                textAppearance="@style/Body_2_Regular"
                textColor="@color/ContentTertiary"
                id="@+id/tv_desc"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="24dp"
                layout_marginTop="8dp"
                layout_marginRight="24dp"
                text="@string/pr_trade_cedefi_desc_authorize_with_old_passkey"
                layout_marginHorizontal="24dp"
                NOT_FOUND_0x11="@+id/tv_title"/>
            <ImageView
                id="@+id/iv_qr_code"
                layout_width="-1"
                android:layout_height="0dp"
                layout_marginLeft="15dp"
                layout_marginTop="32dp"
                layout_marginRight="15dp"
                layout_marginHorizontal="15dp"
                NOT_FOUND_0x10="1:1"
                NOT_FOUND_0x11="@+id/tv_desc"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
    <o.C52794wYp
        id="@+id/btn"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="16dp"
        layout_marginRight="24dp"
        layout_marginBottom="16dp"
        text="@string/pr_trade_cedefi_btn_ive_scanned_qr"
        layout_marginHorizontal="24dp"
        layout_marginVertical="16dp"
        NOT_FOUND_0x13="52"
        NOT_FOUND_0x14="0x101"/>
    <TextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentTertiary"
        gravity="0x1"
        id="@+id/tv_recovery"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_8dp"
        layout_marginHorizontal="@dimen/margin_16dp"/>
</LinearLayout>
