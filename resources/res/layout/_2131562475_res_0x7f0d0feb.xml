<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/avail_container_cl"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/available_title_lry"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x17="@+id/available_text_ll"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="0">
        <o.C55320xhi
            textAppearance="@style/TextAppearance.Text.12SP"
            textSize="12sp"
            textColor="@color/ContentContrast"
            layout_gravity="0x10"
            id="@+id/available_title_tv"
            layout_width="-2"
            android:layout_height="wrap_content"
            fontFamily="@font/harmony_sans_regular"
            textFontWeight="400"
            NOT_FOUND_0x1d="@color/ContentContrast"/>
        <ImageView
            layout_gravity="0x10"
            id="@+id/iv_available"
            visibility="2"
            layout_width="-2"
            android:layout_height="16dp"
            src="@drawable/_2131231649_res_0x7f0803a1"
            paddingEnd="8dp"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/available_text_ll"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingStart="4dp"
        NOT_FOUND_0x15="@+id/available_title_lry"
        NOT_FOUND_0x17="@+id/available_icon_fl"
        NOT_FOUND_0x1b="@+id/available_title_lry">
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textSize="12sp"
            textColor="@color/ContentSecondary"
            ellipsize="3"
            layout_gravity="0x10"
            id="@+id/available_text_tv"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            fontFamily="@font/harmony_sans_regular"
            textFontWeight="400"/>
        <FrameLayout
            id="@+id/available_iso_transfer_fly"
            paddingTop="6dp"
            paddingBottom="6dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_weight="0"
            paddingStart="4dp"
            paddingEnd="4dp"
            NOT_FOUND_0x15="@+id/available_text_tv"
            NOT_FOUND_0x19="@+id/available_text_tv"
            NOT_FOUND_0x1b="@+id/available_text_tv">
            <ImageView
                id="@+id/available_iv"
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131234226_res_0x7f080db2"
                NOT_FOUND_0x1c="@color/ContentPrimary"/>
        </FrameLayout>
    </LinearLayout>
    <FrameLayout
        id="@+id/available_icon_fl"
        background="?attr/selectableItemBackgroundBorderless"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingStart="2dp"
        NOT_FOUND_0x15="@+id/available_title_lry"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1b="@+id/available_title_lry">
        <ImageView
            layout_gravity="0x10"
            id="@+id/available_icon_iv"
            layout_width="14dp"
            android:layout_height="14dp"
            src="@drawable/_2131233688_res_0x7f080b98"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
