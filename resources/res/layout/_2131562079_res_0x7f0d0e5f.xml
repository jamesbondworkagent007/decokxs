<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/margin_8dp"
    paddingBottom="@dimen/padding_32dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_24dp"
    layout_marginRight="@dimen/margin_24dp"
    layout_marginHorizontal="@dimen/margin_24dp">
    <ImageView
        layout_gravity="0x11"
        id="@+id/builtInPasskeyBottomSheetIllustration"
        layout_width="136dp"
        android:layout_height="136dp"
        contentDescription="builtInPasskeyBottomSheetIllustration"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <TextView
        textSize="@dimen/text_size_24sp"
        textColor="@color/ContentPrimary"
        gravity="0x11"
        id="@+id/passkeyBottomSheetHeader"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        contentDescription="passkeyBottomSheetHeader"
        textAlignment="4"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/builtInPasskeyBottomSheetIllustration"
        NOT_FOUND_0x14="@dimen/text_size_28sp"
        style="@style/Headline_5_Bold"/>
    <TextView
        textSize="@dimen/font_16"
        textColor="@color/ContentSecondary"
        gravity="0x11"
        id="@+id/passkeyBottomSheetContent"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_account_passkey_bttmsheet_title_quick_tip"
        contentDescription="passkeyBottomSheetContent"
        textAlignment="4"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/passkeyBottomSheetHeader"
        NOT_FOUND_0x14="@dimen/text_size_24sp"
        style="@style/Body_2_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
