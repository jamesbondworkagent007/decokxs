<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_select_dialog_item_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/choice_ly"
        background="@drawable/_2131231183_res_0x7f0801cf"
        paddingLeft="16dp"
        paddingTop="@dimen/padding_20dp"
        paddingRight="8dp"
        paddingBottom="@dimen/padding_20dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="60dp"
        paddingVertical="@dimen/padding_20dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <ImageView
                id="@+id/image"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="4dp"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/title"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Text.16SP"/>
            <TextView
                textSize="16sp"
                textColor="@color/ContentTertiary"
                id="@+id/subTitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                lineSpacingMultiplier="1.35"
                style="@style/Body_2_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <ImageView
            id="@+id/arrow"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232984_res_0x7f0808d8"
            NOT_FOUND_0x17="@color/ContentTertiary"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        textColor="@color/ContentInverse"
        layout_gravity="0x5"
        id="@+id/choice_tag"
        background="@drawable/_2131231184_res_0x7f0801d0"
        paddingLeft="8dp"
        paddingTop="4dp"
        paddingRight="8dp"
        paddingBottom="4dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingHorizontal="8dp"
        paddingVertical="4dp"
        style="@style/Label_3_Bold"/>
</FrameLayout>
