<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/headerLayout"
    tag="layout/dfragment_okt_bottom_sheet_header_white_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/topBg"
        background="@drawable/_2131231036_res_0x7f08013c"
        layout_width="-1"
        android:layout_height="0dp"
        NOT_FOUND_0xc="@+id/bottomSpace"
        NOT_FOUND_0x11="0"/>
    <ImageView
        id="@+id/topClose"
        background="?android:attr/selectableItemBackground"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232380_res_0x7f08067c"
        layout_marginEnd="14dp"
        NOT_FOUND_0xc="@+id/title"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x11="@+id/title"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textSize="16sp"
        textStyle="0x1"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        layout_marginStart="16dp"
        NOT_FOUND_0xe="@+id/topClose"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"/>
    <View
        id="@+id/topBottomSpace"
        layout_width="-1"
        android:layout_height="12dp"
        NOT_FOUND_0x10="@+id/title"/>
    <View
        id="@+id/v_divider"
        background="@color/okTradeG100"
        layout_width="-1"
        android:layout_height="1px"
        NOT_FOUND_0x10="@+id/topBottomSpace"/>
    <View
        id="@+id/bottomSpace"
        layout_width="-1"
        android:layout_height="8dp"
        NOT_FOUND_0x10="@+id/v_divider"/>
</androidx.constraintlayout.widget.ConstraintLayout>
