<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingTop="@dimen/margin_6dp"
    paddingBottom="@dimen/margin_6dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="56dp"
    paddingVertical="@dimen/margin_6dp">
    <TextView
        textColor="@color/ContentPrimary_Dark"
        ellipsize="3"
        id="@+id/tv_token_symbol"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxLines="1"
        style="@style/Label_3_Medium"/>
    <TextView
        textColor="@color/ContentPrimary_Dark"
        ellipsize="3"
        id="@+id/tv_balance"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxLines="1"
        style="@style/Label_3_Bold"/>
    <TextView
        textColor="@color/ContentPrimary_Dark"
        ellipsize="3"
        id="@+id/tv_pnl"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxLines="1"
        style="@style/Label_4_Regular"/>
</LinearLayout>
