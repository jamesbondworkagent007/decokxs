<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/view_depth_ticker_info_item_0"
    paddingTop="4dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideLine"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="0.6"/>
    <TextView
        textSize="10sp"
        textColor="@color/okTradeG400"
        ellipsize="3"
        id="@+id/title"
        tag="binding_1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        drawablePadding="4dp"
        textAlignment="5"
        NOT_FOUND_0x14="@+id/guideLine"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.10SP.Regular"
        textSize="10sp"
        textColor="@color/okTradeG700"
        gravity="0x800005"
        id="@+id/content"
        tag="binding_2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        autoSizeTextType="uniform"
        autoSizeStepGranularity="1sp"
        autoSizeMinTextSize="5sp"
        autoSizeMaxTextSize="10sp"
        NOT_FOUND_0x12="@+id/title"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="@+id/guideLine"
        NOT_FOUND_0x18="@+id/title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
