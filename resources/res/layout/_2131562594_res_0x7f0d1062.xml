<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x11"
    orientation="1"
    tag="layout/trade_ui_tactics_rec_info_detail_item_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/common_page_edge_space"
    layout_marginRight="@dimen/common_page_edge_space"
    layout_marginHorizontal="@dimen/common_page_edge_space">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x16="true"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="0">
            <ImageView
                id="@+id/iv_coin"
                layout_width="20dp"
                android:layout_height="20dp"
                scaleType="fillCenter"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"/>
            <TextView
                textAppearance="@style/Body_3"
                textColor="@color/ContentPrimary"
                layout_gravity="0x10"
                id="@+id/coin_tv"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="4dp"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1b="@+id/iv_coin"
                NOT_FOUND_0x1d="0"/>
            <TextView
                textAppearance="@style/Body_3"
                textColor="@color/BorderSecondary"
                layout_gravity="0x10"
                id="@+id/divider"
                layout_width="2dp"
                android:layout_height="wrap_content"
                text="|"
                layout_marginStart="8dp"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1b="@+id/coin_tv"
                NOT_FOUND_0x1d="0"/>
            <TextView
                textAppearance="@style/Body_3"
                textColor="@color/ContentPrimary"
                layout_gravity="0x10"
                id="@+id/percent_tv"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="8dp"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1b="@+id/divider"
                NOT_FOUND_0x1d="0"/>
        </LinearLayout>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="16dp"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1d="0">
            <TextView
                textAppearance="@style/Label_2_Medium"
                textColor="@color/ContentPrimary"
                ellipsize="4"
                gravity="0x11"
                id="@+id/tv_coin_price"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_marginEnd="4dp"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="@+id/iv_coin_kline"
                NOT_FOUND_0x1d="0"/>
            <ImageView
                id="@+id/iv_coin_kline"
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131231584_res_0x7f080360"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1d="0"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcv_content"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        overScrollMode="2"/>
    <View
        id="@+id/v_divider"
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="16dp"/>
</LinearLayout>
