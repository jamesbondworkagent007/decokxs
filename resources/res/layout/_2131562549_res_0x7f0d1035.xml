<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/SurfaceSecondary"
    paddingLeft="@dimen/ok_dp_16"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/ok_dp_16"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/ok_dp_16"
    paddingVertical="@dimen/padding_12dp">
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/ContentPrimary"
        id="@+id/invalidCount"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/clear_icon"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131234234_res_0x7f080dba"
        NOT_FOUND_0x10="@+id/clear"
        NOT_FOUND_0x12="@+id/clear"
        NOT_FOUND_0x14="@+id/clear"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Medium"
        textColor="@color/ContentPrimary"
        id="@+id/clear"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_marketplace_favorites_btn_clear_all"
        paddingStart="@dimen/padding_2dp"
        paddingEnd="0dp"
        NOT_FOUND_0x10="@+id/invalidCount"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="@+id/invalidCount"/>
</androidx.constraintlayout.widget.ConstraintLayout>
