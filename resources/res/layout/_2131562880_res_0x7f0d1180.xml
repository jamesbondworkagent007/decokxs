<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/fl_item_view"
        tag="layout/view_self_service_0"
        paddingLeft="@dimen/padding_10dp"
        paddingTop="@dimen/padding_14dp"
        paddingRight="@dimen/padding_10dp"
        paddingBottom="@dimen/padding_14dp"
        layout_width="-1"
        android:layout_height="match_parent"
        paddingHorizontal="@dimen/padding_10dp"
        paddingVertical="@dimen/padding_14dp">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_support_self_service_name"
            paddingBottom="@dimen/padding_2dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x10="@+id/icon"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="0"
            style="@style/TextAppearance.Text.14SP.Medium"/>
        <ImageView
            id="@+id/icon"
            layout_width="20dp"
            android:layout_height="20dp"
            scaleType="fitStart"
            importantForAccessibility="2"
            layout_marginStart="@dimen/margin_6dp"
            NOT_FOUND_0xe="0"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x11="@+id/tv_support_self_service_name"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
