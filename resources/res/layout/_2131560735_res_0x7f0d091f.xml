<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@drawable/_2131231358_res_0x7f08027e"
    layout_width="-1"
    android:layout_height="wrap_content"
    backgroundTint="@color/SurfacePrimary">
    <ImageView
        id="@+id/sa_icon"
        padding="6dp"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginTop="23dp"
        layout_marginBottom="23dp"
        layout_marginStart="16dp"
        layout_marginVertical="23dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x11="@+id/sub_title1"
        NOT_FOUND_0x13="@+id/go_arrow"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/sa_icon"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="2"
        style="@style/Label_1_Bold"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/sub_title1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        maxLines="1"
        layout_marginStart="12dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="@+id/go_arrow"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/sa_icon"
        NOT_FOUND_0x17="@+id/title"
        style="@style/Label_2_Regular"/>
    <ImageView
        id="@+id/go_arrow"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        layout_marginEnd="16dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x18="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
