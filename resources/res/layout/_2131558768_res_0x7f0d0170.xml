<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginLeft="@dimen/margin_default"
    layout_marginRight="@dimen/margin_default"
    layout_marginHorizontal="@dimen/margin_default">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/mainTitleTv"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_smartarb_list_tips_arbitrage_profit"
        layout_alignParentTop="true"
        layout_alignParentStart="true"
        layout_alignParentEnd="true"
        style="@style/TextAppearance.Title.Bold.20SP"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/infoContainer"
        background="@drawable/_2131231413_res_0x7f0802b5"
        paddingLeft="12dp"
        paddingTop="16dp"
        paddingRight="12dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        layout_below="@+id/mainTitleTv"
        layout_alignParentStart="true"
        layout_alignParentEnd="true"
        paddingHorizontal="12dp"
        paddingVertical="16dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_smartarb_botdetails_title_annual_fund_rate"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x800005"
                id="@+id/pnlTitleTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="2dp">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/apyValueTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/Label_1_Bold"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x800005"
                id="@+id/pnlValueTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/Label_1_Bold"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/recyclerView"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_below="@+id/infoContainer"
        overScrollMode="2"
        layout_alignParentStart="true"
        layout_alignParentEnd="true"/>
    <View
        background="@color/background_BasePrimary_BaseSecondary"
        layout_width="-1"
        android:layout_height="20dp"
        layout_below="@+id/infoContainer"
        layout_alignParentStart="true"
        layout_alignParentEnd="true"/>
</RelativeLayout>
