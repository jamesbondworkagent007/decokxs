<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/cl_top_movers"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="24dp"
    layout_marginTop="24dp"
    layout_marginRight="24dp"
    layout_marginHorizontal="24dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_top_mover_header"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0">
        <TextView
            textAppearance="@style/TextAppearance.Text.Bold.18SP"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_coin"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            text="@string/pr_trade_discover_header_title_top_movers"
            maxLines="1"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x13="0"/>
        <o.C55052xcf
            textSize="12sp"
            id="@+id/time_menu_chip"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="@string/pr_trade_discover_cell_today"
            NOT_FOUND_0x15="-5"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <o.C41083qkC
        id="@+id/token_heatmap_view"
        layout_width="-1"
        android:layout_height="223dp"
        layout_marginTop="12dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/cl_top_mover_header"/>
    <o.C55173xeu
        id="@+id/empty_view"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_20dp"
        NOT_FOUND_0xe="6"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/cl_top_mover_header"
        NOT_FOUND_0x16="@string/pr_rewards_text_empty_no_date"/>
</androidx.constraintlayout.widget.ConstraintLayout>
