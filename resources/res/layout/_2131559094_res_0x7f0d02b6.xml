<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/Label_2_Medium"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/md"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <o.C55008xbo
        id="@+id/et_min"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        layout_marginStart="@dimen/margin_24dp"
        NOT_FOUND_0xe="@+id/tv_to"
        NOT_FOUND_0xf="1"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/tv_title"
        NOT_FOUND_0x15="@string/pr_swaptrade_copytrade_cell_title_min"/>
    <TextView
        textAppearance="@style/Body_2_Regular"
        textColor="@color/ContentTertiary"
        id="@+id/tv_to"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_4dp"
        layout_marginRight="@dimen/margin_4dp"
        text="-"
        layout_marginHorizontal="@dimen/margin_4dp"
        NOT_FOUND_0xc="@+id/view_line"
        NOT_FOUND_0xe="@+id/et_max"
        NOT_FOUND_0x11="@+id/et_min"
        NOT_FOUND_0x14="@+id/et_min"/>
    <View
        id="@+id/view_line"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="40dp"
        NOT_FOUND_0x14="@+id/et_min"/>
    <o.C55008xbo
        id="@+id/et_max"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x11="@+id/tv_to"
        NOT_FOUND_0x14="@+id/et_min"
        NOT_FOUND_0x15="@string/pr_swaptrade_copytrade_cell_title_max"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/SemanticNegative"
        id="@+id/tv_error_message"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginTop="@dimen/xxxsm"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp"
        NOT_FOUND_0x13="@+id/et_min"/>
</merge>
