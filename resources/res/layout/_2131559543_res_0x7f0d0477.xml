<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/tv_title_reference_order_info"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_limit_colheader_executed_price"
        drawablePadding="@dimen/padding_4dp"
        NOT_FOUND_0x10="@color/ContentContrast"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_radio_order_info"
        tag="true"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="3"
        paddingEnd="28dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/tv_title_reference_order_info"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_toggle"
        layout_width="20dp"
        android:layout_height="20dp"
        src="@drawable/_2131234226_res_0x7f080db2"
        tint="@color/ContentContrast"
        layout_marginStart="-20dp"
        NOT_FOUND_0x11="@+id/tv_radio_order_info"
        NOT_FOUND_0x14="@+id/tv_radio_order_info"
        NOT_FOUND_0x17="@+id/tv_radio_order_info"/>
</merge>
