<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="14sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_title"
        paddingBottom="8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        style="@style/Label_2_Regular"/>
    <LinearLayout
        gravity="0x10"
        id="@+id/layout_content"
        layout_width="-2"
        android:layout_height="wrap_content">
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_content"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_2_Regular"/>
        <ImageView
            id="@+id/iv_content_arrow"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131231637_res_0x7f080395"
            layout_marginStart="4dp"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/layout_data"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentContrast"
            id="@+id/tv_input"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_1_Regular"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rv_input"
            scrollbars="horizontal"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            overScrollMode="2"
            NOT_FOUND_0x10="androidx.recyclerview.widget.LinearLayoutManager"/>
        <LinearLayout
            gravity="0x11"
            layout_gravity="0x1"
            id="@+id/layout_input_more"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="16dp">
            <TextView
                textSize="14sp"
                textColor="@color/ContentPrimary"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_commonall_modal_btn_more"
                style="@style/Body_2_Regular"/>
            <ImageView
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131231637_res_0x7f080395"
                layout_marginStart="4dp"/>
        </LinearLayout>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="14sp"
            textColor="@color/ContentContrast"
            id="@+id/tv_output"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"
            style="@style/Label_1_Regular"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rv_output"
            scrollbars="horizontal"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            overScrollMode="2"
            NOT_FOUND_0x10="androidx.recyclerview.widget.LinearLayoutManager"/>
        <LinearLayout
            gravity="0x11"
            layout_gravity="0x1"
            id="@+id/layout_output_more"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="16dp">
            <TextView
                textSize="14sp"
                textColor="@color/ContentPrimary"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_commonall_modal_btn_more"
                style="@style/Body_2_Regular"/>
            <ImageView
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131231637_res_0x7f080395"
                layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>
</merge>
