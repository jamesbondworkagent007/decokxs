<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_filter_striker"
        layout_width="-2"
        android:layout_height="30dp"
        maxWidth="@dimen/dp_80"
        text="@string/pr_market_colheader_all_strike"
        maxLines="1"
        drawablePadding="4dp"
        drawableEnd="@drawable/_2131231589_res_0x7f080365"
        layout_marginStart="@dimen/common_page_edge_space"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"/>
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideline"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0.5"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_filter_type"
        layout_width="-2"
        android:layout_height="0dp"
        maxWidth="@dimen/dp_80"
        text="@string/pr_market_colheader_all_type"
        maxLines="1"
        drawablePadding="4dp"
        drawableEnd="@drawable/_2131231589_res_0x7f080365"
        layout_marginStart="107dp"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x10="@+id/tv_filter_striker"
        NOT_FOUND_0x11="@+id/guideline"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/tv_filter_striker"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_sort_price"
        layout_width="-2"
        android:layout_height="0dp"
        text="@string/pr_market_colheader_mark_price"
        maxLines="1"
        drawablePadding="0dp"
        layout_marginEnd="120dp"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x10="@+id/tv_filter_striker"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="@+id/guideline"
        NOT_FOUND_0x16="@+id/tv_filter_striker"
        NOT_FOUND_0x17="0"
        style="@style/OkSortBar"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_sort_ratio"
        layout_width="-2"
        android:layout_height="0dp"
        text="@string/pr_market_colheader_change_rate"
        maxLines="1"
        drawablePadding="0dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x10="@+id/tv_filter_striker"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x16="@+id/tv_filter_striker"
        NOT_FOUND_0x18="0"
        style="@style/OkSortBar"/>
</merge>
