<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/dp24"
        layout_marginRight="@dimen/dp24"
        layout_marginHorizontal="@dimen/dp24"
        NOT_FOUND_0x11="0"
        style="@style/Title_1_Bold"/>
    <TextView
        textColor="@color/ContentTertiary"
        id="@+id/tv_des"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/dp24"
        layout_marginTop="@dimen/dp_8"
        layout_marginRight="@dimen/dp24"
        layout_marginHorizontal="@dimen/dp24"
        NOT_FOUND_0x10="@+id/tv_title"
        style="@style/Body_3_Regular"/>
    <o.C52794wYp
        id="@+id/btn_sms"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/dp24"
        layout_marginTop="@dimen/margin_20dp"
        layout_marginRight="@dimen/dp24"
        text="@string/pr_message_new_chat_btn_invite_via_sms"
        layout_marginHorizontal="@dimen/dp24"
        NOT_FOUND_0x10="@+id/tv_des"
        NOT_FOUND_0x12="52"
        NOT_FOUND_0x13="0x101"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_invite_divder"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/dp24"
        layout_marginTop="@dimen/dp24"
        layout_marginRight="@dimen/dp24"
        layout_marginHorizontal="@dimen/dp24"
        NOT_FOUND_0x10="@+id/btn_sms">
        <View
            background="@color/BorderPrimary"
            layout_width="0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
        <TextView
            textColor="@color/ContentTertiary"
            paddingLeft="@dimen/padding_14dp"
            paddingRight="@dimen/padding_14dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_message_new_chat_textarea_or_through"
            paddingHorizontal="@dimen/padding_14dp"
            NOT_FOUND_0x10="@+id/tv_title"
            style="@style/Label_2_Regular"/>
        <View
            background="@color/BorderPrimary"
            layout_width="0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
    </LinearLayout>
    <FrameLayout
        id="@+id/fl_share_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x10="@+id/ll_invite_divder"/>
</androidx.constraintlayout.widget.ConstraintLayout>
