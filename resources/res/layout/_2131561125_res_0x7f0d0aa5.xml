<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_gravity="0x10"
    paddingLeft="20dp"
    paddingRight="20dp"
    layout_width="-1"
    android:layout_height="30dp"
    paddingHorizontal="20dp">
    <View
        id="@+id/mask"
        background="@drawable/_2131231158_res_0x7f0801b6"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="@dimen/margin_1dp"
        backgroundTint="@color/BaseSecondary"/>
    <ProgressBar
        id="@+id/progress"
        layout_width="62dp"
        android:layout_height="4dp"
        progressDrawable="@drawable/_2131230903_res_0x7f0800b7"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1c="0"
        style="?android:attr/progressBarStyleHorizontal"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/unlock"
        layout_width="54dp"
        android:layout_height="wrap_content"
        maxLines="1"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        layout_marginEnd="@dimen/margin_26dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="@+id/progress"
        NOT_FOUND_0x1c="0"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/total"
        layout_width="54dp"
        android:layout_height="wrap_content"
        maxLines="1"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="@+id/unlock"
        NOT_FOUND_0x1c="0"/>
    <LinearLayout
        orientation="0"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_4"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="@+id/total"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="0">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/titlePrefix"
            layout_width="@dimen/dp_8"
            android:layout_height="@dimen/dp_8"
            layout_marginTop="3dp"
            src="@drawable/_2131234003_res_0x7f080cd3"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="@dimen/text_size_12sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="2"
            includeFontPadding="false"
            fontFamily="@font/harmony_sans_regular"
            paddingEnd="@dimen/dp_4"
            layout_marginStart="@dimen/dp_4"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
