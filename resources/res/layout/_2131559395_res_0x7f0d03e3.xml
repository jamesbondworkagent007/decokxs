        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_info_relevance_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            text="@string/pr_swaptrade_vibes_details_title_relevance"
            maxLines="1"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="@+id/ll_progress_labels"
            style="@style/Label_3_Regular"/>
        <ImageView
            id="@+id/iv_relevance_chevron"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0x14="@+id/tv_info_relevance_title"
            NOT_FOUND_0x18="@+id/tv_info_relevance_title"
            NOT_FOUND_0x1b="@+id/tv_info_relevance_title"
            NOT_FOUND_0x1c="@color/ContentContrast"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_info_relevance_amt"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            maxLines="1"
            layout_marginEnd="8dp"
            NOT_FOUND_0x16="@+id/tv_info_mentioned"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="@+id/tv_info_relevance_title"
            style="@style/Label_2_Medium"/>
        <View
            id="@+id/click_zone_relevance"
            layout_width="0dp"
            android:layout_height="0dp"
            NOT_FOUND_0x14="@+id/tv_info_relevance_amt"
            NOT_FOUND_0x16="@+id/guideline_33_percent"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="@+id/tv_info_relevance_title"/>
        <androidx.constraintlayout.widget.Guideline
            orientation="1"
            id="@+id/guideline_33_percent"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x17="0.33"/>
        <androidx.constraintlayout.widget.Guideline
            orientation="1"
            id="@+id/guideline_66_percent"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x17="0.66"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_info_mentioned"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            text="@string/pr_swaptrade_vibes_details_title_mentioned_by"
            maxLines="1"
            NOT_FOUND_0x19="@+id/guideline_33_percent"
            NOT_FOUND_0x1a="@+id/ll_progress_labels"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_info_mentioned_amt"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            maxLines="1"
            layout_marginEnd="8dp"
            NOT_FOUND_0x16="@+id/guideline_66_percent"
            NOT_FOUND_0x19="@+id/guideline_33_percent"
            NOT_FOUND_0x1a="@+id/tv_info_mentioned"
