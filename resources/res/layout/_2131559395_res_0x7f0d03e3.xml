            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131234480_res_0x7f080eb0"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_title"
            paddingTop="12dp"
            paddingBottom="12dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_vibes_details_title_vibe_score"
