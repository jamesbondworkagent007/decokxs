            layout_marginStart="4dp"
            paddingVertical="12dp"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x18="@+id/iv_x_icon"
            NOT_FOUND_0x1b="0"
            style="@style/Title_2_Bold"/>
        <ImageView
