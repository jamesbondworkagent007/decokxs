            <View
                layout_width="0dp"
                android:layout_height="1dp"
                layout_weight="1"/>
            <TextView
                textColor="@color/ContentTertiary"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="20"
                style="@style/Label_3_Regular"/>
            <View
                layout_width="0dp"
                android:layout_height="1dp"
                layout_weight="1"/>
            <TextView
                textColor="@color/ContentTertiary"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="40"
                style="@style/Label_3_Regular"/>
            <View
                layout_width="0dp"
                android:layout_height="1dp"
                layout_weight="1"/>
            <TextView
                textColor="@color/ContentTertiary"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="60"
                style="@style/Label_3_Regular"/>
            <View
                layout_width="0dp"
                android:layout_height="1dp"
                layout_weight="1"/>
            <TextView
                textColor="@color/ContentTertiary"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="80"
                style="@style/Label_3_Regular"/>
            <View
