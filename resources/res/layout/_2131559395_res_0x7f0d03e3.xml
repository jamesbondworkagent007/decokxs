                    layout_width="2dp"
                    android:layout_height="match_parent"
                    layout_marginStart="4dp"/>
                <View
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    layout_weight="1"/>
                <View
                    background="@color/BaseSecondary"
                    layout_width="2dp"
                    android:layout_height="match_parent"
                    layout_marginStart="4dp"/>
                <View
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    layout_weight="1"/>
            </LinearLayout>
            <View
                layout_gravity="0x10"
                id="@+id/v_vibes_indicator_dot"
                background="@drawable/_2131232013_res_0x7f08050d"
                layout_width="6dp"
                android:layout_height="8dp"
                elevation="1dp"/>
