            ellipsize="3"
            id="@+id/tv_vibes_score_amt"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"
            style="@style/Headline_5_Bold"/>
        <ImageView
