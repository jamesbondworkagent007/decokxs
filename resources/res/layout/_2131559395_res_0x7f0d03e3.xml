            ellipsize="3"
            id="@+id/tv_info_created_date"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            maxLines="1"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x19="@+id/guideline_66_percent"
            NOT_FOUND_0x1a="@+id/tv_info_created"
            style="@style/Label_2_Medium"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
