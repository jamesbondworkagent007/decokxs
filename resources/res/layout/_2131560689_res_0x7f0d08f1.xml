<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/padding_32dp">
    <ImageView
        id="@+id/iv_icon"
        layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"/>
    <LinearLayout
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"
        layout_marginStart="@dimen/margin_16dp">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_permission_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            style="@style/Body_2_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/tv_permission_description"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            style="@style/Body_2_Regular"/>
    </LinearLayout>
</LinearLayout>
