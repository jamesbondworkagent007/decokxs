<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/item_layout"
    tag="layout/item_im_entrance_setting_item_0"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/common_page_edge_space"
    paddingTop="16dp"
    paddingRight="@dimen/common_page_edge_space"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/common_page_edge_space"
    paddingVertical="16dp">
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        minHeight="24dp"
        drawablePadding="@dimen/xsm"
        layout_weight="1"
        layout_marginEnd="@dimen/xxsm"
        style="@style/Label_1_Regular"/>
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/lbl_right"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/xxxxsm"
        style="@style/Label_2_Regular"/>
    <ImageView
        id="@+id/iv_right"
        visibility="2"
        layout_width="@dimen/width_24dp"
        android:layout_height="@dimen/height_24dp"
        importantForAccessibility="2"
        layout_marginEnd="@dimen/xxxxsm"
        NOT_FOUND_0x15="@color/ContentPrimary"/>
    <ImageView
        gravity="0x800015"
        id="@+id/iv_arrow"
        layout_width="@dimen/width_24dp"
        android:layout_height="@dimen/height_24dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        importantForAccessibility="2"
        NOT_FOUND_0x15="@color/ContentContrast"/>
</LinearLayout>
