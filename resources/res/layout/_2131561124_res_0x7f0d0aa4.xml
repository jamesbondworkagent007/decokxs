<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_gravity="0x10"
    layout_width="-1"
    android:layout_height="30dp">
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/okTradeG400"
        gravity="0x800005"
        id="@+id/progressHeader"
        layout_width="83dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_tokenunlocks_colheader_progress"
        maxLines="2"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x10="0"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/okTradeG400"
        gravity="0x800003"
        id="@+id/unlockHeader"
        layout_width="54dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_tokenunlocks_colheader_unlocked"
        maxLines="2"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xe="@+id/progressHeader"
        NOT_FOUND_0x10="0"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/okTradeG400"
        gravity="0x800003"
        id="@+id/totalHeader"
        layout_width="54dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_tokenunlocks_colheader_total"
        maxLines="2"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xe="@+id/unlockHeader"
        NOT_FOUND_0x10="0"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/okTradeG400"
        gravity="0x800003"
        id="@+id/allocationHeader"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_tokenunlocks_colheader_allocation"
        maxLines="2"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xe="@+id/totalHeader"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
