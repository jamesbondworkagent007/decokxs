<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/layout_sync_contact_large_banner"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/im_page_margin"
    layout_marginRight="@dimen/im_page_margin"
    layout_marginHorizontal="@dimen/im_page_margin">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_sync_contact_lg_banner_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8"
        text="@string/pr_message_chat_regularcell_header_sync_contacts"
        layout_marginEnd="@dimen/margin_10dp"
        NOT_FOUND_0x12="@+id/close"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        style="@style/Headline_3_Medium"/>
    <ImageView
        id="@+id/close"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231675_res_0x7f0803bb"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x15="@+id/tv_sync_contact_lg_banner_title"
        NOT_FOUND_0x18="@color/ContentContrast"/>
    <TextView
        textColor="@color/ContentTertiary"
        id="@+id/tv_sync_contact_lg_banner_des"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        text="@string/pr_message_banner_desc_connect_with_friends"
        NOT_FOUND_0x14="@+id/tv_sync_contact_lg_banner_title"
        style="@style/Label_1_Regular"/>
    <o.C52794wYp
        id="@+id/btn_sync_contact_lg_banner"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginBottom="16dp"
        text="@string/pr_message_banner_btn_enable_contacts_permissions"
        drawablePadding="@dimen/dp_8"
        drawableStart="@drawable/_2131230883_res_0x7f0800a3"
        drawableTint="@color/ContentInverse"
        layout_marginVertical="16dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="@+id/tv_sync_contact_lg_banner_des"
        NOT_FOUND_0x16="44"
        NOT_FOUND_0x17="0x103"/>
</androidx.constraintlayout.widget.ConstraintLayout>
