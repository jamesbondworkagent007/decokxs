<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/margin_default"
    paddingTop="@dimen/xxxsm"
    paddingRight="@dimen/margin_default"
    paddingBottom="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/contentContainer"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="1"
            id="@+id/reminder_lin"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0">
            <com.okinc.uilab.reminder.OKReminder
                id="@+id/reminder"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <View
                layout_width="-1"
                android:layout_height="@dimen/ok_dp_16"/>
        </LinearLayout>
        <TextView
            id="@+id/tv_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/reminder_lin"
            style="@style/Title_2_Bold"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/ll_value_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginEnd="@dimen/xxxsm"
            NOT_FOUND_0x1b="@+id/tv_total_value"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/tv_title">
            <TextView
                ellipsize="3"
                id="@+id/tv_value_name"
                layout_width="0dp"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_weight="1"
                layout_marginEnd="@dimen/xxxxsm"
                style="@style/Label_1_Bold"/>
            <o.C55251xgS
                id="@+id/tv_value_tag"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_marginEnd="@dimen/xxxxsm"
                NOT_FOUND_0x21="-3"
                NOT_FOUND_0x22="11"/>
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_trailing"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                style="@style/Label_2_Regular"/>
        </LinearLayout>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/tv_subtitle_container"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxxsm"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/ll_value_title">
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_value_subtitle"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
            <o.wYC
                id="@+id/ic_reverse"
                visibility="2"
                layout_width="16dp"
                android:layout_height="16dp"
                layout_marginStart="@dimen/xxxsm"
                NOT_FOUND_0x23="@drawable/_2131232098_res_0x7f080562"
                NOT_FOUND_0x24="@color/ContentPrimary"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <TextView
            id="@+id/tv_total_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x19="@+id/ll_value_title"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1e="@+id/ll_value_title"
            style="@style/Label_1_Medium"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/warning_container"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxsm"
            NOT_FOUND_0x1d="@+id/tv_subtitle_container">
            <o.wYC
                id="@+id/warning_icon"
                layout_width="@dimen/xsm"
                android:layout_height="@dimen/xsm"
                src="@drawable/_2131234331_res_0x7f080e1b"
                NOT_FOUND_0x24="@color/SemanticNotice"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tv_warning"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_weight="1"
                layout_marginStart="@dimen/xxxxsm"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <View
            id="@+id/divider"
            background="@color/BorderPrimary"
            layout_width="-1"
            android:layout_height="@dimen/height_0.5dp"
            layout_marginTop="@dimen/xsm"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/warning_container"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rv_asset_sections"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xsm"
            NOT_FOUND_0x17="androidx.recyclerview.widget.LinearLayoutManager"
            NOT_FOUND_0x18="true"
            NOT_FOUND_0x1d="@+id/divider"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <o.C55113xdn
        layout_gravity="0x11"
        id="@+id/loading_view"
        background="@color/BasePrimary"
        layout_width="-2"
        android:layout_height="wrap_content"
        scaleType="fillCenter"
        NOT_FOUND_0x1f="true"
        NOT_FOUND_0x20="true"/>
</FrameLayout>
