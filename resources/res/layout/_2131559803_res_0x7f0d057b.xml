<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/fragment_bot_guide_banner_order_dialog_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.core.widget.NestedScrollView
        id="@+id/nsv_content"
        paddingBottom="@dimen/padding_24dp"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"
        overScrollMode="2"
        NOT_FOUND_0x18="@+id/btn_create"
        NOT_FOUND_0x19="@+id/headerLayout">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <o.C55258xgZ
                id="@+id/tvInvestTitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_16dp"
                layout_marginTop="16dp"
                layout_marginRight="@dimen/margin_16dp"
                layout_marginBottom="8dp"
                text="@string/pr_signalbot_placeorder_field_investment"
                layout_marginHorizontal="@dimen/margin_16dp"
                NOT_FOUND_0x1a="2"
                NOT_FOUND_0x1b="@color/ContentPrimary"
                NOT_FOUND_0x1c="@dimen/text_size_14sp"
                NOT_FOUND_0x1d="400"/>
            <FrameLayout
                id="@+id/ll_order"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_16dp"
                layout_marginRight="@dimen/margin_16dp"
                minHeight="70dp"
                layout_marginHorizontal="@dimen/margin_16dp"/>
            <LinearLayout
                orientation="0"
                id="@+id/bot_details_layout"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_24dp"
                paddingStart="@dimen/margin_16dp">
                <TextView
                    textAppearance="@style/TextAppearance.Title.14SP.Semibold"
