                    layout_gravity="0x10"
                    id="@+id/iv_show"
                    paddingLeft="16dp"
                    paddingRight="16dp"
                    layout_width="-2"
                    android:layout_height="match_parent"
                    src="@drawable/_2131231639_res_0x7f080397"
                    paddingHorizontal="16dp"
                    NOT_FOUND_0x1e="@color/ContentSecondary"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/rcv_info"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_16dp"
                layout_marginTop="12dp"
                layout_marginRight="@dimen/margin_16dp"
                overScrollMode="2"
                layout_marginHorizontal="@dimen/margin_16dp"/>
