<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/fragment_feedback_history_detail_dialog_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    fillViewport="true">
    <LinearLayout
        orientation="1"
        background="@color/BasePrimary"
        padding="@dimen/common_page_edge_space"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Medium"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_text_detail_main_category"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            id="@+id/main_category"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            layout_marginBottom="@dimen/margin_24dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Medium"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_dropdown_detail_sub_category"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            id="@+id/children_category"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            layout_marginBottom="@dimen/margin_24dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Medium"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_text_detail_subject"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            layout_marginBottom="@dimen/margin_24dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Medium"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_text_detail_description"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            id="@+id/description"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            layout_marginBottom="@dimen/margin_24dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Orange.14SP.Medium"
            id="@+id/status"
            paddingTop="@dimen/padding_4dp"
            paddingBottom="@dimen/padding_4dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/margin_24dp"
            paddingStart="@dimen/padding_8dp"
            paddingEnd="@dimen/padding_8dp"/>
        <TextView
            textSize="14sp"
            textColor="@color/grey_g700"
            id="@+id/info"
            background="@drawable/_2131232213_res_0x7f0805d5"
            padding="@dimen/padding_8dp"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/margin_24dp"
            fontFamily="@font/font_alpha_medium"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/recycler"
            layout_width="-1"
            android:layout_height="wrap_content"
            minHeight="180dp"
            overScrollMode="2"
            NOT_FOUND_0x19="androidx.recyclerview.widget.LinearLayoutManager"/>
        <TextView
            textAppearance="@style/TextAppearance.Blue.14SP"
            id="@+id/reward"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/margin_24dp"
            text="@string/pr_supportcenter_text_detail_view_wallet"
            layout_marginStart="40dp"/>
        <LinearLayout
            orientation="0"
            id="@+id/action_layout"
            paddingBottom="@dimen/common_page_edge_space"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/common_page_edge_space">
            <o.C52794wYp
                gravity="0x11"
                id="@+id/reject"
                layout_width="@dimen/width_0dp"
                android:layout_height="wrap_content"
                text="@string/pr_supportcenter_tab_detail_reject"
                layout_weight="1"
                NOT_FOUND_0x1a="-2"
                NOT_FOUND_0x1b="40"
                NOT_FOUND_0x1c="0x102"/>
            <o.C52794wYp
                gravity="0x11"
                id="@+id/approve"
                layout_width="@dimen/width_0dp"
                android:layout_height="wrap_content"
                text="@string/pr_supportcenter_btn_detail_approve"
                layout_weight="1"
                layout_marginStart="@dimen/common_page_edge_space"
                NOT_FOUND_0x1a="-2"
                NOT_FOUND_0x1b="40"
                NOT_FOUND_0x1c="0x101"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
