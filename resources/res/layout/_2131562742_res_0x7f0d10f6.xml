<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    paddingLeft="24dp"
    paddingTop="12dp"
    paddingRight="24dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp"
    paddingVertical="12dp">
    <ImageView
        id="@+id/networkIcon"
        layout_width="32dp"
        android:layout_height="32dp"
        scaleType="6"
        layout_marginEnd="16dp"/>
    <LinearLayout
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <TextView
            textAppearance="@style/Label_1_Medium"
            textColor="@drawable/_2131233904_res_0x7f080c70"
            ellipsize="3"
            id="@+id/networkText"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"/>
        <TextView
            textAppearance="@style/Label_2_Regular"
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/networkValue"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            maxLines="1"/>
    </LinearLayout>
    <ImageView
        id="@+id/checkIcon"
        visibility="2"
        layout_width="24dp"
        android:layout_height="24dp"
        src="@drawable/_2131232885_res_0x7f080875"
        layout_weight="0"
        NOT_FOUND_0x15="@color/ContentBrand"/>
</LinearLayout>
