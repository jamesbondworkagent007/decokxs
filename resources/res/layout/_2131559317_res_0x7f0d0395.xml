<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/xxsm"
    paddingBottom="@dimen/xxsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/xxsm">
    <ImageView
        id="@+id/iv_icon"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0xf="@+id/iv_expand"
        NOT_FOUND_0x10="@+id/iv_icon"
        NOT_FOUND_0x13="0"
        style="@style/Label_1_Regular"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_subtitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0xf="@+id/iv_expand"
        NOT_FOUND_0x11="@+id/tv_title"
        NOT_FOUND_0x12="@+id/tv_title"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_expand"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231647_res_0x7f08039f"
        tint="@color/ContentContrast"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x13="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
