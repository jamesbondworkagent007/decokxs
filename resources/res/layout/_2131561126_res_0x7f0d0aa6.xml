<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="30dp">
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        gravity="0x800005"
        id="@+id/fiatHeader"
        layout_width="114dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_tokenunlocks_colheader_fiat_value"
        maxLines="2"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="0"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        gravity="0x800003"
        id="@+id/unlockHeader"
        layout_width="84dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_tokenunlocks_colheader_unlocked"
        maxLines="2"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xd="@+id/fiatHeader"
        NOT_FOUND_0xf="0"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        gravity="0x800003"
        id="@+id/distributionHeader"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_tokenunlocks_colheader_distribution"
        maxLines="2"
        includeFontPadding="false"
        fontFamily="@font/harmony_sans_regular"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xd="@+id/unlockHeader"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
