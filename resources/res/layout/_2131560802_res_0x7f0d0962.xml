        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_type"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="12dp"
        layout_marginEnd="4dp"
        NOT_FOUND_0x13="16sp"
        NOT_FOUND_0x14="12sp"
        NOT_FOUND_0x15="2sp"
        NOT_FOUND_0x16="1"
        NOT_FOUND_0x19="true"
        NOT_FOUND_0x1b="@+id/tv_address"
        NOT_FOUND_0x1d="@+id/statusBar"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="2"
