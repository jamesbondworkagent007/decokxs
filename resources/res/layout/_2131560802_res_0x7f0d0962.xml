        id="@+id/guide_line"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1e="0.7"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textSize="14sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
