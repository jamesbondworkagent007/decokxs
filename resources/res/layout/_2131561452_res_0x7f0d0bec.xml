<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/error_view_container"
    background="@color/HighlightsInteractiveLossModern"
    paddingLeft="@dimen/margin_24dp"
    paddingTop="@dimen/dp_8"
    paddingRight="@dimen/margin_24dp"
    paddingBottom="@dimen/dp_8"
    layout_width="-1"
    android:layout_height="@dimen/dp_64"
    paddingHorizontal="@dimen/margin_24dp"
    paddingVertical="@dimen/dp_8">
    <TextView
        textColor="@color/PreferenceShadedLossModern"
        ellipsize="3"
        id="@+id/error_message"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="3"
        autoSizeStepGranularity="@dimen/text_size_1sp"
        autoSizeMinTextSize="@dimen/text_size_12sp"
        NOT_FOUND_0x13="true"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/error_action_btn"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="1"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="0"
        style="@style/Label_2_Medium"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/error_action_btn"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x13="true"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="@+id/error_message"
        NOT_FOUND_0x1b="0">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/error_action_btn_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="true"
            NOT_FOUND_0x13="true"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="@+id/error_action_btn_icon"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="0"
            style="@style/Label_2_Medium"/>
        <ImageView
            id="@+id/error_action_btn_icon"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231649_res_0x7f0803a1"
            contentDescription="@null"
            layout_marginStart="@dimen/dp_4"
            NOT_FOUND_0x12="true"
            NOT_FOUND_0x13="true"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x19="@+id/error_action_btn_text"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="@color/ContentPrimary"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
