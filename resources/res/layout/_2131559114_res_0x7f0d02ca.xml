<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    contentDescription="web3_dex_history_business_entrance_sheet">
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/container_history_item"
        layout_width="-1"
        android:layout_height="wrap_content"
        contentDescription="web3_dex_history_transaction_records_cell"
        NOT_FOUND_0xa="@drawable/history"
        NOT_FOUND_0xb="@color/SurfaceBrand"
        NOT_FOUND_0xd="@string/pr_swaptrade_swap_list_history">
        <ImageView
            layout_gravity="0x800015"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0xc="@color/ContentPrimary"/>
    </com.okinc.uilab.item.OKRegularCell>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/container_auto_confirm_item"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0xa="@drawable/_2131233334_res_0x7f080a36"
        NOT_FOUND_0xb="@color/SurfaceBrand"
        NOT_FOUND_0xd="@string/pr_swaptrade_auto_confirm_title">
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            id="@+id/tv_auto_confirm_status"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <ImageView
            layout_gravity="0x800015"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0xc="@color/ContentPrimary"/>
    </com.okinc.uilab.item.OKRegularCell>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/container_savings_item"
        layout_width="-1"
        android:layout_height="wrap_content"
        contentDescription="web3_dex_savings_summary_cell"
        NOT_FOUND_0xa="@drawable/_2131234098_res_0x7f080d32"
        NOT_FOUND_0xb="@color/SurfaceBrand"
        NOT_FOUND_0xd="@string/pr_swaptrade_order_top_menu_saving_summary">
        <ImageView
            layout_gravity="0x800015"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0xc="@color/ContentPrimary"/>
    </com.okinc.uilab.item.OKRegularCell>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/container_dex_item"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0xa="@drawable/_2131233932_res_0x7f080c8c"
        NOT_FOUND_0xb="@color/SurfaceBrand"
        NOT_FOUND_0xd="@string/pr_swaptrade_bottomsheet_title_select_liquidity">
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/grey_g400"
            id="@+id/tv_count_dex"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <ImageView
            layout_gravity="0x800015"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0xc="@color/ContentPrimary"/>
    </com.okinc.uilab.item.OKRegularCell>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/container_question_item"
        layout_width="-1"
        android:layout_height="wrap_content"
        contentDescription="web3_dex_faq_cell"
        NOT_FOUND_0xa="@drawable/_2131233739_res_0x7f080bcb"
        NOT_FOUND_0xb="@color/SurfaceBrand"
        NOT_FOUND_0xd="@string/pr_swaptrade_swap_list_faq">
        <ImageView
            layout_gravity="0x800015"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0xc="@color/ContentPrimary"/>
    </com.okinc.uilab.item.OKRegularCell>
</androidx.appcompat.widget.LinearLayoutCompat>
