<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/headerLayout"
    tag="layout/dfragment_trade_bottom_sheet_header_0"
    background="@drawable/_2131231036_res_0x7f08013c"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/topBg"
        layout_width="-1"
        android:layout_height="0dp"
        NOT_FOUND_0x18="@+id/topBottomSpace"
        NOT_FOUND_0x1d="0"/>
    <ImageView
        id="@+id/topClose"
        background="?android:attr/selectableItemBackground"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232441_res_0x7f0806b9"
        layout_marginEnd="14dp"
        NOT_FOUND_0x18="@+id/title_lly"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="@+id/title"
        NOT_FOUND_0x1e="@color/ContentContrast"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textSize="16sp"
        textStyle="0x1"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        textAlignment="5"
        layout_marginStart="16dp"
        NOT_FOUND_0x1a="@+id/topClose"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/title_lly"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginStart="16dp"
        NOT_FOUND_0x1a="@+id/topClose"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="@+id/title">
        <TextView
            textAppearance="@style/TextAppearance.Red.12SP.Medium"
            id="@+id/tradeType"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginEnd="@dimen/dp_8"
            NOT_FOUND_0x1b="@+id/tv_title"
            NOT_FOUND_0x1c="@+id/tv_title"/>
        <TextView
            textSize="12sp"
            textColor="@color/okTradeG500"
            id="@+id/subTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginEnd="4dp"/>
        <TextView
            textSize="12sp"
            textColor="@color/okTradeG500"
            gravity="0x10"
            id="@+id/tvSecondTitle"
            background="@drawable/_2131231484_res_0x7f0802fc"
            paddingLeft="@dimen/dp_4"
            paddingTop="2dp"
            paddingRight="@dimen/dp_4"
            paddingBottom="2dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"
            backgroundTint="@color/okTradeRed50"
            paddingHorizontal="@dimen/dp_4"
            paddingVertical="2dp"/>
        <TextView
            textSize="12sp"
            textColor="@color/okTradeG500"
            gravity="0x10"
            id="@+id/tvThirdTitle"
            background="@drawable/_2131231484_res_0x7f0802fc"
            paddingLeft="@dimen/dp_4"
            paddingTop="2dp"
            paddingRight="@dimen/dp_4"
            paddingBottom="2dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="6dp"
            backgroundTint="@color/okTradeRed50"
            paddingHorizontal="@dimen/dp_4"
            paddingVertical="2dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Blue.12SP.Medium"
            textColor="@color/blue_lv1"
            id="@+id/sunName"
            background="@drawable/_2131231011_res_0x7f080123"
            paddingLeft="@dimen/dp_4"
            paddingTop="2dp"
            paddingRight="@dimen/dp_4"
            paddingBottom="2dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="6dp"
            backgroundTint="@color/okTradeB50"
            paddingHorizontal="@dimen/dp_4"
            paddingVertical="2dp"/>
    </LinearLayout>
    <View
        id="@+id/topBottomSpace"
        layout_width="-1"
        android:layout_height="11dp"
        NOT_FOUND_0x1c="@+id/title_lly"/>
    <View
        id="@+id/topBottomSpaceLine"
        background="@color/okTradeG100"
        layout_width="-1"
        android:layout_height="0.5dp"
        NOT_FOUND_0x1c="@+id/topBottomSpace"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/reminderLayout"
        background="@color/okTradeB50"
        paddingTop="8dp"
        paddingBottom="8dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="@+id/topBottomSpaceLine">
        <TextView
            textAppearance="@style/TextAppearance.Silka.MeDium"
            textSize="12sp"
            textColor="@color/blue_lv1"
            id="@+id/reminderTitle"
            paddingBottom="8dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="16dp"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="0"/>
        <TextView
            textAppearance="@style/TextAppearance.Silka"
            textSize="12sp"
            textColor="@color/blue_lv1"
            id="@+id/reminderContent"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="@+id/reminderTitle"/>
        <ImageView
            id="@+id/reminderClose"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131232489_res_0x7f0806e9"
            layout_marginEnd="16dp"
            NOT_FOUND_0x18="@+id/reminderTitle"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1d="@+id/reminderTitle"
            NOT_FOUND_0x1e="@color/okTradeBlue700"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
