<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentContrast"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_transfer_textarea_min_receive"
            layout_weight="0.4"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/parent_custom_slippage"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="0.6"
            layout_marginStart="@dimen/margin_12dp">
            <androidx.constraintlayout.helper.widget.Flow
                layout_width="0dp"
                android:layout_height="wrap_content"
                NOT_FOUND_0x11="tv_minimum_received, tv_minimum_received_currency"
                NOT_FOUND_0x12="1"
                NOT_FOUND_0x13="2"
                NOT_FOUND_0x14="1"
                NOT_FOUND_0x15="4dp"
                NOT_FOUND_0x16="1"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1a="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP.Regular"
                textColor="@color/ContentPrimary"
                ellipsize="2"
                gravity="0x800005"
                layout_gravity="0x800005"
                id="@+id/tv_minimum_received"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0xe="@dimen/font_14"
                NOT_FOUND_0xf="@dimen/font_12"
                NOT_FOUND_0x10="1"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1b="1"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP.Regular"
                textColor="@color/ContentPrimary"
                ellipsize="2"
                layout_gravity="0x800005"
                id="@+id/tv_minimum_received_currency"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginStart="2dp"
                NOT_FOUND_0xe="@dimen/font_14"
                NOT_FOUND_0xf="@dimen/font_12"
                NOT_FOUND_0x10="1"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="@+id/tv_minimum_received"
                NOT_FOUND_0x1a="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        textAppearance="@style/TextAppearance.Text.10SP.Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_hint"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_swaptrade_limit_bttmsheet_desc_min_received"/>
</androidx.appcompat.widget.LinearLayoutCompat>
