<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/kline_swap_dialog"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginTop="@dimen/margin_16dp">
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/grey_g800"
        id="@+id/within10"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_trade_rules_title_within_10_min_cont"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/grey_g500"
        id="@+id/with10_formula"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/grey_g800"
        id="@+id/after10"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_trade_rules_title_over_10_min_cont"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/grey_g500"
        id="@+id/after10Formula"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_trade_rules_subtitle_adjust_without_anncmnt"/>
</LinearLayout>
