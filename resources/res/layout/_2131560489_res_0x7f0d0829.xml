<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/item_disclaimer_message_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x1"
        orientation="1"
        id="@+id/vip_header_container"
        paddingLeft="@dimen/padding_16dp"
        paddingTop="@dimen/ok_dp_16"
        paddingRight="@dimen/padding_16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_16dp">
        <FrameLayout
            layout_gravity="0x1"
            id="@+id/avatar_container"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/ok_dp_12">
            <ImageView
                id="@+id/iv_avatar_left"
                background="@drawable/_2131231459_res_0x7f0802e3"
                padding="3dp"
                layout_width="80dp"
                android:layout_height="80dp"/>
            <ImageView
                id="@+id/iv_avatar_right"
                background="@drawable/_2131231459_res_0x7f0802e3"
                padding="3dp"
                layout_width="64dp"
                android:layout_height="64dp"
                layout_marginTop="@dimen/dp_28"
                layout_marginStart="@dimen/dp_28"/>
        </FrameLayout>
        <TextView
            textSize="24sp"
            gravity="0x11"
            id="@+id/tv_vip_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            fontFamily="@font/okx_sans_tab_regular"/>
        <TextView
            textSize="@dimen/text_size_12sp"
            textColor="@color/ContentContrast"
            gravity="0x11"
            id="@+id/tv_vip_subtitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            fontFamily="@font/okx_sans_tab_regular"/>
    </LinearLayout>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/text"
        paddingLeft="@dimen/padding_16dp"
        paddingTop="@dimen/ok_dp_16"
        paddingRight="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        fontFamily="@font/okx_sans_tab_regular"
        paddingHorizontal="@dimen/padding_16dp"/>
</LinearLayout>
