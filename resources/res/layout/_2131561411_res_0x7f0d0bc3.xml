<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.core.widget.NestedScrollView
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"
        overScrollMode="2">
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Body_3_Regular"
            textColor="@color/ContentPrimary"
            id="@+id/tvDataContent"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginRight="@dimen/margin_24dp"
            layout_marginBottom="@dimen/margin_20dp"
            layout_marginHorizontal="@dimen/margin_24dp"/>
    </androidx.core.widget.NestedScrollView>
    <o.wYF
        id="@+id/btn_data_box"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_16dp"
        layout_marginVertical="@dimen/margin_16dp"/>
</LinearLayout>
