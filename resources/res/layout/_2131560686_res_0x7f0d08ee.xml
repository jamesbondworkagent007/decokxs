<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_16dp"
    layout_marginRight="@dimen/margin_16dp"
    layout_marginHorizontal="@dimen/margin_16dp">
    <o.wYC
        id="@+id/ic_launch"
        layout_width="16dp"
        android:layout_height="16dp"
        NOT_FOUND_0xd="@+id/content_container"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@drawable/_2131231647_res_0x7f08039f"
        NOT_FOUND_0x15="@color/BorderSecondary"/>
    <o.wYC
        id="@+id/radio_btn"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0xd="@+id/content_container"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x800003"
        orientation="1"
        id="@+id/content_container"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        layout_marginStart="20dp"
        NOT_FOUND_0xe="@+id/divider"
        NOT_FOUND_0x10="@+id/ic_launch"
        NOT_FOUND_0x11="@+id/radio_btn"
        NOT_FOUND_0x13="0">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_token_amount"
            layout_width="-1"
            android:layout_height="wrap_content"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/tv_fiat_amount"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            style="@style/Label_3_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <View
        id="@+id/divider"
        background="@color/BorderPrimary"
        layout_width="0dp"
        android:layout_height="0.5dp"
        layout_marginBottom="16dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
