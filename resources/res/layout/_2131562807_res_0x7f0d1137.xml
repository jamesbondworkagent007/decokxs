<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="@dimen/padding_16dp"
    paddingTop="12dp"
    paddingRight="@dimen/padding_16dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_16dp">
    <android.widget.LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/voice_button"
            background="@drawable/_2131231064_res_0x7f080158"
            padding="10dp"
            visibility="2"
            layout_width="44dp"
            android:layout_height="44dp"
            src="@drawable/_2131233502_res_0x7f080ade"
            contentDescription="@null"
            layout_marginEnd="12dp"
            NOT_FOUND_0x23="@color/ContentPrimary"/>
        <FrameLayout
            orientation="0"
            background="@drawable/_2131231193_res_0x7f0801d9"
            layout_width="0dp"
            android:layout_height="wrap_content"
            baselineAligned="false"
            minHeight="48dp"
            layout_weight="1">
            <o.oIY
                textSize="@dimen/font_16"
                textColorHint="@color/ContentDisabled"
                layout_gravity="0x800013"
                id="@+id/edit_text_input"
                paddingTop="8dp"
                paddingBottom="8dp"
                focusable="true"
                focusableInTouchMode="true"
                layout_width="-1"
                android:layout_height="wrap_content"
                minHeight="4dp"
                maxLines="4"
                maxLength="2000"
                inputType="0x24001"
                fontFamily="@font/harmony_sans_regular"
                textAlignment="5"
                layout_marginStart="12dp"
                layout_marginEnd="40dp"
                importantForAutofill="0x2"
                style="@style/EditText.NoLine"/>
            <ImageView
                layout_gravity="0x800015"
                id="@+id/stickerButton"
                visibility="2"
                layout_width="24dp"
                android:layout_height="24dp"
                layout_marginLeft="8dp"
                layout_marginRight="8dp"
                src="@drawable/_2131232193_res_0x7f0805c1"
                contentDescription="@null"
                layout_marginHorizontal="8dp"
                NOT_FOUND_0x23="@color/ContentPrimary"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/add_button"
            visibility="2"
            layout_width="40dp"
            android:layout_height="40dp"
            layout_marginStart="@dimen/xxxsm">
            <ImageView
                id="@+id/add_button_image"
                background="@drawable/_2131231064_res_0x7f080158"
                layout_width="-1"
                android:layout_height="match_parent"
                src="@drawable/_2131233687_res_0x7f080b97"
                scaleType="fitEnd"
                contentDescription="@null"
                NOT_FOUND_0x23="@color/ContentPrimary"/>
        </FrameLayout>
        <ImageView
            id="@+id/send_button"
            background="@drawable/_2131231068_res_0x7f08015c"
            padding="@dimen/xxxsm"
            visibility="2"
            layout_width="40dp"
            android:layout_height="40dp"
            src="@drawable/_2131233928_res_0x7f080c88"
            contentDescription="@string/pr_commonall_button_text_send"
            layout_marginStart="@dimen/xxxsm"
            NOT_FOUND_0x23="@color/ContentInverse"/>
        <ImageView
            id="@+id/stop_button"
            background="@drawable/_2131231068_res_0x7f08015c"
            padding="12dp"
            visibility="2"
            layout_width="40dp"
            android:layout_height="40dp"
            src="@drawable/_2131231615_res_0x7f08037f"
            contentDescription="@string/pr_commonall_button_text_send"
            layout_marginStart="@dimen/xxxsm"
            NOT_FOUND_0x23="@color/ContentInverse"/>
    </android.widget.LinearLayout>
</LinearLayout>
