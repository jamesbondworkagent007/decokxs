<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/scroll_layout"
    tag="layout/layout_kline_trading_tech_item_0"
    paddingTop="10dp"
    scrollbars="0x200"
    layout_width="-1"
    android:layout_height="wrap_content"
    overScrollMode="2"
    paddingStart="16dp"
    paddingEnd="16dp">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/all_layout"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="24sp"
            textStyle="0x1"
            textColor="@color/okTradeG900"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <ImageView
            layout_gravity="0x1"
            id="@+id/iv_gif"
            background="@drawable/_2131231017_res_0x7f080129"
            padding="1dp"
            layout_width="200dp"
            android:layout_height="330dp"
            layout_marginTop="@dimen/dp24"
            layout_marginBottom="@dimen/margin_16dp"
            scaleType="fillCenter"/>
        <TextView
            textSize="@dimen/text_size_14sp"
            textColor="@color/ContentTertiary"
            id="@+id/tv_sub_title"
            layout_width="-1"
            android:layout_height="wrap_content"/>
        <o.C39842pzv
            id="@+id/layout_emotion"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="25dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
