<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="20dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Blue.12SP.Medium"
        textColor="@color/grey_g700"
        id="@+id/sunName"
        background="@drawable/_2131231013_res_0x7f080125"
        paddingLeft="@dimen/dp_4"
        paddingTop="2dp"
        paddingRight="@dimen/dp_4"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="20dp"
        layout_marginRight="16dp"
        text="@string/pr_trade_dropdown_arbitrage_order"
        backgroundTint="@color/background_lv3"
        layout_marginHorizontal="16dp"
        paddingHorizontal="@dimen/dp_4"
        paddingVertical="2dp"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x20="0"/>
    <LinearLayout
        orientation="0"
        id="@+id/coin_header_info"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="20dp"
        layout_marginRight="16dp"
        layout_marginHorizontal="16dp"
        NOT_FOUND_0x1f="@+id/sunName">
        <LinearLayout
            gravity="0x30"
            orientation="0"
            id="@+id/coin_info_left"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginEnd="@dimen/dp_8">
            <ImageView
                id="@+id/iv_coin_icon_left"
                visibility="2"
                layout_width="20dp"
                android:layout_height="20dp"
                layout_marginEnd="8dp"/>
            <TextView
                textSize="14sp"
                textColor="@color/grey_g900"
                id="@+id/tv_coin_name_left"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="--"
                layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            gravity="0x30"
            orientation="0"
            id="@+id/coin_info_right"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/dp_8">
            <ImageView
                id="@+id/iv_coin_icon_right"
                visibility="2"
                layout_width="20dp"
                android:layout_height="20dp"
                layout_marginEnd="8dp"/>
            <TextView
                textSize="14sp"
                textColor="@color/grey_g900"
                id="@+id/tv_coin_name_right"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="--"
                layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
    <o.wUH
        id="@+id/order_confirm_left"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/ok_dp_12"
        layout_marginStart="16dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x1c="@+id/order_confirm_right"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/coin_header_info"/>
    <o.wUH
        id="@+id/order_confirm_right"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/ok_dp_12"
        layout_marginStart="8dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="@+id/order_confirm_left"
        NOT_FOUND_0x1f="@+id/coin_header_info"/>
    <View
        id="@+id/arbitrage_order_divider_line"
        layout_marginLeft="16dp"
        layout_marginTop="16dp"
        layout_marginRight="16dp"
        layout_marginHorizontal="16dp"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/order_confirm_left"
        style="@style/WidgetDivisionLine"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        layout_gravity="0x11"
        id="@+id/arbitrage_order_confirm_tip"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="16dp"
        layout_marginRight="16dp"
        text="@string/pr_trade_arbiltrage_label_confirm_tip"
        layout_marginHorizontal="16dp"
        NOT_FOUND_0x1f="@+id/arbitrage_order_divider_line"/>
    <o.wYK
        theme="@style/OKUITheme"
        textColor="@color/okTradeG900"
        id="@+id/check_no_show"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        text="@string/pr_options_alert_not_tips"
        layout_marginStart="16dp"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="@+id/arbitrage_order_confirm_tip"
        NOT_FOUND_0x23="-4"/>
    <o.C52794wYp
        gravity="0x11"
        id="@+id/confirm_order_confirm_btn"
        layout_width="-1"
        android:layout_height="44dp"
        layout_marginTop="12dp"
        text="@string/pr_margin_btn_change_leverage_confirm"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0x1f="@+id/check_no_show"
        NOT_FOUND_0x21="44"
        NOT_FOUND_0x22="0x101"
        style="@style/TextAppearance.Silka.MeDium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
