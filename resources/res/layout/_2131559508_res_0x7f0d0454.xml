<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-2"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_type_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_commonall_modal_title_type"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentSecondary"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_type_content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        paddingStart="12dp"
        paddingEnd="0dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/tv_type_title"
        NOT_FOUND_0x11="0"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/barrier_type"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="3"
        NOT_FOUND_0xc="tv_type_content,tv_type_title"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_orders_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_commonall_enterfield_text_quantity"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/barrier_type"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentSecondary"
        gravity="0x800005"
        id="@+id/tv_orders_content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        paddingStart="12dp"
        paddingEnd="0dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/tv_orders_title"
        NOT_FOUND_0x11="@+id/tv_orders_title"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/barrier_order"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="3"
        NOT_FOUND_0xc="tv_orders_title,tv_orders_content"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_network_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_commonall_modal_title_network"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/barrier_order"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentSecondary"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_network_content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        paddingStart="12dp"
        paddingEnd="0dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/tv_network_title"
        NOT_FOUND_0x11="@+id/tv_network_title"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/barrier_network"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="3"
        NOT_FOUND_0xc="tv_network_title,tv_network_content"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_bottom_msg"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x10="@+id/barrier_network"/>
</merge>
