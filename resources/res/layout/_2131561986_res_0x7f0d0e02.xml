<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        layout_gravity="0x1"
        id="@+id/navigation_bar_item_icon_container"
        duplicateParentState="true"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/mtrl_navigation_rail_margin"
        layout_marginBottom="@dimen/mtrl_navigation_rail_text_bottom_margin">
        <View
            layout_gravity="0x11"
            id="@+id/navigation_bar_item_active_indicator_view"
            layout_width="0dp"
            android:layout_height="0dp"/>
        <ImageView
            layout_gravity="0x11"
            id="@+id/navigation_bar_item_icon_view"
            duplicateParentState="true"
            layout_width="@dimen/mtrl_navigation_rail_icon_size"
            android:layout_height="@dimen/mtrl_navigation_rail_icon_size"
            contentDescription="@null"/>
    </FrameLayout>
    <com.google.android.material.internal.BaselineLayout
        layout_gravity="0x51"
        id="@+id/navigation_bar_item_labels_group"
        paddingBottom="@dimen/mtrl_navigation_rail_text_bottom_margin"
        duplicateParentState="true"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-2"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/mtrl_navigation_rail_text_size"
            ellipsize="3"
            id="@+id/navigation_bar_item_small_label_view"
            duplicateParentState="true"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"/>
        <TextView
            textSize="@dimen/mtrl_navigation_rail_active_text_size"
            ellipsize="3"
            id="@+id/navigation_bar_item_large_label_view"
            visibility="1"
            duplicateParentState="true"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"/>
    </com.google.android.material.internal.BaselineLayout>
</merge>
