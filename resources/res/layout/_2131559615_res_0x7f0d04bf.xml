<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/dfragment_speed_up_tx_header_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.18SP.Semibold"
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_11dp"
        text="@string/pr_metax_wallet_title_speed_up_trading"
        layout_marginStart="@dimen/padding_16dp"
        layout_marginEnd="14dp"
        NOT_FOUND_0xd="@+id/sub_title"
        NOT_FOUND_0xf="@+id/close"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="2"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentPrimary"
        id="@+id/sub_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_2dp"
        text="@string/pr_metax_wallet_subtitle_speed_up_trade"
        layout_marginStart="@dimen/padding_16dp"
        layout_marginEnd="14dp"
        NOT_FOUND_0xd="@+id/divider"
        NOT_FOUND_0xf="@+id/close"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/title"
        NOT_FOUND_0x13="2"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/close"
        background="?attr/selectableItemBackgroundBorderless"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232438_res_0x7f0806b6"
        tint="@color/ContentContrast"
        layout_marginEnd="14dp"
        NOT_FOUND_0xd="@+id/divider"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x12="0"/>
    <View
        id="@+id/divider"
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="@dimen/width_0.5dp"
        layout_marginTop="@dimen/padding_13dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/sub_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
