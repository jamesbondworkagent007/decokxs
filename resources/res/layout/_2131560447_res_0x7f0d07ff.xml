<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    paddingTop="2dp"
    paddingBottom="2dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="2dp">
    <TextView
        textSize="11sp"
        textStyle="0x1"
        textColor="@color/white"
        id="@+id/channel"
        background="@drawable/_2131231497_res_0x7f080309"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        textAlignment="4"
        layout_marginStart="2dp"
        paddingHorizontal="4dp"
        paddingVertical="2dp"/>
    <TextView
        textSize="11sp"
        textStyle="0x1"
        textColor="@color/white"
        id="@+id/state"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        textAlignment="4"
        layout_marginStart="2dp"
        paddingHorizontal="4dp"
        paddingVertical="2dp"/>
    <TextView
        textSize="11sp"
        textStyle="0x1"
        textColor="@color/white"
        id="@+id/event"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        textAlignment="4"
        layout_marginStart="2dp"/>
</LinearLayout>
