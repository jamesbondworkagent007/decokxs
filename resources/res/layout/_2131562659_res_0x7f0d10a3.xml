<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <View
        id="@+id/topLine"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="1dp"
        layout_alignParentTop="true"/>
    <LinearLayout
        orientation="0"
        id="@+id/contentGroup"
        paddingTop="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="match_parent"
        baselineAligned="false"
        layout_above="@+id/bottomLine"
        layout_below="@+id/topLine"
        paddingStart="@dimen/padding_24dp"
        paddingEnd="@dimen/padding_24dp">
        <ImageView
            layout_gravity="0x10"
            id="@+id/imageView"
            layout_width="96dp"
            android:layout_height="96dp"
            layout_marginEnd="12dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_gravity="0x10"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1">
            <TextView
                textAppearance="@style/Body_3_Regular"
                textColor="@color/color_content_static_subtle"
                id="@+id/title"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="0"/>
            <TextView
                textAppearance="@style/Body_2_Regular"
                textColor="@color/color_content_static_default"
                ellipsize="3"
                id="@+id/content"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                maxLines="3"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="@+id/title"/>
            <o.wYE
                id="@+id/button"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1a="-4"
                NOT_FOUND_0x1b="1"
                NOT_FOUND_0x1c="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <View
        id="@+id/bottomLine"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="1dp"
        layout_alignParentBottom="true"/>
</RelativeLayout>
