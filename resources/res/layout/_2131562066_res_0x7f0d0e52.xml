<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/dp24"
    paddingTop="@dimen/dp_16"
    paddingRight="@dimen/dp24"
    paddingBottom="@dimen/dp_16"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp24"
    paddingVertical="@dimen/dp_16">
    <o.tUQ
        id="@+id/img_avatar"
        layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        NOT_FOUND_0x17="1.5dp"
        NOT_FOUND_0x18="1.5dp"
        NOT_FOUND_0x19="14dp"
        NOT_FOUND_0x1a="14dp"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x24="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textSize="16sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        includeFontPadding="false"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x21="@+id/img_avatar"
        NOT_FOUND_0x24="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        lines="1"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x1b="true"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1e="@+id/iv_official"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="2"
        NOT_FOUND_0x21="@+id/img_avatar"
        NOT_FOUND_0x23="@+id/tv_content"
        style="@style/Label_3_Regular"/>
    <ImageView
        id="@+id/iv_official"
        background="@drawable/_2131232809_res_0x7f080829"
        visibility="2"
        layout_width="@dimen/width_16dp"
        android:layout_height="@dimen/height_16dp"
        contentDescription="@null"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x1c="@+id/tv_name"
        NOT_FOUND_0x1e="@+id/tv_news_tag"
        NOT_FOUND_0x21="@+id/tv_name"
        NOT_FOUND_0x24="@+id/tv_name"/>
    <TextView
        textColor="@color/ContentSecondary_Dark"
        id="@+id/tv_news_tag"
        background="@drawable/_2131231013_res_0x7f080125"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_social_opportunities_tag_news"
        layout_marginStart="@dimen/dp_8"
        backgroundTint="#5f62ff"
        paddingHorizontal="4dp"
        paddingVertical="2dp"
        NOT_FOUND_0x1c="@+id/tv_name"
        NOT_FOUND_0x1e="@+id/tv_time"
        NOT_FOUND_0x21="@+id/iv_official"
        NOT_FOUND_0x24="@+id/tv_name"
        style="@style/Label_4_Regular"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x1c="@+id/tv_name"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x21="@+id/tv_news_tag"
        NOT_FOUND_0x24="@+id/tv_name"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
