<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_16dp"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_16dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/mode_container"
        background="@drawable/_2131233510_res_0x7f080ae6"
        padding="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        foreground="?attr/selectableItemBackground"
        clipToOutline="true">
        <ImageView
            id="@+id/icon"
            layout_width="32dp"
            android:layout_height="32dp"
            src="@drawable/_2131231568_res_0x7f080350"
            importantForAccessibility="2"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="0"/>
        <TextView
            textSize="@dimen/font_16"
            textColor="@color/primary_white"
            id="@+id/title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/margin_12dp"
            NOT_FOUND_0x14="@+id/ic_drop_down"
            NOT_FOUND_0x15="@+id/icon"
            NOT_FOUND_0x18="0"
            style="@style/Label_1_Medium"/>
        <TextView
            id="@+id/description"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            layout_marginStart="@dimen/margin_12dp"
            lineHeight="@dimen/height_16dp"
            NOT_FOUND_0x14="@+id/ic_drop_down"
            NOT_FOUND_0x15="@+id/icon"
            NOT_FOUND_0x17="@+id/title"
            style="@style/Label_3_Regular"/>
        <ImageView
            id="@+id/ic_drop_down"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231637_res_0x7f080395"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="@color/ContentTertiary"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
