<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    layout_width="-1"
    android:layout_height="@dimen/height_40dp">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"
        layout_marginEnd="@dimen/xsm">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tokenSymbol"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginEnd="@dimen/xsm"
            style="@style/Label_1_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tokenValue"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            maxLines="1"
            style="@style/Label_3_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <FrameLayout
        gravity="0x800015"
        layout_gravity="0x800015"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="@dimen/width_200dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x800005"
            layout_gravity="0x800015"
            orientation="1"
            id="@+id/rightTwoLineContainer"
            layout_width="-2"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/primaryValue"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                style="@style/Label_1_Medium"/>
            <TextView
                ellipsize="3"
                id="@+id/innerPnlLabel"
                visibility="0"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_4"
                maxLines="1"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </FrameLayout>
</LinearLayout>
