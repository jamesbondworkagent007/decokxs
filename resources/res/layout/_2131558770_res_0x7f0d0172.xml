<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="24dp"
        layout_marginRight="@dimen/margin_default"
        layout_marginBottom="36dp"
        layout_marginHorizontal="@dimen/margin_default">
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_smartarb_placeorder_header_investment_allocation"
            style="@style/Label_1_Bold"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            background="@drawable/_2131231413_res_0x7f0802b5"
            paddingLeft="12dp"
            paddingTop="16dp"
            paddingRight="12dp"
            paddingBottom="16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            paddingHorizontal="12dp"
            paddingVertical="16dp">
            <androidx.appcompat.widget.LinearLayoutCompat
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentContrast"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_list_colheader_margin"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/initialInvestmentTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                id="@+id/boostedInvestmentContainer"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_smartarb_placeorder_dialog_tips_boosted_investment"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/boostedInvestmentTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                id="@+id/amountBorrowedContainer"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_smartarb_placeorder_dialog_tips_borrow_amount"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/amountBorrowedTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            background="@drawable/_2131231413_res_0x7f0802b5"
            paddingLeft="12dp"
            paddingTop="16dp"
            paddingRight="12dp"
            paddingBottom="16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            paddingHorizontal="12dp"
            paddingVertical="16dp">
            <androidx.appcompat.widget.LinearLayoutCompat
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/spotInvestmentTitleTv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_smartarb_placeorder_dialog_tips_spot_investment"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/spotInvestmentValueTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/futureReservedMarginTitleTv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_smartarb_placeorder_dialog_tips_reserved_margin_for_futures"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/futureReservedMarginValueTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <o.wUX
                id="@+id/barView"
                layout_width="-1"
                android:layout_height="6dp"
                layout_marginTop="20dp"/>
            <View
                id="@+id/stakingDivider"
                background="@color/BorderPrimary"
                visibility="2"
                layout_width="-1"
                android:layout_height="0.5dp"
                layout_marginTop="20dp"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                id="@+id/stakingEarnCcyContainer"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/stakingEarnCcyTitleTv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/stakingEarnCcyValueTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                id="@+id/stakingCcyContainer"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/stakingCcyTitleTv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/stakingCcyValueTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                id="@+id/estNextRewardsContainer"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <o.C55258xgZ
                    theme="@style/OKTheme"
                    id="@+id/estNextRewardsTitleTv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    NOT_FOUND_0x17="1"
                    NOT_FOUND_0x18="@color/ContentContrast"
                    NOT_FOUND_0x19="14sp"
                    NOT_FOUND_0x1a="@string/pr_smartarb_placeorder_dialog_tips_estimated_next_rewards"
                    NOT_FOUND_0x1b="@style/Label_2_Regular"
                    NOT_FOUND_0x1c="400"
                    NOT_FOUND_0x1d="0"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/estNextRewardsValueTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"
            text="@string/pr_smartarb_botdetails_title_twoleg_arbitrage_details"
            style="@style/Label_1_Bold"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/recyclerView"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            overScrollMode="2"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/riskInfoTitleTv"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_smartarb_botdetails_header_risk_info"
            style="@style/Label_1_Bold"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            id="@+id/riskInfoContainer"
            background="@drawable/_2131231413_res_0x7f0802b5"
            paddingLeft="12dp"
            paddingTop="16dp"
            paddingRight="12dp"
            paddingBottom="16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            paddingHorizontal="12dp"
            paddingVertical="16dp">
            <androidx.appcompat.widget.LinearLayoutCompat
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentContrast"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_order_label_margin_ratio"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/marginRateTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_botdetails_colheader_est_liq_price"
                    layout_weight="1"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/liqPriceTv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/riskInfoDescTv"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="10dp"
            layout_marginBottom="24dp"
            style="@style/TextAppearance.Text.12SP.Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
