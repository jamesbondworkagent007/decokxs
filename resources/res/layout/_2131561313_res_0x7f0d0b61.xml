<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginBottom="@dimen/height_36dp">
    <ImageView
        id="@+id/iv_pic"
        layout_width="@dimen/height_56dp"
        android:layout_height="@dimen/height_56dp"
        layout_marginTop="53dp"
        src="@drawable/_2131233141_res_0x7f080975"
        scaleType="fitStart"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1c="@color/ContentPrimary"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.Bold.24SP"
        textColor="@color/text_amplified"
        gravity="0x11"
        id="@+id/reminder_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_investdeposit_bot_title_reminder"
        includeFontPadding="false"
        lineSpacingExtra="4sp"
        layout_marginStart="@dimen/margin_16dp"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/iv_pic"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textColor="@color/text_secondary"
        gravity="0x11"
        id="@+id/unable_to_redeem_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_investdeposit_bot_text_multiple_days_clear_loss"
        includeFontPadding="false"
        lineSpacingExtra="4sp"
        layout_marginStart="@dimen/margin_16dp"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/reminder_title"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/transaction_loss_container"
        background="@drawable/_2131231196_res_0x7f0801dc"
        padding="@dimen/padding_20dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_margin="@dimen/margin_16dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/unable_to_redeem_title">
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP"
            textColor="@color/text_secondary"
            id="@+id/network_fee"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_investdeposit_bot_title_network_fee"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="0"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            textColor="@color/text_amplified"
            id="@+id/network_fee_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="$38.85"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x18="0"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP"
            textColor="@color/text_secondary"
            id="@+id/swap_loss"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="@string/pr_investdeposit_bot_title_swap_loss"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="@+id/network_fee"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            textColor="@color/text_amplified"
            id="@+id/swap_loss_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="$5.85"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x17="@+id/network_fee_value"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP"
            textColor="@color/text_secondary"
            id="@+id/tv_total_transaction_loss"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="@string/pr_investdeposit_bot_title_total_transaction_loss"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="@+id/swap_loss"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            textColor="@color/text_amplified"
            id="@+id/total_transaction_loss_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="$44.85"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x17="@+id/swap_loss_value"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <o.C52794wYp
        textColor="@color/white"
        gravity="0x11"
        id="@+id/btn_invest"
        layout_width="-1"
        android:layout_height="52dp"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginBottom="44dp"
        text="@string/pr_investdeposit_bot_btn_continue_invest"
        textAllCaps="false"
        layout_marginStart="@dimen/margin_16dp"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/transaction_loss_container"
        NOT_FOUND_0x19="@dimen/margin_40dp"
        NOT_FOUND_0x1a="52"
        NOT_FOUND_0x1b="0x101"
        style="@style/Button.Primary"/>
    <o.C52794wYp
        textAppearance="@style/TextAppearance.Text.Bold.16SP"
        textColor="@color/text_amplified"
        gravity="0x11"
        id="@+id/btn_cancel"
        layout_width="-1"
        android:layout_height="52dp"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginBottom="@dimen/margin_38dp"
        text="@string/pr_investdeposit_bot_btn_cancel"
        layout_marginStart="@dimen/margin_16dp"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x17="@+id/btn_invest"
        NOT_FOUND_0x1a="52"
        NOT_FOUND_0x1b="0x104"/>
</androidx.constraintlayout.widget.ConstraintLayout>
