<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="24dp"
    clipChildren="false"
    clipToPadding="false"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/content_linear_layout"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="0">
        <TextView
            textAppearance="@style/TextAppearance.Title.18SP.Semibold"
            textSize="@dimen/text_size_18sp"
            textColor="@color/ContentSecondary"
            gravity="0x31"
            layout_gravity="0x1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"
            text="@string/pr_trade_recurbot_detail_tunbibao_investment"
            includeFontPadding="false"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_gravity="0x31"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp">
            <ImageView
                id="@+id/symbol_img"
                layout_width="26dp"
                android:layout_height="26dp"
                src="@drawable/_2131232920_res_0x7f080898"
                scaleType="6"
                contentDescription="@null"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Title.24SP.Semibold"
                textSize="@dimen/text_size_24sp"
                textColor="@color/ContentPrimary"
                gravity="0x800003"
                id="@+id/final_invest_amount"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="2"
                includeFontPadding="false"
                textAlignment="2"
                layout_marginStart="@dimen/margin_8dp"
                NOT_FOUND_0x1e="@+id/symbol_img"
                NOT_FOUND_0x20="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="56dp">
            <androidx.constraintlayout.widget.Guideline
                orientation="1"
                id="@+id/guide_line_first"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1d="0.57"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP.Regular"
                textSize="@dimen/text_size_16sp"
                textColor="@color/ContentContrast"
                gravity="0x800033"
                layout_gravity="0x800003"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_trade_bot_placeorder_spotgrid_investment_amt"
                maxLines="5"
                includeFontPadding="false"
                layout_marginEnd="10dp"
                NOT_FOUND_0x1c="@+id/guide_line_first"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Medium"
                textSize="@dimen/text_size_16sp"
                textColor="@color/SemanticNeutral"
                gravity="0x800005"
                id="@+id/invest_amount_value"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="5"
                includeFontPadding="false"
                textAlignment="3"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1e="@+id/guide_line_first"
                NOT_FOUND_0x20="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_24dp">
            <androidx.constraintlayout.widget.Guideline
                orientation="1"
                id="@+id/guide_line_second"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1d="0.57"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP.Regular"
                textSize="@dimen/text_size_16sp"
                textColor="@color/ContentContrast"
                gravity="0x800033"
                layout_gravity="0x800003"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_spotgrid_botdetails_reminder_profit_reinvestment"
                maxLines="5"
                includeFontPadding="false"
                layout_marginEnd="10dp"
                NOT_FOUND_0x1c="@+id/guide_line_second"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Medium"
                textSize="@dimen/text_size_16sp"
                textColor="@color/SemanticNeutral"
                gravity="0x800005"
                id="@+id/reinvestment_value"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="5"
                includeFontPadding="false"
                textAlignment="3"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1e="@+id/guide_line_second"
                NOT_FOUND_0x20="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/reserved_layout"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_24dp">
            <androidx.constraintlayout.widget.Guideline
                orientation="1"
                id="@+id/guide_line_third"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1d="0.57"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP.Regular"
                textSize="@dimen/text_size_16sp"
                textColor="@color/ContentContrast"
                gravity="0x800033"
                layout_gravity="0x800003"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_dcabot_orderdetail_tag_reserved"
                maxLines="5"
                includeFontPadding="false"
                layout_marginEnd="10dp"
                NOT_FOUND_0x1c="@+id/guide_line_third"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="0"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Medium"
                textSize="@dimen/text_size_16sp"
                textColor="@color/SemanticNeutral"
                gravity="0x800005"
                id="@+id/reserved_value"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="5"
                includeFontPadding="false"
                textAlignment="3"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1e="@+id/guide_line_third"
                NOT_FOUND_0x20="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.okinc.uilab.reminder.OKReminder
            id="@+id/reminder"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.constraintlayout.widget.ConstraintLayout>
