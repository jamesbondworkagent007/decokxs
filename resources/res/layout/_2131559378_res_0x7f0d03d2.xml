<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/container_priority_item"
    background="@drawable/_2131231997_res_0x7f0804fd"
    padding="@dimen/xsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="@dimen/dp_48">
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/tab_preset_setting_text_color"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_priorityFee_title"
        tag="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0xe="14sp"
        NOT_FOUND_0xf="12sp"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="2"
        style="@style/Label_2_Bold"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/tab_preset_setting_text_color"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_priorityFee_value"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        text="@string/pr_swaptrade_modal_dialog_option_market"
        maxLines="3"
        NOT_FOUND_0xe="14sp"
        NOT_FOUND_0xf="12sp"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/tv_priorityFee_title"
        NOT_FOUND_0x16="2"
        style="@style/Label_2_Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
