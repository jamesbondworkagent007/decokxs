<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textAppearance="@style/TextAppearance.Title.18SP.Medium"
        ellipsize="3"
        gravity="0x51"
        layout_gravity="0x51"
        id="@+id/tv_coin_nav"
        layout_width="250dp"
        android:layout_height="24dp"
        layout_marginTop="55dp"
        text="@string/pr_trade_tutorials_title_line_navig"
        maxLines="1"
        drawablePadding="8dp"
        layout_marginStart="@dimen/margin_10dp"
        layout_marginEnd="@dimen/margin_10dp"
        autoSizeTextType="uniform"
        autoSizeMinTextSize="@dimen/text_size_12sp"
        autoSizeMaxTextSize="18sp"/>
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/grey_g500"
        ellipsize="3"
        gravity="0x51"
        layout_gravity="0x51"
