        layout_marginEnd="@dimen/margin_10dp"
        autoSizeTextType="uniform"
        autoSizeMinTextSize="@dimen/text_size_12sp"
        autoSizeMaxTextSize="@dimen/sp_14"/>
    <o.C55379xio
        layout_gravity="0x11"
        id="@+id/iv_biz_nav"
        layout_width="247dp"
        android:layout_height="380dp"
        layout_marginTop="@dimen/margin_24dp"
        src="@drawable/_2131233468_res_0x7f080abc"
        scaleType="fitStart"
        clipToOutline="true"
        NOT_FOUND_0x17="@color/okTradeG200"
        NOT_FOUND_0x18="1dp"
        NOT_FOUND_0x19="@dimen/dp_16"/>
    <o.C55379xio
        layout_gravity="0x11"
        id="@+id/iv_biz_nav_gif"
        visibility="2"
        layout_width="247dp"
        android:layout_height="380dp"
        layout_marginTop="@dimen/margin_24dp"
        src="@drawable/_2131233468_res_0x7f080abc"
        scaleType="fitStart"
        clipToOutline="true"
        NOT_FOUND_0x17="@color/okTradeG200"
        NOT_FOUND_0x18="1dp"
        NOT_FOUND_0x19="@dimen/dp_16"/>
