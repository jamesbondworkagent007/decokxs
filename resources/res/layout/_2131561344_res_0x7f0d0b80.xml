<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_chain"
        layout_width="@dimen/width_32dp"
        android:layout_height="@dimen/height_32dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"/>
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentPrimary"
        id="@+id/chain_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x15="@+id/iv_chain"
        NOT_FOUND_0x18="0"
        style="@style/TextAppearance.Regular"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentTertiary"
        id="@+id/chain_address"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@+id/iv_copy"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="2"
        NOT_FOUND_0x16="@+id/chain_name"
        NOT_FOUND_0x17="@+id/chain_name"
        NOT_FOUND_0x19="1"
        style="@style/TextAppearance.Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_copy"
        layout_width="12dp"
        android:layout_height="12dp"
        src="@drawable/_2131234345_res_0x7f080e29"
        layout_marginStart="@dimen/margin_8dp"
        layout_marginEnd="@dimen/margin_4dp"
        NOT_FOUND_0x10="@+id/chain_address"
        NOT_FOUND_0x12="@+id/ll_escape_status"
        NOT_FOUND_0x15="@+id/chain_address"
        NOT_FOUND_0x18="@+id/chain_address"
        NOT_FOUND_0x1a="@color/ContentContrast"/>
    <LinearLayout
        orientation="0"
        id="@+id/ll_escape_status"
        paddingLeft="@dimen/padding_8dp"
        paddingTop="@dimen/padding_2dp"
        paddingRight="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_8dp"
        paddingVertical="@dimen/padding_2dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x18="0">
        <androidx.appcompat.widget.AppCompatImageView
            layout_gravity="0x10"
            id="@+id/iv_escape_status"
            layout_width="12dp"
            android:layout_height="12dp"/>
        <TextView
            textSize="@dimen/text_size_14sp"
            textColor="@color/ContentTertiary"
            layout_gravity="0x10"
            id="@+id/tv_escape_status"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/margin_8dp"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
