<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="@dimen/margin_8dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_24dp"
    layout_marginRight="@dimen/margin_24dp"
    layout_marginHorizontal="@dimen/margin_24dp">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Headline_5_Bold"
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_8dp"
        text="@string/pr_acct_passkey_bttmsheet_title_important_notice"
        NOT_FOUND_0x1b="0"/>
    <ImageView
        id="@+id/warning1"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131234331_res_0x7f080e1b"
        NOT_FOUND_0x16="@+id/subtitle1"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="@+id/subtitle1"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_1_Bold"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/subtitle1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_26dp"
        text="@string/pr_acct_passkey_bttmsheet_subtitle_lose_dex_multiple"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/warning1"
        NOT_FOUND_0x1a="@+id/title"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_2_Regular"
        textColor="@color/color_content_static_subtle"
        gravity="0x800003"
        id="@+id/subDescription1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_acct_passkey_bttmsheet_desc_lose_dex_multiple"
        NOT_FOUND_0x17="@+id/subtitle1"
        NOT_FOUND_0x19="@+id/subtitle1"
        NOT_FOUND_0x1a="@+id/subtitle1"
        NOT_FOUND_0x1c="24sp"/>
    <ImageView
        id="@+id/warning2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131234331_res_0x7f080e1b"
        NOT_FOUND_0x16="@+id/subtitle2"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="@+id/subtitle2"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_1_Bold"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/subtitle2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        text="@string/pr_acct_passkey_bttmsheet_subtitle_withdrawal_p2p_paused"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/warning1"
        NOT_FOUND_0x1a="@+id/subDescription1"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Body_2_Regular"
        textColor="@color/color_content_static_subtle"
        gravity="0x800003"
        id="@+id/subDescription2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_acct_passkey_bttmsheet_desc_withdrawal_p2p_paused"
        NOT_FOUND_0x17="@+id/subtitle2"
        NOT_FOUND_0x19="@+id/subtitle2"
        NOT_FOUND_0x1a="@+id/subtitle2"
        NOT_FOUND_0x1c="24sp"/>
    <LinearLayout
        orientation="0"
        id="@+id/checkBoxContainer"
        background="@drawable/_2131231078_res_0x7f080166"
        paddingLeft="@dimen/padding_16dp"
        paddingTop="@dimen/padding_12dp"
        paddingRight="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_12dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_32dp"
        paddingHorizontal="@dimen/padding_16dp"
        paddingVertical="@dimen/padding_12dp"
        NOT_FOUND_0x1a="@+id/subDescription2">
        <o.wYK
            id="@+id/checkBox"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Body_3_Regular"
            textColor="@color/ContentSecondary"
            gravity="0x800003"
            id="@+id/reminder"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_acct_passkey_bttmsheet_checkbox_confirm_proceed"
            layout_weight="1"
            layout_marginStart="@dimen/margin_8dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
