<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/trade_ui_market_place_home_create_strategy_list_item_0"
    background="@drawable/_2131231029_res_0x7f080135"
    padding="@dimen/ok_dp_16"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/item_icon"
        layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x22="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.16SP.Medium"
        textColor="@color/okTradeG900"
        id="@+id/item_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/ok_dp_12"
        layout_marginEnd="@dimen/ok_dp_16"
        NOT_FOUND_0x1f="@+id/item_icon"
        NOT_FOUND_0x22="0"/>
    <LinearLayout
        orientation="0"
        id="@+id/tag_container"
        layout_width="-2"
        android:layout_height="wrap_content"
        divider="@drawable/_2131231435_res_0x7f0802cb"
        showDividers="middle"
        NOT_FOUND_0x1c="@+id/item_title"
        NOT_FOUND_0x1f="@+id/item_title"
        NOT_FOUND_0x22="@+id/item_title"/>
    <androidx.constraintlayout.helper.widget.Flow
        id="@+id/tag_flow"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/ok_dp_12"
        layout_marginRight="@dimen/ok_dp_12"
        layout_marginHorizontal="@dimen/ok_dp_12"
        NOT_FOUND_0x15="item_title, tag_container"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@dimen/padding_6dp"
        NOT_FOUND_0x18="2"
        NOT_FOUND_0x19="@dimen/padding_4dp"
        NOT_FOUND_0x1a="1"
        NOT_FOUND_0x1e="@+id/user_icon"
        NOT_FOUND_0x1f="@+id/item_icon"
        NOT_FOUND_0x22="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        id="@+id/item_des"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x1b="true"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x20="@+id/item_title"
        NOT_FOUND_0x21="@+id/tag_flow"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/orange_lv1"
        ellipsize="3"
        id="@+id/item_copy_trade_tip"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="2"
        NOT_FOUND_0x1b="true"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x20="@+id/item_title"
        NOT_FOUND_0x21="@+id/item_des"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/user_icon"
        visibility="2"
        layout_width="@dimen/ok_dp_16"
        android:layout_height="@dimen/ok_dp_16"
        src="@drawable/_2131231718_res_0x7f0803e6"
        layout_marginEnd="2dp"
        NOT_FOUND_0x1c="@+id/item_icon"
        NOT_FOUND_0x1e="@+id/user_count"
        NOT_FOUND_0x22="@+id/item_icon"
        NOT_FOUND_0x23="@color/ContentContrast"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        id="@+id/user_count"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="@+id/item_icon"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x22="@+id/item_icon"/>
    <androidx.constraintlayout.widget.Group
        id="@+id/users"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="user_icon,user_count"/>
</androidx.constraintlayout.widget.ConstraintLayout>
