<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    fitsSystemWindows="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/app_bar_layout"
        layout_width="-1"
        android:layout_height="44dp"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/back_button"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131231642_res_0x7f08039a"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x27="0"
            NOT_FOUND_0x28="0"/>
        <TextView
            textSize="18sp"
            textStyle="0x1"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginEnd="@dimen/margin_default"
            NOT_FOUND_0x20="@drawable/_2131231588_res_0x7f080364"
            NOT_FOUND_0x21="true"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x23="0"
            NOT_FOUND_0x26="@+id/back_button"
            NOT_FOUND_0x28="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/select_all_row"
        paddingLeft="@dimen/padding_24dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_24dp"
        paddingVertical="@dimen/padding_16dp">
        <androidx.appcompat.widget.AppCompatImageView
            layout_gravity="0x11"
            id="@+id/icSelectedRadio"
            visibility="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x2b="@drawable/_2131232407_res_0x7f080697"
            NOT_FOUND_0x2c="@color/ContentBrand"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_select_all"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_bottomsheet_status_all"
            layout_marginStart="@dimen/margin_8dp"
            style="@style/Label_1_Medium"/>
        <View
            layout_width="0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
        <o.C52794wYp
            id="@+id/alert_button"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_profile_cell_tag_buy"
            drawableLeft="@drawable/_2131234096_res_0x7f080d30"
            NOT_FOUND_0x29="28"
            NOT_FOUND_0x2a="0x103"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/recycler_view"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_gravity="0x50"
        id="@+id/bottom_actions"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp">
        <LinearLayout
            gravity="0x800013"
            orientation="0"
            id="@+id/btn_move_to"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginBottom="@dimen/margin_16dp"
            layout_weight="1"
            layout_marginStart="@dimen/margin_24dp"
            layout_marginEnd="4dp"
            layout_marginVertical="@dimen/margin_16dp"
            NOT_FOUND_0x24="@+id/guide_btn_middle"
            NOT_FOUND_0x27="0"
            NOT_FOUND_0x28="0">
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/move_icon"
                layout_width="20dp"
                android:layout_height="20dp"
                NOT_FOUND_0x2b="@drawable/_2131230882_res_0x7f0800a2"
                NOT_FOUND_0x2c="@color/ContentPrimary"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_move_button"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_cta_bottom_move"
                maxLines="1"
                layout_marginStart="4dp"
                style="@style/Label_1_Medium"/>
        </LinearLayout>
        <androidx.constraintlayout.widget.Guideline
            orientation="1"
            id="@+id/guide_btn_middle"
            layout_width="1dp"
            android:layout_height="match_parent"
            NOT_FOUND_0x23="0"
            NOT_FOUND_0x25="0.5"
            NOT_FOUND_0x27="0"/>
        <LinearLayout
            gravity="0x800015"
            orientation="0"
            id="@+id/btn_unfollow"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginBottom="@dimen/margin_16dp"
            layout_weight="1"
            layout_marginEnd="@dimen/margin_24dp"
            layout_marginVertical="@dimen/margin_16dp"
            NOT_FOUND_0x23="0"
            NOT_FOUND_0x26="@+id/guide_btn_middle"
            NOT_FOUND_0x28="0">
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/unfollow_icon"
                layout_width="20dp"
                android:layout_height="20dp"
                NOT_FOUND_0x2b="@drawable/_2131232481_res_0x7f0806e1"/>
            <TextView
                ellipsize="3"
                id="@+id/tv_unfollow_button"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_cta_bottom_unfollow"
                maxLines="1"
                layout_marginStart="4dp"
                style="@style/Label_1_Medium"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.fragment.app.FragmentContainerView
        id="@+id/fg_container"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"/>
</LinearLayout>
