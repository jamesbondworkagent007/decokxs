<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/ok_dp_16"
    paddingBottom="@dimen/ok_dp_16"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/ok_dp_16">
    <ImageView
        id="@+id/chain_icon_iv"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131232465_res_0x7f0806d1"
        layout_marginStart="4dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x16="2"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textSize="@dimen/sp_14"
        textColor="@color/ContentTertiary"
        id="@+id/title_tv"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="ChainCatcher"
        layout_marginStart="4dp"
        NOT_FOUND_0x13="@+id/chain_icon_iv"
        NOT_FOUND_0x17="@+id/chain_icon_iv"
        NOT_FOUND_0x1a="@+id/chain_icon_iv"/>
    <TextView
        textSize="@dimen/text_size_24sp"
        textStyle="0x1"
        textColor="@color/ContentTertiary"
        id="@+id/chain_tv"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="·"
        layout_marginStart="@dimen/dp_4"
        NOT_FOUND_0x13="@+id/chain_icon_iv"
        NOT_FOUND_0x17="@+id/title_tv"
        NOT_FOUND_0x1a="@+id/chain_icon_iv"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textSize="@dimen/sp_14"
        textColor="@color/ContentTertiary"
        id="@+id/time_tv"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="2m ago"
        layout_marginStart="@dimen/dp_4"
        NOT_FOUND_0x13="@+id/chain_icon_iv"
        NOT_FOUND_0x17="@+id/chain_tv"
        NOT_FOUND_0x1a="@+id/chain_icon_iv"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/content_tv"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="ChainCatcher"
        maxLines="2"
        fontFamily="@font/font_alpha_regular"
        layout_marginEnd="@dimen/dp_8"
        NOT_FOUND_0x15="@+id/expand_iv"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/title_tv"/>
    <ImageView
        id="@+id/expand_iv"
        paddingTop="2dp"
        paddingBottom="2dp"
        layout_width="@dimen/ok_dp_24"
        android:layout_height="@dimen/ok_dp_24"
        src="@drawable/_2131231647_res_0x7f08039f"
        backgroundTint="@color/ContentContrast"
        paddingVertical="2dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x1a="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
