<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/icon"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xc="@color/ContentBrand"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="16sp"
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="16dp"
        NOT_FOUND_0x7="0"
        NOT_FOUND_0x8="@+id/icon"
        NOT_FOUND_0xb="0"
        style="@style/Label_1_Bold"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="14sp"
        textColor="@color/ContentContrast"
        id="@+id/description"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x7="@+id/title"
        NOT_FOUND_0x9="@+id/title"
        NOT_FOUND_0xa="@+id/title"
        style="@style/Label_2_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
