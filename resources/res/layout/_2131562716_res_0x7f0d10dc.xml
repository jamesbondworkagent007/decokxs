<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="18dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        id="@+id/ll_title"
        tag="layout/view_arbitrage_trade_depth_0"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x2b="0"
        NOT_FOUND_0x2d="0">
        <RelativeLayout
            gravity="0x800003"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <o.C55251xgS
                theme="@style/OKTheme"
                id="@+id/tv_margin"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="2dp"
                layout_alignParentEnd="true"
                NOT_FOUND_0x2e="-5"
                NOT_FOUND_0x2f="2"/>
            <TextView
                textSize="12sp"
                textColor="@color/okTradeG900"
                ellipsize="3"
                id="@+id/tv_inst_name"
                layout_width="-2"
                android:layout_height="wrap_content"
                text=""
                singleLine="true"
                layout_centerVertical="true"
                fontFamily="@font/font_alpha_regular"
                layout_toStartOf="@+id/tv_margin"/>
        </RelativeLayout>
        <TextView
            textAppearance="@style/TextAppearance.Headline.12SP.Regular"
            id="@+id/tv_pack_up"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_spotchart_top_close"
            drawablePadding="4dp"
            drawableEnd="@drawable/_2131231654_res_0x7f0803a6"
            layout_marginStart="4dp"
            NOT_FOUND_0x29="#959dad"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/vg_price"
        tag="layout/view_arbitrage_trade_depth_1"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x2b="0"
        NOT_FOUND_0x2c="@+id/ll_title">
        <TextView
            textSize="10sp"
            textColor="@color/okTradeG400"
            id="@+id/priceTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="@string/pr_trade_input_price"
            drawablePadding="4dp"
            style="@style/TextAppearance.Silka"/>
        <TextView
            textSize="10sp"
            textColor="@color/okTradeG400"
            id="@+id/priceUnit"
            layout_width="-2"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x800005"
        orientation="1"
        id="@+id/vg_amt"
        tag="layout/view_arbitrage_trade_depth_2"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x2a="0"
        NOT_FOUND_0x2c="@+id/ll_title">
        <TextView
            textSize="10sp"
            textColor="@color/okTradeG400"
            id="@+id/amtTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="@string/pr_trade_input_amt"
            drawablePadding="4dp"
            style="@style/TextAppearance.Silka"/>
        <TextView
            textSize="10sp"
            textColor="@color/okTradeG400"
            id="@+id/amtUnit"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Silka"/>
    </LinearLayout>
    <o.C49576urE
        id="@+id/depthAsks"
        tag="layout/view_arbitrage_trade_depth_3"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x21="@color/ContentTertiary"
        NOT_FOUND_0x22="12sp"
        NOT_FOUND_0x23="3"
        NOT_FOUND_0x24="8dp"
        NOT_FOUND_0x25="1"
        NOT_FOUND_0x26="?attr/fallDownColor"
        NOT_FOUND_0x27="12sp"
        NOT_FOUND_0x28="@color/okTradeG100"
        NOT_FOUND_0x2c="@+id/vg_price"/>
    <TextView
        textSize="18sp"
        textStyle="0x1"
        textColor="@color/RubyRed500"
        id="@+id/lastPrice"
        tag="layout/view_arbitrage_trade_depth_4"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxLines="1"
        autoSizeTextType="uniform"
        autoSizeMinTextSize="6sp"
        autoSizeMaxTextSize="18sp"
        NOT_FOUND_0x2c="@+id/depthAsks"
        style="@style/TextAppearance.Bold"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_spread"
        tag="layout/view_arbitrage_trade_depth_5"
        visibility="1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x2b="@+id/lastPrice"
        NOT_FOUND_0x2c="@+id/lastPrice">
        <TextView
            textAppearance="@font/font_alpha_regular"
            textSize="12sp"
            textColor="@color/okTradeG900"
            id="@+id/tv_spread"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_text_spread"
            drawablePadding="4dp"
            drawableEnd="@drawable/_2131232483_res_0x7f0806e3"/>
        <TextView
            textSize="12sp"
            textColor="@color/RubyRed500"
            id="@+id/tv_spread_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="--"
            fontFamily="@font/font_alpha_medium"
            layout_marginStart="12dp"/>
    </LinearLayout>
    <o.C49576urE
        id="@+id/depthBids"
        tag="layout/view_arbitrage_trade_depth_6"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x21="@color/ContentTertiary"
        NOT_FOUND_0x22="12sp"
        NOT_FOUND_0x23="3"
        NOT_FOUND_0x24="8dp"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x26="?attr/riseUpColor"
        NOT_FOUND_0x27="12sp"
        NOT_FOUND_0x28="@color/okTradeG100"
        NOT_FOUND_0x2c="@+id/ll_spread"/>
    <o.C51006veq
        textSize="12sp"
        textColor="@color/okTradeG400"
        gravity="0x10"
        id="@+id/depthLevelView"
        tag="layout/view_arbitrage_trade_depth_7"
        background="@drawable/_2131231255_res_0x7f080217"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8"
        minHeight="24dp"
        drawablePadding="4dp"
        drawableEnd="@drawable/_2131231589_res_0x7f080365"
        paddingStart="8dp"
        paddingEnd="8dp"
        NOT_FOUND_0x2b="0"
        NOT_FOUND_0x2c="@+id/depthBids"
        style="@style/TextAppearance.Silka"/>
    <o.C49581urJ
        id="@+id/depthTickerInfoView"
        tag="layout/view_arbitrage_trade_depth_8"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_10dp"
        NOT_FOUND_0x2c="@+id/depthLevelView"/>
</merge>
