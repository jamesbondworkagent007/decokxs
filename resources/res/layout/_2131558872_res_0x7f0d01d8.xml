<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_24dp"
    layout_marginTop="16dp"
    layout_marginRight="@dimen/margin_24dp"
    layout_marginHorizontal="@dimen/margin_24dp">
    <TextView
        textColor="@color/ContentSecondary"
        id="@+id/subtitle"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_message_paid_group_desc_already_paid_novar"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        style="@style/Body_3_Regular"/>
    <androidx.cardview.widget.CardView
        id="@+id/cardContainer"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        NOT_FOUND_0x12="@color/SurfacePrimary"
        NOT_FOUND_0x13="16dp"
        NOT_FOUND_0x14="0dp"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/subtitle">
        <androidx.constraintlayout.widget.ConstraintLayout
            paddingLeft="16dp"
            paddingTop="20dp"
            paddingRight="16dp"
            paddingBottom="20dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="16dp"
            paddingVertical="20dp">
            <TextView
                textColor="@color/ContentTertiary"
                id="@+id/tvFeeType"
                layout_width="0dp"
                android:layout_height="wrap_content"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1a="0"
                style="@style/Label_2_Regular"/>
            <TextView
                textSize="28sp"
                textColor="@color/ContentPrimary"
                id="@+id/tvAmount"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                NOT_FOUND_0x18="@+id/tvFeeType"
                NOT_FOUND_0x19="@+id/tvFeeType"
                style="@style/Headline_3_Medium"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentPrimary"
                id="@+id/tvCurrency"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="8dp"
                NOT_FOUND_0x15="@+id/tvAmount"
                NOT_FOUND_0x17="@+id/tvAmount"
                style="@style/Label_2_Medium"/>
            <View
                id="@+id/divider"
                background="@color/BorderPrimary"
                layout_width="0dp"
                android:layout_height="0.5dp"
                layout_marginTop="16dp"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="@+id/tvAmount"/>
            <TextView
                textColor="@color/ContentTertiary"
                id="@+id/tvPaymentDueLabel"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="12dp"
                text="@string/pr_message_paid_group_payment_due"
                NOT_FOUND_0x18="@+id/tvFeeType"
                NOT_FOUND_0x19="@+id/divider"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tvPaymentDueDate"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x15="@+id/tvPaymentDueLabel"
                NOT_FOUND_0x16="0"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentTertiary"
                id="@+id/tvLastPaymentLabel"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="12dp"
                text="@string/pr_message_paid_group_last_payment"
                NOT_FOUND_0x18="@+id/tvFeeType"
                NOT_FOUND_0x19="@+id/tvPaymentDueLabel"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tvLastPaymentDate"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x15="@+id/tvLastPaymentLabel"
                NOT_FOUND_0x16="0"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
