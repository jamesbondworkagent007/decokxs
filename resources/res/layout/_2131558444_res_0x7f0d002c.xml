<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/ac_uid_nickname_search_list_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        orientation="0"
        id="@+id/title_layout"
        layout_width="-1"
        android:layout_height="50dp">
        <o.wYC
            layout_gravity="0x800013"
            id="@+id/iv_back"
            background="?attr/selectableItemBackgroundBorderless"
            padding="4dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232348_res_0x7f08065c"
            layout_marginStart="@dimen/margin_default"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.18SP.Semibold"
            gravity="0x11"
            layout_gravity="0x800013"
            id="@+id/tv_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_message_header_title_search_results"
            paddingStart="72dp"
            paddingEnd="72dp"/>
    </FrameLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/search_result"
        layout_width="-1"
        android:layout_height="match_parent"/>
</LinearLayout>
