<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@color/okTradeBackground1"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        gravity="0x1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="48dp"
        text="@string/pr_metax_receivefund_maintitle_open_account"
        style="@style/TextAppearance.Title.16SP.Medium"/>
    <o.C6995aZr
        layout_gravity="0x1"
        id="@+id/qr_code"
        layout_width="144dp"
        android:layout_height="144dp"
        layout_marginTop="60dp"/>
    <TextView
        layout_gravity="0x1"
        id="@+id/tv_wallet_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="EOS WALLET"
        style="@style/TextAppearance.Title.14SP.Medium"/>
    <TextView
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        text="@string/pr_metax_wallet_field_owner_key"
        layout_marginStart="32dp"
        style="@style/TextAppearance.Text.12SP"/>
    <TextView
        id="@+id/tv_owner_key"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="32dp"
        layout_marginTop="2dp"
        layout_marginRight="32dp"
        layout_marginHorizontal="32dp"
        style="@style/TextAppearance.Headline.12SP"/>
    <TextView
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_metax_wallet_field_active_key"
        layout_marginStart="32dp"
        style="@style/TextAppearance.Text.12SP"/>
    <TextView
        id="@+id/tv_active_key"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="32dp"
        layout_marginTop="2dp"
        layout_marginRight="32dp"
        layout_marginHorizontal="32dp"
        style="@style/TextAppearance.Headline.12SP"/>
</LinearLayout>
