<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingTop="@dimen/xxxsm"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        gravity="0x11"
        id="@+id/tv_rank_no"
        layout_width="-2"
        android:layout_height="wrap_content"
        lines="1"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"
        style="@style/Label_1_Bold"/>
    <ImageView
        id="@+id/iv_wallet_logo"
        layout_width="@dimen/md"
        android:layout_height="@dimen/md"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x18="@+id/tv_rank_no"
        NOT_FOUND_0x1b="0"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/addressContainer"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/xxsm"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x14="@+id/last_trade_time_tag"
        NOT_FOUND_0x16="@+id/iv_close"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/iv_wallet_logo"
        NOT_FOUND_0x1b="@+id/iv_wallet_logo">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_holder_address"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="@dimen/xxxsm"
            style="@style/Label_1_Bold"/>
        <o.wYC
            id="@+id/ic_following"
            visibility="2"
            layout_width="@dimen/xsm"
            android:layout_height="@dimen/xsm"
            src="@drawable/_2131233325_res_0x7f080a2d"
            tint="@color/BrandPrimaryAlternative"
            layout_marginStart="@dimen/xxxxsm"/>
        <o.wYC
            id="@+id/btn_copy"
            layout_width="@dimen/xsm"
            android:layout_height="@dimen/xsm"
            src="@drawable/_2131234345_res_0x7f080e29"
            tint="@color/ContentContrast"
            layout_marginStart="@dimen/xxxxsm"/>
    </LinearLayout>
    <o.C55251xgS
        id="@+id/last_trade_time_tag"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxxsm"
        text="@string/pr_swaptrade_token_detail_label_active"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x13="@+id/iv_wallet_logo"
        NOT_FOUND_0x18="@+id/iv_wallet_logo"
        NOT_FOUND_0x1a="@+id/addressContainer"
        NOT_FOUND_0x1c="-4"
        NOT_FOUND_0x1d="false"
        NOT_FOUND_0x1e="6"/>
    <o.C28067kNr
        gravity="0x11"
        orientation="0"
        id="@+id/dex_tag"
        visibility="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/xxxxsm"
        NOT_FOUND_0x13="@+id/last_trade_time_tag"
        NOT_FOUND_0x18="@+id/last_trade_time_tag"
        NOT_FOUND_0x1b="@+id/last_trade_time_tag"/>
    <o.wYC
        id="@+id/iv_close"
        layout_width="@dimen/sm"
        android:layout_height="@dimen/sm"
        src="@drawable/_2131231675_res_0x7f0803bb"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x1b="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
