<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/widget_redeem_double_token_display_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/iv_first_token_icon"
            visibility="2"
            layout_width="32dp"
            android:layout_height="32dp"
            scaleType="6"
            layout_marginEnd="@dimen/margin_8dp"/>
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <o.C27516jwf
                textSize="32sp"
                ellipsize="3"
                id="@+id/tv_first_token_amount"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x13="32sp"
                NOT_FOUND_0x14="12sp"
                style="@style/Headline_2_Bold"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tv_first_token_fiat"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                style="@style/Label_1_Regular"/>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        id="@+id/tv_plus_sign"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginBottom="@dimen/margin_8dp"
        src="@drawable/_2131233687_res_0x7f080b97"
        layout_marginStart="0dp"
        layout_marginVertical="@dimen/margin_8dp"
        NOT_FOUND_0x15="@color/ContentContrast"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/iv_second_token_icon"
            visibility="2"
            layout_width="32dp"
            android:layout_height="32dp"
            scaleType="6"
            layout_marginEnd="@dimen/margin_8dp"/>
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <o.C27516jwf
                textSize="32sp"
                ellipsize="3"
                id="@+id/tv_second_token_amount"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x13="32sp"
                NOT_FOUND_0x14="12sp"
                style="@style/Headline_2_Bold"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tv_second_token_fiat"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                style="@style/Label_1_Regular"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
