<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    background="@drawable/_2131232006_res_0x7f080506"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        paddingLeft="@dimen/margin_16dp"
        paddingTop="@dimen/margin_12dp"
        paddingRight="@dimen/margin_16dp"
        paddingBottom="@dimen/margin_12dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_16dp"
        paddingVertical="@dimen/margin_12dp">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <FrameLayout
                layout_width="-1"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatTextView
                    textAppearance="@style/TextAppearance.Text.12SP.Regular"
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    gravity="0x800003"
                    id="@+id/error_message_title_view"
                    visibility="0"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    maxLines="3"
                    lineSpacingExtra="4dp"/>
                <androidx.appcompat.widget.AppCompatTextView
                    textAppearance="@style/TextAppearance.Text.12SP.Regular"
                    textColor="@color/ContentPrimary"
                    gravity="0x800003"
                    id="@+id/error_message_title_more_view"
                    visibility="0"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    lineSpacingExtra="4dp"/>
                <androidx.appcompat.widget.AppCompatTextView
                    textAppearance="@style/TextAppearance.Text.12SP.Regular"
                    textColor="@color/ContentPrimary"
                    gravity="0x800003"
                    id="@+id/calculate_text_view"
                    visibility="2"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    lineSpacingExtra="4dp"/>
            </FrameLayout>
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/ContentPrimary"
                gravity="0x800003"
                id="@+id/error_message_a_view"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                lineSpacingExtra="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/ContentPrimary"
                gravity="0x800003"
                id="@+id/error_message_b_view"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                lineSpacingExtra="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/ContentPrimary"
                gravity="0x800003"
                id="@+id/error_message_c_view"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                lineSpacingExtra="4dp"/>
        </LinearLayout>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.12SP.Medium"
            textColor="@color/ContentPrimary"
            gravity="0x10"
            id="@+id/more_hide_view"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            text="@string/pr_swaptrade_function_dropdown_show_more"
            drawableEnd="@drawable/_2131231637_res_0x7f080395"
            drawableTint="@color/ContentPrimary"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.Bold.12SP"
            textColor="@color/ContentPrimary"
            gravity="0x10"
            id="@+id/customer_service_view"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"
            text="@string/pr_swaptrade_function_textbtn_contact_customer_support"
            drawablePadding="@dimen/dp_4"
            drawableEnd="@drawable/_2131233694_res_0x7f080b9e"
            drawableTint="@color/ContentPrimary"/>
    </LinearLayout>
</FrameLayout>
