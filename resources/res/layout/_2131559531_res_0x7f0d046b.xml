<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    id="@+id/container_sort"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        id="@+id/container_sort_rank"
        visibility="2"
        layout_width="@dimen/dp_70"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/ok_dp_12">
        <com.okinc.uilab.view.OKSortTextView
            ellipsize="3"
            id="@+id/tv_sort_rank_module"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="110dp"
            text="@string/pr_commonall_column_colheader_rank"
            maxLines="1"
            drawablePadding="2dp"
            NOT_FOUND_0x12="0"
            style="@style/OKSortTextView_Market"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        id="@+id/container_sort_turnover"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <com.okinc.uilab.view.OKSortTextView
            ellipsize="3"
            id="@+id/tv_sort_volume_module"
            visibility="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="110dp"
            text="@string/pr_swaptrade_list_subtitle_vol"
            maxLines="1"
            drawablePadding="2dp"
            NOT_FOUND_0x12="0"
            style="@style/OKSortTextView_Market"/>
        <View
            id="@+id/split_line_1"
            background="@color/ContentDisabled"
            layout_width="0.5dp"
            android:layout_height="12dp"
            layout_marginLeft="@dimen/xxxxsm"
            layout_marginRight="@dimen/xxxxsm"
            layout_marginHorizontal="@dimen/xxxxsm"/>
        <com.okinc.uilab.view.OKSortTextView
            ellipsize="3"
            id="@+id/tv_sort_mcap_module"
            visibility="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_mid_subtitle_m_cap"
            maxLines="1"
            drawablePadding="2dp"
            NOT_FOUND_0x12="0"
            style="@style/OKSortTextView_Market"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <LinearLayout
        gravity="0x800015"
        orientation="0"
        id="@+id/container_sort_change"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <com.okinc.uilab.view.OKSortTextView
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_sort_price_module"
            visibility="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="80dp"
            text="@string/pr_swaptrade_modal_dialog_label_price"
            maxLines="1"
            drawablePadding="2dp"
            NOT_FOUND_0x12="0"
            style="@style/OKSortTextView_Market"/>
        <View
            id="@+id/split_line_2"
            background="@color/ContentDisabled"
            layout_width="0.5dp"
            android:layout_height="12dp"
            layout_marginLeft="@dimen/xxxxsm"
            layout_marginRight="@dimen/xxxxsm"
            layout_marginHorizontal="@dimen/xxxxsm"/>
        <com.okinc.uilab.view.OKSortTextView
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_sort_change_module"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="80dp"
            text="@string/pr_swaptrade_market_item_change"
            maxLines="1"
            drawablePadding="2dp"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="0"
            style="@style/OKSortTextView_Market"/>
    </LinearLayout>
</LinearLayout>
