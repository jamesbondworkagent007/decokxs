<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/line_left"
        background="@color/BorderPrimary"
        layout_width="0dp"
        android:layout_height="0.5dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0xb="@+id/tv_title"
        NOT_FOUND_0xd="@+id/tv_title"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/tv_title"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        layout_marginBottom="12dp"
        layout_marginVertical="12dp"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xd="@+id/iv_chevron"
        NOT_FOUND_0xe="2"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_chevron"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231637_res_0x7f080395"
        layout_marginStart="4dp"
        NOT_FOUND_0xb="@+id/tv_title"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="@+id/tv_title"
        NOT_FOUND_0x11="@+id/tv_title"
        NOT_FOUND_0x12="@color/ContentContrast"/>
    <View
        id="@+id/line_right"
        background="@color/BorderPrimary"
        layout_width="0dp"
        android:layout_height="0.5dp"
        layout_marginStart="12dp"
        NOT_FOUND_0xb="@+id/tv_title"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="@+id/iv_chevron"
        NOT_FOUND_0x11="@+id/tv_title"/>
</merge>
