<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/layout_parent"
    tag="layout/dfragment_defi_bottom_sheet_sub_tx_base_0"
    background="@color/BasePrimaryAlternative"
    clickable="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        id="@+id/fl_header"
        layout_width="-1"
        android:layout_height="8dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0">
        <ImageView
            layout_gravity="0x51"
            id="@+id/ivDrag"
            background="@drawable/_2131232905_res_0x7f080889"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/header"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@+id/fl_header">
        <androidx.constraintlayout.widget.Guideline
            orientation="0"
            id="@+id/centerLine"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1b="16dp"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/back"
            background="?attr/selectableItemBackgroundBorderless"
            paddingTop="@dimen/dp_4"
            paddingBottom="@dimen/dp_4"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231963_res_0x7f0804db"
            paddingStart="@dimen/dp_8"
            paddingEnd="@dimen/dp_8"
            layout_marginStart="16dp"
            NOT_FOUND_0x19="@+id/centerLine"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1f="@+id/centerLine"/>
        <TextView
            textAppearance="@style/Headline_4_Bold"
            textSize="18sp"
            textColor="@color/ContentPrimary"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="10dp"
            NOT_FOUND_0x19="@+id/centerLine"
            NOT_FOUND_0x1c="@+id/back"
            NOT_FOUND_0x1f="@+id/centerLine"
            NOT_FOUND_0x20="16dp"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/titleIcon"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="6dp"
            NOT_FOUND_0x19="@+id/title"
            NOT_FOUND_0x1c="@+id/title"
            NOT_FOUND_0x1f="@+id/title"/>
        <TextView
            textAppearance="@style/Label_3_Medium"
            textColor="@color/ContentContrast"
            id="@+id/titleTag"
            background="@drawable/_2131231254_res_0x7f080216"
            paddingLeft="4dp"
            paddingTop="2dp"
            paddingRight="4dp"
            paddingBottom="2dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"
            paddingHorizontal="4dp"
            paddingVertical="2dp"
            NOT_FOUND_0x19="@+id/centerLine"
            NOT_FOUND_0x1c="@+id/title"
            NOT_FOUND_0x1f="@+id/centerLine"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/close"
            background="?attr/selectableItemBackgroundBorderless"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232438_res_0x7f0806b6"
            tint="@color/ContentContrast"
            layout_marginEnd="14dp"
            NOT_FOUND_0x19="@+id/centerLine"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1f="@+id/centerLine"
            NOT_FOUND_0x21="@color/ContentContrast"/>
        <View
            id="@+id/divider"
            layout_width="-1"
            android:layout_height="0x7f0703c9"
            layout_marginTop="26dp"
            NOT_FOUND_0x1e="@+id/centerLine"
            style="@style/Divider"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        id="@+id/subContentContainer"
        layout_width="-1"
        android:layout_height="0dp"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@+id/header"/>
</androidx.constraintlayout.widget.ConstraintLayout>
