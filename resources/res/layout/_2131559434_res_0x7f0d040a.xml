<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_16dp"
    layout_marginBottom="@dimen/margin_16dp"
    layout_marginVertical="@dimen/margin_16dp">
    <ImageView
        id="@+id/iv_wallet_logo"
        background="@drawable/_2131231992_res_0x7f0804f8"
        layout_width="@dimen/md"
        android:layout_height="@dimen/md"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="2"
        id="@+id/tv_wallet_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/xxsm"
        NOT_FOUND_0x11="@+id/iv_wallet_logo"
        NOT_FOUND_0x14="0"
        style="@style/TextAppearance.Text.16SP.Medium"/>
    <ImageView
        id="@+id/iv_social_icon"
        layout_width="@dimen/xxsm"
        android:layout_height="@dimen/xxsm"
        layout_marginStart="@dimen/xxxxsm"
        NOT_FOUND_0xf="@+id/tv_wallet_address"
        NOT_FOUND_0x11="@+id/tv_wallet_address"
        NOT_FOUND_0x14="@+id/tv_wallet_address"/>
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/tv_win_rate"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxxsm"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="@+id/tv_wallet_address"
        NOT_FOUND_0x13="@+id/tv_wallet_address"
        style="@style/Label_3_Regular"/>
    <TextView
        textColor="?attr/tradeRiseDefault"
        gravity="0x800005"
        id="@+id/tv_7d_pnl"
        paddingLeft="@dimen/margin_4dp"
        paddingRight="@dimen/margin_4dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_4dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800005"
        id="@+id/tv_roi"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxxsm"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="@+id/tv_7d_pnl"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
