<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/tv_sort_turnover"
        layout_width="-2"
        android:layout_height="0dp"
        text="@string/pr_demotrade_colheader_crypto"
        drawablePadding="0dp"
        layout_marginStart="@dimen/dp24"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        style="@style/OkSortBar"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        id="@+id/tv_division"
        layout_width="-2"
        android:layout_height="wrap_content"
        text=" / "
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x10="@+id/tv_sort_turnover"
        NOT_FOUND_0x12="0"
        style="@style/Label_3_Regular"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/tv_sort_mcap"
        layout_width="-2"
        android:layout_height="0dp"
        text="@string/pr_demotrade_colheader_turnover"
        drawablePadding="0dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x10="@+id/tv_division"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        style="@style/OkSortBar"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/tv_sort_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_colheader_last_price"
        drawablePadding="0dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="@+id/tv_slash_symbol"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        style="@style/OkSortBar"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/tv_slash_symbol"
        paddingLeft="2dp"
        paddingRight="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="/"
        drawablePadding="0dp"
        paddingHorizontal="2dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="@+id/tv_sort_change"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x800015"
        id="@+id/tv_sort_change"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_demotrade_colheader_change_today"
        drawablePadding="0dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        style="@style/OkSortBar"/>
</merge>
