<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/fg_coin_info_info_0"
    paddingBottom="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <FrameLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <View
            id="@+id/spaceView"
            layout_width="-1"
            android:layout_height="@dimen/ok_dp_16"/>
        <LinearLayout
            orientation="1"
            id="@+id/shareLayout"
            paddingTop="@dimen/padding_24dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingStart="@dimen/padding_16dp"
            paddingEnd="@dimen/padding_16dp">
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/mCoinInfoRecycler"
                layout_width="-1"
                android:layout_height="wrap_content"
                nestedScrollingEnabled="false"/>
            <FrameLayout
                id="@+id/similar_crypto_container"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <TextView
                textSize="@dimen/text_size_20sp"
                textStyle="0x1"
                textColor="@color/okTradeG900"
                id="@+id/mCoinAbout"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_40dp"
                fontFamily="@font/font_alpha_regular"/>
            <TextView
                textSize="@dimen/text_size_14sp"
                textColor="@color/okTradeG900"
                ellipsize="3"
                id="@+id/mCoinAboutDesc"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_12dp"
                maxLines="4"
                fontFamily="@font/font_alpha_regular"
                lineHeight="24dp"/>
            <LinearLayout
                orientation="0"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textSize="@dimen/text_size_14sp"
                    textColor="@color/okTradeG900"
                    gravity="0x10"
                    id="@+id/mCoinMore"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="@dimen/height_24dp"
                    text="@string/pr_demotrade_dropdown_learn_more"
                    fontFamily="@font/font_alpha_regular"/>
                <ImageView
                    layout_gravity="0x11"
                    id="@+id/icon_arrow"
                    visibility="2"
                    layout_width="12dp"
                    android:layout_height="12dp"
                    layout_marginTop="@dimen/margin_2dp"
                    src="@drawable/_2131232335_res_0x7f08064f"
                    layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/mCoinDetailRecycler"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/ok_dp_16"
        layout_marginRight="@dimen/ok_dp_16"
        nestedScrollingEnabled="false"
        layout_marginHorizontal="@dimen/ok_dp_16"/>
</LinearLayout>
