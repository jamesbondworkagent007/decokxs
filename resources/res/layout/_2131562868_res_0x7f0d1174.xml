<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        tag="layout/view_recurring_coin_config_0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="0"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP.Medium"
                textColor="@color/ContentPrimary"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_recurbot_detail_tunbibao_ccy_need_config"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP.Medium"
                textColor="@color/ContentContrast"
                id="@+id/tv_remain"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/margin_4dp"
                breakStrategy="0"/>
        </LinearLayout>
        <FrameLayout
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/margin_16dp">
            <TextView
                textColor="@color/okTradeG900"
                layout_gravity="0x800005"
                id="@+id/tv_add_coin"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_label_recurring_add_coin"
                drawablePadding="4dp"
                NOT_FOUND_0x10="@color/ContentPrimary"
                style="@style/TextAppearance.Text.14SP.Medium"/>
        </FrameLayout>
    </LinearLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="0"
        id="@+id/smart_alloc_layout"
        tag="layout/view_recurring_coin_config_1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <o.C54984xbQ
            id="@+id/smartAlloc"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_smartportfolio_placeorder_tag_smart_allocate"
            drawablePadding="2dp"
            NOT_FOUND_0x11="-5"/>
        <o.C54984xbQ
            id="@+id/avgAlloc"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_smartportfolio_placeorder_tag_equal_allocate"
            drawablePadding="2dp"
            layout_marginStart="@dimen/margin_8dp"
            NOT_FOUND_0x11="-5"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <LinearLayout
        orientation="1"
        id="@+id/ll_coin_container"
        tag="layout/view_recurring_coin_config_2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Medium"
        textColor="@color/RubyRed500"
        id="@+id/tv_coin_config_tip"
        tag="layout/view_recurring_coin_config_3"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"/>
</merge>
