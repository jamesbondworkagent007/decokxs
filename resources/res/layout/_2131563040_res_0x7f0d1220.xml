<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@drawable/_2131231208_res_0x7f0801e8"
    paddingLeft="10dp"
    paddingTop="6dp"
    paddingRight="10dp"
    paddingBottom="6dp"
    layout_width="-2"
    android:layout_height="wrap_content"
    paddingHorizontal="10dp"
    paddingVertical="6dp">
    <LinearLayout
        orientation="0"
        id="@+id/tv_bonus_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="4dp">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_bonus_apy_key"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_invest_bonus_mid_title_bonus_apy"
            layout_weight="1"
            layout_marginEnd="20dp"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/invest_bonus"
            id="@+id/tv_bonus_apy_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_base_apy_key"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_invest_bonus_mid_title_base_apy"
            layout_weight="1"
            layout_marginEnd="20dp"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_base_apy_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
</LinearLayout>
