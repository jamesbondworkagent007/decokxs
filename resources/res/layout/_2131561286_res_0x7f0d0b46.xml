<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-2"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/logo"
        layout_width="48dp"
        android:layout_height="48dp"
        NOT_FOUND_0x3="0"
        NOT_FOUND_0x6="0"
        NOT_FOUND_0x7="0"
        NOT_FOUND_0x8="0"/>
    <ImageView
        id="@+id/top_left_token"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0x4="@+id/logo"
        NOT_FOUND_0x5="24dp"
        NOT_FOUND_0x7="0"
        NOT_FOUND_0x8="0"/>
    <ImageView
        id="@+id/top_right_token"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0x4="@+id/logo"
        NOT_FOUND_0x5="24dp"
        NOT_FOUND_0x6="0"
        NOT_FOUND_0x8="0"/>
    <ImageView
        id="@+id/bottom_left_token"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0x3="0"
        NOT_FOUND_0x4="@+id/logo"
        NOT_FOUND_0x5="24dp"
        NOT_FOUND_0x7="0"/>
    <ImageView
        id="@+id/bottom_right_token"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0x3="0"
        NOT_FOUND_0x4="@+id/logo"
        NOT_FOUND_0x5="24dp"
        NOT_FOUND_0x6="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
