<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/margin_default"
    paddingTop="14dp"
    paddingRight="@dimen/margin_default"
    paddingBottom="14dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default"
    paddingVertical="14dp">
    <FrameLayout
        id="@+id/container_logo"
        layout_width="38dp"
        android:layout_height="38dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0">
        <ImageView
            id="@+id/iv_logo"
            layout_width="36dp"
            android:layout_height="36dp"/>
        <ImageView
            layout_gravity="0x800055"
            id="@+id/iv_chain"
            layout_width="14dp"
            android:layout_height="14dp"/>
    </FrameLayout>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_symbol"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0x15="@+id/container_logo"
        NOT_FOUND_0x18="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="4dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x12="@+id/tv_name"
        NOT_FOUND_0x14="@+id/iv_delete"
        NOT_FOUND_0x15="@+id/tv_symbol"
        NOT_FOUND_0x18="0"
        style="@style/Label_2_Regular"/>
    <LinearLayout
        gravity="0x10"
        id="@+id/ll_address"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="6dp"
        layout_marginStart="12dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="@+id/container_logo"
        NOT_FOUND_0x17="@+id/tv_name">
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_address"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_2_Regular"/>
        <ImageView
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131234345_res_0x7f080e29"
            layout_marginStart="2dp"
            NOT_FOUND_0x19="@color/ContentContrast"/>
    </LinearLayout>
    <ImageView
        id="@+id/iv_delete"
        layout_width="20dp"
        android:layout_height="20dp"
        src="@drawable/_2131234234_res_0x7f080dba"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@color/ContentPrimary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
