<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingTop="4dp"
    paddingBottom="4dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="4dp">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.16SP.Bold"
            textColor="@color/ContentPrimary"
            gravity="0x800003"
            id="@+id/tv_slippage"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_modal_dialog_title_slippage"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentPrimary"
            gravity="0x800003"
            id="@+id/tv_slippage_desc"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_8"
            text="@string/pr_swaptrade_dialog_subtitle_slippage_refers"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.16SP.Bold"
            textColor="@color/ContentPrimary"
            gravity="0x800003"
            id="@+id/tv_dynamic"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"
            text="@string/pr_swaptrade_limit_header_how_it_works"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentPrimary"
            gravity="0x800003"
            id="@+id/tv_dynamic_desc"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_8"
            text="@string/pr_swaptrade_limit_desc_limit_order_will"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.16SP.Bold"
            textColor="@color/ContentPrimary"
            gravity="0x800003"
            id="@+id/tv_fixed"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"
            text="@string/pr_swaptrade_limit_header_custom_slippage"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentPrimary"
            gravity="0x800003"
            id="@+id/tv_fixed_desc"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_8"
            text="@string/pr_swaptrade_limit_desc_well_only_execute"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
