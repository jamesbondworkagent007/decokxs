<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Title.18SP"
        gravity="0x10"
        id="@+id/tv_title"
        paddingLeft="@dimen/padding_24dp"
        paddingRight="@dimen/padding_24dp"
        layout_width="-1"
        android:layout_height="@dimen/height_48dp"
        text="@string/pr_trade_card_title_margintrading"
        fontFamily="@font/font_alpha_bold"
        paddingHorizontal="@dimen/padding_24dp"
        NOT_FOUND_0x1b="0"/>
    <LinearLayout
        orientation="0"
        id="@+id/ll_biz_container"
        paddingLeft="@dimen/padding_24dp"
        paddingRight="@dimen/padding_24dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_24dp"
        NOT_FOUND_0x1a="@+id/tv_title">
        <TextView
            textSize="14sp"
            textColor="@color/widget_color_grey9_grey4_select"
            gravity="0x11"
            id="@+id/tv_futures_biz"
