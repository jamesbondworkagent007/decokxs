            text="@string/pr_trade_heading_futures_new"
            paddingStart="8dp"
            paddingEnd="8dp"
            layout_marginEnd="12dp"/>
        <TextView
            textSize="14sp"
            textColor="@color/widget_color_grey9_grey4_select"
            gravity="0x11"
            id="@+id/tv_options_biz"
            background="@drawable/_2131233926_res_0x7f080c86"
            layout_width="-2"
            android:layout_height="28dp"
            text="@string/pr_market_tab_option"
            paddingStart="8dp"
            paddingEnd="8dp"/>
    </LinearLayout>
    <o.C55244xgL
        id="@+id/tab_options_group"
        layout_width="-1"
        android:layout_height="@dimen/dp_40"
        NOT_FOUND_0x1a="@+id/ll_biz_container"
        NOT_FOUND_0x1c="1"
        NOT_FOUND_0x1d="-6"/>
    <o.C55244xgL
        id="@+id/tab_options_period"
        layout_width="0dp"
        android:layout_height="@dimen/dp_40"
        layout_marginEnd="@dimen/margin_4dp"
        NOT_FOUND_0x16="@+id/options_filter_sorter_view"
        NOT_FOUND_0x18="@+id/tv_options_chain"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@+id/tab_options_group"
        NOT_FOUND_0x1c="1"
        NOT_FOUND_0x1d="-6"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_12sp"
        textColor="#0569ff"
        gravity="0x11"
        layout_gravity="0x10"
        id="@+id/tv_options_chain"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="0dp"
        text="@string/pr_trade_option_chain_text_options_chain"
        drawablePadding="@dimen/padding_4dp"
        drawableEnd="@drawable/_2131232903_res_0x7f080887"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x15="@+id/tab_options_period"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1b="@+id/tab_options_period"/>
    <o.qSV
        id="@+id/options_filter_sorter_view"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="0"/>
