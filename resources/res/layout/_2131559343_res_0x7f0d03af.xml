<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@color/okTradeBackground1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="14sp"
        textColor="@color/grey_g900"
        gravity="0x800003"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_limit_dialog_desc_insufficient_balance_or_approved1"
        fontFamily="@font/harmony_sans_regular"/>
    <TextView
        textSize="14sp"
        textColor="@color/grey_g900"
        gravity="0x800003"
        id="@+id/tv_value_one"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        text="@string/pr_swaptrade_limit_dialog_desc_insufficient_balance_or_approved2"
        fontFamily="@font/harmony_sans_regular"/>
    <TextView
        textSize="14sp"
        textColor="@color/grey_g900"
        gravity="0x800003"
        id="@+id/tv_value_two"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        text="@string/pr_swaptrade_limit_dialog_desc_insufficient_balance_or_approved3"
        fontFamily="@font/harmony_sans_regular"/>
</LinearLayout>
