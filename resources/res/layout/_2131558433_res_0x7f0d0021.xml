<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/ac_contact_by_uid_nickname_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        id="@+id/title_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginRight="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default">
        <TextView
            textAppearance="@style/TextAppearance.Title.18SP.Semibold"
            gravity="0x11"
            layout_gravity="0x10"
            id="@+id/tv_title"
            paddingTop="@dimen/padding_10dp"
            paddingBottom="@dimen/padding_10dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_message_header_title_add_by_uid"
            paddingVertical="@dimen/padding_10dp"/>
        <o.wYC
            layout_gravity="0x10"
            id="@+id/iv_back"
            background="?attr/selectableItemBackgroundBorderless"
            paddingTop="@dimen/padding_10dp"
            paddingBottom="@dimen/padding_10dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232348_res_0x7f08065c"
            contentDescription="@null"
            paddingVertical="@dimen/padding_10dp"/>
    </FrameLayout>
    <View
        background="@color/LineMuted"
        layout_width="-1"
        android:layout_height="0.5dp"/>
    <com.okinc.uilab.edit.OKEditText
        textAppearance="@style/TextAppearance.Title.15SP"
        id="@+id/et_uid_nickname"
        background="@drawable/_2131232078_res_0x7f08054e"
        paddingLeft="@dimen/padding_8dp"
        paddingTop="@dimen/padding_12dp"
        paddingRight="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_12dp"
        focusable="true"
        focusableInTouchMode="true"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_default"
        hint="@string/pr_message_input_placeholder_enter_uid_nickname"
        lines="1"
        inputType="0x1"
        layout_marginHorizontal="@dimen/margin_default"
        paddingHorizontal="@dimen/padding_8dp"
        paddingVertical="@dimen/padding_12dp"
        autofillHints="username"
        style="@style/EditText.NoLine"/>
    <o.C52794wYp
        enabled="false"
        id="@+id/btn_confirm"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="@dimen/padding_32dp"
        layout_marginRight="@dimen/margin_default"
        text="@string/pr_message_mid_btn_search"
        layout_marginHorizontal="@dimen/margin_default"
        NOT_FOUND_0x1d="52"
        NOT_FOUND_0x1e="0x101"/>
</LinearLayout>
