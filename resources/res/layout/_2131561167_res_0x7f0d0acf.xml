<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <ImageView
        id="@+id/iv_close"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231675_res_0x7f0803bb"
        layout_marginEnd="@dimen/dp_8"
        layout_alignParentEnd="true"/>
    <ImageView
        id="@+id/iv_failed"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131234291_res_0x7f080df3"
        layout_below="@+id/iv_close"
        layout_centerHorizontal="true"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_failed_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="32dp"
        text="@string/pr_compliance_jumio_header_link_error"
        layout_below="@+id/iv_failed"
        layout_centerHorizontal="true"
        style="@style/TextAppearance.Title.Bold.24SP"/>
    <TextView
        textColor="@color/ContentSecondary"
        gravity="0x11"
        id="@+id/tv_failed_message"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/dp24"
        layout_marginTop="32dp"
        layout_marginRight="@dimen/dp24"
        text="@string/pr_compliance_jumio_desc_link_error"
        layout_below="@+id/tv_failed_title"
        layout_centerHorizontal="true"
        layout_marginHorizontal="@dimen/dp24"
        style="@style/TextAppearance.Title.16SP"/>
    <o.C52794wYp
        gravity="0x1"
        id="@+id/try_again"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_20dp"
        text="@string/pr_compliance_common_btn_try_again"
        singleLine="true"
        layout_alignParentBottom="true"
        layout_centerHorizontal="true"
        layout_marginHorizontal="@dimen/margin_16dp"
        NOT_FOUND_0x12="32"
        NOT_FOUND_0x13="0x101"
        NOT_FOUND_0x14="-2"/>
</RelativeLayout>
