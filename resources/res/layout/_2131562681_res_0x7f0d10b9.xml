<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/rootView"
    background="@color/background_lv1"
    paddingLeft="16dp"
    paddingTop="20dp"
    paddingRight="16dp"
    paddingBottom="20dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="16dp"
    paddingVertical="20dp">
    <ImageView
        layout_gravity="0x10"
        id="@+id/iv_start"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="16dp"/>
    <LinearLayout
        layout_gravity="0x10"
        orientation="1"
        id="@+id/ll_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_weight="1">
        <o.C55258xgZ
            id="@+id/title_label"
            layout_width="-2"
            android:layout_height="wrap_content"
            textAlignment="5"
            NOT_FOUND_0x16="2"
            NOT_FOUND_0x17="@color/grey_g900"
            NOT_FOUND_0x18="@dimen/text_size_18sp"
            NOT_FOUND_0x19="@style/OKTextFont.Bold"/>
        <TextView
            textAppearance="@style/OKTextFont.Regular"
            textSize="@dimen/text_size_14sp"
            textColor="@color/grey_g500"
            id="@+id/descriptionTextView"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="6dp"
            textAlignment="5"/>
    </LinearLayout>
    <ImageView
        layout_gravity="0x10"
        id="@+id/iv_end"
        layout_width="-2"
        android:layout_height="wrap_content"
        scaleType="6"
        layout_marginStart="16dp"
        NOT_FOUND_0x1a="@color/grey_g400"/>
</merge>
