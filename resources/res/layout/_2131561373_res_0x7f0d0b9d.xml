<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/layout_kline_tips_spot_cost_0"
    background="@drawable/_2131234138_res_0x7f080d5a"
    padding="@dimen/dp_6"
    layout_width="-2"
    android:layout_height="wrap_content"
    elevation="1dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_net"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/text_size_10sp"
            textColor="@color/white"
            id="@+id/tv_net_key"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_charts_tooltips_net_buy_amount"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.10SP.Regular"
            textColor="@color/white"
            gravity="0x800005"
            id="@+id/tv_net"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            layout_weight="1"
            layout_marginStart="@dimen/dp_6"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_cost_price"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/text_size_10sp"
            textColor="@color/white"
            id="@+id/tv_cost_price_key"
            layout_width="-2"
            android:layout_height="match_parent"
            text="@string/pr_trade_charts_tooltips_cost_price"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.10SP.Regular"
            textColor="@color/white"
            gravity="0x800005"
            id="@+id/tv_cost_price"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            layout_weight="1"
            layout_marginStart="@dimen/dp_6"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_floating"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/text_size_10sp"
            textColor="@color/white"
            id="@+id/tv_floating_key"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_charts_tooltips_floating_pnl"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.10SP.Regular"
            textColor="@color/white"
            gravity="0x800005"
            id="@+id/tv_floating_size"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            layout_weight="1"
            layout_marginStart="@dimen/dp_6"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_tab"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/text_size_10sp"
            textColor="@color/white"
            id="@+id/tv_tab_key"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_commonall_column_tab_pnl"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.10SP.Regular"
            textColor="@color/white"
            gravity="0x800005"
            id="@+id/tv_tab"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            layout_weight="1"
            layout_marginStart="@dimen/dp_6"/>
    </LinearLayout>
</LinearLayout>
