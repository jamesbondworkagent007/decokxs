<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="@dimen/dp_86">
    <ImageView
        id="@+id/default_shimmer_image"
        layout_width="@dimen/dp_70"
        android:layout_height="@dimen/dp_70"
        layout_margin="@dimen/dp_4"
        NOT_FOUND_0x8="0"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xc="0"/>
    <TextView
        id="@+id/default_shimmer_tv_top"
        padding="@dimen/padding_1dp"
        layout_width="@dimen/dp_220"
        android:layout_height="@dimen/dp_15"
        text="Shimmer item top"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x9="@+id/default_shimmer_image"
        NOT_FOUND_0xc="@+id/default_shimmer_image"/>
    <TextView
        id="@+id/default_shimmer_tv_middle"
        padding="@dimen/padding_1dp"
        layout_width="@dimen/dp_180"
        android:layout_height="@dimen/dp_15"
        layout_marginTop="@dimen/dp_4"
        text="Default shimmer item middle"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x9="@+id/default_shimmer_image"
        NOT_FOUND_0xb="@+id/default_shimmer_tv_top"/>
    <TextView
        id="@+id/default_shimmer_tv_bottom"
        padding="@dimen/padding_1dp"
        layout_width="@dimen/dp_120"
        android:layout_height="@dimen/dp_15"
        layout_marginTop="@dimen/dp_4"
        text="Default shimmer item bottom"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x9="@+id/default_shimmer_image"
        NOT_FOUND_0xb="@+id/default_shimmer_tv_middle"/>
</androidx.constraintlayout.widget.ConstraintLayout>
