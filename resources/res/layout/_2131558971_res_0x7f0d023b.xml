<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginBottom="24dp"
    layout_marginStart="24dp">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/topContainer"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x11"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                id="@+id/titleTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/TextAppearance.Text.12SP.Medium"/>
            <TextView
                textColor="@color/ContentDisabled"
                id="@+id/statusTv"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="4dp"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp">
            <TextView
                id="@+id/valueTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/TextAppearance.Text.12SP.Medium"/>
            <ImageView
                id="@+id/chevronIv"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131231639_res_0x7f080397"
                contentDescription="@null"
                layout_marginStart="4dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/detailsContainer"
        background="@drawable/_2131231413_res_0x7f0802b5"
        paddingLeft="12dp"
        paddingTop="16dp"
        paddingRight="12dp"
        paddingBottom="16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        paddingHorizontal="12dp"
        paddingVertical="16dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            background="@drawable/_2131231413_res_0x7f0802b5"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_trade_position_modal_hold_position_cost_tip"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x800005"
                id="@+id/posValueTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            background="@drawable/_2131231413_res_0x7f0802b5"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_fdcabot_orderdetail_item_actual_leverage"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x800005"
                id="@+id/leverTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            background="@drawable/_2131231413_res_0x7f0802b5"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_dcabot_orderdetail_colheader_filled_price"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x800005"
                id="@+id/avgPxTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            background="@drawable/_2131231413_res_0x7f0802b5"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_trade_botspot_text_estimated_liquidation_price"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x800005"
                id="@+id/estLiqPxTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <View
            layout_marginTop="12dp"
            layout_marginBottom="12dp"
            layout_marginVertical="12dp"
            style="@style/Divider"/>
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_fdcabot_orderdetails_subtitle_est_value_after_fill"
            style="@style/Label_3_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <o.C52794wYp
        id="@+id/cancelBtn"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        text="@string/pr_fdcabot_orderdetails_modalbtn_cancel"
        NOT_FOUND_0x16="24"
        NOT_FOUND_0x17="0x104"/>
</androidx.appcompat.widget.LinearLayoutCompat>
