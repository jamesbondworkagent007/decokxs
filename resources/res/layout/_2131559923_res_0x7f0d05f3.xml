<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="@dimen/margin_20dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.okinc.uilab.edit.OKEditText
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/et_straty_name"
        background="@drawable/_2131231428_res_0x7f0802c4"
        layout_width="-1"
        android:layout_height="@dimen/height_48dp"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="12dp"
        layout_marginRight="@dimen/margin_default"
        singleLine="true"
        paddingStart="12dp"
        paddingEnd="12dp"
        layout_marginHorizontal="@dimen/margin_default"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/SemanticNegative"
        id="@+id/tv_error_msg"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x14="@+id/tv_max_length_desc"
        NOT_FOUND_0x15="@+id/et_straty_name"
        NOT_FOUND_0x16="@+id/et_straty_name"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        gravity="0x800015"
        id="@+id/tv_max_length_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x13="@+id/et_straty_name"
        NOT_FOUND_0x16="@+id/et_straty_name"/>
    <o.wYF
        id="@+id/button_box"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="@+id/tv_max_length_desc"
        NOT_FOUND_0x18="@string/pr_trade_bots_recurring_modal_nameconfirm"
        NOT_FOUND_0x19="@string/pr_trade_bots_recurring_modal_namecancel"
        NOT_FOUND_0x1a="52"
        NOT_FOUND_0x1b="14"/>
</androidx.constraintlayout.widget.ConstraintLayout>
