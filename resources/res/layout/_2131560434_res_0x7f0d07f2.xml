<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/xxxsm"
    layout_marginBottom="@dimen/xxxsm"
    minHeight="@dimen/dp_40"
    layout_marginVertical="@dimen/xxxsm">
    <LinearLayout
        gravity="0x10"
        orientation="1"
        id="@+id/ll_name"
        layout_width="0dp"
        android:layout_height="match_parent"
        minWidth="100dp"
        layout_weight="1"
        paddingStart="0dp"
        paddingEnd="@dimen/xxxsm">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tvInvestName"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x13="true"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="@+id/feeRate"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="2"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0"
                style="@style/Label_1_Regular"/>
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                layout_gravity="0x50"
                id="@+id/feeRate"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginStart="2dp"
                NOT_FOUND_0x14="@+id/tvInvestName"
                NOT_FOUND_0x17="@+id/poolTag"
                NOT_FOUND_0x19="2"
                NOT_FOUND_0x1a="@+id/tvInvestName"
                style="@style/Body_4_Regular_Invest"/>
            <o.C55251xgS
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/poolTag"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginStart="4dp"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x19="2"
                NOT_FOUND_0x1a="@+id/feeRate"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0.5"
                NOT_FOUND_0x1e="-4"
                NOT_FOUND_0x1f="6"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tvCoinAmount"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxxsm"
            maxLines="1"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x800015"
        orientation="1"
        id="@+id/ll_info"
        layout_width="-2"
        android:layout_height="match_parent">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tvFiatAmount"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_1_Medium"/>
        <TextView
            layout_gravity="0x800005"
            id="@+id/tvPnl"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
</LinearLayout>
