        background="@color/BorderPrimary"
        visibility="2"
        layout_width="1dp"
        android:layout_height="12dp"
        layout_marginLeft="12dp"
        layout_marginRight="12dp"
        layout_marginHorizontal="12dp"/>
    <View
        id="@+id/oktrade_borrow_space2"
        layout_width="@dimen/width_0dp"
        android:layout_height="0dp"
        layout_weight="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.Regular"
        textSize="12sp"
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/oktrade_borrow_tv_lever"
        layout_width="-2"
        android:layout_height="wrap_content"
        drawablePadding="2dp"
        layout_centerVertical="true"
        drawableEnd="@drawable/_2131232354_res_0x7f080662"
        layout_alignParentEnd="true"
        drawableTint="@color/ContentPrimary"/>
</LinearLayout>
