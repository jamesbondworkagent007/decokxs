<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/view_margin_switch"
    tag="layout/view_spot_loan_switch_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <o.wYK
        theme="@style/OKUITheme"
        id="@+id/switch_margin"
        clickable="false"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_placeorder_checkbox_borrowing"
        NOT_FOUND_0x18="-5"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_switch_margin"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
