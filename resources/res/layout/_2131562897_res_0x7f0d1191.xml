        layout_marginStart="8dp"
        style="@style/TextAppearance.Text.12SP.Medium"/>
    <View
        id="@+id/oktrade_borrow_space1"
        layout_width="@dimen/width_0dp"
        android:layout_height="0dp"
        layout_weight="1"/>
