<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/dp24"
    paddingRight="@dimen/dp24"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginBottom="@dimen/dp_24"
    paddingHorizontal="@dimen/dp24">
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x10"
        id="@+id/img_icon"
        layout_width="18dp"
        android:layout_height="18dp"
        NOT_FOUND_0x10="@+id/tv_real_time_rate_title"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="2"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="2dp"
        NOT_FOUND_0xf="@+id/img_icon"
        NOT_FOUND_0x13="@+id/img_icon"
        NOT_FOUND_0x16="@+id/img_icon"
        style="@style/Label_3_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_real_time_rate_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_12"
        text="@string/pr_trade_futuresanalysis_title_real_time_funding_rate"
        maxLines="1"
        NOT_FOUND_0x12="@+id/tv_real_time_rate_data"
        NOT_FOUND_0x14="@+id/img_icon"
        NOT_FOUND_0x15="@+id/img_icon"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_real_time_rate_data"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xf="@+id/tv_real_time_rate_title"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x16="@+id/tv_real_time_rate_title"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_real_time_price_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_trade_futuresanalysis_title_estimated_funding_fee"
        maxLines="1"
        NOT_FOUND_0x12="@+id/tv_real_time_price_data"
        NOT_FOUND_0x14="@+id/tv_real_time_rate_title"
        NOT_FOUND_0x15="@+id/tv_real_time_rate_title"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/SemanticNegative"
        id="@+id/tv_real_time_price_data"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xf="@+id/tv_real_time_price_title"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x16="@+id/tv_real_time_price_title"
        style="@style/Label_2_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
