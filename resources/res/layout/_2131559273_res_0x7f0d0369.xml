<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/xxsm"
    paddingBottom="@dimen/xxsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/xxsm">
    <ImageView
        id="@+id/iv_kol_avatar"
        layout_width="@dimen/md"
        android:layout_height="@dimen/md"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x19="2"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"/>
    <TextView
        ellipsize="3"
        id="@+id/tv_kol_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x13="true"
        NOT_FOUND_0x15="@+id/ll_kol_tags"
        NOT_FOUND_0x17="@+id/iv_copy"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="2"
        NOT_FOUND_0x1a="@+id/iv_kol_avatar"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="1"
        style="@style/Label_3_Medium"/>
    <ImageView
        id="@+id/iv_copy"
        layout_width="@dimen/xxsm"
        android:layout_height="@dimen/xxsm"
        src="@drawable/_2131234345_res_0x7f080e29"
        layout_marginStart="@dimen/xxxxxsm"
        layout_marginEnd="@dimen/xxsm"
        NOT_FOUND_0x14="@+id/tv_kol_name"
        NOT_FOUND_0x17="@+id/tv_holding_amt"
        NOT_FOUND_0x1a="@+id/tv_kol_name"
        NOT_FOUND_0x1d="@+id/tv_kol_name"
        NOT_FOUND_0x20="@color/ContentContrast"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        id="@+id/ll_kol_tags"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/tv_holding_pct"
        NOT_FOUND_0x1a="@+id/iv_kol_avatar"
        NOT_FOUND_0x1c="@+id/tv_kol_name">
        <o.C55251xgS
            textColor="@color/ContentTertiary"
            id="@+id/tag_kol"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="Influencer"
            drawableStart="@drawable/_2131231912_res_0x7f0804a8"
            drawableTint="@color/ContentTertiary"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_holding_amt"
        layout_width="@dimen/width_80dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/xxsm"
        layout_marginRight="@dimen/xxsm"
        maxLines="1"
        layout_marginHorizontal="@dimen/xxsm"
        NOT_FOUND_0x15="@+id/tv_holding_pct"
        NOT_FOUND_0x17="@+id/tv_pnl_amount"
        NOT_FOUND_0x18="1"
        NOT_FOUND_0x19="2"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="2"
        style="@style/Label_3_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_holding_pct"
        layout_width="@dimen/width_80dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/xxsm"
        layout_marginRight="@dimen/xxsm"
        maxLines="1"
        layout_marginHorizontal="@dimen/xxsm"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/tv_pnl_pct"
        NOT_FOUND_0x1a="@+id/ll_kol_tags"
        NOT_FOUND_0x1c="@+id/tv_holding_amt"
        style="@style/Label_3_Regular"/>
    <TextView
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_pnl_amount"
        layout_width="@dimen/width_80dp"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0x15="@+id/tv_pnl_pct"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="1"
        NOT_FOUND_0x1d="0"
        style="@style/Label_3_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_pnl_pct"
        layout_width="@dimen/width_80dp"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="@+id/tv_holding_pct"
        NOT_FOUND_0x1c="@+id/tv_pnl_amount"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
