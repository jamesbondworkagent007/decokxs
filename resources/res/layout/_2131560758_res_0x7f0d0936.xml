<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_nft_collection_item_0"
    layout_width="-2"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        layout_width="-1"
        android:layout_height="match_parent"
        layout_margin="0.5dp"
        elevation="0dp"
        NOT_FOUND_0x10="4dp"
        NOT_FOUND_0x11="0dp">
        <ImageView
            id="@+id/img_vague"
            layout_width="-1"
            android:layout_height="match_parent"
            scaleType="6"/>
        <ImageView
            id="@+id/img_cover"
            background="@color/white"
            layout_width="-1"
            android:layout_height="match_parent"
            scaleType="6"
            alpha="0.5"/>
        <ImageView
            id="@+id/img_top"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <View
            id="@+id/more_cover"
            background="@color/ScrimPrimary"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <LinearLayout
            gravity="0x11"
            orientation="0"
            id="@+id/more_text"
            background="@color/transparent"
            layout_width="-1"
            android:layout_height="match_parent">
            <TextView
                textSize="@dimen/text_size_10sp"
                textColor="@color/ContentPrimary_Dark"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_commonall_text_btn_view_more"
                style="@style/Label_4_Medium"/>
            <ImageView
                layout_width="12dp"
                android:layout_height="12dp"
                src="@drawable/_2131233694_res_0x7f080b9e"
                layout_marginStart="@dimen/margin_4dp"
                NOT_FOUND_0x12="@color/ContentPrimary_Dark"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <View
        background="@drawable/_2131231174_res_0x7f0801c6"
        layout_width="-1"
        android:layout_height="match_parent"/>
</FrameLayout>
