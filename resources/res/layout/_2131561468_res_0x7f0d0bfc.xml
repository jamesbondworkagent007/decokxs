<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_select_wallet_notice_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_container"
        background="@drawable/_2131234084_res_0x7f080d24"
        paddingLeft="16dp"
        paddingTop="12dp"
        paddingRight="16dp"
        paddingBottom="4dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        layout_marginHorizontal="16dp"
        paddingHorizontal="16dp">
        <ImageView
            id="@+id/iv_warning"
            layout_width="16dp"
            android:layout_height="16dp"
            layout_marginTop="1dp"
            src="@drawable/_2131231745_res_0x7f080401"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"/>
        <TextView
            textSize="12sp"
            textColor="?attr/st_color_g900"
            id="@+id/tv_notice"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginBottom="8dp"
            layout_marginStart="8dp"
            NOT_FOUND_0x16="@+id/ll_action_container"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="@+id/iv_warning"
            NOT_FOUND_0x1b="0"/>
        <LinearLayout
            gravity="0x10"
            id="@+id/ll_action_container"
            paddingLeft="16dp"
            paddingTop="8dp"
            paddingRight="16dp"
            paddingBottom="8dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="8dp"
            paddingHorizontal="16dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x19="@+id/iv_warning"
            NOT_FOUND_0x1a="@+id/tv_notice">
            <TextView
                textSize="12sp"
                textColor="?attr/st_color_g900"
                id="@+id/tv_action"
                layout_width="-2"
                android:layout_height="wrap_content"
                fontFamily="@font/harmony_sans_bold"/>
            <o.wYC
                id="@+id/iv_action"
                layout_width="16dp"
                android:layout_height="16dp"
                layout_marginLeft="4dp"
                src="@drawable/_2131231740_res_0x7f0803fc"
                NOT_FOUND_0x1c="?attr/st_color_g900"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
