<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/padding_8dp"
    paddingBottom="@dimen/padding_8dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/padding_8dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_title"
        paddingTop="@dimen/xxsm"
        paddingBottom="@dimen/xxsm"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp"
        paddingVertical="@dimen/xxsm"
        NOT_FOUND_0x13="0">
        <TextView
            textAppearance="@style/Title_2_Bold"
            textColor="@color/ContentPrimary"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_copytrade_cell_tips_token_filter"
            layout_weight="1"/>
        <ImageView
            id="@+id/iv_arrow"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            layout_marginStart="@dimen/md"
            NOT_FOUND_0x14="@drawable/_2131231654_res_0x7f0803a6"
            NOT_FOUND_0x15="@color/ContentPrimary"/>
    </LinearLayout>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_description"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        text="@string/pr_swaptrade_copytrade_error_for_copy_buying_only"
        layout_marginHorizontal="@dimen/margin_24dp"
        NOT_FOUND_0x12="@+id/ll_title"/>
    <com.okinc.business.dex.trade.copytrading.edit.ui.widget.CopyTradingRangeFilterLayout
        id="@+id/copy_buy_amount_filter"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0x12="@+id/tv_description"
        NOT_FOUND_0x16="@string/pr_swaptrade_copytrade_token_filter_title_buy_amount"/>
    <com.okinc.business.dex.trade.copytrading.edit.ui.widget.CopyTradingRangeFilterLayout
        id="@+id/market_cap_filter"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_10dp"
        NOT_FOUND_0x12="@+id/copy_buy_amount_filter"
        NOT_FOUND_0x16="@string/pr_swaptrade_copytrade_status_market_cap_not_met"/>
    <com.okinc.business.dex.trade.copytrading.edit.ui.widget.CopyTradingRangeFilterLayout
        id="@+id/liquidity_filter"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_10dp"
        NOT_FOUND_0x12="@+id/market_cap_filter"
        NOT_FOUND_0x16="@string/pr_swaptrade_copytrade_cell_title_liquidity"/>
    <com.okinc.business.dex.trade.copytrading.edit.ui.widget.CopyTradingRangeFilterLayout
        id="@+id/token_age_filter"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_10dp"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x12="@+id/liquidity_filter"
        NOT_FOUND_0x16="@string/pr_swaptrade_copytrade_cell_title_token_age"/>
    <o.C19933gUs
        id="@+id/token_blocklist"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0x12="@+id/token_age_filter"/>
</merge>
