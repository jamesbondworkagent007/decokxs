<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x11"
    orientation="0"
    id="@+id/llParent"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x11"
        orientation="0"
        id="@+id/llContent"
        background="@drawable/_2131233964_res_0x7f080cac"
        paddingLeft="@dimen/padding_8dp"
        paddingTop="10dp"
        paddingRight="@dimen/padding_8dp"
        paddingBottom="10dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_8dp"
        paddingVertical="10dp">
        <ImageView
            id="@+id/coin_icon"
            layout_width="16dp"
            android:layout_height="16dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Medium"
            textColor="@color/grey_g700"
            id="@+id/coin_name"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/margin_4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Medium"
            textColor="@color/grey_g900"
            id="@+id/coin_distribute"
            layout_width="-2"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>
