<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="match_parent">
    <ImageView
        id="@+id/iv_error"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131233555_res_0x7f080b13"
        layout_centerInParent="true"
        layout_centerHorizontal="true"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x11"
        id="@+id/tv_failed_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="14dp"
        layout_marginTop="12dp"
        layout_marginRight="14dp"
        text="@string/pr_compliance_jumio_emptystate_network_error"
        layout_below="@+id/iv_error"
        layout_centerHorizontal="true"
        layout_marginHorizontal="14dp"
        style="@style/TextAppearance.Text.14SP"/>
    <TextView
        textColor="@color/ContentSecondary"
        id="@+id/tv_reconnect"
        background="@drawable/_2131231153_res_0x7f0801b1"
        paddingLeft="@dimen/ok_dp_12"
        paddingTop="@dimen/dp_8"
        paddingRight="@dimen/ok_dp_12"
        paddingBottom="@dimen/dp_8"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        text="@string/pr_compliance_common_btn_reload"
        layout_below="@+id/tv_failed_title"
        layout_centerHorizontal="true"
        paddingHorizontal="@dimen/ok_dp_12"
        paddingVertical="@dimen/dp_8"
        style="@style/TextAppearance.Text.14SP"/>
</RelativeLayout>
