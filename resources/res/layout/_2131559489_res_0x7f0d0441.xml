<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131231798_res_0x7f080436"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        padding="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/select_mode_panel"
            layout_width="-2"
            android:layout_height="wrap_content"
            contentDescription="web3_dex_route_selection_dropdown"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1d="0">
            <androidx.appcompat.widget.AppCompatTextView
                textAppearance="@style/TextAppearance.Text.16SP.Regular"
                textColor="@color/ContentPrimary"
                gravity="0x800015"
                id="@+id/tv_select_mode"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxWidth="150dp"
                layout_marginStart="@dimen/margin_16dp"/>
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/iv_chevron"
                layout_width="-2"
                android:layout_height="20dp"
                src="@drawable/_2131231637_res_0x7f080395"
                scaleType="7"
                tint="@color/ContentPrimary"
                layout_marginStart="@dimen/margin_4dp"/>
        </LinearLayout>
        <o.C55320xhi
            textAppearance="@style/TextAppearance.Text.16SP.Regular"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_trade_dialog_title_route_selection"
            maxLines="1"
            layout_marginEnd="8dp"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="@+id/select_mode_panel"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="true"
            NOT_FOUND_0x1f="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        orientation="0"
        id="@+id/mev_panel"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginHorizontal="@dimen/margin_16dp">
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x11"
            id="@+id/btn_mev"
            background="@drawable/_2131231824_res_0x7f080450"
            layout_width="@dimen/width_0dp"
            android:layout_height="36dp"
            text="@string/pr_swaptrade_trade_segmentedctl_mevprotected"
            maxLines="1"
            layout_weight="1"
            contentDescription="web3_dex_route_anti_mev_button"
            layout_marginEnd="@dimen/margin_8dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x11"
            id="@+id/btn_fast"
            background="@drawable/_2131231824_res_0x7f080450"
            layout_width="@dimen/width_0dp"
            android:layout_height="36dp"
            text="@string/pr_swaptrade_trade_segmentedctl_fast"
            maxLines="1"
            layout_weight="1"
            contentDescription="web3_dex_route_fast_button"/>
    </LinearLayout>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/SemanticNegative"
        id="@+id/tv_mev_message"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="8dp"
        layout_marginRight="@dimen/margin_16dp"
        text="@string/pr_swaptrade_trading_mode_alert_mev_switch_routes"
        layout_marginHorizontal="@dimen/margin_16dp"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/SemanticNotice"
        id="@+id/tv_mev_tips"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="8dp"
        layout_marginRight="@dimen/margin_16dp"
        text="@string/pr_swaptrade_meme_reminder_turn_off_mev"
        layout_marginHorizontal="@dimen/margin_16dp"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/SemanticNotice"
        id="@+id/tv_mev_off_message"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="8dp"
        layout_marginRight="@dimen/margin_16dp"
        text="@string/pr_swaptrade_trade_reminder_turn_off_mev"
        layout_marginHorizontal="@dimen/margin_16dp"/>
    <View
        id="@+id/interval"
        visibility="2"
        layout_width="-1"
        android:layout_height="@dimen/margin_16dp"/>
</androidx.appcompat.widget.LinearLayoutCompat>
