<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.AlertDialogLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x800033"
    orientation="1"
    id="@+id/parentPanel"
    layout_width="-1"
    android:layout_height="wrap_content">
    <include layout="@layout/_2131562018_res_0x7f0d0e22"/>
    <FrameLayout
        id="@+id/contentPanel"
        paddingBottom="24dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="48dp">
        <View
            layout_gravity="0x30"
            id="@+id/scrollIndicatorUp"
            background="?attr/colorControlHighlight"
            visibility="2"
            layout_width="-1"
            android:layout_height="1dp"/>
        <androidx.core.widget.NestedScrollView
            id="@+id/scrollView"
            clipToPadding="false"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                orientation="1"
                layout_width="-1"
                android:layout_height="wrap_content">
                <androidx.legacy.widget.Space
                    id="@+id/textSpacerNoTitle"
                    visibility="2"
                    layout_width="-1"
                    android:layout_height="@dimen/abc_dialog_padding_top_material"/>
                <TextView
                    textColor="@color/subtitle_color"
                    id="@android:id/message"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    paddingStart="?attr/dialogPreferredPadding"
                    paddingEnd="?attr/dialogPreferredPadding"
                    style="@style/TextAppearance.Subtitle.14SP"/>
                <androidx.legacy.widget.Space
                    id="@+id/textSpacerNoButtons"
                    visibility="2"
                    layout_width="-1"
                    android:layout_height="@dimen/abc_dialog_padding_top_material"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <View
            layout_gravity="0x50"
            id="@+id/scrollIndicatorDown"
            background="?attr/colorControlHighlight"
            visibility="2"
            layout_width="-1"
            android:layout_height="1dp"/>
    </FrameLayout>
    <FrameLayout
        id="@+id/customPanel"
        paddingBottom="24dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="64dp">
        <FrameLayout
            id="@+id/custom"
            layout_width="-1"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <include
        layout_width="-1"
        android:layout_height="wrap_content"
        layout="@layout/_2131562016_res_0x7f0d0e20"/>
</androidx.appcompat.widget.AlertDialogLayout>
