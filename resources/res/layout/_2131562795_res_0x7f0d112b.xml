<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/file_message_bubble_padding"
    paddingTop="@dimen/file_message_bubble_padding_vertical"
    paddingRight="@dimen/file_message_bubble_padding"
    paddingBottom="@dimen/file_message_bubble_padding_vertical"
    layout_width="-2"
    android:layout_height="wrap_content"
    maxWidth="@dimen/file_message_bubble_max_width"
    minWidth="@dimen/file_message_bubble_min_width"
    paddingHorizontal="@dimen/file_message_bubble_padding"
    paddingVertical="@dimen/file_message_bubble_padding_vertical">
    <FrameLayout
        id="@+id/fl_icon_container"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0">
        <o.wYB
            id="@+id/btn_file_icon"
            layout_width="-2"
            android:layout_height="wrap_content"
            importantForAccessibility="2"
            NOT_FOUND_0x18="0"/>
        <FrameLayout
            id="@+id/fl_downloading_overlay"
            visibility="2"
            layout_width="32dp"
            android:layout_height="32dp">
            <com.google.android.material.progressindicator.CircularProgressIndicator
                layout_gravity="0x11"
                id="@+id/progress_indicator"
                layout_width="32dp"
                android:layout_height="32dp"
                max="100"
                progress="0"
                NOT_FOUND_0x19="0dp"
                NOT_FOUND_0x1a="32dp"
                NOT_FOUND_0x23="3dp"/>
            <ImageView
                layout_gravity="0x11"
                id="@+id/iv_cancel_download"
                layout_width="12dp"
                android:layout_height="12dp"
                scaleType="7"
                importantForAccessibility="2"/>
        </FrameLayout>
    </FrameLayout>
    <TextView
        textSize="16sp"
        textColor="@color/ContentPrimary"
        ellipsize="2"
        id="@+id/tv_file_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        fontFamily="@font/okx_sans_tab_regular"
        layout_marginStart="8dp"
        NOT_FOUND_0x1c="@+id/tv_file_size"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@+id/fl_icon_container"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x22="2"/>
    <TextView
        textSize="12sp"
        textColor="@color/ContentTertiary"
        id="@+id/tv_file_size"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="1"
        fontFamily="@font/okx_sans_tab_regular"
        layout_marginStart="8dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@+id/fl_icon_container"
        NOT_FOUND_0x20="@+id/tv_file_name"/>
</androidx.constraintlayout.widget.ConstraintLayout>
