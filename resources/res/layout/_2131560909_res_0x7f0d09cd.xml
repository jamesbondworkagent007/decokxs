<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_gravity="0x10"
    layout_width="-2"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/mLlMarketSeach"
        visibility="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x24="0">
        <TextView
            textAppearance="@style/TextAppearance.Title.18SP.Semibold"
            ellipsize="3"
            gravity="0x800013"
            id="@+id/mTvMarketCoinName"
            layout_width="-2"
            android:layout_height="@dimen/height_24dp"
            maxLines="1"
            NOT_FOUND_0x1b="true"
            NOT_FOUND_0x1e="@+id/mTvTradeMarginNum"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="2"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x24="0"/>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="12sp"
            textColor="@color/ContentSecondary"
            id="@+id/spot_tag"
            background="@drawable/_2131233294_res_0x7f080a0e"
            paddingLeft="@dimen/padding_4dp"
            paddingTop="@dimen/padding_2dp"
            paddingRight="@dimen/padding_4dp"
            paddingBottom="@dimen/padding_2dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_heading_spot"
            maxLines="1"
            fontFamily="@font/font_alpha_regular"
            layout_marginStart="4dp"
            backgroundTint="@color/SurfacePrimary"
            paddingHorizontal="@dimen/padding_4dp"
            paddingVertical="@dimen/padding_2dp"
            NOT_FOUND_0x1c="@+id/mTvMarketCoinName"
            NOT_FOUND_0x21="@+id/mTvMarketCoinName"
            NOT_FOUND_0x24="@+id/mTvMarketCoinName"/>
        <TextView
            textSize="12sp"
            textColor="@color/ContentSecondary"
            id="@+id/mTvTradeMarginNum"
            background="@drawable/_2131233294_res_0x7f080a0e"
            paddingLeft="@dimen/padding_4dp"
            paddingTop="@dimen/padding_2dp"
            paddingRight="@dimen/padding_4dp"
            paddingBottom="@dimen/padding_2dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="5X"
            maxLines="1"
            fontFamily="@font/font_alpha_regular"
            layout_marginStart="4dp"
            backgroundTint="@color/SurfacePrimary"
            paddingHorizontal="@dimen/padding_4dp"
            paddingVertical="@dimen/padding_2dp"
            NOT_FOUND_0x1c="@+id/mTvMarketCoinName"
            NOT_FOUND_0x1e="@+id/mMarketIvArrow"
            NOT_FOUND_0x21="@+id/spot_tag"
            NOT_FOUND_0x24="@+id/mTvMarketCoinName"/>
        <ImageView
            layout_gravity="0x800013"
            id="@+id/mMarketIvArrow"
            background="@drawable/_2131233921_res_0x7f080c81"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            contentDescription="@null"
            layout_marginStart="2dp"
            NOT_FOUND_0x1c="@+id/mTvMarketCoinName"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x21="@+id/mTvTradeMarginNum"
            NOT_FOUND_0x24="@+id/mTvMarketCoinName"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        orientation="0"
        id="@+id/ll_vice_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        alpha="0"
        NOT_FOUND_0x22="@+id/mLlMarketSeach"
        NOT_FOUND_0x23="@+id/mLlMarketSeach">
        <TextView
            textSize="@dimen/text_size_12sp"
            id="@+id/tv_vice_price"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"
            includeFontPadding="false"
            fontFamily="@font/font_alpha_medium"/>
        <TextView
            textSize="@dimen/text_size_12sp"
            id="@+id/tv_vice_range"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"
            includeFontPadding="false"
            fontFamily="@font/font_alpha_medium"
            layout_marginStart="12dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
