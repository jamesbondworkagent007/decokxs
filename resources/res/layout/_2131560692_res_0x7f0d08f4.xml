<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="18sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            layout_weight="1"
            fontFamily="@font/font_alpha_bold"/>
        <o.pGS
            id="@+id/calendarReminderView"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/dp_6"/>
    </LinearLayout>
    <TextView
        textSize="14sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_time"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="3dp"
        text="--"
        fontFamily="@font/font_alpha_regular"/>
    <LinearLayout
        orientation="0"
        id="@+id/actual_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_14dp">
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_title_actual"
            layout_width="88dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_mid_label_econ_calendar_actual"
            fontFamily="@font/font_alpha_regular"/>
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_actual"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="--"
            fontFamily="@font/font_alpha_regular"
            layout_marginStart="@dimen/dp_10"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        id="@+id/consensus_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_6">
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_title_forecast"
            layout_width="88dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_mid_label_econ_calendar_forecast"
            fontFamily="@font/font_alpha_regular"/>
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_forecast"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="--"
            fontFamily="@font/font_alpha_regular"
            layout_marginStart="@dimen/dp_10"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        id="@+id/previous_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_6">
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_title_previous"
            layout_width="88dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_mid_label_econ_calendar_previous"
            fontFamily="@font/font_alpha_regular"/>
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_previous"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="--"
            fontFamily="@font/font_alpha_regular"
            layout_marginStart="@dimen/dp_10"/>
    </LinearLayout>
    <View
        id="@+id/divider"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="0.75dp"
        layout_marginTop="@dimen/padding_22dp"
        layout_marginBottom="@dimen/padding_22dp"
        layout_marginVertical="@dimen/padding_22dp"/>
</LinearLayout>
