<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@drawable/_2131233963_res_0x7f080cab"
    paddingLeft="@dimen/ok_dp_16"
    paddingTop="@dimen/ok_dp_16"
    paddingRight="@dimen/ok_dp_16"
    paddingBottom="@dimen/padding_8dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginBottom="@dimen/ok_dp_16"
    paddingHorizontal="@dimen/ok_dp_16">
    <ImageView
        id="@+id/de_fi_platform_logo"
        layout_width="@dimen/ok_dp_16"
        android:layout_height="@dimen/ok_dp_16"
        src="@drawable/_2131231496_res_0x7f080308"
        importantForAccessibility="2"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/de_fi_platform_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/margin_6dp"
        layout_marginEnd="@dimen/margin_6dp"
        NOT_FOUND_0x18="true"
        NOT_FOUND_0x19="@+id/de_fi_platform_logo"
        NOT_FOUND_0x1b="@+id/de_fi_platform_info_icon"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="2"
        NOT_FOUND_0x1e="@+id/de_fi_platform_logo"
        NOT_FOUND_0x21="@+id/de_fi_platform_logo"
        style="@style/Label_3_Medium"/>
    <ImageView
        id="@+id/de_fi_platform_info_icon"
        layout_width="@dimen/ok_dp_16"
        android:layout_height="@dimen/ok_dp_16"
        src="@drawable/_2131233141_res_0x7f080975"
        importantForAccessibility="2"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x1b="@+id/approved_tag"
        NOT_FOUND_0x1e="@+id/de_fi_platform_name"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x25="@color/ContentContrast"/>
    <o.C55251xgS
        id="@+id/approved_tag"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_providerselection_quotecolumn_title_approved"
        layout_marginEnd="@dimen/margin_8dp"
        NOT_FOUND_0x1b="@+id/best_tag"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x23="-5"
        NOT_FOUND_0x24="6"/>
    <o.C55251xgS
        id="@+id/best_tag"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_providerselection_quotecolumn_title_best"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x23="-5"
        NOT_FOUND_0x24="7"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/amount_out"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/ok_dp_12"
        maxLines="1"
        NOT_FOUND_0x18="true"
        NOT_FOUND_0x1b="@+id/to_token_symbol"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="2"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/de_fi_platform_name"
        style="@style/Title_2_Bold"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/to_token_symbol"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/ok_dp_12"
        layout_marginStart="@dimen/dp_4"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1e="@+id/amount_out"
        NOT_FOUND_0x20="@+id/de_fi_platform_name"
        style="@style/Title_2_Bold"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/estimated_fiat_amount"
        paddingBottom="@dimen/padding_4dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        NOT_FOUND_0x20="@+id/amount_out"
        style="@style/Label_3_Regular"/>
    <o.C55258xgZ
        textColor="@color/ContentPrimary"
        id="@+id/liquidity_label"
        paddingTop="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_1swap_selectioncard_label_liquidity"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/estimated_fiat_amount"
        NOT_FOUND_0x22="@string/pr_swaptrade_1swap_selectioncard_label_liquidity"
        style="@style/Label_3_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/liquidity_value"
        paddingTop="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingEnd="@dimen/margin_4dp"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x19="@+id/liquidity_label"
        NOT_FOUND_0x1b="@+id/liquidity_chevron_right"
        NOT_FOUND_0x21="@+id/liquidity_label"
        style="@style/Label_3_Regular"/>
    <ImageView
        id="@+id/liquidity_chevron_right"
        paddingTop="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="@dimen/ok_dp_16"
        android:layout_height="0dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        importantForAccessibility="2"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x19="@+id/liquidity_label"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x21="@+id/liquidity_label"
        NOT_FOUND_0x25="@color/ContentPrimary"/>
    <View
        id="@+id/divider"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="@dimen/dp_4"
        NOT_FOUND_0x20="@+id/liquidity_label"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/network_fee_label"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        text="@string/pr_metax_trade_title_estimated_gas"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/divider"
        style="@style/Label_3_Regular"/>
    <TextView
        textColor="?attr/defaultProfit"
        id="@+id/network_fee_free"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_transfer_tag_free"
        layout_marginEnd="@dimen/margin_4dp"
        NOT_FOUND_0x19="@+id/network_fee_label"
        NOT_FOUND_0x1b="@+id/network_fee_value"
        NOT_FOUND_0x21="@+id/network_fee_label"
        style="@style/Label_3_Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/network_fee_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x19="@+id/network_fee_label"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x21="@+id/network_fee_label"
        style="@style/Label_3_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/route_label"
        paddingTop="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        text="@string/pr_swaptrade_1swap_selectioncard_label_trading_route"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/network_fee_label"
        style="@style/Label_3_Regular"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/route_ll"
        layout_width="-2"
        android:layout_height="0dp"
        NOT_FOUND_0x19="@+id/route_label"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x21="@+id/route_label">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/route_list"
            paddingLeft="@dimen/padding_2dp"
            paddingRight="@dimen/padding_2dp"
            layout_width="-2"
            android:layout_height="@dimen/ok_dp_16"
            importantForAccessibility="2"
            paddingHorizontal="@dimen/padding_2dp"
            NOT_FOUND_0x19="@+id/route_label"
            NOT_FOUND_0x1b="@+id/route_chevron_right"
            NOT_FOUND_0x21="@+id/route_label"/>
        <ImageView
            id="@+id/route_chevron_right"
            layout_width="@dimen/ok_dp_16"
            android:layout_height="@dimen/ok_dp_16"
            src="@drawable/_2131231647_res_0x7f08039f"
            importantForAccessibility="2"
            NOT_FOUND_0x19="@+id/route_label"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x21="@+id/route_label"
            NOT_FOUND_0x25="@color/ContentSecondary"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
