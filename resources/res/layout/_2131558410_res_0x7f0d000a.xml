<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/topPanel"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x800013"
        orientation="0"
        id="@+id/title_template"
        paddingLeft="?attr/dialogPreferredPadding"
        paddingTop="@dimen/abc_dialog_padding_top_material"
        paddingRight="?attr/dialogPreferredPadding"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@android:id/icon"
            layout_width="32dp"
            android:layout_height="32dp"
            layout_marginRight="8dp"
            src="@null"
            scaleType="fitStart"
            layout_marginEnd="8dp"/>
        <androidx.appcompat.widget.DialogTitle
            ellipsize="3"
            layout_gravity="0x800003"
            id="@+id/alertTitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            singleLine="true"
            textAlignment="5"
            style="?android:attr/windowTitleStyle"/>
    </LinearLayout>
    <android.widget.Space
        id="@+id/titleDividerNoCustom"
        visibility="2"
        layout_width="-1"
        android:layout_height="@dimen/abc_dialog_title_divider_material"/>
</LinearLayout>
