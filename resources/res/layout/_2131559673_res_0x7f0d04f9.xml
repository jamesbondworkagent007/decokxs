<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x1"
        orientation="1"
        layout_width="-1"
        android:layout_height="0dp"
        layout_marginTop="30dp"
        layout_marginBottom="30dp"
        layout_weight="1"
        layout_marginVertical="30dp">
        <ImageView
            id="@+id/ivProjectIcon"
            layout_width="80dp"
            android:layout_height="80dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x20="@drawable/_2131232468_res_0x7f0806d4"/>
        <TextView
            textAppearance="@style/Title_1_Bold"
            textColor="@color/grey_g900"
            gravity="0x11"
            id="@+id/tvTitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="28dp"
            layout_marginTop="16dp"
            layout_marginRight="28dp"
            text="@string/pr_wallet_connection_title_wants_to_connect"
            layout_marginHorizontal="28dp"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="@+id/ivProjectIcon"/>
        <TextView
            textAppearance="@style/Label_1_Regular"
            textColor="@color/grey_g400"
            gravity="0x11"
            id="@+id/tvSubtitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="28dp"
            layout_marginTop="8dp"
            layout_marginRight="28dp"
            layout_marginHorizontal="28dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="28dp"
            layout_marginTop="16dp"
            layout_marginRight="28dp"
            layout_marginBottom="30dp"
            layout_marginHorizontal="28dp">
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/rvConnectedNetworks"
                background="@drawable/_2131231487_res_0x7f0802ff"
                paddingTop="8dp"
                paddingBottom="8dp"
                visibility="2"
                scrollbars="0x200"
                clipToPadding="false"
                layout_width="-1"
                android:layout_height="wrap_content"
                paddingVertical="8dp"
                NOT_FOUND_0x16="androidx.recyclerview.widget.GridLayoutManager"
                NOT_FOUND_0x17="true"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1f="2"/>
            <View
                id="@+id/dividerConnectedNetworks"
                background="@color/LineSecondary"
                layout_width="0.5dp"
                android:layout_height="0dp"
                layout_marginTop="16dp"
                layout_marginBottom="16dp"
                layout_marginVertical="16dp"
                NOT_FOUND_0x18="@+id/rvConnectedNetworks"
                NOT_FOUND_0x19="@+id/rvConnectedNetworks"
                NOT_FOUND_0x1a="@+id/rvConnectedNetworks"
                NOT_FOUND_0x1c="@+id/rvConnectedNetworks"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <o.C52794wYp
        textAppearance="@style/Label_1_Bold"
        gravity="0x11"
        id="@+id/btnDisconnect"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginBottom="20dp"
        text="@string/pr_metax_btn_disconnect"
        layout_marginHorizontal="@dimen/margin_16dp"
        NOT_FOUND_0x1d="52"
        NOT_FOUND_0x1e="0x101"/>
</LinearLayout>
