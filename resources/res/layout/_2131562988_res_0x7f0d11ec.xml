<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/ll_question_container"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_default"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0">
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x10"
            id="@+id/tv_qa_question"
            layout_width="0dp"
            android:layout_height="wrap_content"
            contentDescription="web3_defi_home_faq_title"
            layout_marginEnd="@dimen/xxxsm"
            NOT_FOUND_0xf="@+id/img_down_arrow"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x12="0"
            style="@style/Body_2"/>
        <ImageView
            id="@+id/img_down_arrow"
            layout_width="16dp"
            android:layout_height="16dp"
            layout_centerVertical="true"
            contentDescription="@null"
            NOT_FOUND_0xe="0"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="@drawable/_2131231637_res_0x7f080395"
            NOT_FOUND_0x14="@color/ContentPrimary"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        textColor="@color/ContentDisabled"
        id="@+id/tv_qa_answer"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_10dp"
        lineSpacingMultiplier="1.2"
        contentDescription="web3_defi_home_faq_content"
        layout_marginEnd="@dimen/margin_40dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/ll_question_container"
        style="@style/Label_2_Regular"/>
    <Space
        id="@+id/bottom_space"
        layout_width="-1"
        android:layout_height="@dimen/margin_24dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x11="@+id/tv_qa_answer"/>
    <View
        id="@+id/bottom_divider"
        background="@color/BorderSecondary"
        layout_width="-1"
        android:layout_height="0.5dp"
        NOT_FOUND_0xd="@+id/bottom_space"/>
</androidx.constraintlayout.widget.ConstraintLayout>
