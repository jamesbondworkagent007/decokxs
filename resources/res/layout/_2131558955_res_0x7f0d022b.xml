<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        id="@+id/searchTitleBar"
        visibility="2"
        layout_width="-1"
        android:layout_height="44dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.18SP.Semibold"
            layout_gravity="0x11"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_discover_tabar_title"/>
        <FrameLayout
            id="@+id/fl_setting"
            padding="@dimen/dp_10"
            visibility="2"
            layout_width="44dp"
            android:layout_height="44dp"
            layout_marginStart="@dimen/margin_14dp"/>
    </FrameLayout>
    <o.C55230xfy
        id="@+id/sb_search"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="8dp"
        layout_marginRight="16dp"
        layout_marginBottom="8dp"
        hint="@string/pr_trade_search_tab_search_pair_strategy_trader"
        contentDescription="discoverSearchButton"
        layout_marginHorizontal="16dp"
        layout_marginVertical="8dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="false"
        NOT_FOUND_0x18="false"
        NOT_FOUND_0x19="-3"/>
    <FrameLayout
        layout_width="-1"
        android:layout_height="match_parent">
        <FrameLayout
            id="@+id/fl_container"
            visibility="0"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <FrameLayout
            id="@+id/market_switch_fragment_anim"
            visibility="2"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <FrameLayout
            id="@+id/emptyViewContainer"
            layout_width="-1"
            android:layout_height="match_parent">
            <o.C55173xeu
                gravity="0x1"
                layout_gravity="0x11"
                id="@+id/emptyView"
                visibility="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0x14="7"
                NOT_FOUND_0x1a="@string/pr_rewards_text_empty_no_date"/>
        </FrameLayout>
    </FrameLayout>
</LinearLayout>
