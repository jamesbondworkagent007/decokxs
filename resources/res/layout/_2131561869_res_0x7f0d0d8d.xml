<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="60dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/img_token_icon"
        layout_width="32dp"
        android:layout_height="32dp"
        src="@drawable/_2131231677_res_0x7f0803bd"
        scaleType="6"
        layout_marginStart="24dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/img_chain_icon"
        background="@drawable/_2131233406_res_0x7f080a7e"
        padding="0.5dp"
        layout_width="@dimen/dp_14"
        android:layout_height="@dimen/dp_14"
        layout_marginTop="20dp"
        src="@drawable/_2131233467_res_0x7f080abb"
        scaleType="fillCenter"
        layout_marginStart="20dp"
        NOT_FOUND_0x1d="@+id/img_token_icon"
        NOT_FOUND_0x1f="@+id/img_token_icon"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800003"
        id="@+id/tv_token_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="16dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x19="@+id/tv_desc"
        NOT_FOUND_0x1c="@+id/img_token_icon"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="2"
        style="@style/TextAppearance.Title.15SP.Medium"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        gravity="0x800003"
        id="@+id/tv_desc"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="2"
        lineSpacingMultiplier="1.3"
        layout_marginStart="16dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1b="@+id/tv_change"
        NOT_FOUND_0x1c="@+id/img_token_icon"
        NOT_FOUND_0x1e="@+id/tv_token_name"
        style="@style/TextAppearance.Title.12SP"/>
