        textColor="@color/okTradeG50"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_change"
        background="@drawable/_2131233755_res_0x7f080bdb"
        layout_width="80dp"
        android:layout_height="32dp"
        maxLines="1"
        paddingStart="5dp"
        paddingEnd="5dp"
        layout_marginEnd="@dimen/dp24"
        NOT_FOUND_0x14="14sp"
        NOT_FOUND_0x15="8sp"
        NOT_FOUND_0x16="1sp"
        NOT_FOUND_0x17="1"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
