        textSize="15sp"
        textColor="@color/ContentPrimary"
        gravity="0x800015"
        layout_gravity="0x800015"
        id="@+id/tv_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        includeFontPadding="false"
        layout_marginEnd="@dimen/dp_12"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1b="@+id/tv_change"
        NOT_FOUND_0x1f="0"
        style="@style/TextAppearance.Title.15SP.Medium"/>
