<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x11"
    orientation="1"
    paddingTop="25dp"
    paddingBottom="5dp"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        layout_width="-2"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_avatar"
            layout_width="120dp"
            android:layout_height="120dp"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_avatar_vip"
            visibility="2"
            layout_width="120dp"
            android:layout_height="120dp"
            src="@drawable/_2131233674_res_0x7f080b8a"/>
    </FrameLayout>
    <TextView
        textAppearance="@style/Title_1_Bold"
        textColor="@color/ContentPrimary_Dark"
        gravity="0x1"
        id="@+id/nickname"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        maxLines="2"/>
    <TextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/ContentPrimary_Dark"
        ellipsize="3"
        gravity="0x1"
        id="@+id/content_text"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        maxLines="3"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        background="@drawable/_2131231135_res_0x7f08019f"
        padding="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp">
        <LinearLayout
            orientation="1"
            paddingLeft="8dp"
            paddingRight="8dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            paddingHorizontal="8dp">
            <TextView
                textAppearance="@style/Label_1_Medium"
                textColor="@color/ContentBrand_Dark"
                gravity="0x1"
                id="@+id/feed_text"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="1"/>
            <TextView
                textAppearance="@style/Label_2_Regular"
                textColor="@color/ContentContrast_Dark"
                gravity="0x1"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="@string/pr_social_homepage_dialog_share_posts"
                maxLines="1"/>
        </LinearLayout>
        <View
            background="@color/BorderPrimary_Dark"
            layout_width="0.5dp"
            android:layout_height="24dp"/>
        <LinearLayout
            orientation="1"
            paddingLeft="8dp"
            paddingRight="8dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            paddingHorizontal="8dp">
            <TextView
                textAppearance="@style/Label_1_Medium"
                textColor="@color/ContentBrand_Dark"
                gravity="0x1"
                id="@+id/followers_text"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="1"/>
            <TextView
                textAppearance="@style/Label_2_Regular"
                textColor="@color/ContentContrast_Dark"
                gravity="0x1"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="@string/pr_social_homepage_dialog_share_followers"
                maxLines="1"/>
        </LinearLayout>
        <View
            background="@color/BorderPrimary_Dark"
            layout_width="0.5dp"
            android:layout_height="24dp"/>
        <LinearLayout
            orientation="1"
            paddingLeft="8dp"
            paddingRight="8dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            paddingHorizontal="8dp">
            <TextView
                textAppearance="@style/Label_1_Medium"
                textColor="@color/ContentBrand_Dark"
                gravity="0x1"
                id="@+id/likes_text"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="1"/>
            <TextView
                textAppearance="@style/Label_2_Regular"
                textColor="@color/ContentContrast"
                gravity="0x1"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="@string/pr_social_homepage_dialog_share_likes"
                maxLines="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
