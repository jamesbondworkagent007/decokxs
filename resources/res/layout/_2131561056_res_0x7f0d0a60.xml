<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <com.okinc.uilab.banner.OKAlertBanner
        id="@+id/okAlertBanner"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="4dp"
        NOT_FOUND_0x1b="@string/pr_swaptrade_token_detail_alertbanner_desc_pnl_unavailable"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="4"/>
    <com.okinc.uilab.reminder.OKReminder
        id="@+id/reminder_no_tx"
        paddingLeft="@dimen/padding_24dp"
        paddingTop="@dimen/height_16dp"
        paddingRight="@dimen/padding_24dp"
        paddingBottom="@dimen/padding_24dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_24dp"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/balance_container"
        paddingLeft="@dimen/sm"
        paddingTop="@dimen/md"
        paddingRight="@dimen/sm"
        paddingBottom="@dimen/md"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/sm"
        paddingVertical="@dimen/md">
        <o.C55258xgZ
            textColor="@color/ContentPrimary"
            id="@+id/title_balance"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x26="1"
            NOT_FOUND_0x27="@color/ContentPrimary"
            NOT_FOUND_0x28="@dimen/text_size_16sp"
            NOT_FOUND_0x29="@string/pr_swaptrade_market_label_my_balance"
            NOT_FOUND_0x2a="@style/TextAppearance.Bold"
            NOT_FOUND_0x2b="500"
            NOT_FOUND_0x2c="@color/BorderSecondary"
            NOT_FOUND_0x2d="0"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxsm">
            <o.C52794wYp
                textColor="@color/ContentPrimary"
                id="@+id/btn_sell_quick"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_commonall_enterfield_title_sell"
                drawableStart="@drawable/_2131233742_res_0x7f080bce"
                drawableTint="@color/ContentPrimary"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x23="0"
                NOT_FOUND_0x24="28"
                NOT_FOUND_0x25="0x102"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/tvBalance"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginEnd="12dp"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x21="@+id/btn_sell_quick"
                NOT_FOUND_0x22="0"
                NOT_FOUND_0x23="0"
                style="@style/Headline_4_Bold"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <o.C34530ndn
            id="@+id/pnl_widget"
            layout_width="-1"
            android:layout_height="wrap_content"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/smartRefreshContainer"
        paddingLeft="@dimen/sm"
        paddingRight="@dimen/sm"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/sm">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/ll_recent_txn"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/title_recent_transactions"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxsm"
                layout_marginBottom="@dimen/xxsm"
                text="@string/pr_swaptrade_market_title_recent_transactions"
                layout_weight="1"
                layout_marginVertical="@dimen/xxsm"
                style="@style/Title_2_Bold"/>
            <o.wYC
                id="@+id/ic_toggle"
                layout_width="@dimen/sm"
                android:layout_height="@dimen/sm"
                NOT_FOUND_0x2f="@drawable/_2131231654_res_0x7f0803a6"
                NOT_FOUND_0x30="@color/ContentPrimary"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            id="@+id/list_top_item"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxsm">
            <RelativeLayout
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="0.8">
                <com.okinc.uilab.view.OKSortTextView
                    ellipsize="3"
                    gravity="0x800003"
                    id="@+id/label_sort"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_market_colheader_type_time"
                    maxLines="2"
                    NOT_FOUND_0x2e="2"
                    style="@style/DexKlineSortTextView_Holder"/>
            </RelativeLayout>
            <com.okinc.uilab.view.OKSortTextView
                ellipsize="3"
                gravity="0x800005"
                id="@+id/label_amount"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_token_detail_tab_amount"
                maxLines="2"
                layout_weight="1"
                layout_marginStart="@dimen/xxxsm"
                NOT_FOUND_0x2e="0"
                style="@style/DexKlineSortTextView_Holder"/>
            <com.okinc.uilab.view.OKSortTextView
                ellipsize="3"
                gravity="0x800005"
                id="@+id/label_price"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_market_text_valueprice"
                maxLines="2"
                layout_weight="0.8"
                layout_marginStart="@dimen/xxxsm"
                NOT_FOUND_0x2e="0"
                style="@style/DexKlineSortTextView_Holder"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rvRecentTransactions"
            layout_width="-1"
            android:layout_height="0dp"
            layout_weight="1"
            NOT_FOUND_0x1e="androidx.recyclerview.widget.LinearLayoutManager"/>
        <o.C52794wYp
            id="@+id/btn_view_more"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxsm"
            layout_marginBottom="@dimen/margin_default"
            text="@string/pr_swaptrade_token_detail_btn_view_more"
            NOT_FOUND_0x24="36"
            NOT_FOUND_0x25="0x104"
            style="@style/Label_2_Bold"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            id="@+id/active_position_header_container"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/title_active_transactions"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/xxsm"
                    layout_marginBottom="@dimen/xxsm"
                    text="@string/pr_swaptrade_token_details_header_active_positons"
                    layout_weight="1"
                    layout_marginVertical="@dimen/xxsm"
                    style="@style/Title_2_Bold"/>
                <o.wYC
                    id="@+id/ic_config_settings"
                    layout_width="@dimen/sm"
                    android:layout_height="@dimen/sm"
                    NOT_FOUND_0x2f="@drawable/_2131231606_res_0x7f080376"
                    NOT_FOUND_0x30="@color/ContentPrimary"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                id="@+id/list_top_item_2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxsm"
                layout_marginBottom="@dimen/xxxsm"
                layout_marginVertical="@dimen/xxxsm">
                <LinearLayout
                    orientation="0"
                    id="@+id/label_mcap"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="0.8">
                    <TextView
                        textColor="@color/ContentContrast"
                        ellipsize="3"
                        layout_gravity="0x10"
                        id="@+id/tv_label_mcap_price"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_swaptrade_common_label_mcap"
                        maxLines="1"
                        style="@style/DexKlineSortTextView_Holder"/>
                    <ImageView
                        layout_gravity="0x10"
                        id="@+id/iv_mcap_price"
                        layout_width="@dimen/xxsm"
                        android:layout_height="@dimen/xxsm"
                        src="@drawable/_2131232098_res_0x7f080562"
                        contentDescription="@string/pr_swaptrade_common_label_mcap"
                        NOT_FOUND_0x30="@color/ContentContrast"/>
                </LinearLayout>
                <com.okinc.uilab.view.OKSortTextView
                    ellipsize="3"
                    gravity="0x800005"
                    id="@+id/label_balance"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_common_label_balance"
                    maxLines="2"
                    layout_weight="1"
                    layout_marginStart="@dimen/xxxsm"
                    NOT_FOUND_0x2e="0"
                    style="@style/DexKlineSortTextView_Holder"/>
                <com.okinc.uilab.view.OKSortTextView
                    ellipsize="3"
                    gravity="0x800005"
                    id="@+id/label_pnl"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_common_label_pnl"
                    maxLines="2"
                    layout_weight="0.8"
                    layout_marginStart="@dimen/xxxsm"
                    NOT_FOUND_0x2e="0"
                    style="@style/DexKlineSortTextView_Holder"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</LinearLayout>
