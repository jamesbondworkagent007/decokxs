<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    background="@drawable/_2131231143_res_0x7f0801a7"
    paddingTop="@dimen/padding_12dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-2"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/padding_12dp">
    <ImageView
        id="@+id/coin_icon"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_centerVertical="true"
        layout_marginStart="@dimen/margin_12dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/grey_g700"
        id="@+id/coin_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_4dp"
        layout_toEndOf="@+id/coin_icon"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/grey_g900"
        id="@+id/coin_distribute"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/margin_12dp"
        layout_alignParentEnd="true"/>
</RelativeLayout>
