<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-2"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/PreferenceProfitModern"
        gravity="0x11"
        id="@+id/ranking_trade_history_win_tv"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="0"
        style="@style/Label_2_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/separator"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="/"
        NOT_FOUND_0xa="@+id/ranking_trade_history_loss_tv"
        NOT_FOUND_0xc="@+id/ranking_trade_history_win_tv"
        NOT_FOUND_0xf="0"
        style="@style/Label_2_Medium"/>
    <TextView
        textColor="@color/PreferenceLossModern"
        gravity="0x11"
        id="@+id/ranking_trade_history_loss_tv"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xc="@+id/separator"
        NOT_FOUND_0xf="0"
        style="@style/Label_2_Medium"/>
    <View
        orientation="1"
        id="@+id/separator_center"
        layout_width="1dp"
        android:layout_height="1dp"
        NOT_FOUND_0x9="@+id/separator"
        NOT_FOUND_0xb="0.5"
        NOT_FOUND_0xd="@+id/separator"
        NOT_FOUND_0xe="@+id/separator"/>
    <LinearLayout
        orientation="0"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x9="@+id/ranking_trade_history_loss_tv"
        NOT_FOUND_0xd="@+id/ranking_trade_history_win_tv"
        NOT_FOUND_0xe="@+id/separator_center">
        <View
            id="@+id/win_underscore_view"
            background="@drawable/_2131231819_res_0x7f08044b"
            layout_width="0dp"
            android:layout_height="2dp"
            layout_weight="0.5"/>
        <View
            id="@+id/loss_underscore_view"
            background="@drawable/_2131231820_res_0x7f08044c"
            layout_width="0dp"
            android:layout_height="2dp"
            layout_weight="0.5"/>
    </LinearLayout>
</merge>
