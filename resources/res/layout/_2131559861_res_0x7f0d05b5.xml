<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        id="@+id/root_scroll_view"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"
        overScrollMode="2">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="match_parent">
            <LinearLayout
                orientation="1"
                id="@+id/chartContainer"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_20dp"/>
            <LinearLayout
                orientation="1"
                id="@+id/infoContainer"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <FrameLayout
                id="@+id/team_members_container"
                layout_width="-1"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
