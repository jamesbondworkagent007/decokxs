<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    background="@drawable/_2131234245_res_0x7f080dc5"
    paddingLeft="@dimen/padding_16dp"
    paddingRight="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/padding_16dp">
    <ImageView
        id="@+id/imageView"
        layout_width="@dimen/dp_72"
        android:layout_height="@dimen/dp_72"
        layout_centerVertical="true"
        layout_marginEnd="@dimen/margin_16dp"
        layout_alignParentStart="true"/>
    <LinearLayout
        gravity="0x10"
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        layout_toEndOf="@+id/imageView">
        <TextView
            textColor="@color/color_content_static_subtle"
            ellipsize="3"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginEnd="47dp"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/color_content_static_subtler"
            ellipsize="3"
            id="@+id/content"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            maxLines="3"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
</RelativeLayout>
