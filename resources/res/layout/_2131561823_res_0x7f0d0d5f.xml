<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="@dimen/dp24"
    paddingRight="@dimen/dp24"
    layout_width="-1"
    android:layout_height="74dp"
    paddingHorizontal="@dimen/dp24">
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x10"
        id="@+id/img_icon"
        layout_width="18dp"
        android:layout_height="18dp"
        NOT_FOUND_0x15="@+id/progress_bar"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="2"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="4dp"
        NOT_FOUND_0x14="@+id/img_icon"
        NOT_FOUND_0x17="@+id/img_icon"
        NOT_FOUND_0x1a="@+id/img_icon"
        style="@style/Label_3_Regular"/>
    <o.qXV
        id="@+id/progress_bar"
        layout_width="0dp"
        android:layout_height="4dp"
        layout_marginTop="10dp"
        layout_marginEnd="4dp"
        NOT_FOUND_0x13="@color/BorderPrimary"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/img_icon"
        NOT_FOUND_0x1c="0.67"
        NOT_FOUND_0x1d="100"
        NOT_FOUND_0x1e="@color/positive"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/positive"
        ellipsize="3"
        gravity="0x800015"
        id="@+id/tv_value"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        autoSizeTextType="uniform"
        autoSizeStepGranularity="1sp"
        autoSizeMinTextSize="8sp"
        autoSizeMaxTextSize="12sp"
        NOT_FOUND_0x14="@+id/progress_bar"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="@+id/progress_bar"
        NOT_FOUND_0x1c="0.33"
        style="@style/Label_3_Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
