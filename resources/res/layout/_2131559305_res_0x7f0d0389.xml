                    gravity="0x10"
                    orientation="0"
                    id="@+id/tv_mcap_label"
                    background="@drawable/_2131231856_res_0x7f080470"
                    paddingLeft="6dp"
                    paddingRight="6dp"
                    layout_width="-2"
                    android:layout_height="match_parent"
                    paddingHorizontal="6dp">
                    <TextView
                        textColor="@color/ContentContrast"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_swaptrade_common_label_mcap_abbreviated"
                        includeFontPadding="false"
                        style="@style/Label_3_Regular"/>
                    <TextView
                        ellipsize="3"
                        id="@+id/tv_mcap_value"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxLines="1"
                        layout_marginStart="2dp"
                        style="@style/Label_2_Medium"/>
                </androidx.appcompat.widget.LinearLayoutCompat>
                <androidx.appcompat.widget.LinearLayoutCompat
                    gravity="0x10"
                    orientation="0"
                    id="@+id/tv_vol_label"
                    background="@drawable/_2131231856_res_0x7f080470"
                    paddingLeft="6dp"
                    paddingRight="6dp"
                    layout_width="-2"
                    android:layout_height="match_parent"
                    layout_marginLeft="4dp"
                    layout_marginRight="4dp"
                    layout_marginHorizontal="4dp"
                    paddingHorizontal="6dp">
                    <TextView
                        textColor="@color/ContentContrast"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_swaptrade_common_label_volume_abbreviated"
                        includeFontPadding="false"
                        style="@style/Label_3_Regular"/>
                    <TextView
                        textColor="@color/ContentPrimary"
                        ellipsize="3"
                        id="@+id/tv_vol_value"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxLines="1"
                        layout_marginStart="2dp"
                        style="@style/Label_2_Medium"/>
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </HorizontalScrollView>
        <o.C52794wYp
            id="@+id/btn_buy"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1d="@+id/hsv_mcap_vol"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x24="@+id/hsv_mcap_vol"
            NOT_FOUND_0x25="24"
            NOT_FOUND_0x26="0x103"/>
