            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x24="@+id/iv_token_icon"/>
        <HorizontalScrollView
            id="@+id/hsv_mcap_vol"
            scrollbars="horizontal"
            layout_width="-2"
            android:layout_height="24dp"
            layout_marginTop="8dp"
            NOT_FOUND_0x1c="true"
            NOT_FOUND_0x1f="@+id/btn_buy"
            NOT_FOUND_0x20="0"
            NOT_FOUND_0x22="@+id/iv_token_icon"
            NOT_FOUND_0x23="@+id/iv_token_icon">
