            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_token_name"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                textAlignment="2"
                layout_marginStart="@dimen/xxxxsm"
                style="@style/Label_2_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <HorizontalScrollView
            gravity="0x800013"
            orientation="0"
            scrollbars="horizontal"
            layout_width="-2"
            android:layout_height="16dp"
            layout_marginLeft="@dimen/xxsm"
            layout_marginTop="4dp"
            layout_marginRight="@dimen/xxsm"
            layout_marginHorizontal="@dimen/xxsm"
            NOT_FOUND_0x1c="true"
            NOT_FOUND_0x1f="@+id/chart_view"
            NOT_FOUND_0x20="0"
            NOT_FOUND_0x21="@+id/iv_token_icon"
            NOT_FOUND_0x23="@+id/ll_token_info_container">
