                <ImageView
                    id="@+id/tv_dev_hold_separator"
                    layout_width="3dp"
                    android:layout_height="3dp"
                    layout_marginLeft="@dimen/xxxxsm"
                    layout_marginRight="@dimen/xxxxsm"
                    src="@drawable/_2131232044_res_0x7f08052c"
                    layout_marginHorizontal="@dimen/xxxxsm"
                    NOT_FOUND_0x27="@color/BorderSecondary"/>
                <ImageView
