<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root_view"
    background="@color/BasePrimary"
    paddingLeft="@dimen/margin_default"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/margin_default"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    backgroundTint="@color/crypto_cell_color_selector"
    paddingHorizontal="@dimen/margin_default"
    paddingVertical="@dimen/padding_12dp">
    <o.C31222lpu
        layout_gravity="0x10"
        id="@+id/coin_chain_icon"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1b="@dimen/height_16dp"
        NOT_FOUND_0x1c="@dimen/height_36dp"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x24="@dimen/height_16dp"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textSize="16sp"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/crypto_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        textAlignment="5"
        layout_marginStart="@dimen/xxsm"
        lineHeight="20dp"
        NOT_FOUND_0x20="@+id/coin_chain_icon"
        NOT_FOUND_0x23="0"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        id="@+id/crypto_description"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        textAlignment="5"
        layout_marginStart="@dimen/xxsm"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x20="@+id/coin_chain_icon"
        NOT_FOUND_0x22="@+id/crypto_title"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textSize="16sp"
        textColor="@color/grey_g900"
        gravity="0x800015"
        id="@+id/price_main_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginEnd="@dimen/xxsm"
        autoSizeTextType="uniform"
        autoSizeStepGranularity="2sp"
        autoSizeMinTextSize="12sp"
        autoSizeMaxTextSize="16sp"
        NOT_FOUND_0x1f="@+id/selectAction"
        NOT_FOUND_0x23="@+id/crypto_title"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/price_sub_title"
        layout_width="-2"
        android:layout_height="16dp"
        layout_marginTop="4dp"
        maxLines="1"
        textAlignment="6"
        layout_marginEnd="@dimen/xxsm"
        autoSizeTextType="uniform"
        autoSizeMinTextSize="12sp"
        autoSizeMaxTextSize="16sp"
        NOT_FOUND_0x1d="@+id/crypto_description"
        NOT_FOUND_0x1f="@+id/selectAction"/>
    <ImageView
        id="@+id/selectAction"
        layout_width="@dimen/width_20dp"
        android:layout_height="@dimen/width_20dp"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x23="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
