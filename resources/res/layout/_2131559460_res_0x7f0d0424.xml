<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_label_title_search_x"
        paddingTop="12dp"
        paddingBottom="12dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_token_detail_title_search_on_x"
        paddingVertical="12dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        style="@style/Title_2_Bold"/>
    <com.google.android.flexbox.FlexboxLayout
        id="@+id/flexbox_search"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x9="2"
        NOT_FOUND_0xa="@drawable/_2131231967_res_0x7f0804df"
        NOT_FOUND_0xb="1"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="false"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/tv_label_title_search_x"
        NOT_FOUND_0x12="0x2"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_label_title_social_links"
        paddingTop="12dp"
        paddingBottom="12dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_swaptrade_common_header_social_links"
        paddingVertical="12dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/flexbox_search"
        style="@style/Title_2_Bold"/>
    <com.google.android.flexbox.FlexboxLayout
        id="@+id/flexbox_socials"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x9="2"
        NOT_FOUND_0xa="@drawable/_2131231967_res_0x7f0804df"
        NOT_FOUND_0xb="1"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="false"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/tv_label_title_social_links"
        NOT_FOUND_0x12="0x2"/>
</merge>
