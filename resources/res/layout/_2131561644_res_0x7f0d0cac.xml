<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content"
    contentDescription="marketsFavoritesGroupManageNewGroupPage">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        text="@string/pr_trade_favorites_btn_new_group"
        layout_marginStart="@dimen/dp_24"
        style="@style/Label_2_Regular"/>
    <com.okinc.uilab.edit.OKEditText
        textSize="16sp"
        textColor="@color/ContentPrimary"
        textColorHint="@color/ContentDisabled"
        id="@+id/edit_text"
        background="@drawable/_2131233407_res_0x7f080a7f"
        padding="12dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="8dp"
        layout_marginRight="24dp"
        hint="@string/pr_trade_favorites_bttmsheet_title_enter_group_name"
        inputType="0x1"
        layout_marginHorizontal="24dp"
        style="@style/Label_2_Regular">
        <requestFocus/>
    </com.okinc.uilab.edit.OKEditText>
    <TextView
        textColor="@color/SemanticNegative"
        id="@+id/tv_invalid_tip"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="8dp"
        layout_marginRight="24dp"
        text="@string/pr_trade_favorites_bttmsheet_error_only_letters_numbers_underscores"
        layout_marginHorizontal="24dp"
        style="@style/Label_3_Regular"/>
    <o.C52794wYp
        enabled="false"
        id="@+id/btn_new_group"
        layout_width="-1"
        android:layout_height="52dp"
        layout_marginTop="40dp"
        layout_marginBottom="16dp"
        text="@string/pr_trade_favorites_bttmsheet_btn_create_group"
        layout_marginStart="24dp"
        layout_marginEnd="@dimen/dp24"
        NOT_FOUND_0x16="48"
        NOT_FOUND_0x17="0x101"/>
</LinearLayout>
