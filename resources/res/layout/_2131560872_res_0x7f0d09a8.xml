<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="@dimen/padding_16dp"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_16dp">
    <TextView
        textAppearance="@style/Headline_4_Bold"
        textColor="@color/ContentPrimary"
        id="@+id/tvTitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_metax_wallet_header_wallet_center"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/grey_g400"
        gravity="0x10"
        id="@+id/tvSubtitle"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"/>
    <o.C52794wYp
        textAppearance="@style/TextAppearance.Text.Bold"
        id="@+id/btnPrimary"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_metax_onboard_button_create_new"
        NOT_FOUND_0xe="52"
        NOT_FOUND_0xf="0x101"/>
    <o.C52794wYp
        textAppearance="@style/TextAppearance.Text.Bold"
        id="@+id/btnSecondary"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_metax_onboard_button_importing_existing"
        NOT_FOUND_0xe="52"
        NOT_FOUND_0xf="0x31"/>
    <Space
        id="@+id/emptySpace"
        visibility="2"
        layout_width="-1"
        android:layout_height="@dimen/height_16dp"/>
</LinearLayout>
