<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    scrollbars="horizontal"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        paddingTop="@dimen/height_48dp"
        paddingBottom="@dimen/dp_40"
        layout_width="-1"
        android:layout_height="match_parent">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/warning"
            layout_width="100dp"
            android:layout_height="100dp"
            src="@drawable/_2131232315_res_0x7f08063b"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x13="0"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Headline_5_Bold"
            textColor="@color/title_color"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            text="@string/pr_wallet_import_title_being_imported"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="@+id/warning"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.16SP"
            textSize="@dimen/text_size_16sp"
            textColor="@color/text_secondary"
            gravity="0x1"
            paddingLeft="@dimen/padding_32dp"
            paddingRight="@dimen/padding_32dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            text="@string/pr_wallet_import_subtitle_being_imported"
            paddingHorizontal="@dimen/padding_32dp"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="@+id/title"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
