<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_dapp_interaction_wallet_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="16sp"
        textColor="@color/grey_g400"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_metax_trade_subtitle_wallet"
        layout_marginEnd="16dp"
        NOT_FOUND_0x14="@+id/guideline"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="1"/>
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideline"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="0.5"/>
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="16sp"
        textColor="@color/grey_g900"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_wallet"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        layout_marginStart="32dp"
        layout_marginEnd="4dp"
        NOT_FOUND_0x14="@+id/iv_copy"
        NOT_FOUND_0x17="@+id/tv_title"
        NOT_FOUND_0x1a="0"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_address"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x13="@+id/tv_wallet"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/tv_wallet">
        <TextView
            textAppearance="@style/TextAppearance"
            textSize="14sp"
            textColor="@color/grey_g400"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_address"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginEnd="6dp"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x14="@+id/address_tag"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0dp"/>
        <o.C55251xgS
            ellipsize="3"
            id="@+id/address_tag"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1d="-2"
            NOT_FOUND_0x1e="-4"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="6"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/btc_balance_layout"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0x13="@+id/tv_wallet"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/cl_address">
        <ImageView
            id="@+id/iv_btc_bal_info"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            src="@drawable/_2131233141_res_0x7f080975"
            contentDescription="@null"
            layout_marginEnd="@dimen/margin_4dp"
            NOT_FOUND_0x12="@+id/tv_btc_balance"
            NOT_FOUND_0x14="@+id/tv_btc_balance"
            NOT_FOUND_0x1a="@+id/tv_btc_balance"
            NOT_FOUND_0x21="@color/ContentContrast_Light"/>
        <TextView
            textColor="@color/ContentContrast_Light"
            gravity="0x800005"
            id="@+id/tv_btc_balance"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x1a="0"
            style="@style/Label_3_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView
        id="@+id/iv_copy"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231721_res_0x7f0803e9"
        NOT_FOUND_0x12="@+id/cl_address"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x1a="@+id/cl_address"
        NOT_FOUND_0x21="@color/ContentContrast"/>
