<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/item_creator_centre_earnings_total_paid_out_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="8dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/aboutLayout"
        paddingLeft="24dp"
        paddingRight="24dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingHorizontal="24dp">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_orbit_creatorcenter_title_total_paid_out"
            style="@style/Label_2_Regular"/>
        <ImageView
            id="@+id/faq"
            layout_width="12dp"
            android:layout_height="12dp"
            src="@drawable/_2131233141_res_0x7f080975"
            contentDescription="@null"
            layout_marginStart="4dp"
            NOT_FOUND_0x11="@color/ContentContrast"/>
    </LinearLayout>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tvTotalPaidOutAmount"
        paddingLeft="24dp"
        paddingRight="24dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        paddingHorizontal="24dp"
        style="@style/Headline_5_Bold"/>
    <View
        background="@color/color_border_static_default"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="24dp"
        layout_marginBottom="12dp"/>
</LinearLayout>
