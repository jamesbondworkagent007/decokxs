<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/order_layout"
    tag="layout/fragment_bot_order_confirm_0"
    paddingLeft="@dimen/margin_default"
    paddingRight="@dimen/margin_default"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/margin_default">
    <androidx.core.widget.NestedScrollView
        id="@+id/nsvLayout"
        background="@null"
        layout_width="-1"
        android:layout_height="wrap_content"
        overScrollMode="2">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                gravity="0x1"
                orientation="1"
                id="@+id/llInvest"
                paddingTop="16dp"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentSecondary"
                    id="@+id/tvInvestTitle"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Title.18SP.Semibold"/>
                <LinearLayout
                    gravity="0x11"
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_12dp"
                    layout_marginBottom="28dp">
                    <ImageView
                        id="@+id/ivCoin"
                        layout_width="26dp"
                        android:layout_height="26dp"/>
                    <TextView
                        textAppearance="@style/TextAppearance.Title.24SP.Semibold"
                        textColor="@color/ContentPrimary"
                        id="@+id/tvInvestAmount"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        layout_marginStart="8dp"/>
                </LinearLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    id="@+id/allocationlly"
                    background="@drawable/_2131231494_res_0x7f080306"
                    paddingLeft="@dimen/padding_12dp"
                    paddingTop="@dimen/padding_16dp"
                    paddingRight="@dimen/padding_12dp"
                    paddingBottom="@dimen/padding_16dp"
                    visibility="2"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    backgroundTint="@color/SurfacePrimary"
                    paddingHorizontal="@dimen/padding_12dp"
                    paddingVertical="@dimen/padding_16dp">
                    <TextView
                        textColor="@color/ContentPrimary"
                        id="@+id/tvAllocationTitle"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_spotgrid_confirmorder_cardtitle_est_initial_allocation"
                        NOT_FOUND_0x19="0"
                        NOT_FOUND_0x1b="0"
                        style="@style/TextAppearance.Text.14SP.Medium"/>
                    <o.wUX
                        id="@+id/distributionBarView"
                        background="@color/SurfacePrimary"
                        layout_width="0dp"
                        android:layout_height="@dimen/dp_6"
                        layout_marginTop="@dimen/padding_12dp"
                        NOT_FOUND_0x18="0"
                        NOT_FOUND_0x19="0"
                        NOT_FOUND_0x1a="@+id/tvAllocationTitle"/>
                    <LinearLayout
                        orientation="0"
                        id="@+id/coinTextLly"
                        visibility="2"
                        layout_width="0dp"
                        android:layout_height="wrap_content"
                        layout_marginTop="@dimen/padding_12dp"
                        NOT_FOUND_0x18="0"
                        NOT_FOUND_0x19="0"
                        NOT_FOUND_0x1a="@+id/distributionBarView"/>
                    <androidx.appcompat.widget.LinearLayoutCompat
                        orientation="0"
                        id="@+id/positionsOpenedLL"
                        visibility="2"
                        layout_width="-1"
                        android:layout_height="wrap_content"
                        layout_marginTop="12dp"
                        NOT_FOUND_0x18="0"
                        NOT_FOUND_0x19="0"
                        NOT_FOUND_0x1a="@+id/coinTextLly">
                        <o.C55258xgZ
                            theme="@style/OKTheme"
                            id="@+id/positionsOpenedTitle"
                            visibility="2"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            NOT_FOUND_0x1c="2"
                            NOT_FOUND_0x1d="@color/ContentTertiary"
                            NOT_FOUND_0x1e="@string/pr_futuresgrid_placeorder_dialogtitle_est_pos_opened"
                            NOT_FOUND_0x1f="@style/Label_3_Regular"
                            NOT_FOUND_0x20="0"/>
                        <TextView
                            textColor="@color/ContentPrimary"
                            gravity="0x800005"
                            layout_gravity="0x800005"
                            id="@+id/positionsOpenedVal"
                            visibility="2"
                            layout_width="-1"
                            android:layout_height="wrap_content"
                            layout_marginTop="2dp"
                            style="@style/Label_2_Medium"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/recyclerView"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp24"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
