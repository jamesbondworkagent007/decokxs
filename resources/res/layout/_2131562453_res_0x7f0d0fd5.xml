<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        layout_gravity="0x1"
        id="@+id/triangleUp"
        layout_width="8dp"
        android:layout_height="4dp"
        layout_marginBottom="-1dp"
        src="@drawable/_2131232800_res_0x7f080820"
        NOT_FOUND_0x17="@color/background_lv4"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        orientation="1"
        background="@drawable/_2131233755_res_0x7f080bdb"
        padding="8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        minWidth="123dp"
        backgroundTint="@color/ContainerContrast">
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP.Regular"
            textColor="@color/ContentAlwaysLight"
            gravity="0x800003"
            id="@+id/tvTime"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP.Regular"
            textColor="@color/ContentAlwaysLight"
            id="@+id/pnlTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_6"
            text="@string/pr_smartarb_placeorder_title_backtest_annual_return_short"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="@+id/tvTime"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP.Regular"
            textColor="@color/ContentAlwaysLight"
            id="@+id/pnl"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/ok_dp_12"
            NOT_FOUND_0x12="@+id/pnlTitle"
            NOT_FOUND_0x13="@+id/pnlTitle"
            NOT_FOUND_0x16="@+id/pnlTitle"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView
        layout_gravity="0x1"
        id="@+id/triangleDown"
        visibility="1"
        layout_width="8dp"
        android:layout_height="4dp"
        layout_marginTop="-1dp"
        src="@drawable/_2131232799_res_0x7f08081f"
        NOT_FOUND_0x17="@color/background_lv4"/>
</LinearLayout>
