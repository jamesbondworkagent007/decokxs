<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/rc_conversation_item"
    background="@color/BasePrimary"
    paddingLeft="@dimen/im_page_margin"
    paddingRight="@dimen/im_page_margin"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_12dp"
    foreground="?attr/selectableItemBackgroundBorderless"
    paddingHorizontal="@dimen/im_page_margin">
    <ImageView
        id="@+id/iv_sync_contact"
        background="@drawable/_2131231341_res_0x7f08026d"
        padding="12dp"
        layout_width="52dp"
        android:layout_height="52dp"
        src="@drawable/_2131230883_res_0x7f0800a3"
        scaleType="6"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x23="@color/ContentTertiary"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        paddingTop="3dp"
        paddingBottom="3dp"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_12dp"
        layout_marginEnd="@dimen/margin_8dp"
        paddingVertical="3dp"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="@+id/close"
        NOT_FOUND_0x1c="@+id/iv_sync_contact"
        NOT_FOUND_0x1e="0">
        <TextView
            textAppearance="@style/Title_2_Medium"
            textColor="@color/okTradeG900"
            ellipsize="3"
            id="@+id/tv_title_sync_contact"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_message_chat_regularcell_header_sync_contacts"
            singleLine="true"
            style="@style/TextStyle.Alignment"/>
        <TextView
            textColor="@color/okTradeG400"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/tv_des_sync_contact"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            text="@string/pr_message_chat_regularcell_body_connections"
            singleLine="true"
            textAlignment="5"
            style="@style/Label_1_Regular"/>
        <o.wYE
            textColor="@color/ContentPrimary"
            id="@+id/btn_sync_contact_item"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            text="@string/pr_message_banner_btn_enable_contacts_permissions"
            NOT_FOUND_0x1f="-5"
            NOT_FOUND_0x20="1"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x22="1"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <ImageView
        id="@+id/close"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231675_res_0x7f0803bb"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x23="@color/ContentContrast"/>
</androidx.constraintlayout.widget.ConstraintLayout>
