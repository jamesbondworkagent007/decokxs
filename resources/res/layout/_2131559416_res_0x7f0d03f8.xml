<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    paddingTop="@dimen/padding_4dp"
    paddingBottom="@dimen/padding_4dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/padding_4dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_address"
        layout_width="108dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0">
        <com.google.android.material.imageview.ShapeableImageView
            id="@+id/trader_avatar"
            layout_width="16dp"
            android:layout_height="16dp"/>
        <TextView
            textColor="@color/ContentTertiary"
            ellipsize="3"
            id="@+id/trader_address"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="@dimen/margin_4dp"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_tx"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_8dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x18="@+id/ll_address"
        NOT_FOUND_0x1a="0">
        <TextView
            textSize="12sp"
            textStyle="0x1"
            textColor="@color/pnl_modern_profit_default"
            gravity="0x11"
            id="@+id/trade_type_indicator"
            layout_width="16dp"
            android:layout_height="16dp"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/trade_time"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/margin_4dp"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="1"
        NOT_FOUND_0x18="@+id/ll_tx"
        NOT_FOUND_0x1a="0">
        <TextView
            textColor="@color/ContentTertiary"
            ellipsize="3"
            id="@+id/position_amount"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentDisabled"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_2dp"
            layout_marginRight="@dimen/margin_2dp"
            text="/"
            layout_marginHorizontal="@dimen/margin_2dp"
            style="@style/Label_3_Regular"/>
        <TextView
            ellipsize="3"
            id="@+id/pnl_amount"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
