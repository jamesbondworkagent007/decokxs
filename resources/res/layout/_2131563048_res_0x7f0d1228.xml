<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@drawable/_2131230913_res_0x7f0800c1"
    paddingLeft="@dimen/dp_16"
    paddingTop="@dimen/margin_18dp"
    paddingRight="@dimen/dp_16"
    paddingBottom="@dimen/margin_18dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/dp_16"
    paddingVertical="@dimen/margin_18dp">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginEnd="2dp">
            <TextView
                textSize="@dimen/text_size_10sp"
                textColor="@color/okTradeG400"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/p2p_widget_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_p2p_cefi_widget_p2p_market_price"
                singleLine="true"
                style="@style/TextAppearance.Text.10SP"/>
            <TextView
                textSize="@dimen/text_size_10sp"
                textColor="@color/okTradeG400"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/p2p_widget_time"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxWidth="@dimen/height_72dp"
                singleLine="true"
                style="@style/TextAppearance.Text.10SP"/>
        </LinearLayout>
        <LinearLayout
            textSize="@dimen/text_size_10sp"
            textColor="@color/okTradeG400"
            ellipsize="3"
            layout_gravity="0x800035"
            orientation="0"
            id="@+id/app_widget_setting_layout"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="@dimen/height_72dp"
            text="@string/pr_widgets_header_label_watchlist_crypto"
            singleLine="true">
            <ImageView
                layout_width="0dp"
                android:layout_height="1dp"
                layout_weight="1"
                contentDescription="@null"/>
            <ImageView
                layout_gravity="0x800015"
                id="@+id/app_widget_setting"
                background="@drawable/_2131233932_res_0x7f080c8c"
                layout_width="@dimen/dp_16"
                android:layout_height="@dimen/dp_16"
                scaleType="fillCenter"
                contentDescription="p2pWidgetSetting"
                layout_marginEnd="8dp"
                backgroundTint="@color/okTradeG400"/>
            <ImageView
                layout_gravity="0x800015"
                background="@mipmap/_2131689474_res_0x7f0f0002"
                layout_width="@dimen/dp_16"
                android:layout_height="@dimen/dp_16"
                scaleType="fillCenter"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        gravity="0x11"
        orientation="1"
        id="@+id/p2p_widget_empty_state"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="24dp">
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x11"
            id="@+id/p2p_widget_empty_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_commonall_emptystate_text_no_data"
            style="@style/Label_1_Medium"/>
    </LinearLayout>
    <RelativeLayout
        id="@+id/p2p_widget_item_layout"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="24dp">
        <LinearLayout
            orientation="0"
            id="@+id/p2p_widget_inner_price"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_alignParentBottom="true">
            <LinearLayout
                orientation="1"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1">
                <LinearLayout
                    orientation="0"
                    layout_width="-2"
                    android:layout_height="wrap_content">
                    <TextView
                        textStyle="0x1"
                        textColor="@color/ContentPrimary"
                        id="@+id/p2p_widget_coin_name"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        textFontWeight="700"
                        style="@style/Label_2_Bold"/>
                    <TextView
                        textColor="@color/ContentTertiary"
                        id="@+id/p2p_widget_fiat_name"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        style="@style/Label_4_Regular"/>
                </LinearLayout>
                <TextView
                    textStyle="0x1"
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    id="@+id/p2p_widget_market_price"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    singleLine="true"
                    includeFontPadding="false"
                    layout_marginEnd="6dp"
                    textFontWeight="700"
                    style="@style/Headline_5_Bold"/>
            </LinearLayout>
            <FrameLayout
                layout_gravity="0x800055"
                layout_width="-2"
                android:layout_height="wrap_content">
                <ImageView
                    id="@+id/p2p_widget_trade_side_bg"
                    layout_width="-1"
                    android:layout_height="match_parent"
                    scaleType="fillCenter"/>
                <TextView
                    textSize="12sp"
                    textColor="@color/positive"
                    gravity="0x11"
                    layout_gravity="0x11"
                    id="@+id/p2p_widget_trade_side"
                    background="@android:color/transparent"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    singleLine="true"
                    includeFontPadding="false"
                    style="@style/TextAppearance.Title.12SP"/>
            </FrameLayout>
        </LinearLayout>
        <ImageView
            id="@+id/p2p_widget_icon"
            layout_width="@dimen/dp_32"
            android:layout_height="@dimen/dp_32"
            layout_marginBottom="@dimen/ok_dp_12"
            scaleType="fillCenter"
            layout_above="@+id/p2p_widget_inner_price"/>
    </RelativeLayout>
</FrameLayout>
