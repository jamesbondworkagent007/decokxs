<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/sm"
    paddingTop="@dimen/xxxsm"
    paddingRight="@dimen/sm"
    paddingBottom="@dimen/xxxsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/sm"
    paddingVertical="@dimen/xxxsm">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/txt_description_label"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_message_planet_label_description"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="2"
        style="@style/Label_2_Medium"/>
    <o.oIW
        id="@+id/input_description"
        layout_width="0dp"
        android:layout_height="@dimen/height_100dp"
        layout_marginTop="@dimen/xxxsm"
        layout_marginBottom="@dimen/xxxsm"
        minHeight="100dp"
        layout_marginVertical="@dimen/xxxsm"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/txt_description_label"
        NOT_FOUND_0x17="2"
        NOT_FOUND_0x18="@string/pr_message_planet_placeholder_short_note"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/requirement_desc"
        paddingTop="@dimen/dp_8"
        visibility="0"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_message_planet_placeholder_desc_min_2"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/input_description"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
