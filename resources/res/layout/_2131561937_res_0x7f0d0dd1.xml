<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/market_calendar_marker_view_host"
    paddingLeft="24dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="@dimen/dp_48"
    paddingHorizontal="24dp">
    <View
        background="@drawable/_2131231257_res_0x7f080219"
        layout_width="0dp"
        android:layout_height="0dp"
        backgroundTint="@color/ContainerContrast_Light"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentAlwaysLight"
        gravity="0x10"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        drawablePadding="12dp"
        drawableStart="@drawable/_2131233456_res_0x7f080ab0"
        layout_marginStart="@dimen/dp_16"
        layout_marginEnd="4dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="@+id/tv_subtitle"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        style="@style/Body_3_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentAlwaysLight"
        gravity="0x10"
        id="@+id/tv_subtitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        drawablePadding="4dp"
        drawableEnd="@drawable/_2131231647_res_0x7f08039f"
        layout_marginEnd="@dimen/dp_12"
        NOT_FOUND_0x10="@color/ContentInverse_Light"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="0"
        style="@style/Body_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
