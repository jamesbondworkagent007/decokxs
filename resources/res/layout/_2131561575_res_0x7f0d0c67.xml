<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/grey"
    layout_width="-1"
    android:layout_height="match_parent">
    <com.okinc.liveness.lca.components.PreviewTextureView
        id="@+id/preview_texture_view"
        layout_width="-1"
        android:layout_height="match_parent"/>
    <com.okinc.liveness.lca.components.ClippedOvalImageView
        layout_gravity="0x11"
        id="@+id/iv_face_oval_guide_overlap"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232203_res_0x7f0805cb"
        scaleType="fillCenter"/>
    <com.okinc.liveness.lca.components.FaceOvalView
        id="@+id/face_oval_view"
        layout_width="-1"
        android:layout_height="match_parent"/>
    <com.okinc.liveness.lca.components.FreshnessView
        id="@+id/freshness_view"
        layout_width="-1"
        android:layout_height="match_parent"/>
    <LinearLayout
        gravity="0x11"
        layout_gravity="0x1"
        orientation="1"
        id="@+id/ll_tips"
        background="@drawable/_2131233316_res_0x7f080a24"
        layout_width="-2"
        android:layout_height="wrap_content">
        <com.airbnb.lottie.LottieAnimationView
            layout_gravity="0x1"
            id="@+id/lottie_guide_tips"
            visibility="2"
            layout_width="115dp"
            android:layout_height="90dp"
            NOT_FOUND_0x18="true"
            NOT_FOUND_0x19="true"
            NOT_FOUND_0x1a="@raw/_2131886098_res_0x7f120012"/>
        <TextView
            textColor="@color/ContentInverse_Light"
            id="@+id/tv_tips"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Title.Bold.18SP"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x11"
        orientation="1"
        id="@+id/ll_final_check_loading"
        background="@color/BasePrimary"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent">
        <ProgressBar
            layout_width="@dimen/width_48dp"
            android:layout_height="@dimen/height_48dp"
            indeterminateTint="@color/lca_loading_background"
            indeterminateTintMode="9"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x11"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp24"
            text="@string/pr_compliance_sdk_liveness_title_processing_state"
            style="@style/Headline_5_Bold"/>
    </LinearLayout>
    <FrameLayout
        id="@+id/starting_up_overlay"
        background="@color/BasePrimary"
        focusable="true"
        visibility="0"
        clickable="true"
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            gravity="0x11"
            layout_gravity="0x11"
            orientation="1"
            padding="20dp"
            layout_width="-1"
            android:layout_height="match_parent">
            <ProgressBar
                id="@+id/pb_loading"
                layout_width="@dimen/width_48dp"
                android:layout_height="@dimen/height_48dp"
                indeterminateTint="@color/lca_loading_background"
                indeterminateTintMode="9"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                id="@+id/starting_up_text"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp24"
                text="@string/pr_compliance_sdk_liveness_title_initializing_state"
                style="@style/Headline_5_Bold"/>
        </LinearLayout>
    </FrameLayout>
    <LinearLayout
        gravity="0x11"
        layout_gravity="0x10"
        orientation="1"
        id="@+id/ll_reload_overlay"
        background="@color/BasePrimary"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent">
        <ImageView
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131233552_res_0x7f080b10"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_exception_msg"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            layout_marginBottom="12dp"
            text="@string/pr_compliance_sdk_liveness_emptystate_generic_fail"
            layout_marginStart="14dp"
            layout_marginEnd="14dp"
            style="@style/TextAppearance.Title.14SP"/>
        <o.C52794wYp
            id="@+id/btn_reload"
            focusable="true"
            clickable="true"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_compliance_common_btn_reload"
            layout_marginStart="14dp"
            layout_marginEnd="14dp"
            NOT_FOUND_0x1b="36"
            NOT_FOUND_0x1c="0x104"
            NOT_FOUND_0x1d="-1"/>
    </LinearLayout>
    <o.C33537myN
        layout_gravity="0x30"
        id="@+id/app_bar_guide"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="true"
        NOT_FOUND_0x16="@drawable/_2131231642_res_0x7f08039a"
        NOT_FOUND_0x17="@color/transparent"
        NOT_FOUND_0x1e="@color/transparent"/>
</FrameLayout>
