<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/ll_protocol_container"
    focusable="true"
    clickable="true"
    layout_width="-1"
    android:layout_height="@dimen/height_72dp">
    <LinearLayout
        gravity="0x800013"
        layout_gravity="0x800013"
        orientation="0"
        id="@+id/ll_protocol"
        layout_width="0dp"
        android:layout_height="match_parent"
        minWidth="110dp"
        layout_weight="1"
        paddingEnd="@dimen/xxxsm"
        layout_marginStart="@dimen/xsm">
        <ImageView
            layout_gravity="0x10"
            id="@+id/protocol_icon"
            visibility="2"
            layout_width="32dp"
            android:layout_height="32dp"
            scaleType="6"
            layout_marginEnd="@dimen/margin_12dp"/>
        <TextView
            textSize="@dimen/text_size_16sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800003"
            layout_gravity="0x10"
            id="@+id/protocol_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_1_Medium"/>
    </LinearLayout>
    <FrameLayout
        layout_gravity="0x800015"
        layout_width="-2"
        android:layout_height="match_parent">
        <LinearLayout
            gravity="0x800015"
            layout_gravity="0x800015"
            orientation="0"
            id="@+id/apy_container"
            layout_width="-2"
            android:layout_height="match_parent"
            layout_marginEnd="@dimen/xsm">
            <LinearLayout
                gravity="0x800015"
                layout_gravity="0x800005"
                orientation="1"
                id="@+id/apy_content_container"
                layout_width="-2"
                android:layout_height="match_parent">
                <LinearLayout
                    orientation="0"
                    layout_width="-2"
                    android:layout_height="wrap_content">
                    <TextView
                        textColor="@color/ContentPrimary"
                        ellipsize="3"
                        gravity="0x800055"
                        layout_gravity="0x800005"
                        id="@+id/apy_text"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxLines="1"
                        style="@style/Label_1_Medium"/>
                    <o.wYC
                        layout_gravity="0x10"
                        id="@+id/card_chart_line_icon"
                        visibility="0"
                        layout_width="@dimen/dp_16"
                        android:layout_height="@dimen/dp_16"
                        layout_marginStart="@dimen/margin_4dp"
                        NOT_FOUND_0x1a="@drawable/_2131232915_res_0x7f080893"
                        NOT_FOUND_0x1b="@color/ContentPrimary"/>
                </LinearLayout>
                <FrameLayout
                    layout_gravity="0x800015"
                    id="@+id/daily_earn_container"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/xxxxsm"
                    minHeight="@dimen/height_16dp">
                    <TextView
                        textColor="@color/ContentContrast"
                        ellipsize="3"
                        gravity="0x800005"
                        layout_gravity="0x800005"
                        id="@+id/daily_earn_text"
                        visibility="1"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        maxLines="1"
                        style="@style/Label_3_Regular"/>
                    <o.C55113xdn
                        layout_gravity="0x800005"
                        id="@+id/daily_earn_loading"
                        visibility="1"
                        layout_width="@dimen/xsm"
                        android:layout_height="@dimen/xsm"
                        NOT_FOUND_0x18="true"
                        NOT_FOUND_0x19="true"/>
                </FrameLayout>
            </LinearLayout>
            <ImageView
                layout_gravity="0x10"
                id="@+id/click_arrow"
                visibility="2"
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131232351_res_0x7f08065f"
                layout_marginStart="@dimen/xxxsm"
                NOT_FOUND_0x1b="@color/ContentPrimary"/>
        </LinearLayout>
        <View
            layout_gravity="0x800005"
            id="@+id/help_click_view"
            background="@color/transparent"
            visibility="2"
            layout_width="@dimen/width_40dp"
            android:layout_height="@dimen/width_40dp"
            layout_marginTop="@dimen/margin_4dp"
            layout_marginRight="@dimen/margin_4dp"/>
    </FrameLayout>
</LinearLayout>
