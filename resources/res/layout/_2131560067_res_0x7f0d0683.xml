<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/fragment_my_wallets_0"
    paddingTop="@dimen/padding_13dp"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textAppearance="@style/Title_2_Medium"
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_metax_wallet_header_my_wallets"
        layout_marginStart="@dimen/padding_16dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/close"
        paddingTop="@dimen/dp_4"
        paddingBottom="@dimen/dp_4"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232442_res_0x7f0806ba"
        tint="@color/ContentPrimary"
        paddingStart="@dimen/dp_4"
        paddingEnd="@dimen/padding_16dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="0"/>
    <View
        id="@+id/divider"
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="@dimen/width_0.5dp"
        layout_marginTop="@dimen/padding_13dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/title"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/list"
        layout_width="-1"
        android:layout_height="0dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="@+id/divider"/>
</androidx.constraintlayout.widget.ConstraintLayout>
