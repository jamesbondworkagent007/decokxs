<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.Toolbar xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_gravity="0x37"
    id="@+id/toolbar"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="@dimen/appbar_height"
    elevation="0dp"
    NOT_FOUND_0x16="0dp"
    NOT_FOUND_0x17="0dp"
    NOT_FOUND_0x18="0dp"
    NOT_FOUND_0x1f="0">
    <androidx.constraintlayout.widget.ConstraintLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginRight="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default">
        <o.wYC
            layout_gravity="0x11"
            id="@+id/menu_back_icon"
            background="?attr/selectableItemBackgroundBorderless"
            visibility="1"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232348_res_0x7f08065c"
            contentDescription="@string/pr_commonall_text_btn_back"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1f="0"/>
        <ImageView
            layout_gravity="0x11"
            id="@+id/personal_setting_icon"
            background="?attr/selectableItemBackgroundBorderless"
            padding="@dimen/padding_2dp"
            visibility="1"
            layout_width="@dimen/width_28dp"
            android:layout_height="@dimen/width_28dp"
            src="@drawable/_2131233653_res_0x7f080b75"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1f="0"/>
        <View
            id="@+id/empty_view"
            layout_width="@dimen/width_28dp"
            android:layout_height="@dimen/width_28dp"
            layout_marginStart="@dimen/margin_10dp"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1c="@+id/menu_back_icon"
            NOT_FOUND_0x1f="0"/>
        <TextView
            ellipsize="3"
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/toolbar_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_72dp"
            layout_marginRight="@dimen/margin_72dp"
            maxLines="1"
            layout_marginHorizontal="@dimen/margin_72dp"
            NOT_FOUND_0x1a="@+id/toolbar_subtitle"
            NOT_FOUND_0x1f="0"
            style="@style/TextAppearance.Title.Bold.18SP"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.10SP"
            ellipsize="3"
            layout_gravity="0x11"
            id="@+id/toolbar_subtitle"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            text="@string/pr_message_chat_label_waiting_for_network"
            maxLines="1"
            drawablePadding="4dp"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="@+id/toolbar_title"
            NOT_FOUND_0x1d="@+id/toolbar_title"
            NOT_FOUND_0x1e="@+id/toolbar_title"/>
        <ImageView
            layout_gravity="0x11"
            id="@+id/menu_more_icon"
            background="?attr/selectableItemBackgroundBorderless"
            padding="@dimen/padding_2dp"
            visibility="2"
            layout_width="@dimen/width_28dp"
            android:layout_height="@dimen/width_28dp"
            src="@drawable/_2131233687_res_0x7f080b97"
            contentDescription="@string/pr_commonall_modal_btn_more"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="0dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.Toolbar>
