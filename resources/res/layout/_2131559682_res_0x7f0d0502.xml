<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <com.google.android.exoplayer2.ui.AspectRatioFrameLayout
        layout_gravity="0x11"
        id="@+id/exo_content_frame"
        layout_width="-1"
        android:layout_height="match_parent">
        <View
            id="@+id/exo_shutter"
            background="@android:color/black"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <ImageView
            id="@+id/exo_artwork"
            layout_width="-1"
            android:layout_height="match_parent"
            scaleType="fillCenter"/>
        <com.google.android.exoplayer2.ui.SubtitleView
            id="@+id/exo_subtitles"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <ProgressBar
            layout_gravity="0x11"
            id="@+id/exo_buffering"
            layout_width="-2"
            android:layout_height="wrap_content"
            indeterminate="true"/>
        <TextView
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/exo_error_message"
            background="@color/exo_error_message_background_color"
            padding="16dp"
            layout_width="-1"
            android:layout_height="match_parent"/>
    </com.google.android.exoplayer2.ui.AspectRatioFrameLayout>
    <FrameLayout
        id="@+id/exo_ad_overlay"
        layout_width="-1"
        android:layout_height="match_parent"/>
    <FrameLayout
        id="@+id/exo_overlay"
        layout_width="-1"
        android:layout_height="match_parent"/>
    <View
        id="@+id/exo_controller_placeholder"
        layout_width="-1"
        android:layout_height="match_parent"/>
</merge>
