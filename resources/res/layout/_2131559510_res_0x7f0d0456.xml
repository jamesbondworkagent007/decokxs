<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_approved_amount_prompt"
        paddingTop="@dimen/margin_8dp"
        paddingBottom="@dimen/margin_8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        paddingVertical="@dimen/margin_8dp">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_confirm_bot_approve_amount"
            style="@style/Label_2_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/approved_amount_prompt_text"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="8dp"
            style="@style/Label_2_Medium"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            id="@+id/token_symbol"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="2dp"
            style="@style/Label_2_Medium"/>
        <ImageView
            id="@+id/approved_amount_prompt_edit"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            src="@drawable/_2131232074_res_0x7f08054a"
            layout_marginStart="@dimen/margin_4dp"
            NOT_FOUND_0x1a="@color/ContentPrimary"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/edit_view_container"
        layout_width="-2"
        android:layout_height="wrap_content">
        <FrameLayout
            id="@+id/fl_input_view"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content">
            <o.C55008xbo
                id="@+id/input_field"
                layout_width="-1"
                android:layout_height="wrap_content"
                inputType="0x2002"
                NOT_FOUND_0x16="0dp"
                NOT_FOUND_0x17="44"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentPrimary"
                layout_gravity="0x10"
                id="@+id/unlimited_value_text"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_confirm_bot_approve_amt_unlimited"
                layout_marginStart="12dp"
                style="@style/Label_1_Regular"/>
        </FrameLayout>
        <LinearLayout
            orientation="0"
            id="@+id/ll_option_panel"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                id="@+id/balance_text"
                paddingTop="@dimen/margin_8dp"
                paddingBottom="@dimen/margin_8dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingVertical="@dimen/margin_8dp"
                style="@style/Body_3_Regular"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentPrimary"
                id="@+id/max_text_button"
                paddingTop="@dimen/margin_8dp"
                paddingBottom="@dimen/margin_8dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_confirm_max_amount_filled"
                layout_marginStart="@dimen/margin_12dp"
                paddingVertical="@dimen/margin_8dp"
                style="@style/Label_3_Medium"/>
            <View
                layout_gravity="0x10"
                background="@color/BorderPrimary"
                layout_width="0.5dp"
                android:layout_height="10dp"
                layout_marginTop="@dimen/margin_8dp"
                layout_marginBottom="@dimen/margin_8dp"
                layout_marginStart="@dimen/margin_8dp"
                layout_marginVertical="@dimen/margin_8dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentPrimary"
                id="@+id/traded_amount_text_button"
                paddingTop="@dimen/margin_8dp"
                paddingBottom="@dimen/margin_8dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_confirm_bot_trade_amount"
                layout_marginStart="@dimen/margin_8dp"
                paddingVertical="@dimen/margin_8dp"
                style="@style/Label_3_Medium"/>
        </LinearLayout>
        <View
            id="@+id/divider_inside"
            background="@color/BorderPrimary"
            visibility="2"
            layout_width="-1"
            android:layout_height="@dimen/dp_0.5"/>
    </LinearLayout>
    <View
        id="@+id/divider_outside"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="@dimen/dp_0.5"/>
    <o.C52794wYp
        id="@+id/btn_confirm"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_default"
        text="@string/pr_swaptrade_confirm_bot_confirm_account"
        NOT_FOUND_0x18="52"
        NOT_FOUND_0x19="0x101"/>
</merge>
