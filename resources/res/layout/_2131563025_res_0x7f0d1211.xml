<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentContrast"
        layout_gravity="0x10"
        id="@+id/tv_receive_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_investdeposit_mid_text_invest_process"
        includeFontPadding="false"
        NOT_FOUND_0x14="@+id/route_panel"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="@+id/route_panel"
        style="@style/Label_2_Regular"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        layout_gravity="0x10"
        id="@+id/route_panel"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        NOT_FOUND_0x15="@+id/tv_receive_title"
        NOT_FOUND_0x16="@+id/tv_receive_title">
        <o.C27212jqt
            id="@+id/invest_with_coin"
            padding="@dimen/width_0dp"
            layout_width="-2"
            android:layout_height="@dimen/height_24dp"
            NOT_FOUND_0x13="12dp"/>
        <ImageView
            id="@+id/cross_middle_line"
            visibility="2"
            layout_width="@dimen/xsm"
            android:layout_height="@dimen/xsm"
            src="@drawable/_2131234226_res_0x7f080db2"
            scaleType="fitStart"
            scaleX="-1"
            layout_marginStart="@dimen/xxxsm"
            layout_marginEnd="@dimen/xxxsm"
            NOT_FOUND_0x18="@color/text_lighter"/>
        <o.C27212jqt
            id="@+id/swap_to_coin"
            padding="@dimen/width_0dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="@dimen/height_24dp"
            NOT_FOUND_0x13="12dp"/>
        <ImageView
            id="@+id/middle_line"
            layout_width="@dimen/xsm"
            android:layout_height="@dimen/xsm"
            src="@drawable/_2131233694_res_0x7f080b9e"
            scaleType="fitStart"
            layout_marginStart="@dimen/xxxsm"
            layout_marginEnd="@dimen/xxxsm"
            NOT_FOUND_0x18="@color/text_lighter"/>
        <ImageView
            id="@+id/to_coin"
            layout_width="@dimen/width_24dp"
            android:layout_height="@dimen/height_24dp"
            scaleType="6"
            layout_marginEnd="@dimen/xxxsm"/>
        <ImageView
            id="@+id/icon_route_load"
            layout_width="@dimen/width_20dp"
            android:layout_height="@dimen/width_20dp"
            scaleType="fitStart"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Medium"
        textColor="@color/Warning"
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_process_view_tips"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_6dp"
        singleLine="true"
        NOT_FOUND_0x15="@+id/route_panel"
        NOT_FOUND_0x16="@+id/route_panel"/>
</androidx.constraintlayout.widget.ConstraintLayout>
