<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    paddingLeft="16dp"
    paddingTop="28dp"
    paddingRight="16dp"
    paddingBottom="28dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="16dp"
    paddingVertical="28dp">
    <LinearLayout
        layout_gravity="0x10"
        orientation="1"
        id="@+id/ll_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        layout_toStartOf="@+id/customLayout"
        layout_alignParentStart="true">
        <o.C55258xgZ
            id="@+id/title_label"
            layout_width="-2"
            android:layout_height="wrap_content"
            textAlignment="5"
            NOT_FOUND_0x17="2"
            NOT_FOUND_0x18="@color/grey_g900"
            NOT_FOUND_0x19="@dimen/text_size_18sp"
            NOT_FOUND_0x1a="@style/OKTextFont.Bold"/>
        <TextView
            textAppearance="@style/OKTextFont.Regular"
            textSize="@dimen/text_size_14sp"
            textColor="@color/grey_g500"
            id="@+id/descriptionTextView"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            textAlignment="5"/>
    </LinearLayout>
    <LinearLayout
        id="@+id/customLayout"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        layout_marginStart="24dp"
        layout_alignParentEnd="true">
        <ImageView
            textAppearance="@style/TextAppearance"
            textSize="14sp"
            id="@+id/imageView"
            visibility="2"
            layout_width="72dp"
            android:layout_height="72dp"/>
    </LinearLayout>
</RelativeLayout>
