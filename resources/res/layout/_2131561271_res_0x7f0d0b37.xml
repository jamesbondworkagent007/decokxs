<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/layout_info"
    tag="layout/layout_information_bottom_sheet_0"
    paddingLeft="20dp"
    paddingTop="@dimen/xxsm"
    paddingRight="20dp"
    paddingBottom="@dimen/xxsm"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="20dp"
    paddingVertical="@dimen/xxsm">
    <TextView
        textSize="@dimen/font_14"
        textColor="@color/ContentSecondary"
        id="@+id/content"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="@dimen/xxsm"
        text="@string/pr_supportcenter_deposit_uncredited_desc_explain_txid"
        NOT_FOUND_0x22="0"
        style="@style/Body_3_Regular"/>
    <LinearLayout
        orientation="0"
        id="@+id/quote"
        paddingTop="@dimen/sm"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x21="@+id/content">
        <View
            background="@color/SurfacePressed"
            layout_width="@dimen/margin_4dp"
            android:layout_height="match_parent"/>
        <TextView
            textColor="@color/ContentContrast"
            gravity="0x800013"
            id="@+id/quote_id"
            paddingTop="@dimen/xxxsm"
            paddingBottom="@dimen/xxxsm"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_deposit_uncredited_text_example_hash"
            paddingStart="@dimen/xxsm"
            paddingEnd="@dimen/xxsm"
            style="@style/Body_3_Regular"/>
    </LinearLayout>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        paddingTop="@dimen/sm"
        paddingBottom="@dimen/xxsm"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_supportcenter_deposit_uncredited_desc_where_find"
        textAlignment="2"
        NOT_FOUND_0x20="@+id/layout_info"
        NOT_FOUND_0x21="@+id/quote"
        style="@style/Label_1_Bold"/>
    <LinearLayout
        orientation="1"
        id="@+id/bullet"
        paddingBottom="@dimen/xxsm"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingEnd="@dimen/padding_6dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="@+id/tv_title">
        <TextView
            textSize="14sp"
            textColor="@color/ContentSecondary"
            id="@+id/bullet_one"
            paddingBottom="@dimen/xxxsm"
            layout_width="-2"
            android:layout_height="match_parent"
            style="@style/Body_3_Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/information"
        background="@drawable/_2131233880_res_0x7f080c58"
        paddingLeft="@dimen/padding_16dp"
        paddingRight="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxHeight="76dp"
        minHeight="76dp"
        backgroundTint="@color/SurfacePrimary"
        paddingHorizontal="@dimen/padding_16dp"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="@+id/bullet">
        <ImageView
            layout_gravity="0x800013"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            layout_marginBottom="@dimen/margin_16dp"
            src="@drawable/_2131233145_res_0x7f080979"
            layout_marginEnd="@dimen/margin_8dp"/>
        <TextView
            textAppearance="@style/Body_3_Regular"
            textSize="@dimen/font_14"
            textColorHint="@color/ContentPrimary"
            layout_gravity="0x800013"
            layout_width="0dp"
            android:layout_height="wrap_content"
            hint="@string/pr_supportcenter_deposit_uncredited_desc_cant_find_txid"
            layout_weight="1"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
