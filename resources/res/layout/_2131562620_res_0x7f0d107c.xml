<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="4dp"
    paddingBottom="4dp"
    layout_width="-2"
    android:layout_height="wrap_content"
    paddingVertical="4dp">
    <ImageView
        id="@+id/icon"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"/>
    <TextView
        textColor="@color/cell_title_color"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        singleLine="true"
        layout_marginStart="4dp"
        lineHeight="16dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/icon"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0dp"
        style="@style/OKTextFont.Regular"/>
    <ImageView
        id="@+id/select_icon"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131231589_res_0x7f080365"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/title"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@color/cell_title_color"/>
</androidx.constraintlayout.widget.ConstraintLayout>
