<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_info_simple_option_0"
    background="@drawable/_2131231009_res_0x7f080121"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_16dp"
    layout_marginTop="@dimen/margin_4dp"
    layout_marginRight="@dimen/margin_16dp"
    minHeight="70dp"
    layout_marginHorizontal="@dimen/margin_16dp">
    <ImageView
        id="@+id/iv_coin"
        layout_width="24dp"
        android:layout_height="24dp"
        layout_marginStart="@dimen/common_page_edge_space"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x11="@+id/tv_content"
        NOT_FOUND_0x13="@+id/iv_coin"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        id="@+id/tv_content"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="@+id/tv_title"
        NOT_FOUND_0x15="@+id/tv_title"/>
    <View
        id="@+id/iv_right"
        background="@drawable/_2131232353_res_0x7f080661"
        layout_width="@dimen/height_14dp"
        android:layout_height="@dimen/height_14dp"
        layout_marginEnd="@dimen/ok_dp_16"
        backgroundTint="@color/okTradeG300"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
