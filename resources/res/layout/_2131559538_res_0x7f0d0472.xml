<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/add_gas_iv"
        layout_width="20dp"
        android:layout_height="20dp"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginBottom="@dimen/margin_8dp"
        src="@drawable/_2131233687_res_0x7f080b97"
        scaleType="7"
        layout_marginStart="24dp"
        layout_marginVertical="@dimen/margin_8dp"
        NOT_FOUND_0x1d="@color/ContentSecondary"/>
    <ImageView
        id="@+id/iv_show_coin_order_detail_view"
        background="@drawable/_2131231884_res_0x7f08048c"
        layout_width="32dp"
        android:layout_height="32dp"
        src="@drawable/_2131231887_res_0x7f08048f"
        layout_below="@+id/add_gas_iv"
        layout_marginStart="24dp"/>
    <LinearLayout
        gravity="0x800015"
        orientation="0"
        id="@+id/state_panel"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_above="@+id/iv_show_coin_order_detail_view"
        layout_below="@+id/add_gas_iv"
        layout_alignTop="@+id/iv_show_coin_order_detail_view"
        layout_alignBottom="@+id/iv_show_coin_order_detail_view"
        layout_centerVertical="true"
        layout_marginEnd="24dp"
        layout_alignParentEnd="true">
        <androidx.appcompat.widget.AppCompatImageView
            layout_gravity="0x11"
            id="@+id/iv_link_order_detail_view"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            src="@drawable/_2131234404_res_0x7f080e64"
            scaleType="7"
            NOT_FOUND_0x1d="@color/ContentContrast"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/name_panel"
        layout_width="-2"
        android:layout_height="32dp"
        layout_below="@+id/add_gas_iv"
        layout_marginEnd="@dimen/margin_8dp"
        layout_toStartOf="@+id/state_panel"
        layout_toEndOf="@+id/iv_show_coin_order_detail_view">
        <o.C24247iaI
            textAppearance="@style/TextAppearance.Title.24SP.Medium"
            textColor="@color/grey_g900"
            ellipsize="3"
            gravity="0x10"
            id="@+id/tv_value_coin_from_order_detail_view"
            layout_width="-2"
            android:layout_height="wrap_content"
            includeFontPadding="false"
            drawablePadding="@dimen/margin_6dp"
            layout_marginStart="8dp"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="false"/>
        <o.C24253iaO
            gravity="0x800013"
            orientation="0"
            id="@+id/tv_state_order_detail_view"
            layout_width="-2"
            android:layout_height="wrap_content"
            includeFontPadding="false"
            layout_marginStart="@dimen/margin_4dp"/>
    </LinearLayout>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/grey_g400"
        id="@+id/tv_chain_name_order_detail_view"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        includeFontPadding="false"
        layout_below="@+id/name_panel"
        layout_marginStart="8dp"
        layout_toEndOf="@+id/iv_show_coin_order_detail_view"/>
</RelativeLayout>
