<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/iv_arrow"
        tag="layout/layout_web3_transaction_network_fee_view_0"
        visibility="2"
        layout_width="20dp"
        android:layout_height="20dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        NOT_FOUND_0x19="@+id/network_fee"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x21="@+id/network_fee"
        NOT_FOUND_0x26="@color/ContentContrast"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        orientation="0"
        id="@+id/ll_header"
        tag="layout/layout_web3_transaction_network_fee_view_1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="@+id/iv_arrow"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0">
        <ImageView
            layout_gravity="0x10"
            id="@+id/iv_header_icon"
            visibility="2"
            layout_width="14dp"
            android:layout_height="14dp"
            NOT_FOUND_0x19="@+id/changeTxMode"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x21="@+id/changeTxMode"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/grey_g400"
            id="@+id/tv_header_title"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"
            NOT_FOUND_0x19="@+id/iv_header_icon"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="@+id/iv_header_icon"
            NOT_FOUND_0x21="@+id/iv_header_icon"
            NOT_FOUND_0x22="0dp"/>
        <View
            id="@+id/header_title_underLine"
            background="@drawable/_2131231117_res_0x7f08018d"
            visibility="2"
            layout_width="0dp"
            android:layout_height="2dp"
            NOT_FOUND_0x1b="@+id/tv_header_title"
            NOT_FOUND_0x1f="@+id/tv_header_title"
            NOT_FOUND_0x20="@+id/tv_header_title"/>
        <o.C55249xgQ
            id="@+id/changeTxMode"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            checked="false"
            layout_marginStart="@dimen/margin_6dp"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="1"
            NOT_FOUND_0x1e="@+id/tv_header_title"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x23="-1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <o.C55251xgS
        id="@+id/tag_free_gas"
        tag="layout/layout_web3_transaction_network_fee_view_2"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="9dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/ll_header"
        NOT_FOUND_0x24="-4"
        NOT_FOUND_0x25="7"/>
    <LinearLayout
        orientation="0"
        id="@+id/network_fee"
        tag="layout/layout_web3_transaction_network_fee_view_3"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x1c="@+id/iv_arrow"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/ll_header">
        <TextView
            textAppearance="@style/TextAppearance.Regular"
            textSize="16sp"
            textColor="@color/grey_g900"
            ellipsize="3"
            layout_gravity="0x10"
            id="@+id/tv_left_content"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"/>
        <View
            layout_gravity="0x10"
            id="@+id/copy_divider"
            background="@color/grey_g100"
            layout_width="1dp"
            android:layout_height="@dimen/height_16dp"
            layout_marginLeft="8dp"
            layout_marginRight="8dp"
            layout_marginHorizontal="8dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Regular"
            textSize="16sp"
            textColor="@color/grey_g900"
            ellipsize="3"
            layout_gravity="0x10"
            id="@+id/tv_right_content"
            visibility="2"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"/>
        <TextView
            textAppearance="@style/TextAppearance.Regular"
            textSize="16sp"
            textColor="@color/grey_g900"
            ellipsize="3"
            layout_gravity="0x800003"
            id="@+id/tv_free_content"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="@dimen/margin_4dp"/>
    </LinearLayout>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_primary_tip"
        tag="layout/layout_web3_transaction_network_fee_view_4"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x1c="@+id/iv_arrow"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/network_fee"
        style="@style/TextAppearance.Text.14SP.Regular"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_express_mode_desc"
        tag="layout/layout_web3_transaction_network_fee_view_5"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="@string/pr_wallet_transfer_tooltips_desc_express_mode"
        NOT_FOUND_0x1c="@+id/iv_arrow"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/tv_primary_tip"
        style="@style/TextAppearance.Text.14SP.Regular"/>
    <View
        id="@+id/divider"
        tag="layout/layout_web3_transaction_network_fee_view_6"
        background="@drawable/_2131231118_res_0x7f08018e"
        layout_width="0dp"
        android:layout_height="2dp"
        layout_marginTop="8dp"
        layout_marginBottom="8dp"
        layout_marginVertical="8dp"
        NOT_FOUND_0x1a="@+id/ll_secondary_tip"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/tv_express_mode_desc"/>
    <LinearLayout
        orientation="0"
        id="@+id/ll_secondary_tip"
        tag="layout/layout_web3_transaction_network_fee_view_7"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1c="@+id/iv_arrow"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/divider">
        <ImageView
            layout_gravity="0x10"
            id="@+id/iv_secondary_tip"
            layout_width="14dp"
            android:layout_height="14dp"
            src="@drawable/_2131232725_res_0x7f0807d5"
            layout_marginEnd="4dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/positive"
            layout_gravity="0x10"
            id="@+id/tv_secondary_tip"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x21="0"/>
    </LinearLayout>
</merge>
