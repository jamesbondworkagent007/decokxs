<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root_layout"
    tag="layout/ac_qrcode_display_0"
    background="#121212"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        orientation="0"
        id="@+id/title_layout"
        layout_width="-1"
        android:layout_height="@dimen/appbar_height"
        baselineAligned="false">
        <ImageView
            layout_gravity="0x800013"
            id="@+id/iv_back"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232600_res_0x7f080758"
            scaleType="fitStart"
            layout_marginStart="@dimen/common_page_edge_space"/>
        <TextView
            layout_gravity="0x11"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_im_qr_code_header_qr_code"
            style="@style/LiteTextAppearance.TextWhite.18SP.Bold"/>
        <ImageView
            layout_gravity="0x800015"
            id="@+id/iv_share"
            paddingLeft="2dp"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131232601_res_0x7f080759"
            scaleType="fitStart"
            layout_marginEnd="@dimen/common_page_edge_space"/>
    </FrameLayout>
    <LinearLayout
        gravity="0x1"
        orientation="1"
        background="#121212"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="97dp"
        layout_marginStart="@dimen/margin_48dp"
        layout_marginEnd="@dimen/margin_48dp">
        <FrameLayout
            gravity="0x1"
            id="@+id/content_layout"
            background="#121212"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                id="@+id/cardview"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="44dp"
                NOT_FOUND_0x1e="@color/transparent">
                <LinearLayout
                    gravity="0x1"
                    orientation="1"
                    id="@+id/card_content"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    paddingStart="@dimen/padding_16dp"
                    paddingEnd="@dimen/padding_16dp">
                    <TextView
                        textAppearance="@style/TextAppearance.Title.Bold.18SP"
                        textColor="#ffffff"
                        ellipsize="3"
                        gravity="0x11"
                        id="@+id/tv_name"
                        layout_width="168dp"
                        android:layout_height="wrap_content"
                        layout_marginTop="56dp"
                        maxLines="2"
                        singleLine="false"/>
                    <TextView
                        id="@+id/tv_tag"
                        visibility="0"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        layout_marginTop="@dimen/margin_12dp"
                        text="@string/pr_message_feed_label_official"
                        singleLine="true"
                        NOT_FOUND_0x1f="@+id/tv_name"
                        NOT_FOUND_0x20="0"
                        NOT_FOUND_0x21="@+id/tv_name"
                        NOT_FOUND_0x22="@+id/tv_name"
                        style="@style/TagTextView"/>
                    <o.C6995aZr
                        id="@+id/qr_content"
                        layout_width="184dp"
                        android:layout_height="184dp"
                        layout_marginTop="28dp"/>
                    <TextView
                        textAppearance="@style/TextAppearance.Text.14SP"
                        textColor="#ffffffe0"
                        gravity="0x11"
                        id="@+id/tv_subtitle"
                        visibility="0"
                        layout_width="184dp"
                        android:layout_height="wrap_content"
                        layout_marginTop="@dimen/margin_24dp"
                        maxLines="2"
                        singleLine="false"/>
                    <ImageView
                        id="@+id/iv_logo"
                        layout_width="64dp"
                        android:layout_height="24dp"
                        layout_marginTop="@dimen/dp_40"
                        layout_marginBottom="@dimen/margin_8dp"
                        adjustViewBounds="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <o.C35893oHp
                layout_gravity="0x1"
                id="@+id/iv_avatar"
                layout_width="@dimen/text_avatar_bg_size"
                android:layout_height="@dimen/text_avatar_bg_size"
                elevation="12dp"/>
        </FrameLayout>
    </LinearLayout>
    <o.C52794wYp
        textAppearance="@style/LiteTextAppearance.Black.16SP.Bold"
        textColor="@color/text_black"
        layout_gravity="0x50"
        id="@+id/btn_save"
        background="@drawable/_2131231191_res_0x7f0801d7"
        paddingLeft="32dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="32dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="52dp"
        layout_marginBottom="@dimen/margin_20dp"
        text="@string/pr_message_function_btn_save_to_photos"
        layout_marginStart="@dimen/common_page_edge_space"
        layout_marginEnd="@dimen/common_page_edge_space"
        style="@style/Button.White.Round"/>
</FrameLayout>
