<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/dialog_finger_print_verify_0"
    background="@drawable/_2131231482_res_0x7f0802fa"
    layout_width="-2"
    android:layout_height="wrap_content"
    minWidth="280dp">
    <ImageView
        layout_gravity="0x1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="30dp"
        src="@drawable/_2131232992_res_0x7f0808e0"/>
    <TextView
        gravity="0x11"
        layout_gravity="0x1"
        id="@+id/tvTips"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="20dp"
        layout_marginRight="16dp"
        layout_marginBottom="32dp"
        text="@string/pr_metax_wallet_text_verify_your_finger_print"
        layout_marginHorizontal="16dp"
        style="@style/TextAppearance.Title.16SP"/>
    <LinearLayout
        orientation="1"
        id="@+id/llTryAgain"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content">
        <View
            background="@color/list_divider_color"
            layout_width="-1"
            android:layout_height="1dp"/>
        <TextView
            gravity="0x11"
            id="@+id/tvTryAgain"
            paddingTop="5dp"
            paddingBottom="10dp"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginLeft="16dp"
            layout_marginRight="16dp"
            text="@string/pr_common_fingerprint_textbtn_try_again"
            layout_marginHorizontal="16dp"
            style="@style/TextAppearance.Blue.16SP"/>
    </LinearLayout>
    <View
        background="@color/list_divider_color"
        layout_width="-1"
        android:layout_height="1dp"/>
    <TextView
        gravity="0x11"
        id="@+id/cancel"
        layout_width="-1"
        android:layout_height="44dp"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        text="@string/pr_wallet_dapps_textbtn_cancel"
        layout_marginHorizontal="16dp"
        style="@style/TextAppearance.Blue.16SP"/>
</LinearLayout>
