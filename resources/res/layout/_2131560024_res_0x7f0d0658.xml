<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/ll_time_select"
    tag="layout/fragment_kline_right_time_0"
    background="@color/BasePrimary"
    paddingLeft="16dp"
    paddingRight="16dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="16dp">
    <TextView
        textSize="@dimen/text_size_18sp"
        textStyle="0x1"
        textColor="@color/grey_g900"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginBottom="12dp"
        text="@string/pr_spotcharts_bot_header_timeframe_sheet_all"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_time"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingEnd="8dp"/>
</LinearLayout>
