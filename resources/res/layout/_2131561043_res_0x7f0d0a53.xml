<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="1"
    id="@+id/list_top_item"
    paddingLeft="@dimen/margin_default"
    paddingRight="@dimen/margin_default"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/xxxsm"
    paddingHorizontal="@dimen/margin_default">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content">
        <RelativeLayout
            orientation="0"
            paddingTop="@dimen/margin_8dp"
            paddingBottom="@dimen/margin_8dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingVertical="@dimen/margin_8dp">
            <o.C55052xcf
                id="@+id/filter_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_centerVertical="true"
                layout_marginEnd="@dimen/ok_dp_16"
                NOT_FOUND_0x25="@string/pr_swaptrade_token_detail_dropdown_all_labels"/>
            <o.C55052xcf
                id="@+id/filter_transaction"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_centerVertical="true"
                layout_toEndOf="@+id/filter_label"
                NOT_FOUND_0x25="@string/pr_trade_cedefi_select_tab_all_types"/>
            <androidx.appcompat.widget.SwitchCompat
                id="@+id/switch_token"
                background="@drawable/_2131233752_res_0x7f080bd8"
                padding="2dp"
                layout_width="-2"
                android:layout_height="20dp"
                thumb="@drawable/_2131232010_res_0x7f08050a"
                layout_centerVertical="true"
                layout_marginEnd="@dimen/ok_dp_12"
                layout_toStartOf="@+id/iv_filter"
                backgroundTint="@color/SurfacePrimary"
                NOT_FOUND_0x28="@color/SurfacePrimary"/>
            <ImageView
                id="@+id/iv_filter"
                layout_width="@dimen/width_20dp"
                android:layout_height="@dimen/width_20dp"
                src="@drawable/_2131232227_res_0x7f0805e3"
                layout_centerVertical="true"
                layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        paddingTop="@dimen/margin_8dp"
        paddingBottom="@dimen/margin_8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/margin_8dp">
        <LinearLayout
            orientation="0"
            id="@+id/ll_label_type_time"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            paddingEnd="8dp"
            NOT_FOUND_0x20="@+id/tv_label_value_price"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x23="0">
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_label_type_time"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_token_detail_item_type_time"
                maxLines="1"
                style="@style/Label_3_Regular"/>
            <ImageView
                layout_gravity="0x10"
                id="@+id/iv_time_icon"
                layout_width="12dp"
                android:layout_height="12dp"
                src="@drawable/_2131231570_res_0x7f080352"
                layout_marginStart="4dp"
                NOT_FOUND_0x27="@color/ContentContrast"/>
        </LinearLayout>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_label_value_price"
            paddingLeft="8dp"
            paddingRight="8dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_token_detail_item_value_price"
            maxLines="1"
            layout_weight="1"
            paddingHorizontal="8dp"
            NOT_FOUND_0x20="@+id/tv_label_address"
            NOT_FOUND_0x21="@+id/ll_label_type_time"
            NOT_FOUND_0x23="0"
            style="@style/Label_3_Regular"/>
        <o.C55258xgZ
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_label_address"
            layout_width="100dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_token_detail_textarea_address"
            maxLines="1"
            paddingStart="8dp"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x21="@+id/tv_label_value_price"
            NOT_FOUND_0x23="0"
            NOT_FOUND_0x24="0.33"
            NOT_FOUND_0x26="0"
            style="@style/TextAppearance.Text.12SP.Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
