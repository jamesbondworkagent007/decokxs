<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="0"
    paddingTop="@dimen/padding_16dp"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingVertical="@dimen/padding_16dp">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"
        layout_marginEnd="@dimen/margin_12dp"
        style="@style/Title_2_Medium"/>
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x10"
        id="@+id/iv"
        layout_width="@dimen/width_24dp"
        android:layout_height="@dimen/height_24dp"
        tint="@color/ContentPrimary"/>
</LinearLayout>
