<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="24dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="24dp">
    <TextView
        textColor="@color/ContentPrimary"
        layout_gravity="0x10"
        id="@+id/title"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_orbit_upgrade_bttmsheet_header_now_orbiter"
        style="@style/Headline_5_Bold"/>
    <TextView
        textColor="@color/ContentTertiary"
        layout_gravity="0x10"
        id="@+id/subTitle"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="@string/pr_orbit_upgrade_bttmsheet_desc_youre_able_to"
        style="@style/Body_2_Regular"/>
    <LinearLayout
        orientation="0"
        paddingTop="16dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        paddingVertical="16dp">
        <ImageView
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232049_res_0x7f080531"
            NOT_FOUND_0x10="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentSecondary"
            layout_gravity="0x10"
            id="@+id/tv1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginStart="7dp"
            style="@style/Label_1_Regular"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        paddingTop="16dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="16dp">
        <ImageView
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231718_res_0x7f0803e6"
            NOT_FOUND_0x10="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentSecondary"
            layout_gravity="0x10"
            id="@+id/tv2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginStart="7dp"
            style="@style/Label_1_Regular"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        paddingTop="16dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="16dp">
        <ImageView
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231584_res_0x7f080360"
            NOT_FOUND_0x10="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentSecondary"
            layout_gravity="0x10"
            id="@+id/tv3"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginStart="7dp"
            style="@style/Label_1_Regular"/>
    </LinearLayout>
</LinearLayout>
