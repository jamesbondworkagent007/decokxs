<?xml version="1.0" encoding="utf-8"?>
<view xmlns:android="http://schemas.android.com/apk/res/android"
    theme="@style/ThemeOverlay.AppCompat.Dark"
    layout_gravity="0x50"
    layout_width="-1"
    android:layout_height="wrap_content"
    class="com.google.android.material.snackbar.SnackbarContentLayout">
    <TextView
        textAppearance="@style/TextAppearance.Design.Snackbar.Message"
        ellipsize="3"
        layout_gravity="0x800013"
        id="@+id/snackbar_text"
        paddingLeft="@dimen/design_snackbar_padding_horizontal"
        paddingTop="@dimen/design_snackbar_padding_vertical"
        paddingRight="@dimen/design_snackbar_padding_horizontal"
        paddingBottom="@dimen/design_snackbar_padding_vertical"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="@integer/design_snackbar_text_max_lines"
        layout_weight="1"
        textAlignment="5"/>
    <Button
        textColor="?attr/colorAccent"
        layout_gravity="0x800015"
        id="@+id/snackbar_action"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/design_snackbar_extra_spacing_horizontal"
        minWidth="48dp"
        layout_marginStart="@dimen/design_snackbar_extra_spacing_horizontal"
        style="?attr/borderlessButtonStyle"/>
</view>
