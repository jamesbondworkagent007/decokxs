<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-2"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        background="@drawable/_2131233184_res_0x7f0809a0"
        padding="0.5dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="1"
            id="@+id/layout_title_column"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                id="@+id/tv_first_row_first_column"
                background="@drawable/_2131233185_res_0x7f0809a1"
                layout_width="-1"
                android:layout_height="48dp"/>
            <View
                background="@color/BorderPrimary"
                layout_width="-1"
                android:layout_height="0.5dp"/>
        </LinearLayout>
        <View
            background="@color/BorderPrimary"
            layout_width="0.5dp"
            android:layout_height="match_parent"/>
        <LinearLayout
            orientation="1"
            id="@+id/layout_content_column"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="3">
            <LinearLayout
                background="@drawable/_2131233186_res_0x7f0809a2"
                layout_width="-1"
                android:layout_height="48dp">
                <TextView
                    textSize="@dimen/font_12"
                    textColor="@color/ContentContrast"
                    gravity="0x11"
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    layout_marginLeft="@dimen/xxxxsm"
                    layout_marginRight="@dimen/xxxxsm"
                    text="@string/pr_invest_revamp_dialog_desc_tvl"
                    layout_weight="1"
                    textAlignment="4"
                    layout_marginHorizontal="@dimen/xxxxsm"/>
                <View
                    background="@color/BorderPrimary"
                    layout_width="0.5dp"
                    android:layout_height="match_parent"/>
                <TextView
                    textSize="@dimen/font_12"
                    textColor="@color/ContentContrast"
                    gravity="0x11"
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    layout_marginLeft="@dimen/xxxxsm"
                    layout_marginRight="@dimen/xxxxsm"
                    text="@string/pr_invest_revamp_dialog_desc_uptime"
                    layout_weight="1"
                    textAlignment="4"
                    layout_marginHorizontal="@dimen/xxxxsm"/>
                <View
                    background="@color/BorderPrimary"
                    layout_width="0.5dp"
                    android:layout_height="match_parent"/>
                <TextView
                    textSize="@dimen/font_12"
                    textColor="@color/ContentContrast"
                    gravity="0x11"
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    layout_marginLeft="@dimen/xxxxsm"
                    layout_marginRight="@dimen/xxxxsm"
                    text="@string/pr_invest_revamp_dialog_desc_credit_score"
                    layout_weight="1"
                    textAlignment="4"
                    layout_marginHorizontal="@dimen/xxxxsm"/>
            </LinearLayout>
            <View
                background="@color/BorderPrimary"
                layout_width="-1"
                android:layout_height="0.5dp"/>
        </LinearLayout>
    </LinearLayout>
</merge>
