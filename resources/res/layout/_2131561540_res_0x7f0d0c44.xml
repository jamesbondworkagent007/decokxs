<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/ContentContrast"
        id="@+id/header_title"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"/>
    <RelativeLayout
        id="@+id/cl_address"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp">
        <TextView
            textAppearance="@style/TextAppearance.Regular"
            textSize="16sp"
            textColor="@color/ContentPrimary"
            id="@+id/tv_content_info"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_alignParentTop="true"
            layout_toStartOf="@+id/view_content"
            layout_alignParentStart="true"/>
        <View
            id="@+id/view_content"
            layout_width="48dp"
            android:layout_height="wrap_content"
            layout_alignParentTop="true"
            layout_alignParentBottom="true"
            layout_alignWithParentIfMissing="true"
            layout_toStartOf="@+id/iv_action_icon"/>
        <ImageView
            id="@+id/iv_action_icon"
            visibility="2"
            layout_width="18dp"
            android:layout_height="18dp"
            src="@drawable/_2131234345_res_0x7f080e29"
            layout_alignParentTop="true"
            layout_alignParentEnd="true"
            NOT_FOUND_0x17="@color/ContentContrast"/>
        <ImageView
            id="@+id/iv_arrow_icon"
            visibility="2"
            layout_width="18dp"
            android:layout_height="18dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            layout_alignParentTop="true"
            layout_alignParentEnd="true"
            NOT_FOUND_0x17="@color/ContentContrast"/>
    </RelativeLayout>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_sub_content"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        style="@style/TextAppearance.Text.14SP.Regular"/>
    <LinearLayout
        orientation="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp">
        <o.C55251xgS
            ellipsize="3"
            id="@+id/tv_tag_info_primary"
            visibility="2"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            NOT_FOUND_0x13="-2"
            NOT_FOUND_0x14="-4"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="6"/>
        <o.C55251xgS
            ellipsize="3"
            id="@+id/tv_tag_info_secondary"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0x13="-2"
            NOT_FOUND_0x14="-4"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="6"/>
    </LinearLayout>
</merge>
