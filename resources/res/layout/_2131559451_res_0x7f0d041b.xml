<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@drawable/_2131231846_res_0x7f080466"
    padding="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.14SP.Bold"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_max_fee_header_order_execution_history"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_sub_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_execution_history"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"/>
</LinearLayout>
