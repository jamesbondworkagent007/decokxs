<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    id="@+id/content_constraint_layout"
    tag="layout/item_cta_list_item_0"
    clickable="true"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="48dp">
    <LinearLayout
        orientation="1"
        id="@+id/ll_cta_list_item_container"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/tv_cta_list_item_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_cta_list_item_content"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp8"
            style="@style/Label_1_Medium"/>
    </LinearLayout>
    <ImageView
        layout_gravity="0x10"
        id="@+id/iv_eye_icon"
        visibility="2"
        layout_width="@dimen/width_20dp"
        android:layout_height="@dimen/height_20dp"
        src="@drawable/_2131232197_res_0x7f0805c5"
        layout_marginStart="@dimen/dp24"
        NOT_FOUND_0xe="@color/ContentContrast"/>
    <ImageView
        layout_gravity="0x10"
        id="@+id/iv_arrow"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232354_res_0x7f080662"
        layout_marginStart="@dimen/dp24"
        NOT_FOUND_0xe="@color/ContentContrast"/>
</androidx.appcompat.widget.LinearLayoutCompat>
