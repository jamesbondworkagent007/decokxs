<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/iv"
        layout_width="44dp"
        android:layout_height="44dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Regular"
        textSize="14sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0xd="@+id/tv_primary"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x12="@+id/iv"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Bold"
        textSize="14sp"
        textColor="@color/ContentBrand"
        ellipsize="3"
        id="@+id/tv_primary"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        singleLine="true"
        NOT_FOUND_0xb="true"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="@+id/tv_secondary"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="2"
        NOT_FOUND_0x13="@+id/tv"
        NOT_FOUND_0x14="@+id/tv"/>
    <TextView
        textAppearance="@style/TextAppearance.Bold"
        textSize="14sp"
        textColor="@color/ContentBrand"
        ellipsize="3"
        id="@+id/tv_secondary"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        singleLine="true"
        layout_marginStart="24dp"
        NOT_FOUND_0xb="true"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@+id/tv_primary"
        NOT_FOUND_0x14="@+id/tv"/>
</merge>
