<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <com.okinc.auth.impl.widget.SimpleToolBar
        id="@+id/appBar"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="@drawable/_2131231675_res_0x7f0803bb"/>
    <LinearLayout
        orientation="1"
        id="@+id/confirmRemovePasskeyContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x11="@+id/appBar">
        <TextView
            textAppearance="@style/TextAppearance.Text.Bold.28SP"
            textColor="@color/ContentPrimary"
            id="@+id/title"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_28dp"
            layout_marginTop="@dimen/margin_24dp"
            layout_marginRight="@dimen/margin_28dp"
            text="@string/pr_account_passkey2fa_top_title_remove_passkey"
            contentDescription="title"
            layout_marginHorizontal="@dimen/margin_28dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.Regular"
            textColor="@color/ContentTertiary"
            id="@+id/subTitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_28dp"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginRight="@dimen/margin_28dp"
            text="@string/pr_account_passkey2fa_top_desc_remove_passkey"
            contentDescription="subTitle"
            layout_marginHorizontal="@dimen/margin_28dp"
            NOT_FOUND_0x13="@dimen/dp24"/>
        <ImageView
            layout_gravity="0x1"
            id="@+id/passkeyRemoveIcon"
            visibility="2"
            layout_width="240dp"
            android:layout_height="240dp"
            layout_marginTop="64dp"
            contentDescription="passkeyRemoveIcon"/>
        <ImageView
            layout_gravity="0x1"
            id="@+id/passkeyResetIcon"
            layout_width="240dp"
            android:layout_height="240dp"
            layout_marginTop="100dp"
            scaleType="6"
            contentDescription="passkeyResetIcon"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/buttonContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginBottom="@dimen/margin_16dp"
        layout_marginHorizontal="@dimen/margin_24dp"
        NOT_FOUND_0x10="0">
        <com.okinc.uilab.reminder.OKReminder
            id="@+id/guideReminder"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/margin_24dp"/>
        <o.C52794wYp
            id="@+id/confirmButton"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/margin_12dp"
            text="@string/pr_commonall_text_btn_confirm"
            contentDescription="confirmButton"
            NOT_FOUND_0x14="52"/>
        <o.C52794wYp
            id="@+id/cancelButton"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_commonall_text_btn_cancel"
            contentDescription="cancelButton"
            NOT_FOUND_0x14="52"
            NOT_FOUND_0x15="0x104"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
