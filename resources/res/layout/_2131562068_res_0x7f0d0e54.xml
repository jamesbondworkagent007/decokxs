<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/dp24"
    paddingTop="12dp"
    paddingRight="@dimen/dp24"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp24"
    paddingVertical="12dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/img_avatar"
        layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        src="@drawable/_2131232465_res_0x7f0806d1"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="12dp"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x15="@+id/tv_tag"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="2"
        NOT_FOUND_0x18="@+id/img_avatar"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="1"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentSecondary_Dark"
        id="@+id/tv_tag"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="4dp"
        paddingHorizontal="4dp"
        paddingVertical="2dp"
        NOT_FOUND_0x13="@+id/tv_title"
        NOT_FOUND_0x15="@+id/iv_premium_icon"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="@+id/tv_title"
        NOT_FOUND_0x1b="@+id/tv_title"
        style="@style/Label_4_Regular"/>
    <ImageView
        id="@+id/iv_premium_icon"
        padding="2dp"
        visibility="2"
        layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"
        src="@drawable/_2131233718_res_0x7f080bb6"
        layout_marginStart="4dp"
        NOT_FOUND_0x13="@+id/tv_title"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="@+id/tv_tag"
        NOT_FOUND_0x1b="@+id/tv_title"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_content"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="1"
        layout_marginStart="12dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="@+id/img_avatar"
        NOT_FOUND_0x1a="@+id/tv_title"
        style="@style/Body_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
