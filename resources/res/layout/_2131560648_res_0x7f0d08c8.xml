<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_invest_babylon_redeem_position_0"
    background="@drawable/_2131233182_res_0x7f08099e"
    padding="@dimen/xsm"
    focusable="true"
    clickable="true"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/xsm"
    layout_marginTop="@dimen/xsm"
    layout_marginRight="@dimen/xsm"
    minHeight="84dp"
    layout_marginHorizontal="@dimen/xsm">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/asset_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"/>
    <o.C55251xgS
        theme="@style/Theme.Design.Light"
        id="@+id/overflow_tag"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_investredeem_card_tag_overflow"
        layout_marginStart="4dp"
        NOT_FOUND_0x13="@+id/asset_name"
        NOT_FOUND_0x15="@+id/asset_name"
        NOT_FOUND_0x18="@+id/asset_name"
        NOT_FOUND_0x19="-5"
        NOT_FOUND_0x1a="6"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/coin_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x18="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/date"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/asset_name"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/dollar_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/coin_amount"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_4_Regular"
        textColor="@color/ContentPrimary"
        id="@+id/provider_name"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/date"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/status_text"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/provider_name"/>
</androidx.constraintlayout.widget.ConstraintLayout>
