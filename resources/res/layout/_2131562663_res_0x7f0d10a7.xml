<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="match_parent">
    <RelativeLayout
        layout_gravity="0x10"
        orientation="1"
        id="@+id/contentContainer"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1">
        <TextView
            textAppearance="@style/OKTextFont.Regular"
            textSize="16sp"
            textColor="@color/ContentDisabled"
            orientation="1"
            id="@+id/title"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_centerVertical="true"/>
        <LinearLayout
            layout_gravity="0x10"
            orientation="0"
            id="@+id/inputContent"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_below="@+id/title">
            <RelativeLayout
                layout_gravity="0x10"
                id="@+id/rl_label"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    id="@+id/content_label"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginEnd="4dp"/>
            </RelativeLayout>
            <o.C55001xbh
                gravity="0x10"
                layout_gravity="0x10"
                id="@+id/edt_content"
                background="@null"
                layout_width="0dp"
                android:layout_height="match_parent"
                singleLine="true"
                layout_weight="1"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        gravity="0x10"
        layout_gravity="0x10"
        orientation="0"
        id="@+id/ll_function"
        layout_width="-2"
        android:layout_height="match_parent"/>
</merge>
