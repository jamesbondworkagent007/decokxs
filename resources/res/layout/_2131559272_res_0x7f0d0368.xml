<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/remote_strategy_container"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x10"
            id="@+id/tv_remote_strategy"
            background="@drawable/_2131230992_res_0x7f080110"
            paddingLeft="@dimen/dp_12"
            paddingRight="@dimen/dp_12"
            layout_width="0dp"
            android:layout_height="@dimen/dp_48"
            maxLines="1"
            layout_weight="1"
            paddingHorizontal="@dimen/dp_12"
            style="@style/Body_2_Regular"/>
        <ImageView
            id="@+id/iv_remove_remote"
            layout_width="@dimen/dp24"
            android:layout_height="@dimen/dp24"
            layout_marginStart="7dp"
            NOT_FOUND_0x16="@drawable/_2131233506_res_0x7f080ae2"
            NOT_FOUND_0x17="@color/ContainerInverse"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/custom_strategy_container"
        layout_width="-1"
        android:layout_height="wrap_content">
        <o.C55008xbo
            id="@+id/et_price_change_percentage"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            NOT_FOUND_0x12="48"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="1"
            NOT_FOUND_0x15="0"/>
        <o.C55008xbo
            id="@+id/et_sell_percentage"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/margin_8dp"
            NOT_FOUND_0x12="48"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="1"
            NOT_FOUND_0x15="0"/>
        <ImageView
            id="@+id/iv_remove_custom"
            layout_width="@dimen/dp24"
            android:layout_height="@dimen/dp24"
            layout_marginStart="7dp"
            NOT_FOUND_0x16="@drawable/_2131233506_res_0x7f080ae2"
            NOT_FOUND_0x17="@color/ContainerInverse"/>
    </LinearLayout>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/SemanticNegative"
        id="@+id/tv_error_message"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        text="@string/pr_swaptrade_tee_error_fill_in_sell_parameters"/>
</merge>
