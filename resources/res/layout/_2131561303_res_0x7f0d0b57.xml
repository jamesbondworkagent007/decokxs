<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <RelativeLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/iv_close"
            visibility="2"
            layout_width="24dp"
            android:layout_height="24dp"
            layout_marginTop="4dp"
            src="@drawable/_2131231675_res_0x7f0803bb"
            scaleType="fitStart"
            layout_marginEnd="16dp"
            layout_alignParentEnd="true"
            NOT_FOUND_0x19="@color/ContentContrast"/>
        <ImageView
            id="@+id/iv_pic"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxsm"
            scaleType="fitStart"
            layout_centerHorizontal="true"/>
    </RelativeLayout>
    <TextView
        textAppearance="@style/TextAppearance.Title.Bold.24SP"
        textSize="@dimen/text_size_26sp"
        textColor="@color/ContentPrimary"
        id="@+id/reminder_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_investdetails_bot_popuptitle_tip"
        includeFontPadding="false"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"/>
    <androidx.core.widget.NestedScrollView
        id="@+id/scroll_container"
        layout_width="-1"
        android:layout_height="0dp"
        layout_marginTop="16dp"
        layout_marginBottom="16dp"
        layout_weight="1">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textAppearance="@style/TextAppearance.Text.15SP"
                textSize="@dimen/text_size_15sp"
                textColor="@color/ContentSecondary"
                gravity="0x800003"
                id="@+id/reminder_subtitle"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="10dp"
                text="@string/pr_investdetails_bot_popupcontent_risk"
                layout_marginStart="24dp"
                layout_marginEnd="24dp"
                NOT_FOUND_0x18="24dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <o.wYK
        theme="@style/OKUITheme"
        textAppearance="@style/TextAppearance.Text.14SP"
        textColor="@color/ContentPrimary"
        textColorLink="@color/ContentPrimary"
        gravity="0x30"
        id="@+id/check_never_remind"
        layout_width="-1"
        android:layout_height="wrap_content"
        checked="false"
        text="@string/pr_investdetails_bot_popuptitle_check"
        contentDescription="invest_remind_check_box"
        layout_marginStart="@dimen/margin_24dp"
        layout_marginEnd="@dimen/margin_24dp"/>
    <Space
        id="@+id/space_view"
        layout_width="-1"
        android:layout_height="@dimen/dp_16"/>
</LinearLayout>
