<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/trade_ui_item_smart_arbitrage_binder_0"
    paddingBottom="@dimen/margin_24dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/line"
        background="@color/list_divider_color"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0x11="0"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xd="@+id/tv_value"
        NOT_FOUND_0xe="1"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/line"
        style="@style/TextAppearance.Text.14SP.Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800005"
        id="@+id/tv_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0xa="true"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="@+id/tv_title"
        NOT_FOUND_0x11="@+id/line"
        style="@style/TextAppearance.Title.16SP.Semibold"/>
</androidx.constraintlayout.widget.ConstraintLayout>
