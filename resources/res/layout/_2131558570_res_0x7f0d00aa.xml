<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/activity_hardware_wallet_bluetooth_device_matching_0"
    background="@color/background_lv1"
    layout_width="-1"
    android:layout_height="match_parent">
    <o.C33537myN
        id="@+id/app_bar"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x11="@color/transparent"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@color/transparent"/>
    <FrameLayout
        layout_gravity="0x1"
        layout_width="248dp"
        android:layout_height="248dp"
        layout_marginTop="-6dp">
        <com.airbnb.lottie.LottieAnimationView
            layout_gravity="0x1"
            id="@+id/lottie_view_matching"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <com.airbnb.lottie.LottieAnimationView
            layout_gravity="0x1"
            id="@+id/lottie_view_match_success"
            visibility="1"
            layout_width="-1"
            android:layout_height="match_parent"/>
    </FrameLayout>
    <TextView
        textAppearance="@style/TextAppearance.Bold"
        textSize="24sp"
        textColor="@color/grey_g900"
        gravity="0x1"
        id="@+id/tv_pairing"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="20dp"
        layout_marginRight="16dp"
        layout_marginHorizontal="16dp"/>
    <TextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/grey_g400"
        gravity="0x1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginTop="16dp"
        layout_marginRight="16dp"
        text="@string/pr_wallet_hardwallet_subtitle_nanox_unlocked"
        layout_marginHorizontal="16dp"/>
</LinearLayout>
