<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/preview_close_image"
        background="@drawable/_2131233598_res_0x7f080b3e"
        padding="4dp"
        layout_width="28dp"
        android:layout_height="28dp"
        layout_marginTop="@dimen/margin_12dp"
        layout_marginBottom="@dimen/margin_12dp"
        src="@drawable/_2131231675_res_0x7f0803bb"
        scaleType="fitStart"
        layout_marginStart="@dimen/margin_24dp"
        layout_alignParentStart="true"
        NOT_FOUND_0x19="@color/ContentPrimary_Dark"/>
    <TextView
        textColor="@color/white"
        id="@+id/preview_original"
        background="@drawable/_2131233597_res_0x7f080b3d"
        paddingLeft="@dimen/margin_2dp"
        paddingTop="@dimen/margin_2dp"
        paddingRight="@dimen/margin_2dp"
        paddingBottom="@dimen/margin_2dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_message_btn_view_original"
        layout_centerVertical="true"
        layout_marginStart="@dimen/margin_24dp"
        layout_toEndOf="@+id/preview_close_image"
        paddingHorizontal="@dimen/margin_2dp"
        paddingVertical="@dimen/margin_2dp"/>
    <LinearLayout
        orientation="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingEnd="@dimen/width_24dp"
        layout_alignParentEnd="true">
        <ImageView
            id="@+id/preview_download_iv"
            background="@drawable/_2131233598_res_0x7f080b3e"
            padding="4dp"
            visibility="2"
            layout_width="28dp"
            android:layout_height="28dp"
            layout_marginTop="@dimen/margin_12dp"
            layout_marginBottom="@dimen/margin_12dp"
            src="@drawable/_2131232047_res_0x7f08052f"
            scaleType="fitStart"
            NOT_FOUND_0x19="@color/ContentPrimary_Dark"/>
        <ImageView
            id="@+id/preview_share_iv"
            background="@drawable/_2131233598_res_0x7f080b3e"
            padding="4dp"
            visibility="2"
            layout_width="28dp"
            android:layout_height="28dp"
            layout_marginTop="@dimen/margin_12dp"
            layout_marginBottom="@dimen/margin_12dp"
            src="@drawable/_2131233788_res_0x7f080bfc"
            scaleType="fitStart"
            layout_marginStart="@dimen/margin_12dp"
            NOT_FOUND_0x19="@color/ContentPrimary_Dark"/>
    </LinearLayout>
</RelativeLayout>
