<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingTop="24dp"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="24dp">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        background="@drawable/_2131231482_res_0x7f0802fa"
        padding="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        backgroundTint="@color/SurfaceSecondary">
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_fdcabot_orderdetail_colheader_completed_cycle"
                layout_weight="1"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x800005"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_dcdbot_orderdetails_header_arbitrage_gains"
                layout_weight="1"
                layout_marginStart="10dp"
                style="@style/Label_3_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="2dp">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/completeCycleTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="--"
                layout_weight="1"
                style="@style/Label_1_Bold"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x800005"
                id="@+id/arbProfitTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="--"
                layout_weight="1"
                layout_marginStart="10dp"
                style="@style/Label_1_Bold"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        id="@+id/fundingFeeContainer"
        background="@drawable/_2131231482_res_0x7f0802fa"
        padding="16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        backgroundTint="@color/SurfaceSecondary">
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_smartarb_botdetails_tab_title_funding_rate_history"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/fundingFeeTv"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            layout_weight="1"
            layout_marginStart="24dp"
            style="@style/Label_2_Medium"/>
        <ImageView
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231649_res_0x7f0803a1"
            contentDescription="@null"
            layout_marginStart="4dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        id="@+id/earnProfitContainer"
        background="@drawable/_2131231482_res_0x7f0802fa"
        padding="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        backgroundTint="@color/SurfaceSecondary">
        <o.C55258xgZ
            theme="@style/OKUITheme"
            id="@+id/earnProfitTitleTv"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="1"
            NOT_FOUND_0x15="@color/ContentPrimary"
            NOT_FOUND_0x16="14sp"
            NOT_FOUND_0x17="@string/pr_spotgrid_botdetails_title_earn_profit"
            NOT_FOUND_0x18="@style/Label_2_Medium"
            NOT_FOUND_0x19="500"
            NOT_FOUND_0x1a="0"/>
        <o.C54120wyP
            id="@+id/vipTag"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/earnProfitTv"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            layout_weight="1"
            layout_marginStart="24dp"
            style="@style/Label_2_Medium"/>
        <ImageView
            id="@+id/earnProfitArrow"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231649_res_0x7f0803a1"
            contentDescription="@null"
            layout_marginStart="4dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        id="@+id/stakeProfitContainer"
        background="@drawable/_2131231482_res_0x7f0802fa"
        padding="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        backgroundTint="@color/SurfaceSecondary">
        <o.C55258xgZ
            theme="@style/OKUITheme"
            id="@+id/stakeProfitTitleTv"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="1"
            NOT_FOUND_0x15="@color/ContentPrimary"
            NOT_FOUND_0x16="14sp"
            NOT_FOUND_0x17="@string/pr_spotgrid_botdetails_header_staking_history"
            NOT_FOUND_0x18="@style/Label_2_Medium"
            NOT_FOUND_0x19="500"
            NOT_FOUND_0x1a="0"/>
        <o.C54120wyP
            id="@+id/stakeVipTag"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"/>
        <TextView
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/stakeProfitTv"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="--"
            layout_weight="1"
            layout_marginStart="24dp"
            style="@style/Label_2_Medium"/>
        <ImageView
            id="@+id/stakeProfitArrow"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231649_res_0x7f0803a1"
            contentDescription="@null"
            layout_marginStart="4dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
