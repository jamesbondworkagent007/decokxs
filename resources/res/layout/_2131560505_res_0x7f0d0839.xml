<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-2"
    android:layout_height="24dp">
    <View
        id="@+id/bgView"
        background="@drawable/_2131231326_res_0x7f08025e"
        layout_width="0dp"
        android:layout_height="0dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        gravity="0x10"
        orientation="0"
        id="@+id/emojiWithCount"
        paddingLeft="4dp"
        paddingRight="4dp"
        layout_width="-2"
        android:layout_height="match_parent"
        paddingHorizontal="4dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0">
        <TextView
            textSize="16sp"
            textColor="@color/ContentPrimary"
            id="@+id/emojiText"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingStart="4dp"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0"/>
        <TextView
            textSize="10sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/countText"
            paddingLeft="4dp"
            paddingRight="4dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            lines="1"
            paddingHorizontal="4dp"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="@+id/emojiText"
            NOT_FOUND_0x15="0"
            style="@style/Label_4_Regular"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/ivAvatarContainer"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingStart="4dp"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="@+id/countText"
            NOT_FOUND_0x15="0">
            <o.C35893oHp
                id="@+id/ivAvatarBack"
                visibility="2"
                layout_width="20dp"
                android:layout_height="20dp"
                layout_marginStart="13dp"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x15="0"/>
            <o.C35893oHp
                id="@+id/ivAvatarFront"
                visibility="2"
                layout_width="20dp"
                android:layout_height="20dp"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x15="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
