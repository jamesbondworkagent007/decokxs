<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/bottom_cell"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_16dp">
    <ImageView
        id="@+id/enable_dex_icon"
        visibility="0"
        layout_width="@dimen/width_24dp"
        android:layout_height="@dimen/height_24dp"
        src="@drawable/_2131230781_res_0x7f08003d"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        textColor="@color/ContentPrimary"
        id="@+id/enable_dex_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_8dp"
        lineHeight="20sp"/>
</LinearLayout>
