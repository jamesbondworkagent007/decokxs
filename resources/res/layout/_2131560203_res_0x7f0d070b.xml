<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/root_layout"
    tag="layout/fragment_tactics_information_0"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        id="@+id/appbar_layout"
        background="@color/BasePrimary"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x19="0dp">
        <com.google.android.material.appbar.CollapsingToolbarLayout
            id="@+id/toolbar_layout"
            fitsSystemWindows="true"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1b="0x3"
            NOT_FOUND_0x1c="@android:color/transparent">
            <LinearLayout
                orientation="1"
                layout_width="-1"
                android:layout_height="match_parent">
                <LinearLayout
                    orientation="0"
                    id="@+id/grid_assets_root_lly"
                    background="@drawable/_2131231430_res_0x7f0802c6"
                    paddingLeft="16dp"
                    paddingTop="@dimen/padding_12dp"
                    paddingRight="16dp"
                    paddingBottom="@dimen/padding_12dp"
                    visibility="2"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginLeft="@dimen/common_page_edge_space"
                    layout_marginTop="@dimen/margin_16dp"
                    layout_marginRight="@dimen/common_page_edge_space"
                    layout_marginHorizontal="@dimen/common_page_edge_space"
                    paddingHorizontal="16dp"
                    paddingVertical="@dimen/padding_12dp">
                    <LinearLayout
                        orientation="1"
                        id="@+id/asstes_current_lly"
                        layout_width="0dp"
                        android:layout_height="wrap_content"
                        layout_weight="1">
                        <TextView
                            id="@+id/current_assets"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            text="@string/pr_trade_strategy_item_current_holding"
                            style="@style/TextAppearance.Text.14SP"/>
                        <TextView
                            id="@+id/current_assets_number1"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            layout_marginTop="@dimen/margin_4dp"
                            style="@style/TextAppearance.Title.14SP.Medium"/>
                        <TextView
                            id="@+id/current_assets_number2"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            layout_marginTop="@dimen/margin_4dp"
                            style="@style/TextAppearance.Title.14SP.Medium"/>
                    </LinearLayout>
                    <LinearLayout
                        orientation="1"
                        id="@+id/asstes_initial_lly"
                        layout_width="0dp"
                        android:layout_height="wrap_content"
                        layout_weight="1">
                        <TextView
                            id="@+id/initial_assets"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            text="@string/pr_trade_strategy_item_total_investment"
                            style="@style/TextAppearance.Text.14SP"/>
                        <TextView
                            id="@+id/initial_assets_number1"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            layout_marginTop="@dimen/margin_4dp"
                            style="@style/TextAppearance.Title.14SP.Medium"/>
                        <TextView
                            id="@+id/initial_assets_number2"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            layout_marginTop="@dimen/margin_4dp"
                            style="@style/TextAppearance.Title.14SP.Medium"/>
                    </LinearLayout>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    id="@+id/info_recycler_view"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginLeft="@dimen/common_page_edge_space"
                    layout_marginTop="14dp"
                    layout_marginRight="@dimen/common_page_edge_space"
                    layout_marginBottom="14dp"
                    overScrollMode="2"
                    layout_marginHorizontal="@dimen/common_page_edge_space"/>
                <View
                    id="@+id/divider"
                    background="@color/okTradeG50"
                    visibility="2"
                    layout_width="-1"
                    android:layout_height="8dp"/>
            </LinearLayout>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP"
            id="@+id/tv_coin_config"
            paddingTop="14dp"
            paddingBottom="14dp"
            visibility="2"
            layout_width="-1"
            android:layout_height="match_parent"
            text="@string/pr_trade__label_recurring_coin_config"
            paddingStart="@dimen/common_page_edge_space"
            paddingVertical="14dp"/>
        <View
            id="@+id/view_top_divider"
            background="@color/grey_g100"
            visibility="2"
            layout_width="-1"
            android:layout_height="0.5dp"/>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.core.widget.NestedScrollView
        id="@+id/nsv_info"
        background="@color/BasePrimary"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"
        fillViewport="true"
        overScrollMode="2"
        NOT_FOUND_0x1a="@string/appbar_scrolling_view_behavior">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rcv_detail"
            layout_width="-1"
            android:layout_height="match_parent"
            overScrollMode="2"/>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
