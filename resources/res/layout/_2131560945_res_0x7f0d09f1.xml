<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_transfer_coin_from_exchange_header_0"
    background="@drawable/_2131231491_res_0x7f080303"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_24dp"
    layout_marginTop="8dp"
    layout_marginRight="@dimen/margin_24dp"
    layout_marginBottom="20dp"
    layout_marginHorizontal="@dimen/margin_24dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_gravity="0x11"
        id="@+id/transferContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        layout_marginBottom="24dp">
        <TextView
            textSize="@dimen/text_size_18sp"
            textColor="@color/defi_withdraw_banner_text_color"
            id="@+id/tv_withdraw_quick_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_popup_option_transfer_crypto"
            layout_marginStart="@dimen/margin_16dp"
            layout_marginEnd="90dp"
            NOT_FOUND_0x12="@+id/tv_withdraw_quick_desc"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="2"
            NOT_FOUND_0x17="24dp"
            style="@style/TextAppearance.Bold"/>
        <TextView
            textSize="@dimen/text_size_12sp"
            textColor="@color/defi_withdraw_banner_text_color"
            id="@+id/tv_withdraw_quick_desc"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            text="@string/pr_nft_binding_desc_no_authentication_after_binding"
            layout_marginStart="@dimen/margin_16dp"
            layout_marginEnd="90dp"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="@+id/tv_withdraw_quick_title"
            NOT_FOUND_0x17="18dp"
            style="@style/TextAppearance.Text"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x800015"
        id="@+id/iv_withdraw_quick_icon"
        layout_width="83dp"
        android:layout_height="wrap_content"
        src="@drawable/_2131233108_res_0x7f080954"/>
</FrameLayout>
