        textColorHint="@color/hint_color"
        id="@+id/etOverride"
        layout_width="-1"
        android:layout_height="wrap_content"
        hint="Enter new override value"
        inputType="0x20001"/>
    <TextView
        textSize="18sp"
        textStyle="0x1"
        id="@+id/tvOverridePayload"
        padding="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
