<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/trade_ui_item_fund_rate_trade_arbitrage_0"
    layout_width="-1"
    android:layout_height="68dp"
    paddingStart="16dp"
    paddingEnd="16dp">
    <ImageView
        id="@+id/iv_store"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131233925_res_0x7f080c85"
        paddingEnd="2dp"
        NOT_FOUND_0x1b="@+id/tv_down"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x20="@+id/tv_top"/>
    <TextView
        textAppearance="@style/TextAppearance.Red.12SP"
        gravity="0x1"
        id="@+id/tv_top"
        background="@drawable/_2131231484_res_0x7f0802fc"
        paddingLeft="2dp"
        paddingTop="1dp"
        paddingRight="2dp"
        paddingBottom="1dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="18dp"
        text="@string/pr_trade_bot_label_sell"
        backgroundTint="@color/okTradeGreen50"
        paddingHorizontal="2dp"
        paddingVertical="1dp"
        NOT_FOUND_0x1d="@+id/iv_store"
        NOT_FOUND_0x20="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Green.12SP"
        gravity="0x1"
        id="@+id/tv_down"
        background="@drawable/_2131231484_res_0x7f0802fc"
        paddingLeft="2dp"
        paddingTop="1dp"
        paddingRight="2dp"
        paddingBottom="1dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="@string/pr_trade_bot_label_buy"
        backgroundTint="@color/okTradeGreen50"
        paddingHorizontal="2dp"
        paddingVertical="1dp"
        NOT_FOUND_0x1d="@+id/iv_store"
        NOT_FOUND_0x1f="@+id/tv_top"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.Medium"
        textSize="@dimen/text_size_14sp"
        textColor="@color/grey_g900"
        gravity="0x10"
        id="@+id/tv_top_product"
        tag="binding_1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="6dp"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0x1a="@+id/tv_top"
        NOT_FOUND_0x1d="@+id/tv_top"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.Medium"
        textSize="@dimen/text_size_14sp"
        textColor="@color/grey_g900"
        gravity="0x10"
        id="@+id/tv_down_product"
        tag="binding_2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginStart="6dp"
        layout_marginEnd="@dimen/dp_4"
        NOT_FOUND_0x1a="@+id/tv_down"
        NOT_FOUND_0x1d="@+id/tv_down"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.Medium"
        textSize="@dimen/text_size_14sp"
        textColor="@color/okTradeG900"
        id="@+id/tv_rate_apy_amout"
        tag="binding_3"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1a="@+id/tv_top_product"
        NOT_FOUND_0x1c="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.Medium"
        textSize="@dimen/text_size_14sp"
        textColor="@color/okTradeG900"
        layout_gravity="0x800005"
        id="@+id/tv_funding_rate"
        tag="binding_4"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1a="@+id/tv_down_product"
        NOT_FOUND_0x1c="0"/>
    <LinearLayout
        orientation="1"
        id="@+id/ll_ratio"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingEnd="0dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x20="0">
        <TextView
            textAppearance="@style/TextAppearance.Text.Medium"
            textSize="@dimen/text_size_12sp"
            textColor="@color/okTradeRed700"
            layout_gravity="0x800005"
            id="@+id/tv_pre_funding_rate"
            tag="binding_5"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="101.12%"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
