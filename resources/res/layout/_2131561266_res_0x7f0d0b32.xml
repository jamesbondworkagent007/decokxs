<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/noBackUpHomeIllustration"
            layout_width="168dp"
            android:layout_height="168dp"
            scaleType="fillCenter"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x20="0"
            NOT_FOUND_0x23="@drawable/_2131232727_res_0x7f0807d7"/>
        <TextView
            textAppearance="@style/Label_2_Medium"
            textColor="@color/ContentContrast"
            id="@+id/tv_getStarted"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_16dp"
            layout_marginRight="@dimen/margin_16dp"
            text="@string/pr_wallet_banner_header_subtitle_get_started"
            layout_marginHorizontal="@dimen/margin_16dp"
            NOT_FOUND_0x1a="true"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="@+id/noBackUpHomeIllustration"/>
        <TextView
            textAppearance="@style/Headline_5_Bold"
            textColor="@color/ContentPrimary"
            gravity="0x1"
            id="@+id/tv_back_desc"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginTop="4dp"
            layout_marginRight="@dimen/margin_24dp"
            text="@string/pr_wallet_banner_nav_title_secure_wallet"
            layout_marginHorizontal="@dimen/margin_24dp"
            NOT_FOUND_0x1a="true"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="@+id/tv_getStarted"/>
        <o.C52794wYp
            textSize="@dimen/text_size_16sp"
            gravity="0x11"
            id="@+id/btn_backToIcloud"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_40dp"
            text="@string/pr_wallet_home_btn_backup_to_cloud"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="@+id/tv_back_desc"
            NOT_FOUND_0x21="52"
            NOT_FOUND_0x22="0x101"
            style="@style/Label_1_Bold"/>
        <o.C52794wYp
            textSize="@dimen/text_size_16sp"
            gravity="0x11"
            id="@+id/btn_manually"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="@string/pr_wallet_home_btn_backup_manually"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1f="@+id/btn_backToIcloud"
            NOT_FOUND_0x21="52"
            NOT_FOUND_0x22="0x104"
            style="@style/Label_1_Bold"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_gravity="0x1"
        orientation="0"
        id="@+id/networks_container"
        background="@drawable/_2131231256_res_0x7f080218"
        paddingLeft="@dimen/padding_16dp"
        paddingRight="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginTop="40dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp"
        paddingHorizontal="@dimen/padding_16dp">
        <o.C57440yiU
            id="@+id/chain_icons"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            layout_marginBottom="12dp"
            layout_marginEnd="4dp"
            layout_marginVertical="12dp"
            NOT_FOUND_0x19="-4dp"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="@+id/tv_networks"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x20="0"/>
        <TextView
            textAppearance="@style/Label_2_Medium"
            textColor="@color/grey_g900"
            ellipsize="3"
            id="@+id/tv_networks"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="30dp"
            NOT_FOUND_0x1b="@+id/chain_icons"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x20="@+id/chain_icons"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
