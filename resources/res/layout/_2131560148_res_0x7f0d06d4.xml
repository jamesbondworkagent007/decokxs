<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    scrollbars="horizontal"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x1"
        orientation="1"
        layout_width="-1"
        android:layout_height="match_parent">
        <ImageView
            id="@+id/image_top"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_24dp"
            src="@drawable/_2131233020_res_0x7f0808fc"/>
        <TextView
            textAppearance="@style/Headline_4_Bold"
            textColor="@color/grey_g900"
            gravity="0x11"
            id="@+id/tv_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="20dp"
            text="@string/pr_wallet_header_title_security_tips"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginTop="@dimen/margin_48dp"
            layout_marginRight="@dimen/margin_24dp"
            layout_marginBottom="@dimen/margin_24dp"
            layout_marginHorizontal="@dimen/margin_24dp">
            <TextView
                textAppearance="@style/Title_2_Bold"
                textColor="@color/grey_g900"
                id="@+id/tv_num1_title"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_wallet_mid_subtitle_beware_of_scams"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x12="0"/>
            <TextView
                textAppearance="@style/Label_2_Regular"
                textColor="@color/grey_g400"
                id="@+id/tv_num1_subtitle"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                text="@string/pr_wallet_mid_desc_scam"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x10="@+id/tv_num1_title"
                NOT_FOUND_0x11="@+id/tv_num1_title"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginRight="@dimen/margin_24dp"
            layout_marginBottom="@dimen/margin_24dp"
            layout_marginHorizontal="@dimen/margin_24dp">
            <TextView
                textAppearance="@style/Title_2_Bold"
                textColor="@color/grey_g900"
                id="@+id/tv_num2_title"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_wallet_mid_subtitle_keep_assets_under_control"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x10="0"
                NOT_FOUND_0x12="0"/>
            <TextView
                textAppearance="@style/Label_2_Regular"
                textColor="@color/grey_g400"
                id="@+id/tv_num2_subtitle"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                text="@string/pr_wallet_mid_desc_keep_asset_safe"
                NOT_FOUND_0xf="0"
                NOT_FOUND_0x10="@+id/tv_num2_title"
                NOT_FOUND_0x11="@+id/tv_num2_title"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
