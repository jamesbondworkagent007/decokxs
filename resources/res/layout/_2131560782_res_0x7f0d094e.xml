<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/item_message_layout"
    tag="layout/item_planet_mine_likes_content_0"
    background="?attr/selectableItemBackground"
    paddingTop="12dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="24dp"
    paddingEnd="24dp">
    <ImageView
        id="@+id/ivAvatar"
        layout_width="40dp"
        android:layout_height="40dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        id="@+id/tvTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0x10="@+id/tvTime"
        NOT_FOUND_0x11="@+id/ivAvatar"
        NOT_FOUND_0x14="@+id/ivAvatar"/>
    <TextView
        textAppearance="@style/Label_2_Medium"
        textColor="@color/ContentContrast"
        id="@+id/tvTime"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="8dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="@+id/tvTitle"
        NOT_FOUND_0x14="@+id/ivAvatar"/>
    <TextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvDesc"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="2"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="@+id/tvTitle"
        NOT_FOUND_0x13="@+id/tvTitle"/>
</androidx.constraintlayout.widget.ConstraintLayout>
