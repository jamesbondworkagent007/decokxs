<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/fragment_coin_introduction_layout_0"
    paddingBottom="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        id="@+id/shareLayout"
        paddingTop="@dimen/height_32dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingStart="@dimen/padding_24dp"
        paddingEnd="@dimen/padding_24dp">
        <TextView
            textAppearance="@style/Title_1_Bold"
            textSize="@dimen/text_size_20sp"
            textColor="@color/okTradeG900"
            gravity="0x10"
            id="@+id/mCoinAbout"
            layout_width="-1"
            android:layout_height="52dp"/>
        <TextView
            textSize="@dimen/text_size_14sp"
            textColor="@color/okTradeG900"
            ellipsize="3"
            id="@+id/mCoinAboutDesc"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="4"
            lineHeight="24dp"/>
        <LinearLayout
            orientation="0"
            layout_width="-2"
            android:layout_height="wrap_content">
            <TextView
                textSize="@dimen/text_size_14sp"
                textColor="@color/ContentContrast"
                gravity="0x10"
                id="@+id/mCoinMore"
                visibility="2"
                layout_width="-2"
                android:layout_height="@dimen/height_24dp"
                text="@string/pr_demotrade_dropdown_learn_more"/>
            <ImageView
                layout_gravity="0x11"
                id="@+id/icon_arrow"
                visibility="2"
                layout_width="12dp"
                android:layout_height="12dp"
                layout_marginTop="@dimen/margin_2dp"
                src="@drawable/_2131232335_res_0x7f08064f"
                layout_marginStart="4dp"
                NOT_FOUND_0x1a="@color/ContentContrast"/>
        </LinearLayout>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/mCoinDetailRecycler"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/ok_dp_24"
        layout_marginRight="@dimen/ok_dp_24"
        nestedScrollingEnabled="false"
        layout_marginHorizontal="@dimen/ok_dp_24"/>
    <include
        id="@+id/dataFromItemView"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp"
        layout="@layout/_2131560291_res_0x7f0d0763"/>
</LinearLayout>
