<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <o.C55001xbh
        theme="@style/OKUITheme.Alternative.Web3"
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textSize="@dimen/text_size_28sp"
        textColor="@color/ContentPrimary"
        textColorHint="@color/ContentPrimary"
        id="@+id/et_amount"
        background="@null"
        layout_width="0dp"
        android:layout_height="40dp"
        text=""
        hint="0"
        lines="1"
        digits="0123456789,."
        inputType="0x2"
        textSelectHandleLeft="@drawable/_2131234233_res_0x7f080db9"
        textSelectHandleRight="@drawable/_2131234233_res_0x7f080db9"
        textSelectHandle="@drawable/_2131234233_res_0x7f080db9"
        NOT_FOUND_0x1f="@+id/tv_label"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="2"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x26="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        textSize="@dimen/text_size_28sp"
        id="@+id/tv_label"
        layout_width="-2"
        android:layout_height="40dp"
        text="%"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x1d="@+id/et_amount"
        NOT_FOUND_0x1f="@+id/tag_quarter"
        NOT_FOUND_0x22="@+id/et_amount"
        NOT_FOUND_0x25="@+id/et_amount"/>
    <o.C55251xgS
        id="@+id/tag_quarter"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="25%"
        drawablePadding="@dimen/padding_4dp"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x1d="@+id/et_amount"
        NOT_FOUND_0x1f="@+id/tag_half"
        NOT_FOUND_0x25="@+id/et_amount"
        NOT_FOUND_0x27="-3"
        NOT_FOUND_0x28="0"/>
    <o.C55251xgS
        id="@+id/tag_half"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="50%"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x1d="@+id/et_amount"
        NOT_FOUND_0x1f="@+id/tag_3quarters"
        NOT_FOUND_0x25="@+id/et_amount"
        NOT_FOUND_0x27="-3"
        NOT_FOUND_0x28="0"/>
    <o.C55251xgS
        id="@+id/tag_3quarters"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="75%"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x1d="@+id/et_amount"
        NOT_FOUND_0x1f="@+id/tag_total"
        NOT_FOUND_0x25="@+id/et_amount"
        NOT_FOUND_0x27="-3"
        NOT_FOUND_0x28="0"/>
    <o.C55251xgS
        id="@+id/tag_total"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_investredeem_mid_tag_max"
        NOT_FOUND_0x1d="@+id/et_amount"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x25="@+id/et_amount"
        NOT_FOUND_0x27="-3"
        NOT_FOUND_0x28="0"/>
    <androidx.constraintlayout.widget.Group
        id="@+id/v3TagGroup"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="tag_quarter,tag_half,tag_3quarters,tag_total"/>
    <androidx.appcompat.widget.AppCompatSeekBar
        id="@+id/seek_bar"
        background="@null"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        maxHeight="2dp"
        progressDrawable="@drawable/_2131231213_res_0x7f0801ed"
        minHeight="2dp"
        thumb="@drawable/_2131233987_res_0x7f080cc3"
        thumbOffset="0dp"
        paddingStart="0dp"
        paddingEnd="0dp"
        splitTrack="false"
        NOT_FOUND_0x24="@+id/et_amount"/>
</merge>
