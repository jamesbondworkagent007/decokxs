<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    layout_gravity="0x10"
    orientation="0"
    id="@+id/item_root_layout"
    paddingLeft="@dimen/dp24"
    paddingRight="@dimen/dp24"
    clipChildren="false"
    layout_width="-1"
    android:layout_height="@dimen/width_60dp"
    foreground="?attr/selectableItemBackground"
    baselineAligned="true"
    elevation="0dp"
    paddingHorizontal="@dimen/dp24">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_icon"
        layout_width="@dimen/margin_28dp"
        android:layout_height="@dimen/margin_28dp"
        scaleType="fitStart"
        layout_marginEnd="12dp"/>
    <o.C42989rgn
        id="@+id/crypto_layout"
        clipChildren="false"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"/>
    <o.C55071xcy
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_change_percent"
        layout_width="80dp"
        android:layout_height="32dp"
        maxLines="1"
        layout_marginStart="12dp"
        autoSizeTextType="uniform"
        autoSizeStepGranularity="1sp"
        autoSizeMinTextSize="9sp"
        autoSizeMaxTextSize="14sp"
        style="@style/TextAppearance.Text.14SP.Medium"/>
</LinearLayout>
