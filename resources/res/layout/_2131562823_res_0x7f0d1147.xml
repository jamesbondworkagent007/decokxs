<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="20dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="match_parent">
        <View
            id="@+id/view_left"
            background="@color/grey_g100"
            layout_width="0dp"
            android:layout_height="4dp"
            layout_weight="1"/>
        <View
            id="@+id/view_right"
            background="@color/grey_g100"
            layout_width="0dp"
            android:layout_height="4dp"
            layout_weight="1"/>
    </LinearLayout>
    <RelativeLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="match_parent">
        <ImageView
            id="@+id/iv_small"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231058_res_0x7f080152"
            layout_centerVertical="true"/>
        <View
            id="@+id/view_small"
            layout_width="22dp"
            android:layout_height="match_parent"/>
        <ImageView
            id="@+id/iv_mid"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231058_res_0x7f080152"
            layout_centerInParent="true"/>
        <View
            id="@+id/view_mid"
            layout_width="22dp"
            android:layout_height="match_parent"
            layout_centerInParent="true"/>
        <ImageView
            id="@+id/iv_large"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231058_res_0x7f080152"
            layout_centerVertical="true"
            layout_alignParentEnd="true"/>
        <View
            id="@+id/view_large"
            layout_width="22dp"
            android:layout_height="match_parent"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
</RelativeLayout>
