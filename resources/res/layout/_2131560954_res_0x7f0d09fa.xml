        ellipsize="3"
        id="@+id/account_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0x10="@+id/account_asset"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="2"
        NOT_FOUND_0x15="@+id/account_icon"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="2"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/account_asset"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginBottom="@dimen/margin_16dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="@+id/selected_icon"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="@+id/account_name"
        NOT_FOUND_0x17="@+id/account_name"
        NOT_FOUND_0x1a="50dp"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/selected_icon"
        layout_width="20dp"
        android:layout_height="20dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1b="@color/ContentContrast"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/SemanticNegative"
        layout_gravity="0x10"
        id="@+id/tv_status"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="4dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="@+id/selected_icon"
        NOT_FOUND_0x18="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
