<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_gravity="0x50"
    orientation="1"
    background="@drawable/_2131231490_res_0x7f080302"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        layout_gravity="0x1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_marginBottom="@dimen/margin_4dp"
        src="@drawable/_2131232048_res_0x7f080530"
        NOT_FOUND_0x11="@color/grey_g300"/>
    <RelativeLayout
        layout_width="-1"
        android:layout_height="44dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.18SP.Semibold"
            textColor="@color/okTradeG900"
            gravity="0x10"
            id="@+id/tv_title_bs"
            layout_width="-2"
            android:layout_height="wrap_content"
            minHeight="44dp"
            text="@string/pr_im_group_chat_drawer_title_select_an_option"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        orientation="1"
        id="@+id/ll_at_mention_user"
        background="@drawable/_2131231188_res_0x7f0801d4"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP.Medium"
            textColor="@color/grey_g900"
            id="@+id/tv_mention_user_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_16dp"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginBottom="@dimen/margin_4dp"
            text="@string/pr_im_group_chat_drawer_label_mention_user"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP.Regular"
            textColor="@color/grey_g500"
            id="@+id/tv_mention_user_subtitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_16dp"
            layout_marginBottom="@dimen/margin_16dp"
            text="@string/pr_im_group_chat_drawer_desc_mention_user"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/ll_remove_user"
        background="@drawable/_2131231188_res_0x7f0801d4"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginBottom="@dimen/height_56dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP.Medium"
            textColor="@color/RubyRed500"
            id="@+id/tv_remove_user_message_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_16dp"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginBottom="@dimen/margin_4dp"
            text="@string/pr_im_group_chat_drawer_label_remove_user"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP.Regular"
            textColor="@color/grey_g500"
            id="@+id/tv_remove_user_message_subtitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_16dp"
            layout_marginBottom="@dimen/margin_16dp"
            text="@string/pr_im_group_chat_drawer_desc_remove_user"/>
    </LinearLayout>
</LinearLayout>
