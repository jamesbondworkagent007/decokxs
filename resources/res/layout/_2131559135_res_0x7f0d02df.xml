<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_label_title"
        paddingTop="12dp"
        paddingBottom="12dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_token_details_txn_info"
        paddingVertical="12dp"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x22="0"
        style="@style/Title_2_Bold"/>
    <LinearLayout
        orientation="1"
        id="@+id/parent_trading_info"
        background="@drawable/_2131231797_res_0x7f080435"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="@+id/tv_label_title">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="0"
            id="@+id/time_panel"
            layout_width="-1"
            android:layout_height="60dp"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x20="0"
            NOT_FOUND_0x22="0">
            <LinearLayout
                gravity="0x11"
                orientation="1"
                id="@+id/m5_panel"
                background="@drawable/_2131231891_res_0x7f080493"
                padding="@dimen/padding_12dp"
                layout_width="0dp"
                android:layout_height="match_parent"
                layout_weight="1"
                layout_marginEnd="-0.6dp">
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="@color/ContentPrimary"
                    gravity="0x1"
                    id="@+id/tv_time_5m"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_market_filter_select_btn_5m"
                    maxLines="1"
                    style="@style/Label_2_Regular"/>
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="?attr/defaultProfit"
                    ellipsize="3"
                    gravity="0x1"
                    id="@+id/tv_time_5m_change"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    maxLines="1"
                    NOT_FOUND_0x17="@dimen/text_size_14sp"
                    NOT_FOUND_0x18="@dimen/text_size_10sp"
                    NOT_FOUND_0x19="1sp"
                    NOT_FOUND_0x1a="1"
                    style="@style/Label_3_Medium"/>
            </LinearLayout>
            <View
                background="@color/BorderPrimary"
                layout_width="0.5dp"
                android:layout_height="match_parent"/>
            <LinearLayout
                gravity="0x11"
                orientation="1"
                id="@+id/h1_panel"
                background="@drawable/_2131231892_res_0x7f080494"
                paddingLeft="@dimen/padding_12dp"
                paddingTop="@dimen/padding_12dp"
                paddingRight="@dimen/padding_12dp"
                paddingBottom="@dimen/padding_12dp"
                layout_width="0dp"
                android:layout_height="match_parent"
                layout_weight="1"
                layout_marginEnd="-0.6dp"
                paddingHorizontal="@dimen/padding_12dp"
                paddingVertical="@dimen/padding_12dp">
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tv_time_1h"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_filter_select_btn_1h"
                    maxLines="1"
                    style="@style/Label_2_Regular"/>
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="?attr/defaultLoss"
                    ellipsize="3"
                    id="@+id/tv_time_1h_change"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    maxLines="1"
                    NOT_FOUND_0x17="@dimen/text_size_14sp"
                    NOT_FOUND_0x18="@dimen/text_size_10sp"
                    NOT_FOUND_0x19="1sp"
                    NOT_FOUND_0x1a="1"
                    style="@style/Label_3_Medium"/>
            </LinearLayout>
            <View
                background="@color/BorderPrimary"
                layout_width="0.5dp"
                android:layout_height="match_parent"/>
            <LinearLayout
                gravity="0x11"
                orientation="1"
                id="@+id/h4_panel"
                background="@drawable/_2131231892_res_0x7f080494"
                paddingLeft="@dimen/padding_12dp"
                paddingTop="@dimen/padding_12dp"
                paddingRight="@dimen/padding_12dp"
                paddingBottom="@dimen/padding_12dp"
                layout_width="0dp"
                android:layout_height="match_parent"
                layout_weight="1"
                layout_marginEnd="-0.6dp"
                paddingHorizontal="@dimen/padding_12dp"
                paddingVertical="@dimen/padding_12dp">
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tv_time_4h"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_filter_select_btn_4h"
                    maxLines="1"
                    style="@style/Label_2_Regular"/>
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="?attr/defaultLoss"
                    ellipsize="3"
                    id="@+id/tv_time_4h_change"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    maxLines="1"
                    NOT_FOUND_0x17="@dimen/text_size_14sp"
                    NOT_FOUND_0x18="@dimen/text_size_10sp"
                    NOT_FOUND_0x19="1sp"
                    NOT_FOUND_0x1a="1"
                    style="@style/Label_3_Medium"/>
            </LinearLayout>
            <View
                background="@color/BorderPrimary"
                layout_width="0.5dp"
                android:layout_height="match_parent"/>
            <LinearLayout
                gravity="0x11"
                orientation="1"
                id="@+id/h24_panel"
                background="@drawable/_2131231893_res_0x7f080495"
                paddingLeft="@dimen/padding_12dp"
                paddingTop="@dimen/padding_12dp"
                paddingRight="@dimen/padding_12dp"
                paddingBottom="@dimen/padding_12dp"
                layout_width="0dp"
                android:layout_height="match_parent"
                layout_weight="1"
                paddingHorizontal="@dimen/padding_12dp"
                paddingVertical="@dimen/padding_12dp">
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tv_time_24h"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_filter_select_btn_24h"
                    maxLines="1"
                    style="@style/Label_2_Regular"/>
                <androidx.appcompat.widget.AppCompatTextView
                    textColor="?attr/defaultLoss"
                    ellipsize="3"
                    id="@+id/tv_time_24h_change"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    maxLines="1"
                    NOT_FOUND_0x17="@dimen/text_size_14sp"
                    NOT_FOUND_0x18="@dimen/text_size_10sp"
                    NOT_FOUND_0x19="1sp"
                    NOT_FOUND_0x1a="1"
                    style="@style/Label_3_Medium"/>
            </LinearLayout>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <View
            background="@color/BorderPrimary"
            layout_width="-1"
            android:layout_height="0.5dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            paddingLeft="16dp"
            paddingTop="20dp"
            paddingRight="16dp"
            paddingBottom="20dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            backgroundTint="@color/BaseSecondary"
            paddingHorizontal="16dp"
            paddingVertical="20dp">
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/total_vol_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_token_detail_total_volume"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x22="0"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_total_vol"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginStart="2dp"
                NOT_FOUND_0x1d="@+id/total_net_label"
                NOT_FOUND_0x1e="1"
                NOT_FOUND_0x1f="@+id/total_vol_label"
                NOT_FOUND_0x22="0"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/total_net_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_token_detail_net_volume"
                layout_marginEnd="2dp"
                NOT_FOUND_0x1d="@+id/tv_net_vol"
                NOT_FOUND_0x1f="@+id/tv_total_vol"
                NOT_FOUND_0x22="0"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_net_vol"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x22="0"
                style="@style/Label_2_Regular"/>
            <o.hTK
                id="@+id/txs_progressbar"
                layout_width="-1"
                android:layout_height="4dp"
                layout_marginTop="12dp"
                NOT_FOUND_0x21="@+id/total_vol_label"/>
            <TextView
                textColor="?attr/tradeRiseDefault"
                gravity="0x11"
                id="@+id/tv_buy_icon"
                background="@drawable/_2131231813_res_0x7f080445"
                layout_width="@dimen/xsm"
                android:layout_height="wrap_content"
                layout_marginTop="6dp"
                minHeight="@dimen/xsm"
                text="@string/pr_swaptrade_token_detail_label_buy"
                maxLines="1"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x21="@+id/txs_progressbar"
                style="@style/Label_3_Medium"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_buy_value"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginStart="2dp"
                NOT_FOUND_0x1b="@+id/tv_buy_icon"
                NOT_FOUND_0x1d="@+id/tv_sell_value"
                NOT_FOUND_0x1e="1"
                NOT_FOUND_0x1f="@+id/tv_buy_icon"
                NOT_FOUND_0x22="@+id/tv_buy_icon"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_sell_value"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginEnd="2dp"
                NOT_FOUND_0x1b="@+id/tv_buy_value"
                NOT_FOUND_0x1d="@+id/tv_sell_icon"
                NOT_FOUND_0x1e="1"
                NOT_FOUND_0x1f="@+id/tv_buy_value"
                NOT_FOUND_0x22="@+id/tv_buy_value"
                style="@style/Label_3_Regular"/>
            <TextView
                textColor="?attr/tradeFallDefault"
                gravity="0x11"
                id="@+id/tv_sell_icon"
                background="@drawable/_2131231809_res_0x7f080441"
                layout_width="@dimen/xsm"
                android:layout_height="wrap_content"
                minHeight="@dimen/xsm"
                text="@string/pr_swaptrade_token_detail_label_sell"
                maxLines="1"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x22="@+id/tv_buy_icon"
                style="@style/Label_3_Medium"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</merge>
