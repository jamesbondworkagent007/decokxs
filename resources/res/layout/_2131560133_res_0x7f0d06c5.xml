<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x11"
        orientation="0"
        id="@+id/gourp_coin"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        NOT_FOUND_0x11="@+id/tv_title"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0">
        <com.google.android.material.imageview.ShapeableImageView
            id="@+id/iv_coin_icon"
            layout_width="32dp"
            android:layout_height="32dp"
            src="@drawable/_2131232940_res_0x7f0808ac"
            NOT_FOUND_0x19="@style/CircleStyle"/>
        <TextView
            ellipsize="3"
            id="@+id/tv_coin_name"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="8dp"
            text="BTC"
            maxLines="1"/>
    </LinearLayout>
    <TextView
        textAppearance="@style/Title_2_Bold"
        textColor="@color/ContentPrimary"
        gravity="0x11"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="16dp"
        layout_marginRight="24dp"
        text="@string/pr_wallet_assets_bttmsheet_title_report_token"
        layout_marginHorizontal="24dp"
        NOT_FOUND_0x11="@+id/tv_details"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/gourp_coin"/>
    <TextView
        textAppearance="@style/Body_3_Regular"
        textColor="@color/ContentSecondary"
        gravity="0x11"
        id="@+id/tv_details"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="12dp"
        layout_marginRight="24dp"
        text="@string/pr_wallet_assets_bttmsheet_title_report_long"
        layout_marginHorizontal="24dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/tv_title"/>
    <o.wYF
        id="@+id/btnbox_report"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="28dp"
        layout_marginBottom="16dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/tv_details"
        NOT_FOUND_0x16="@string/pr_wallet_assets_bttmsheet_btn_report"
        NOT_FOUND_0x17="52"
        NOT_FOUND_0x18="0x101"/>
</androidx.constraintlayout.widget.ConstraintLayout>
