<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/oknc_activity_notification_center_0"
    fitsSystemWindows="true"
    layout_width="-1"
    android:layout_height="match_parent"
    baselineAligned="false">
    <androidx.appcompat.widget.Toolbar
        layout_gravity="0x37"
        id="@+id/toolbar"
        background="@color/BasePrimary"
        layout_width="-1"
        android:layout_height="@dimen/appbar_height"
        elevation="0dp"
        NOT_FOUND_0x15="0dp"
        NOT_FOUND_0x16="0dp"
        NOT_FOUND_0x17="0dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_default"
            layout_marginRight="@dimen/margin_default"
            layout_marginHorizontal="@dimen/margin_default">
            <o.wYC
                layout_gravity="0x11"
                id="@+id/menu_back_icon"
                background="?attr/selectableItemBackgroundBorderless"
                padding="@dimen/padding_2dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131232348_res_0x7f08065c"
                contentDescription="@string/pr_commonall_text_btn_back"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1b="0"/>
            <TextView
                ellipsize="3"
                gravity="0x11"
                layout_gravity="0x11"
                id="@+id/toolbar_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_72dp"
                layout_marginRight="@dimen/margin_72dp"
                maxLines="1"
                layout_marginHorizontal="@dimen/margin_72dp"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1b="0"
                style="@style/Title_2_Bold"/>
            <ImageView
                layout_gravity="0x11"
                id="@+id/menu_more_icon"
                background="?attr/selectableItemBackgroundBorderless"
                padding="@dimen/padding_2dp"
                visibility="2"
                layout_width="@dimen/width_28dp"
                android:layout_height="@dimen/width_28dp"
                src="@drawable/_2131233932_res_0x7f080c8c"
                contentDescription="@string/pr_commonall_modal_btn_more"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1b="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>
    <androidx.fragment.app.FragmentContainerView
        id="@+id/im_fragment_container"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"/>
</LinearLayout>
