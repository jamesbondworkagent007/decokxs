<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/trade_ui_dialog_smart_invest_detail_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    overScrollMode="2">
    <androidx.constraintlayout.widget.ConstraintLayout
        paddingLeft="@dimen/padding_16dp"
        paddingTop="@dimen/padding_20dp"
        paddingRight="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_16dp">
        <TextView
            textColor="@color/okTradeG900"
            id="@+id/invest_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_smartportfolio_placeorder_modaltitle_total_investment_value"
            NOT_FOUND_0xf="@+id/total_invest"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="@+id/total_invest"
            NOT_FOUND_0x16="0.5"
            style="@style/TextAppearance.Text.14SP.Regular"/>
        <TextView
            textColor="@color/okTradeG900"
            gravity="0x800005"
            id="@+id/total_invest"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/margin_16dp"
            breakStrategy="0"
            NOT_FOUND_0x10="@+id/invest_details_title"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="@+id/invest_title"
            style="@style/TextAppearance.Text.Bold.16SP"/>
        <TextView
            textColor="@color/grey_g400"
            id="@+id/invest_details_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"
            text="@string/pr_smartportfolio_placeorder_modaltitle_allocation"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="@+id/total_invest"
            style="@style/TextAppearance.Text.14SP.Regular"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/invest_recycler_view"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            overScrollMode="2"
            NOT_FOUND_0x14="@+id/invest_details_title"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
