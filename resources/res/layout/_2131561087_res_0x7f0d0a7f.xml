<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_gravity="0x1"
    orientation="1"
    tag="layout/kline_diagram_footer_view_0"
    paddingBottom="50dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/grey_g400"
        gravity="0x1"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_chart_tutorial_feedback_helpful"
        layout_marginStart="@dimen/margin_16dp"
        layout_marginEnd="@dimen/margin_16dp"
        style="@style/TextAppearance"/>
    <LinearLayout
        layout_gravity="0x1"
        orientation="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp">
        <LinearLayout
            gravity="0x1"
            orientation="1"
            id="@+id/ll_no_help"
            layout_width="-2"
            android:layout_height="match_parent"
            layout_marginEnd="12dp">
            <RelativeLayout
                id="@+id/rl_no_help_background"
                background="@drawable/_2131232522_res_0x7f08070a"
                layout_width="-2"
                android:layout_height="36dp">
                <ImageView
                    id="@+id/iv_no_help"
                    visibility="0"
                    layout_width="40dp"
                    android:layout_height="40dp"
                    src="@drawable/_2131232519_res_0x7f080707"
                    layout_centerInParent="true"/>
            </RelativeLayout>
            <TextView
                textSize="@dimen/text_size_12sp"
                textColor="@color/okTradeG900"
                id="@+id/iv_no_help_text"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_10dp"
                text="@string/pr_chart_tutorial_feedback_no"
                style="@style/TextAppearance"/>
        </LinearLayout>
        <LinearLayout
            gravity="0x1"
            orientation="1"
            id="@+id/ll_help"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="12dp">
            <LinearLayout
                gravity="0x11"
                id="@+id/rl_help_background"
                background="@drawable/_2131232522_res_0x7f08070a"
                layout_width="-2"
                android:layout_height="36dp">
                <ImageView
                    id="@+id/iv_help"
                    visibility="0"
                    layout_width="40dp"
                    android:layout_height="40dp"
                    src="@drawable/_2131232517_res_0x7f080705"/>
            </LinearLayout>
            <TextView
                textSize="@dimen/text_size_12sp"
                textColor="@color/okTradeG900"
                id="@+id/iv_help_text"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_10dp"
                text="@string/pr_chart_tutorial_feedback_yes"
                style="@style/TextAppearance"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
