<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="20dp"
    paddingBottom="20dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="16dp"
    paddingEnd="2.5dp">
    <ImageView
        id="@+id/img"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"/>
    <TextView
        textSize="16sp"
        textColor="?attr/st_color_g900"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="match_parent"
        drawablePadding="@dimen/dp_4"
        layout_marginStart="12dp"
        layout_marginEnd="5dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="@+id/img"
        NOT_FOUND_0x12="0"/>
    <ImageView
        id="@+id/select"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232885_res_0x7f080875"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@color/ContentBrand"/>
</androidx.constraintlayout.widget.ConstraintLayout>
