<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.okinc.uilab.view.OKSortTextView
        ellipsize="3"
        id="@+id/turnover"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="120dp"
        text="@string/pr_swaptrade_token_detail_textarea_transaction_amount"
        maxLines="2"
        drawablePadding="2dp"
        NOT_FOUND_0x14="0"
        style="@style/OKSortTextView_Market"/>
    <View
        id="@+id/split_line_1"
        background="@color/ContentDisabled"
        layout_width="0.5dp"
        android:layout_height="12dp"
        layout_marginLeft="6dp"
        layout_marginRight="6dp"
        layout_marginBottom="1dp"
        layout_marginHorizontal="6dp"/>
    <com.okinc.uilab.view.OKSortTextView
        ellipsize="3"
        id="@+id/market_cap"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="120dp"
        text="@string/pr_swaptrade_mid_subtitle_m_cap"
        maxLines="2"
        drawablePadding="2dp"
        NOT_FOUND_0x14="0"
        style="@style/OKSortTextView_Market"/>
    <View
        id="@+id/gap"
        layout_width="0dp"
        android:layout_height="0dp"
        minWidth="@dimen/xxsm"
        layout_weight="1"/>
    <com.okinc.uilab.view.OKSortTextView
        ellipsize="3"
        gravity="0x800005"
        id="@+id/price"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="120dp"
        text="@string/pr_swaptrade_modal_dialog_label_price"
        maxLines="2"
        drawablePadding="2dp"
        NOT_FOUND_0x14="0"
        style="@style/OKSortTextView_Market"/>
    <View
        id="@+id/split_line_2"
        background="@color/ContentDisabled"
        layout_width="0.5dp"
        android:layout_height="12dp"
        layout_marginLeft="6dp"
        layout_marginRight="6dp"
        layout_marginBottom="1dp"
        layout_marginHorizontal="6dp"/>
    <com.okinc.uilab.view.OKSortTextView
        ellipsize="3"
        gravity="0x800005"
        id="@+id/change"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="120dp"
        text="@string/pr_swaptrade_market_item_change"
        maxLines="2"
        drawablePadding="2dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        style="@style/OKSortTextView_Market"/>
</androidx.appcompat.widget.LinearLayoutCompat>
