<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="match_parent">
    <o.C33537myN
        id="@+id/indicator_setting_ab"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x26="@string/pr_spotcharts_text_market_monitoring"
        NOT_FOUND_0x27="true"/>
    <View
        id="@+id/divider"
        background="@color/list_divider_color"
        layout_width="-1"
        android:layout_height="0.5dp"/>
    <com.okinc.uilab.banner.OKAlertBanner
        id="@+id/save_power_alert"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x24="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor."
        NOT_FOUND_0x25="2"/>
    <com.okinc.uilab.reminder.OKReminder
        id="@+id/reminder"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_8dp"
        layout_marginHorizontal="@dimen/margin_16dp"
        layout_marginVertical="@dimen/margin_8dp"/>
    <RelativeLayout
        id="@+id/rl_floatwindow_switch"
        padding="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="16sp"
            textColor="@color/okTradeG900"
            gravity="0x800033"
            id="@+id/open_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_discover_pop_crypto_market_monitor_window"/>
        <TextView
            textSize="12sp"
            textColor="@color/okTradeG400"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_2dp"
            text="@string/pr_discover_text_crypto_market_monitor_open_window"
            layout_below="@+id/open_title"
            layout_marginEnd="@dimen/margin_8dp"
            layout_toStartOf="@+id/open_floatwindow_switch"/>
        <o.C33609mzg
            id="@+id/open_floatwindow_switch"
            background="@drawable/_2131233716_res_0x7f080bb4"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_centerVertical="true"
            layout_alignParentEnd="true"
            NOT_FOUND_0x2a="@color/transparent"
            NOT_FOUND_0x2b="@color/transparent"/>
    </RelativeLayout>
    <LinearLayout
        orientation="1"
        id="@+id/ll_floating_open"
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/ll_floating_setting"
            paddingLeft="@dimen/margin_16dp"
            paddingRight="@dimen/margin_16dp"
            layout_width="-1"
            android:layout_height="68dp"
            paddingHorizontal="@dimen/margin_16dp">
            <TextView
                textSize="@dimen/text_size_16sp"
                textColor="@color/grey_g900"
                layout_width="@dimen/width_0dp"
                android:layout_height="wrap_content"
                text="@string/pr_tradechart_list_label_preferences"
                layout_weight="1"/>
            <ImageView
                background="@drawable/_2131232356_res_0x7f080664"
                layout_width="-2"
                android:layout_height="wrap_content"
                backgroundTint="#dbdbdb"/>
        </LinearLayout>
        <View
            background="@color/background_lv2"
            layout_width="-1"
            android:layout_height="8dp"/>
        <TextView
            textSize="16sp"
            textColor="@color/grey_g900"
            padding="@dimen/margin_16dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_tradechart_list_label_watchlist"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/coin_list_title"
            paddingLeft="@dimen/padding_8dp"
            paddingRight="@dimen/padding_8dp"
            layout_width="-1"
            android:layout_height="32dp"
            paddingHorizontal="@dimen/padding_8dp">
            <TextView
                textAppearance="@style/TextAppearance.Hint.12SP"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_discover_text_coin"
                layout_weight="1"
                layout_marginStart="@dimen/margin_8dp"/>
            <TextView
                textAppearance="@style/TextAppearance.Hint.12SP"
                gravity="0x11"
                layout_width="@dimen/width_40dp"
                android:layout_height="wrap_content"
                text="@string/pr_favourites_colheader_top"
                layout_marginStart="8dp"/>
            <TextView
                textAppearance="@style/TextAppearance.Hint.12SP"
                gravity="0x11"
                layout_width="@dimen/width_40dp"
                android:layout_height="wrap_content"
                text="@string/pr_trade_text_drag"
                layout_marginStart="8dp"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rcy_content"
            scrollbars="horizontal"
            clipChildren="false"
            clipToPadding="false"
            layout_width="-1"
            android:layout_height="0dp"
            layout_weight="1"
            overScrollMode="2"/>
        <FrameLayout
            id="@+id/frame"
            paddingBottom="46dp"
            layout_width="-1"
            android:layout_height="wrap_content">
            <o.C52794wYp
                ellipsize="4"
                gravity="0x11"
                id="@+id/btn_add"
                layout_width="-1"
                android:layout_height="48dp"
                layout_marginLeft="@dimen/margin_16dp"
                layout_marginRight="@dimen/margin_16dp"
                text="新增BTC/USDT盯盘"
                singleLine="true"
                marqueeRepeatLimit="-1"
                layout_marginHorizontal="@dimen/margin_16dp"
                NOT_FOUND_0x28="48"
                NOT_FOUND_0x29="0x101"
                NOT_FOUND_0x2c="6"/>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
