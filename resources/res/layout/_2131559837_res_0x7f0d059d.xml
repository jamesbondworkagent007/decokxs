<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/fragment_btc_asset_tip_0"
    background="@color/BasePrimaryAlternative"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"
        overScrollMode="2">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x1"
                id="@+id/risk_icon"
                layout_width="@dimen/height_120dp"
                android:layout_height="@dimen/height_120dp"
                src="@drawable/_2131232932_res_0x7f0808a4"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x1"
                layout_gravity="0x1"
                id="@+id/risk_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginLeft="24dp"
                layout_marginTop="@dimen/margin_12dp"
                layout_marginRight="24dp"
                layout_marginHorizontal="24dp"
                style="@style/TextAppearance.Title.24SP.Medium"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x1"
                layout_gravity="0x1"
                id="@+id/risk_sub_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginLeft="24dp"
                layout_marginTop="@dimen/margin_12dp"
                layout_marginRight="24dp"
                layout_marginHorizontal="24dp"
                style="@style/TextAppearance.Text.16SP"/>
            <View
                id="@+id/risk_divider"
                background="@color/BorderPrimaryAlternative"
                layout_width="-1"
                android:layout_height="@dimen/height_0.5dp"
                layout_marginLeft="24dp"
                layout_marginTop="32dp"
                layout_marginRight="24dp"
                layout_marginBottom="32dp"
                layout_marginHorizontal="24dp"
                layout_marginVertical="32dp"/>
            <o.C57422yiC
                id="@+id/asset_change_view"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <o.C57508yjj
                id="@+id/asset_group_view"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <o.C57468yiw
        id="@+id/button_group"
        layout_width="-1"
        android:layout_height="wrap_content"/>
</LinearLayout>
