<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/dex_contract_transaction_swap_coin_price_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp">
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.12SP.Regular"
            textSize="@dimen/text_size_16sp"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800013"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="2"
            includeFontPadding="false"
            layout_weight="4"
            layout_alignParentStart="true"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.12SP.Regular"
            textSize="@dimen/text_size_16sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800015"
            id="@+id/tv_value"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="2"
            includeFontPadding="false"
            layout_weight="6"
            layout_marginStart="@dimen/margin_12dp"
            autoSizeTextType="uniform"
            autoSizeStepGranularity="1sp"
            autoSizeMinTextSize="@dimen/text_size_12sp"
            autoSizeMaxTextSize="@dimen/text_size_16sp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <View
        id="@+id/line"
        background="@color/line_light"
        layout_width="-1"
        android:layout_height="@dimen/height_0.5dp"
        layout_marginLeft="@dimen/margin_24dp"
        layout_marginTop="@dimen/margin_20dp"
        layout_marginRight="@dimen/margin_24dp"
        layout_marginBottom="@dimen/margin_24dp"
        layout_marginHorizontal="@dimen/margin_24dp"/>
</androidx.appcompat.widget.LinearLayoutCompat>
