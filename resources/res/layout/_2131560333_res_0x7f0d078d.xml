<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_bot_lead_signal_bot_settlement_0"
    paddingBottom="@dimen/margin_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_16dp"
    layout_marginRight="@dimen/margin_16dp"
    layout_marginHorizontal="@dimen/margin_16dp">
    <TextView
        textColor="@color/okTradeG400"
        id="@+id/tv_date"
        paddingTop="@dimen/margin_8dp"
        paddingBottom="@dimen/margin_8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/margin_8dp"
        NOT_FOUND_0x14="0"
        style="@style/TextAppearance.Text.12SP"/>
    <ImageView
        id="@+id/ic_avatar"
        layout_width="@dimen/height_36dp"
        android:layout_height="@dimen/height_36dp"
        layout_marginTop="@dimen/margin_12dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/tv_date"/>
    <TextView
        textColor="@color/okTradeG900"
        id="@+id/tv_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0xe="@+id/ic_avatar"
        NOT_FOUND_0x11="@+id/ic_avatar"
        NOT_FOUND_0x14="@+id/ic_avatar"
        style="@style/TextAppearance.Text.14SP"/>
    <TextView
        textColor="@color/okTradeG900"
        gravity="0x800005"
        id="@+id/tv_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x11="@+id/tv_name"
        NOT_FOUND_0x14="@+id/tv_name"
        style="@style/TextAppearance.Text.14SP.Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
