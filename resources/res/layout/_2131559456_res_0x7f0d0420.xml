<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content"
    baselineAligned="false">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_ca"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="0.5"
        layout_marginEnd="12dp">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentContrast"
            gravity="0x800013"
            id="@+id/tv_label_ca"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_token_details_contract_address"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x11="0"
            style="@style/Label_3_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_ca"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_2dp"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/tv_label_ca"
            style="@style/Label_3_Medium"/>
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="@dimen/width_16dp"
            android:layout_height="0dp"
            src="@drawable/_2131231720_res_0x7f0803e8"
            layout_marginStart="4dp"
            NOT_FOUND_0xd="@+id/tv_ca"
            NOT_FOUND_0xe="@+id/tv_ca"
            NOT_FOUND_0x11="@+id/tv_ca"
            NOT_FOUND_0x12="@color/ContentPrimary"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_token_age"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="0.5"
        layout_marginEnd="12dp">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentContrast"
            gravity="0x800013"
            id="@+id/tv_label_token_age"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x11="0"
            style="@style/Label_3_Regular"/>
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="14dp"
            android:layout_height="14dp"
            src="@drawable/_2131234226_res_0x7f080db2"
            layout_marginStart="2dp"
            NOT_FOUND_0xd="@+id/tv_label_token_age"
            NOT_FOUND_0xe="@+id/tv_label_token_age"
            NOT_FOUND_0x11="@+id/tv_label_token_age"
            NOT_FOUND_0x12="@color/ContentContrast"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_token_age"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_2dp"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/tv_label_token_age"
            style="@style/Label_3_Medium"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
