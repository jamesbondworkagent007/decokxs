<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/activity_select_group_call_member_list_0"
    layout_width="-1"
    android:layout_height="match_parent"
    baselineAligned="false">
    <androidx.appcompat.widget.Toolbar
        layout_gravity="0x37"
        id="@+id/toolbar"
        background="@color/BasePrimary"
        layout_width="-1"
        android:layout_height="@dimen/appbar_height"
        elevation="0dp"
        NOT_FOUND_0x14="0dp"
        NOT_FOUND_0x15="0dp"
        NOT_FOUND_0x16="0dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_default"
            layout_marginRight="@dimen/margin_default"
            layout_marginHorizontal="@dimen/margin_default">
            <o.wYC
                layout_gravity="0x11"
                id="@+id/menu_back_icon"
                background="?attr/selectableItemBackgroundBorderless"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131231642_res_0x7f08039a"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"/>
            <LinearLayout
                orientation="1"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/dp_8"
                layout_marginRight="@dimen/dp_8"
                layout_marginHorizontal="@dimen/dp_8"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="@+id/menu_more_icon"
                NOT_FOUND_0x1a="0.5"
                NOT_FOUND_0x1b="@+id/menu_back_icon"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="0.5">
                <TextView
                    ellipsize="3"
                    gravity="0x11"
                    id="@+id/toolbar_title"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    style="@style/TextAppearance.Title.16SP.Semibold"/>
                <TextView
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    gravity="0x11"
                    id="@+id/tv_selection_count"
                    visibility="2"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    style="@style/TextAppearance.Title.10SP"/>
