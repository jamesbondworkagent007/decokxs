            <ImageView
                layout_gravity="0x11"
                id="@+id/menu_more_icon"
                background="?attr/selectableItemBackgroundBorderless"
                padding="2dp"
                visibility="1"
                layout_width="@dimen/width_28dp"
                android:layout_height="@dimen/width_28dp"
                src="@drawable/_2131232292_res_0x7f080624"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1d="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>
    <androidx.fragment.app.FragmentContainerView
        id="@+id/select_group_call_fragment_container"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"/>
