<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/sm"
    paddingTop="@dimen/xsm"
    paddingRight="@dimen/sm"
    paddingBottom="@dimen/xsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/sm"
    paddingVertical="@dimen/xsm">
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        singleLine="true"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        style="@style/Label_1_Bold"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_sub_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        singleLine="true"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/tv_title"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
