<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    layout_gravity="0x10"
    orientation="0"
    id="@+id/item_root_layout"
    paddingTop="@dimen/padding_8dp"
    paddingBottom="@dimen/padding_8dp"
    clipChildren="false"
    layout_width="-1"
    android:layout_height="wrap_content"
    foreground="?attr/selectableItemBackground"
    maxHeight="70dp"
    baselineAligned="true"
    minHeight="@dimen/width_60dp"
    paddingStart="@dimen/dp24"
    paddingEnd="@dimen/dp24"
    elevation="0dp"
    paddingVertical="@dimen/padding_8dp">
    <ImageView
        id="@+id/iv_icon"
        visibility="2"
        layout_width="28dp"
        android:layout_height="28dp"
        scaleType="fitStart"
        layout_marginEnd="8dp"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="0"
        id="@+id/ll_price_container"
        clipChildren="false"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"
        layout_marginEnd="16dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            clipChildren="false"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <com.google.android.flexbox.FlexboxLayout
                layout_gravity="0x800003"
                orientation="0"
                id="@+id/tv_name_layout"
                clipChildren="false"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x24="2"
                NOT_FOUND_0x28="0"
                NOT_FOUND_0x29="1">
                <TextView
                    textSize="@dimen/sp_15"
                    textColor="@color/okTradeG900"
                    ellipsize="3"
                    gravity="0x800013"
                    id="@+id/tv_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    minHeight="@dimen/width_20dp"
                    singleLine="true"
                    includeFontPadding="false"
                    style="@style/TextAppearance.Title.15SP.Medium"/>
                <TextView
                    textSize="@dimen/text_size_10sp"
                    gravity="0x11"
                    id="@+id/tv_name_tag"
                    background="@drawable/_2131233195_res_0x7f0809ab"
                    paddingLeft="@dimen/dp_4"
                    paddingTop="@dimen/padding_2dp"
                    paddingRight="@dimen/dp_4"
                    paddingBottom="@dimen/padding_2dp"
                    visibility="0"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    includeFontPadding="false"
                    fontFamily="@font/font_alpha_regular"
                    layout_marginStart="@dimen/dp_2"
                    paddingHorizontal="@dimen/dp_4"
                    paddingVertical="@dimen/padding_2dp"/>
            </com.google.android.flexbox.FlexboxLayout>
            <TextView
                textAppearance="@style/TextAppearance.Title.12SP"
                textSize="@dimen/text_size_12sp"
                textColor="@color/okTradeG400"
                ellipsize="3"
                id="@+id/tv_name_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                singleLine="true"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <LinearLayout
            layout_gravity="0x10"
            orientation="1"
            layout_width="-2"
            android:layout_height="wrap_content">
            <o.C42963rgN
                textSize="15sp"
                textColor="@color/okTradeG900"
                gravity="0x800015"
                layout_gravity="0x800015"
                id="@+id/tv_price"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0x25="@dimen/sp_15"
                NOT_FOUND_0x26="10sp"
                NOT_FOUND_0x27="1"
                NOT_FOUND_0x2a="0"
                NOT_FOUND_0x2b="0"
                NOT_FOUND_0x2c="0"
                style="@style/TextAppearance.Title.15SP.Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textSize="@dimen/sp_12"
                gravity="0x800005"
                layout_gravity="0x800005"
                id="@+id/tv_sub_price"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                style="@style/TextAppearance.Text.12SP.Regular"/>
        </LinearLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <o.C42920rfX
        textSize="14sp"
        textColor="@color/okTradeG50"
        gravity="0x11"
        id="@+id/tv_change_percent"
        layout_width="80dp"
        android:layout_height="32dp"
        minWidth="@dimen/width_76dp"
        paddingStart="5dp"
        paddingEnd="5dp"
        style="@style/TextAppearance.Title.14SP.Medium"/>
</LinearLayout>
