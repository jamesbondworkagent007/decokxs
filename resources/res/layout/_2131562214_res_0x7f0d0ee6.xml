<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        paddingTop="@dimen/xxsm"
        paddingBottom="@dimen/xxsm"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/sm"
        layout_marginRight="@dimen/sm"
        contentDescription="web3_defi_protocol_view"
        layout_marginHorizontal="@dimen/sm"
        paddingVertical="@dimen/xxsm">
        <LinearLayout
            gravity="0x800013"
            layout_gravity="0x10"
            orientation="0"
            id="@+id/ll_token_container"
            layout_width="0dp"
            android:layout_height="wrap_content"
            minWidth="@dimen/dp_130"
            layout_weight="1">
            <ImageView
                id="@+id/iv_token_icon"
                layout_width="32dp"
                android:layout_height="32dp"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x17="0"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_token_name"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/xxsm"
                maxLines="1"
                singleLine="true"
                style="@style/Label_1_Medium"/>
        </LinearLayout>
        <LinearLayout
            layout_gravity="0x10"
            orientation="1"
            id="@+id/recommenf_apy_lin"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="8dp">
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentBrand"
                    ellipsize="3"
                    gravity="0x800005"
                    layout_gravity="0x5"
                    id="@+id/tv_apy_range"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    style="@style/Label_1_Medium"/>
                <o.wYC
                    layout_gravity="0x13"
                    id="@+id/chart_line_icon"
                    layout_width="@dimen/dp_16"
                    android:layout_height="@dimen/dp_16"
                    layout_marginStart="@dimen/margin_4dp"
                    NOT_FOUND_0x18="@drawable/_2131232915_res_0x7f080893"/>
            </LinearLayout>
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                gravity="0x800005"
                layout_gravity="0x5"
                id="@+id/tv_tvl"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxxsm"
                maxLines="1"
                style="@style/Label_3_Regular"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
