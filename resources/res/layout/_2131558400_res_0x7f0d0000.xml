<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-2"
    android:layout_height="wrap_content"
    style="@style/RtlOverlay.Widget.AppCompat.ActionBar.TitleItem">
    <TextView
        ellipsize="3"
        id="@+id/action_bar_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        singleLine="true"/>
    <TextView
        ellipsize="3"
        id="@+id/action_bar_subtitle"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/abc_action_bar_subtitle_top_margin_material"
        singleLine="true"/>
</LinearLayout>
