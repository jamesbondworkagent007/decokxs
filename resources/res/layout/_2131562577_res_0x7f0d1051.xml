<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/common_page_edge_space"
        layout_marginStart="@dimen/common_page_edge_space"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x27="0">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP.Medium"
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/tv_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            drawablePadding="6dp"/>
        <TextView
            textSize="10sp"
            textColor="@color/oktemp_primary_orange_color"
            gravity="0x11"
            id="@+id/mTvTradeMarginNum"
            background="@drawable/_2131233991_res_0x7f080cc7"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="5X"
            paddingStart="4dp"
            paddingEnd="4dp"
            layout_marginStart="5dp"/>
        <ImageView
            gravity="0x11"
            layout_gravity="0x10"
            id="@+id/iv_trade"
            visibility="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231649_res_0x7f0803a1"
            layout_marginStart="6dp"
            NOT_FOUND_0x28="@color/ContentDisabled"/>
    </LinearLayout>
    <ImageView
        id="@+id/iv_edit_share"
        layout_width="-2"
        android:layout_height="0dp"
        src="@drawable/_2131232049_res_0x7f080531"
        scaleType="7"
        paddingStart="16dp"
        paddingEnd="6dp"
        NOT_FOUND_0x1f="@+id/ll_title"
        NOT_FOUND_0x22="@+id/tv_cancel_status"
        NOT_FOUND_0x27="@+id/ll_title"/>
    <TextView
        textAppearance="@style/TextAppearance"
        textSize="@dimen/text_size_12sp"
        textColor="@color/okTradeG900"
        gravity="0x11"
        id="@+id/tv_cancel_status"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_perp_btn_withdrawl_order"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x1f="@+id/ll_title"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x27="@+id/ll_title"/>
    <o.C55251xgS
        id="@+id/tv_trade_type"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0x25="@+id/ll_title"
        NOT_FOUND_0x26="@+id/ll_title"/>
    <o.C55251xgS
        id="@+id/ok_tag_manual"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="6dp"
        NOT_FOUND_0x1f="@+id/tv_trade_type"
        NOT_FOUND_0x24="@+id/tv_trade_type"
        NOT_FOUND_0x27="@+id/tv_trade_type"/>
    <TextView
        textAppearance="@style/TextAppearance.Subtitle.12SP"
        id="@+id/tv_fond_type"
        background="@drawable/_2131231485_res_0x7f0802fd"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginStart="6dp"
        backgroundTint="@color/okTradeG100"
        paddingHorizontal="4dp"
        paddingVertical="2dp"
        NOT_FOUND_0x1f="@+id/tv_trade_type"
        NOT_FOUND_0x24="@+id/ok_tag_manual"
        NOT_FOUND_0x27="@+id/tv_trade_type"/>
    <TextView
        textAppearance="@style/TextAppearance.Subtitle.12SP"
        gravity="0x11"
        id="@+id/tv_lever"
        background="@drawable/_2131231485_res_0x7f0802fd"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginStart="6dp"
        backgroundTint="@color/okTradeG100"
        paddingHorizontal="4dp"
        paddingVertical="2dp"
        NOT_FOUND_0x1f="@+id/tv_trade_type"
        NOT_FOUND_0x24="@+id/tv_fond_type"
        NOT_FOUND_0x27="@+id/tv_trade_type"/>
    <TextView
        textAppearance="@style/TextAppearance.Subtitle.12SP"
        gravity="0x11"
        id="@+id/tv_borrowing"
        background="@drawable/_2131231485_res_0x7f0802fd"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginStart="6dp"
        backgroundTint="@color/okTradeG100"
        paddingHorizontal="4dp"
        paddingVertical="2dp"
        NOT_FOUND_0x1f="@+id/tv_trade_type"
        NOT_FOUND_0x24="@+id/tv_lever"
        NOT_FOUND_0x27="@+id/tv_trade_type"/>
    <TextView
        textAppearance="@style/Body_4"
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/tv_time"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginStart="6dp"
        NOT_FOUND_0x1f="@+id/tv_trade_type"
        NOT_FOUND_0x24="@+id/tv_borrowing"
        NOT_FOUND_0x27="@+id/tv_trade_type"/>
    <TextView
        textAppearance="@style/Body_4"
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/tv_deal_order_type"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginStart="6dp"
        NOT_FOUND_0x1f="@+id/tv_trade_type"
        NOT_FOUND_0x24="@+id/tv_lever"
        NOT_FOUND_0x27="@+id/tv_trade_type"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcv_view"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_marginBottom="12dp"
        overScrollMode="2"
        layout_marginStart="@dimen/common_page_edge_space"
        layout_marginEnd="@dimen/common_page_edge_space"
        touchscreenBlocksFocus="false"
        NOT_FOUND_0x1e="true"
        NOT_FOUND_0x20="@+id/view_line"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x26="@+id/tv_trade_type"/>
    <View
        id="@+id/view_line"
        layout_marginTop="@dimen/common_page_edge_space"
        layout_marginStart="@dimen/ok_dp_16"
        layout_marginEnd="@dimen/ok_dp_16"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x25="0"
        NOT_FOUND_0x26="@+id/rcv_view"
        style="@style/WidgetDivisionLine"/>
</androidx.constraintlayout.widget.ConstraintLayout>
