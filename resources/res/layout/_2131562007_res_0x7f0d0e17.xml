<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/status_bar_latest_event_content"
    layout_width="-1"
    android:layout_height="128dp">
    <ImageView
        id="@+id/icon"
        layout_width="128dp"
        android:layout_height="128dp"
        scaleType="6"/>
    <include
        layout_width="48dp"
        android:layout_height="48dp"
        layout_marginLeft="2dp"
        layout_marginRight="2dp"
        layout_alignParentRight="true"
        layout_alignParentEnd="true"
        layout="@layout/_2131562003_res_0x7f0d0e13"/>
    <include
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="128dp"
        layout_toLeftOf="@+id/cancel_action"
        layout_marginStart="128dp"
        layout_toStartOf="@+id/cancel_action"
        layout="@layout/_2131562011_res_0x7f0d0e1b"/>
    <LinearLayout
        orientation="0"
        id="@+id/media_actions"
        layout_width="-1"
        android:layout_height="48dp"
        layout_marginLeft="12dp"
        layout_marginRight="12dp"
        layout_toRightOf="@+id/icon"
        layout_alignParentBottom="true"
        layoutDirection="0"
        layout_toEndOf="@+id/icon"/>
    <ImageView
        id="@+id/action_divider"
        background="?android:attr/dividerHorizontal"
        layout_width="-1"
        android:layout_height="1dp"
        layout_toRightOf="@+id/icon"
        layout_above="@+id/media_actions"
        layout_toEndOf="@+id/icon"/>
</RelativeLayout>
