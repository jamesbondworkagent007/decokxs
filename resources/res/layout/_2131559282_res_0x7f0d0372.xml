<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="98dp"
    layout_marginLeft="@dimen/margin_default"
    layout_marginRight="@dimen/margin_default"
    layout_marginHorizontal="@dimen/margin_default"
    NOT_FOUND_0x15="@color/SurfaceSecondary"
    NOT_FOUND_0x16="8dp"
    NOT_FOUND_0x17="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="98dp"
        paddingStart="@dimen/padding_16dp">
        <TextView
            textColor="@color/ContentBrand"
            ellipsize="3"
            id="@+id/tv_banner_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/ok_dp_12"
            maxLines="1"
            layout_marginEnd="@dimen/margin_10dp"
            NOT_FOUND_0x1a="@+id/iv_icon"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="0"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentBrand"
            ellipsize="3"
            id="@+id/tv_banner_subtitle"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            maxLines="1"
            layout_marginEnd="@dimen/dp_10"
            NOT_FOUND_0x1a="@+id/iv_icon"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="@+id/tv_banner_title"
            style="@style/Title_2_Bold"/>
        <ImageView
            id="@+id/iv_icon"
            layout_width="98dp"
            android:layout_height="98dp"
            scaleType="6"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1d="0"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/countdown_container"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/ok_dp_12"
            layout_marginBottom="@dimen/ok_dp_12"
            layout_marginEnd="@dimen/dp_10"
            layout_marginVertical="@dimen/ok_dp_12"
            NOT_FOUND_0x1a="@+id/iv_icon"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="@+id/tv_banner_subtitle">
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                id="@+id/tv_countdown_days"
                background="@drawable/_2131231158_res_0x7f0801b6"
                layout_width="-2"
                android:layout_height="20dp"
                minWidth="20dp"
                backgroundTint="@color/SurfacePressed"
                style="@style/Label_4_Medium"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                text="D"
                style="@style/Label_4_Medium"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                id="@+id/tv_countdown_hour"
                background="@drawable/_2131231158_res_0x7f0801b6"
                layout_width="-2"
                android:layout_height="20dp"
                minWidth="20dp"
                backgroundTint="@color/SurfacePressed"
                style="@style/Label_4_Medium"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                text="H"
                style="@style/Label_4_Medium"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                id="@+id/tv_countdown_minute"
                background="@drawable/_2131231158_res_0x7f0801b6"
                layout_width="-2"
                android:layout_height="20dp"
                minWidth="20dp"
                backgroundTint="@color/SurfacePressed"
                style="@style/Label_4_Medium"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                text="M"
                style="@style/Label_4_Medium"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                id="@+id/tv_countdown_second"
                background="@drawable/_2131231158_res_0x7f0801b6"
                layout_width="-2"
                android:layout_height="20dp"
                minWidth="20dp"
                backgroundTint="@color/SurfacePressed"
                style="@style/Label_4_Medium"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x11"
                layout_width="20dp"
                android:layout_height="20dp"
                text="S"
                style="@style/Label_4_Medium"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
