<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/root_view"
    layout_width="-1"
    android:layout_height="wrap_content">
    <FrameLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                id="@+id/ll_setting_time"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/margin_16dp"
                layout_marginEnd="@dimen/margin_4dp">
                <HorizontalScrollView
                    id="@+id/scroll_layout"
                    scrollbars="horizontal"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1">
                    <LinearLayout
                        layout_width="-2"
                        android:layout_height="wrap_content">
                        <o.C39816pzV
                            id="@+id/mMarketTitleSelectViewTop"
                            layout_width="-1"
                            android:layout_height="32dp"
                            NOT_FOUND_0x1e="0"
                            NOT_FOUND_0x1f="false"/>
                    </LinearLayout>
                </HorizontalScrollView>
                <ImageView
                    id="@+id/iv_shadow"
                    visibility="0"
                    layout_width="@dimen/width_16dp"
                    android:layout_height="@dimen/padding_32dp"
                    src="@drawable/_2131232854_res_0x7f080856"
                    layout_marginStart="-16dp"/>
                <LinearLayout
                    gravity="0x10"
                    orientation="0"
                    id="@+id/ll_hide_kine"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/dp_4"
                    layout_marginEnd="20dp">
                    <TextView
                        textSize="@dimen/text_size_12sp"
                        textColor="@color/grey_g700"
                        id="@+id/tv_hide"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_trade_charts_textbtn_hide"
                        layout_marginEnd="@dimen/margin_5dp"/>
                    <ImageView
                        id="@+id/iv_arrow"
                        layout_width="@dimen/width_16dp"
                        android:layout_height="@dimen/height_16dp"
                        src="@drawable/_2131231656_res_0x7f0803a8"
                        NOT_FOUND_0x2c="@color/ContentTertiary"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                gravity="0x10"
                orientation="0"
                visibility="2"
                layout_width="-1"
                android:layout_height="28dp">
                <com.google.android.material.tabs.TabLayout
                    id="@+id/tl_time"
                    background="@color/transparent"
                    layout_width="0dp"
                    android:layout_height="22dp"
                    layout_marginLeft="@dimen/dp_8"
                    layout_marginRight="@dimen/dp_8"
                    layout_weight="1"
                    layout_marginHorizontal="@dimen/dp_8"
                    NOT_FOUND_0x21="@drawable/_2131233857_res_0x7f080c41"
                    NOT_FOUND_0x22="0"
                    NOT_FOUND_0x23="0dp"
                    NOT_FOUND_0x24="0"
                    NOT_FOUND_0x25="@dimen/dp_10"
                    NOT_FOUND_0x26="@dimen/dp_10"
                    NOT_FOUND_0x27="@android:color/transparent"
                    NOT_FOUND_0x28="@color/grey_g900"
                    NOT_FOUND_0x29="@style/MarketTitle"
                    NOT_FOUND_0x2a="@color/grey_g700"/>
                <View
                    background="@color/grey_g100"
                    layout_width="1dp"
                    android:layout_height="16dp"/>
                <ImageView
                    id="@+id/iv_hide_kine"
                    padding="@dimen/dp_4"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    src="@drawable/_2131232360_res_0x7f080668"
                    layout_marginStart="@dimen/dp_6"
                    layout_marginEnd="10dp"/>
            </LinearLayout>
            <RelativeLayout style="@style/HFill">
                <o.C36250oUv
                    id="@+id/mMarketChart"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    NOT_FOUND_0x18="true"/>
                <LinearLayout
                    gravity="0x11"
                    orientation="1"
                    id="@+id/ll_no_network"
                    background="@color/BasePrimary"
                    visibility="2"
                    clickable="true"
                    layout_width="-1"
                    android:layout_height="match_parent">
                    <o.C55173xeu
                        id="@+id/no_network"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        layout_centerInParent="true"
                        NOT_FOUND_0x17="8"
                        NOT_FOUND_0x20="@string/pr_resources_deep_network"
                        NOT_FOUND_0x2b="@string/pr_common_error_btn_reload"/>
                </LinearLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    orientation="1"
                    id="@+id/fragment_loading_cly"
                    background="@color/BasePrimary"
                    visibility="2"
                    clickable="true"
                    layout_width="-1"
                    android:layout_height="match_parent"
                    NOT_FOUND_0x1b="0"
                    NOT_FOUND_0x1c="0">
                    <com.airbnb.lottie.LottieAnimationView
                        layout_gravity="0x11"
                        id="@+id/fragment_trade_loading_view"
                        layout_width="-1"
                        android:layout_height="match_parent"
                        scaleType="fillCenter"
                        NOT_FOUND_0x19="0"
                        NOT_FOUND_0x1a="0"
                        NOT_FOUND_0x1b="0"
                        NOT_FOUND_0x1c="0"
                        NOT_FOUND_0x1d="true"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </RelativeLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
