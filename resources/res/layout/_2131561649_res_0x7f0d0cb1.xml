<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="@dimen/dp_56">
    <LinearLayout
        layout_gravity="0x11"
        orientation="0"
        id="@+id/editBtnLayout"
        paddingLeft="@dimen/padding_24dp"
        paddingRight="@dimen/padding_24dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_24dp">
        <LinearLayout
            gravity="0x800005"
            orientation="0"
            id="@+id/btn_add"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x10"
                id="@+id/iv_add"
                layout_width="@dimen/dp_16"
                android:layout_height="@dimen/dp_16"
                src="@drawable/_2131230882_res_0x7f0800a2"
                tint="@color/ContentPrimary"/>
            <TextView
                textSize="@dimen/text_size_12sp"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_add"
                paddingTop="8dp"
                paddingBottom="8dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_favorites_btn_add_crypto"
                maxLines="1"
                includeFontPadding="false"
                layout_marginStart="@dimen/dp_4"
                paddingVertical="8dp"
                style="@style/Label_3_Medium"/>
        </LinearLayout>
        <View
            layout_gravity="0x10"
            id="@+id/divider"
            background="@color/BorderPrimary"
            layout_width="1dp"
            android:layout_height="16dp"
            layout_marginLeft="@dimen/dp_16"
            layout_marginRight="@dimen/dp_16"
            layout_marginHorizontal="@dimen/dp_16"/>
        <LinearLayout
            orientation="0"
            id="@+id/btn_edit"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x10"
                id="@+id/iv_edit"
                layout_width="@dimen/dp_16"
                android:layout_height="@dimen/dp_16"
                src="@drawable/_2131232074_res_0x7f08054a"
                tint="@color/ContentPrimary"/>
            <TextView
                textSize="@dimen/text_size_12sp"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_edit"
                paddingTop="8dp"
                paddingBottom="8dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_favourites_title_edit_selected_crypto"
                maxLines="1"
                includeFontPadding="false"
                layout_marginStart="@dimen/dp_4"
                paddingVertical="8dp"
                style="@style/Label_3_Medium"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
