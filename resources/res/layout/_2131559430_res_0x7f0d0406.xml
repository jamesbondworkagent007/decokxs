<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/ll_address"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/margin_8dp"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xb="@+id/ll_value_price"
        NOT_FOUND_0xc="1"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0">
        <ImageView
            id="@+id/iv_address"
            layout_width="@dimen/sm"
            android:layout_height="@dimen/sm"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_address"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="@dimen/margin_4dp"
            style="@style/Label_2_Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x800005"
        orientation="1"
        id="@+id/ll_value_price"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xb="@+id/tv_time"
        NOT_FOUND_0xc="1"
        NOT_FOUND_0xd="@+id/ll_address"
        NOT_FOUND_0xf="0">
        <TextView
            id="@+id/tv_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="@dimen/margin_4dp"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/tv_price"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="@dimen/margin_4dp"
            style="@style/Label_3_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800005"
        id="@+id/tv_time"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xc="1"
        NOT_FOUND_0xd="@+id/ll_value_price"
        NOT_FOUND_0xf="0"
        style="@style/Label_2_Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
