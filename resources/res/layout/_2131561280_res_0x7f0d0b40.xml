<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/background_BasePrimary_BaseSecondary"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_16dp"
    layout_marginBottom="@dimen/margin_20dp">
    <TextView
        textAppearance="@style/TextAppearance.Text.15SP"
        textColor="@color/text_amplified"
        gravity="0x800003"
        id="@+id/tv_content"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginBottom="52dp"
        text="@string/pr_investdeposit_bot_pop_add_liquidity_getnft"
        includeFontPadding="false"
        textAlignment="5"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0x12="@+id/btn_accept"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="24sp"/>
    <o.C52794wYp
        id="@+id/btn_accept"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        layout_marginBottom="@dimen/margin_12dp"
        text="@string/pr_investdeposit_bot_btn_add_liquidity"
        layout_marginHorizontal="16dp"
        NOT_FOUND_0x12="@+id/btn_back"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="52"
        NOT_FOUND_0x17="0x101"/>
    <o.C52794wYp
        id="@+id/btn_back"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        text="@string/pr_investdeposit_bot_btn_cancel"
        layout_marginHorizontal="16dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="52"
        NOT_FOUND_0x17="0x102"/>
</androidx.constraintlayout.widget.ConstraintLayout>
