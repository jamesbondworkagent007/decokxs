<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/grey_40"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        fontFamily="@font/font_alpha_regular"/>
    <TextView
        id="@+id/content"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        style="@style/TextAppearance.Title.14SP.Medium"/>
</LinearLayout>
