<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/dp24"
    paddingTop="@dimen/dp_16"
    paddingRight="@dimen/dp24"
    paddingBottom="@dimen/dp_16"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp24"
    paddingVertical="@dimen/dp_16">
    <o.tUQ
        id="@+id/img_avatar"
        layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        NOT_FOUND_0x14="1.5dp"
        NOT_FOUND_0x15="1.5dp"
        NOT_FOUND_0x16="14dp"
        NOT_FOUND_0x17="14dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        lines="1"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x18="true"
        NOT_FOUND_0x1b="@+id/iv_official"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="2"
        NOT_FOUND_0x1e="@+id/img_avatar"
        NOT_FOUND_0x21="0"
        style="@style/Label_1_Medium"/>
    <ImageView
        id="@+id/iv_official"
        background="@drawable/_2131232809_res_0x7f080829"
        visibility="2"
        layout_width="@dimen/width_16dp"
        android:layout_height="@dimen/height_16dp"
        contentDescription="@null"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x19="@+id/tv_name"
        NOT_FOUND_0x1e="@+id/tv_name"
        NOT_FOUND_0x21="@+id/tv_name"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_followers"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x19="@+id/tv_name"
        NOT_FOUND_0x1e="@+id/iv_official"
        NOT_FOUND_0x21="@+id/tv_name"
        style="@style/Label_3_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentTertiary"
        ellipsize="3"
        id="@+id/tv_bio"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        maxLines="2"
        includeFontPadding="false"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1e="@+id/img_avatar"
        NOT_FOUND_0x20="@+id/tv_name"
        style="@style/Body_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
