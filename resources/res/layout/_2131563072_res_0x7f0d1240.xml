<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="@dimen/sm"
    paddingRight="@dimen/sm"
    paddingBottom="@dimen/padding_20dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/sm">
    <o.C55258xgZ
        textColor="@color/ContentContrast"
        id="@+id/tvUnClaimFeeTitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_investpositionplatform_list_text_unclaimed_fee_income"
        NOT_FOUND_0x11="1"
        NOT_FOUND_0x12="0"
        style="@style/Label_2_Regular"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/firstTokenLayout"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_marginBottom="8dp">
        <ImageView
            id="@+id/ivFirstToken"
            layout_width="24dp"
            android:layout_height="24dp"
            scaleType="7"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tvFirstToken"
            layout_width="-2"
            android:layout_height="wrap_content"
            minWidth="1dp"
            layout_marginStart="8dp"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/secondTokenLayout"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/ivSecondToken"
            layout_width="24dp"
            android:layout_height="24dp"
            scaleType="7"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tvSecondToken"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="8dp"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
</LinearLayout>
