<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="#f5f5f5"
    padding="16dp"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textSize="24sp"
        textStyle="0x1"
        textColor="#333333"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="32dp"
        text="文本渐变效果演示"/>
    <o.C19600gIj
        textSize="20sp"
        textStyle="0x1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        text="默认渐变效果"/>
    <o.C19600gIj
        textSize="20sp"
        textStyle="0x1"
        id="@+id/rainbowText"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        text="彩虹渐变效果"/>
    <o.C19600gIj
        textSize="20sp"
        textStyle="0x1"
        id="@+id/goldText"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        text="金色渐变效果"/>
    <o.C19600gIj
        textSize="20sp"
        textStyle="0x1"
        id="@+id/silverText"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        text="银色渐变效果"
        drawableRight="@drawable/_2131231637_res_0x7f080395"/>
    <o.C19600gIj
        textSize="20sp"
        textStyle="0x1"
        id="@+id/fireText"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        text="火焰渐变效果"/>
    <o.C19600gIj
        textSize="20sp"
        textStyle="0x1"
        id="@+id/oceanText"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        text="海洋渐变效果"/>
    <o.C19600gIj
        textSize="20sp"
        textStyle="0x1"
        id="@+id/customText"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        text="自定义渐变效果"/>
    <o.C19600gIj
        textSize="32sp"
        textStyle="0x1"
        id="@+id/largeText"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        text="大字体渐变效果"/>
    <o.C19600gIj
        textSize="18sp"
        textStyle="0x1"
        id="@+id/multilineText"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="这是多行文本渐变效果\10第二行文本\10第三行文本"
        lineSpacingExtra="4dp"/>
</LinearLayout>
