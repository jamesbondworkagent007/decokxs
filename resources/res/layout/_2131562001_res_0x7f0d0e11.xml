<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="8dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/markAllAsReadSection"
        paddingLeft="@dimen/margin_default"
        paddingTop="16dp"
        paddingRight="@dimen/margin_default"
        paddingBottom="16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_default"
        paddingVertical="16dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0">
        <ImageView
            id="@+id/markAllAsReadIcon"
            layout_width="32dp"
            android:layout_height="32dp"
            src="@drawable/_2131234096_res_0x7f080d30"/>
        <TextView
            id="@+id/markAllAsReadText"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_message_options_mark_all_as_read"
            layout_marginStart="12dp"
            style="@style/Title_2_Medium"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/customiseNotifcationsSection"
        paddingLeft="@dimen/margin_default"
        paddingTop="16dp"
        paddingRight="@dimen/margin_default"
        paddingBottom="16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_default"
        paddingVertical="16dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/markAllAsReadSection">
        <ImageView
            id="@+id/customiseNotificationsIcon"
            layout_width="32dp"
            android:layout_height="32dp"
            src="@drawable/_2131233932_res_0x7f080c8c"/>
        <TextView
            id="@+id/customiseNotificationsText"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_message_options_customize_notifications"
            layout_marginStart="12dp"
            style="@style/Title_2_Medium"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
