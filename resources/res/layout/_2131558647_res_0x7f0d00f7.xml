<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/container"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        id="@+id/toolbar"
        background="@android:color/transparent"
        layout_marginTop="40dp"
        NOT_FOUND_0x14="1"
        style="@style/AppTheme.Toolbar">
        <LinearLayout
            gravity="0x11"
            id="@+id/ll_back"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatImageView
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131232347_res_0x7f08065b"
                NOT_FOUND_0x15="@color/okTradeG900"/>
            <TextView
                textSize="@dimen/font_18"
                textStyle="0x1"
                textColor="@color/title_color"
                gravity="0x11"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="设备信息(Device Info)"
                maxLines="1"/>
        </LinearLayout>
        <TextView
            textSize="@dimen/font_18"
            textStyle="0x1"
            textColor="@color/debugbox_colorPrimaryDark"
            layout_gravity="0x800005"
            id="@+id/toolbar_upload"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_margin="6dp"
            text="@string/pr_debuge_text_uploadalert"
            maxLines="1"
            paddingStart="18dp"/>
        <TextView
            textSize="@dimen/font_18"
            textStyle="0x1"
            textColor="@color/debugbox_colorPrimaryDark"
            layout_gravity="0x800005"
            id="@+id/toolbar_copy"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_margin="6dp"
            text="@string/pr_debug_text_copy"
            maxLines="1"/>
        <ImageView
            layout_gravity="0x800005"
            id="@+id/iv_menu"
            visibility="2"
            layout_width="-2"
            android:layout_height="match_parent"/>
    </androidx.appcompat.widget.Toolbar>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/recycler_view"
        layout_width="-1"
        android:layout_height="match_parent"
        contentDescription="PDDeviceInfoTableID"
        overScrollMode="2"
        paddingStart="@dimen/sixteen"
        paddingEnd="@dimen/sixteen"/>
</LinearLayout>
