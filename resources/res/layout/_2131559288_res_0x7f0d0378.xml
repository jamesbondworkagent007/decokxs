<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/tv_token"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/sm"
    paddingRight="@dimen/sm"
    layout_width="-1"
    android:layout_height="64dp"
    layout_centerVertical="true"
    layout_alignParentStart="true"
    paddingHorizontal="@dimen/sm">
    <FrameLayout
        id="@+id/coin_panel"
        layout_width="36dp"
        android:layout_height="36dp"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x22="0"
        NOT_FOUND_0x24="0">
        <ImageView
            layout_gravity="0x800033"
            id="@+id/coin_ico_iv"
            background="@drawable/_2131231885_res_0x7f08048d"
            layout_width="32dp"
            android:layout_height="32dp"
            scaleType="7"/>
        <ImageView
            layout_gravity="0x800055"
            id="@+id/iv_chain_logo"
            background="@drawable/_2131231867_res_0x7f08047b"
            layout_width="16dp"
            android:layout_height="16dp"
            scaleType="7"/>
    </FrameLayout>
    <LinearLayout
        gravity="0x800013"
        orientation="0"
        id="@+id/ll_symbol_tag"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"
        layout_marginStart="@dimen/xxsm"
        NOT_FOUND_0x20="@+id/tv_price"
        NOT_FOUND_0x21="@+id/coin_panel"
        NOT_FOUND_0x24="@+id/coin_panel"
        NOT_FOUND_0x25="2">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/coin_symbol_tv"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            includeFontPadding="false"
            layout_marginEnd="4dp"
            style="@style/Label_1_Medium"/>
        <o.C28067kNr
            id="@+id/dex_tag"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"/>
    </LinearLayout>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        gravity="0x800005"
        id="@+id/tv_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="180dp"
        maxLines="1"
        includeFontPadding="false"
        paddingStart="12dp"
        NOT_FOUND_0x1e="@+id/ll_symbol_tag"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x24="@+id/ll_symbol_tag"
        style="@style/Label_1_Medium"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x800013"
        id="@+id/container_turnover_market_cap"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxxsm"
        maxWidth="100dp"
        layout_below="@+id/ll_symbol_tag"
        layout_marginStart="@dimen/xxsm"
        layout_marginEnd="@dimen/xxsm"
        layout_toEndOf="@+id/coin_panel"
        NOT_FOUND_0x1e="@+id/coin_panel"
        NOT_FOUND_0x20="@+id/tv_change"
        NOT_FOUND_0x21="@+id/coin_panel"
        NOT_FOUND_0x23="@+id/ll_symbol_tag">
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_token_volume"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_3_Regular"/>
        <View
            layout_gravity="0x10"
            background="@drawable/_2131232278_res_0x7f080616"
            layout_width="4dp"
            android:layout_height="4dp"
            layout_marginLeft="6dp"
            layout_marginRight="6dp"
            backgroundTint="@color/BorderSecondary"
            layout_marginHorizontal="6dp"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/tv_token_mcap"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            style="@style/Label_3_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="?attr/tradeRiseDefault"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_change"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="180dp"
        text=""
        maxLines="1"
        includeFontPadding="false"
        NOT_FOUND_0x1e="@+id/container_turnover_market_cap"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x24="@+id/container_turnover_market_cap"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
