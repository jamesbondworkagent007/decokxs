<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/BasePrimaryAlternative"
    paddingLeft="@dimen/dp_16"
    paddingRight="@dimen/dp_16"
    layout_width="-1"
    android:layout_height="@dimen/dp_44"
    paddingHorizontal="@dimen/dp_16">
    <ImageView
        id="@+id/header_back"
        background="?attr/selectableItemBackgroundBorderless"
        focusable="true"
        clickable="true"
        layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        src="@drawable/_2131232347_res_0x7f08065b"
        contentDescription="@null"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@color/grey_g900"/>
    <ImageView
        id="@+id/start_icon"
        background="?attr/selectableItemBackgroundBorderless"
        focusable="true"
        visibility="2"
        clickable="true"
        layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        src="@drawable/_2131232347_res_0x7f08065b"
        contentDescription="@null"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@color/ContentPrimary"/>
    <RelativeLayout
        id="@+id/header_title_container"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginLeft="@dimen/dp_32"
        layout_marginRight="@dimen/dp_32"
        layout_marginHorizontal="@dimen/dp_32"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="@+id/end_icon"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/title_icon_wrapper"
            layout_width="-2"
            android:layout_height="match_parent"
            layout_centerInParent="true">
            <ImageView
                id="@+id/title_icon"
                background="?attr/selectableItemBackgroundBorderless"
                focusable="true"
                visibility="2"
                clickable="true"
                layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                layout_centerVertical="true"
                contentDescription="@null"
                layout_marginEnd="@dimen/dp_8"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1b="@+id/header_title"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"/>
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                gravity="0x11"
                id="@+id/header_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                lines="1"
                layout_centerVertical="true"
                autoSizeStepGranularity="@dimen/text_size_2sp"
                autoSizeMinTextSize="@dimen/text_size_14sp"
                autoSizeMaxTextSize="@dimen/text_size_16sp"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1d="0"
                style="@style/Label_1_Bold"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
    <ImageView
        id="@+id/end_icon"
        background="?attr/selectableItemBackgroundBorderless"
        focusable="true"
        visibility="2"
        clickable="true"
        layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        contentDescription="@null"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@color/ContentPrimary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
