    <o.C52794wYp
        textSize="16sp"
        gravity="0x11"
        layout_gravity="0x1"
        id="@+id/btn_available_know"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="36dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginBottom="20dp"
        text="@string/pr_wallet_dialog_btn_got_it"
        layout_marginHorizontal="@dimen/margin_16dp"
