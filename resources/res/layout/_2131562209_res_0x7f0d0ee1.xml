<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/dp24"
    paddingTop="@dimen/ok_dp_12"
    paddingRight="@dimen/dp24"
    paddingBottom="@dimen/ok_dp_12"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp24">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/coin_img"
        layout_width="@dimen/dp_28"
        android:layout_height="@dimen/dp_28"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_coin_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_12dp"
        layout_marginRight="@dimen/margin_12dp"
        maxLines="1"
        layout_marginHorizontal="@dimen/margin_12dp"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x13="@+id/tv_date"
        NOT_FOUND_0x15="@+id/call_auction_state"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/coin_img"
        NOT_FOUND_0x1a="0"
        style="@style/TextAppearance.Text.15SP.Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_date"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="1"
        singleLine="true"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/tv_coin_name"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="@+id/tv_coin_name"
        NOT_FOUND_0x19="@+id/tv_coin_name"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="@dimen/text_size_15sp"
        textColor="@color/ContentPrimary"
        id="@+id/call_auction_state"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x1a="0"
        style="@style/Label_3_Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
