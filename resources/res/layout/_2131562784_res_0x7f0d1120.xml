<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/view_dynamic_selectview_search_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        id="@+id/searchLayout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0x13="@color/background_lv2"
        NOT_FOUND_0x14="4dp"
        NOT_FOUND_0x15="0dp"
        NOT_FOUND_0x16="false">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content">
            <EditText
                textSize="14sp"
                textColor="@color/title_color"
                textColorHint="@color/text_color"
                id="@+id/searchET"
                background="@null"
                paddingTop="8dp"
                paddingBottom="8dp"
                layout_width="-1"
                android:layout_height="wrap_content"
                paddingStart="12dp"
                paddingEnd="30dp"
                NOT_FOUND_0x19="0"/>
            <ImageView
                id="@+id/searchDelete"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131232524_res_0x7f08070c"
                layout_marginEnd="4dp"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <FrameLayout
        id="@+id/dynamicSelectViewContainer"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="8dp"
        layout_below="@+id/searchLayout"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/searchResultRV"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="8dp"
        layout_below="@+id/searchLayout"/>
</RelativeLayout>
