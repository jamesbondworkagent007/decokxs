<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_header_icon"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/rc_margin_size_30"
        scaleType="fillCenter"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_main_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="@dimen/margin_45dp"
        layout_marginRight="@dimen/margin_default"
        text="@string/pr_account_smartlink_toast_title_link_wallet_cex_acct"
        layout_marginHorizontal="@dimen/margin_default"
        NOT_FOUND_0x15="@+id/iv_header_icon"
        style="@style/Headline_4_Bold"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/tv_user"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_34"
        text="@string/pr_binding_landing_label_securely_connect_your_wallet"
        drawablePadding="@dimen/ok_dp_12"
        drawableStart="@drawable/_2131234283_res_0x7f080deb"
        layout_marginStart="@dimen/dp24"
        layout_marginEnd="@dimen/dp_24"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/tv_main_title"
        style="@style/TextAppearance.Text.Regular"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/tv_withdraw"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_34"
        text="@string/pr_binding_landing_label_instant_withdraw_from_exchange"
        drawablePadding="@dimen/ok_dp_12"
        drawableStart="@drawable/_2131234340_res_0x7f080e24"
        layout_marginStart="@dimen/dp24"
        layout_marginEnd="@dimen/dp_24"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/tv_user"
        style="@style/TextAppearance.Text.Regular"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/tv_settings"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_34"
        text="@string/pr_binding_landing_cell_label_unlock_more_features_and"
        drawablePadding="@dimen/ok_dp_12"
        drawableStart="@drawable/_2131234339_res_0x7f080e23"
        layout_marginStart="@dimen/dp24"
        layout_marginEnd="@dimen/dp_24"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/tv_withdraw"
        style="@style/TextAppearance.Text.Regular"/>
    <o.C52794wYp
        id="@+id/btn_bind_wallet"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginRight="@dimen/margin_default"
        layout_marginBottom="@dimen/margin_12dp"
        text="@string/pr_account_smartlink_toast_btn_get_started"
        layout_marginHorizontal="@dimen/margin_default"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x17="52"
        NOT_FOUND_0x18="0x101"/>
</androidx.constraintlayout.widget.ConstraintLayout>
