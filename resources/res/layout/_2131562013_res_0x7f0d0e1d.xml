<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    id="@+id/status_bar_latest_event_content"
    layout_width="-1"
    android:layout_height="64dp">
    <include
        layout_width="@dimen/notification_large_icon_width"
        android:layout_height="@dimen/notification_large_icon_height"
        layout="@layout/_2131562010_res_0x7f0d0e1a"/>
    <LinearLayout
        orientation="0"
        id="@+id/notification_main_column_container"
        paddingTop="@dimen/notification_main_column_padding_top"
        layout_width="0dp"
        android:layout_height="wrap_content"
        minHeight="@dimen/notification_large_icon_height"
        layout_weight="1"
        layout_toLeftOf="@+id/cancel_action"
        layout_toStartOf="@+id/cancel_action">
        <FrameLayout
            id="@+id/notification_main_column"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/notification_content_margin_start"
            layout_marginRight="8dp"
            layout_marginBottom="8dp"
            layout_weight="1"
            layout_marginStart="@dimen/notification_content_margin_start"
            layout_marginEnd="8dp"/>
        <FrameLayout
            id="@+id/right_side"
            paddingTop="@dimen/notification_right_side_padding_top"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginRight="8dp"
            layout_marginEnd="8dp">
            <DateTimeView
                textAppearance="@style/TextAppearance.Compat.Notification.Time.Media"
                layout_gravity="0x800035"
                id="@+id/time"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"/>
            <Chronometer
                textAppearance="@style/TextAppearance.Compat.Notification.Time.Media"
                layout_gravity="0x800035"
                id="@+id/chronometer"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"/>
            <TextView
                textAppearance="@style/TextAppearance.Compat.Notification.Info.Media"
                layout_gravity="0x800055"
                id="@+id/info"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="20dp"
                singleLine="true"/>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        layout_gravity="0x800015"
        orientation="0"
        id="@+id/media_actions"
        layout_width="-2"
        android:layout_height="match_parent"
        layoutDirection="0"/>
    <include
        layout_width="48dp"
        android:layout_height="match_parent"
        layout_marginRight="6dp"
        layout_marginEnd="6dp"
        layout="@layout/_2131562003_res_0x7f0d0e13"/>
    <ImageView
        id="@+id/end_padder"
        layout_width="6dp"
        android:layout_height="match_parent"/>
</LinearLayout>
