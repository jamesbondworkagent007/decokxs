<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/ac_choose_mentioned_members_0"
    fitsSystemWindows="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        orientation="0"
        id="@+id/title_layout"
        layout_width="-1"
        android:layout_height="@dimen/appbar_height"
        baselineAligned="false"
        paddingStart="8dp"
        paddingEnd="8dp">
        <ImageView
            layout_gravity="0x800013"
            id="@+id/iv_close"
            background="?attr/selectableItemBackgroundBorderless"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131232438_res_0x7f0806b6"
            scaleType="fitStart"
            layout_marginStart="14dp"
            NOT_FOUND_0x17="@color/title_color"/>
        <TextView
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/toolbar_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_message_group_title_mention_member"
            style="@style/TextAppearance.Title.16SP.Semibold"/>
        <o.C52794wYp
            layout_gravity="0x800015"
            id="@+id/btn_action"
            layout_width="-2"
            android:layout_height="wrap_content"
            minWidth="48dp"
            text="@string/pr_message_charts_menu_multi_select"
            paddingStart="8dp"
            paddingEnd="8dp"
            style="@style/Button.Borderless.Medium"/>
    </FrameLayout>
    <FrameLayout
        id="@+id/fragment_container"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="@dimen/appbar_height"/>
    <LinearLayout
        gravity="0x11"
        layout_gravity="0x50"
        orientation="0"
        id="@+id/confirm_layout"
        background="@color/BasePrimary"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="48dp"
        baselineAligned="false"
        paddingStart="@dimen/common_page_edge_space"
        paddingEnd="@dimen/common_page_edge_space"
        elevation="2dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.12SP"
            id="@+id/tv_selected_count"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"/>
        <Button
            id="@+id/btn_confirm"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_commonall_text_btn_confirm"
            layout_marginStart="@dimen/common_page_edge_space"
            style="@style/Button.Primary.Medium"/>
    </LinearLayout>
</FrameLayout>
