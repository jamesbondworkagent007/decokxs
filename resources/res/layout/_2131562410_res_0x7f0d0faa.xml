<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/trade_impl_signal_position_item_0"
    background="@color/BasePrimary"
    paddingLeft="@dimen/padding_16dp"
    paddingRight="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_16dp">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.15SP.Medium"
        textColor="@color/grey_g900"
        id="@+id/coin_pair"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1e="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g700"
        id="@+id/coin_type"
        background="@drawable/_2131231485_res_0x7f0802fd"
        paddingLeft="@dimen/padding_4dp"
        paddingTop="@dimen/padding_2dp"
        paddingRight="@dimen/padding_4dp"
        paddingBottom="@dimen/padding_2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        backgroundTint="@color/background_lv3"
        paddingHorizontal="@dimen/padding_4dp"
        paddingVertical="@dimen/padding_2dp"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="@+id/coin_pair"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g700"
        id="@+id/side"
        background="@drawable/_2131231485_res_0x7f0802fd"
        paddingLeft="@dimen/padding_4dp"
        paddingTop="@dimen/padding_2dp"
        paddingRight="@dimen/padding_4dp"
        paddingBottom="@dimen/padding_2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        layout_marginStart="@dimen/margin_4dp"
        paddingHorizontal="@dimen/padding_4dp"
        paddingVertical="@dimen/padding_2dp"
        NOT_FOUND_0x1b="@+id/coin_type"
        NOT_FOUND_0x1d="@+id/coin_pair"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/grey_g400"
        id="@+id/create_time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_6dp"
        NOT_FOUND_0x17="@+id/side"
        NOT_FOUND_0x1b="@+id/side"
        NOT_FOUND_0x1e="@+id/side"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/inside_recyclerview"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="-8dp"
        layout_marginBottom="12dp"
        NOT_FOUND_0x1d="@+id/coin_type"/>
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guide_line"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1a="0.5"/>
    <o.C52794wYp
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/manual_order"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_signalbot_orderdetails_icon_manual_order"
        maxLines="2"
        layout_marginEnd="@dimen/margin_4dp"
        NOT_FOUND_0x19="@+id/guide_line"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="@+id/inside_recyclerview"
        NOT_FOUND_0x1f="-1"
        NOT_FOUND_0x20="32"
        NOT_FOUND_0x21="0x104"/>
    <o.C52794wYp
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/grey_g900"
        ellipsize="3"
        id="@+id/close_all"
        layout_width="0dp"
        android:layout_height="match_parent"
        text="@string/pr_trade_futuresgrid_btn_close_all"
        maxLines="2"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1c="@+id/guide_line"
        NOT_FOUND_0x1e="@+id/manual_order"
        NOT_FOUND_0x1f="-1"
        NOT_FOUND_0x20="32"
        NOT_FOUND_0x21="0x104"/>
    <View
        background="@color/LineMuted"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="@dimen/padding_16dp"
        NOT_FOUND_0x1d="@+id/manual_order"/>
    <View
        id="@+id/item_cover"
        background="#c0c0c0"
        visibility="2"
        layout_width="0dp"
        android:layout_height="0dp"
        NOT_FOUND_0x17="@+id/inside_recyclerview"
        NOT_FOUND_0x18="@+id/inside_recyclerview"
        NOT_FOUND_0x1c="@+id/inside_recyclerview"
        NOT_FOUND_0x1e="@+id/inside_recyclerview"/>
</androidx.constraintlayout.widget.ConstraintLayout>
