<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@drawable/_2131231251_res_0x7f080213"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.Bold.18SP"
        textColor="@color/ContentPrimary"
        id="@+id/reward_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_14dp"
        layout_marginTop="@dimen/margin_13dp"
        layout_marginRight="@dimen/margin_14dp"
        text="@string/pr_invest_mid_title_rewards"
        layout_marginHorizontal="@dimen/margin_14dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <ImageView
        id="@+id/info_icon"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131233739_res_0x7f080bcb"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0xe="@+id/reward_text"
        NOT_FOUND_0x10="@+id/reward_text"
        NOT_FOUND_0x13="@+id/reward_text"
        NOT_FOUND_0x14="@color/ContentPrimary"/>
    <ImageView
        id="@+id/close_icon"
        layout_width="24dp"
        android:layout_height="24dp"
        layout_marginTop="@dimen/margin_13dp"
        src="@drawable/_2131232438_res_0x7f0806b6"
        layout_marginEnd="@dimen/margin_14dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@color/ContentContrast"/>
    <View
        id="@+id/separator"
        background="@color/line_light"
        layout_width="-1"
        android:layout_height="@dimen/height_0.5dp"
        layout_marginTop="@dimen/margin_13dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/reward_text"/>
</androidx.constraintlayout.widget.ConstraintLayout>
