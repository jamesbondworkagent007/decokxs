<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.okinc.uilab.edit.OKEditText
        textColor="@color/ContentContrast"
        textColorHint="@color/ContentContrast"
        gravity="0x800035"
        id="@+id/recurring_amount_hint"
        tag="layout/view_recurring_new_amount_0"
        background="@null"
        focusable="false"
        clickable="false"
        layout_width="0dp"
        android:layout_height="wrap_content"
        minHeight="93dp"
        cursorVisible="false"
        maxLines="1"
        singleLine="true"
        inputType="0x1"
        textSelectHandle="@drawable/_2131234233_res_0x7f080db9"
        textAlignment="3"
        layout_marginEnd="@dimen/margin_4dp"
        NOT_FOUND_0x19="@+id/recurring_unit"
        NOT_FOUND_0x1a="1"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="0dp"
        NOT_FOUND_0x20="true"
        NOT_FOUND_0x21="12"
        NOT_FOUND_0x22="1"
        style="@style/amount_regula_70sp"/>
    <o.C55001xbh
        textColorHint="@color/ContentContrast"
        gravity="0x800035"
        id="@+id/recurring_amount"
        tag="layout/view_recurring_new_amount_1"
        background="@null"
        layout_width="0dp"
        android:layout_height="wrap_content"
        minHeight="93dp"
        maxLines="1"
        singleLine="true"
        digits="0123456789,."
        inputType="0x2002"
        textSelectHandle="@drawable/_2131234233_res_0x7f080db9"
        textAlignment="3"
        layout_marginEnd="@dimen/margin_4dp"
        NOT_FOUND_0x17="@+id/recurring_amount_hint"
        NOT_FOUND_0x19="@+id/recurring_unit"
        NOT_FOUND_0x1a="1"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1f="0dp"
        NOT_FOUND_0x20="true"
        NOT_FOUND_0x21="12"
        NOT_FOUND_0x22="1"
        style="@style/amount_regula_70sp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/SemanticNegative"
        id="@+id/errorMsg"
        tag="layout/view_recurring_new_amount_2"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_6"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1c="@+id/recurring_amount"
        NOT_FOUND_0x1d="@+id/recurring_amount"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/recurring_unit"
        tag="layout/view_recurring_new_amount_3"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        textAlignment="3"
        layout_marginEnd="8dp"
        NOT_FOUND_0x17="@+id/recurring_amount_hint"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1b="@+id/recurring_amount"
        style="@style/amount_regula_70sp"/>
</merge>
