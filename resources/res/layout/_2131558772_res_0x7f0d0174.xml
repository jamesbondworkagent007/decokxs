<?xml version="1.0" encoding="utf-8"?>
<view xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@drawable/_2131234467_res_0x7f080ea3"
    layout_width="-1"
    android:layout_height="wrap_content"
    class="com.okinc.okassetslite.api.assets_lite_api.transactionhistory.view.DateRangeFilterView$StateListAnimator">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textAppearance="@style/TextAppearance.Title.Medium"
            textSize="@dimen/text_size_12sp"
            id="@+id/tv_date_filter"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            text="@string/lt_portfolio_transactions_filter_period"
            layout_marginStart="16dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.10SP"
            id="@+id/tv_only_3_month"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="@string/lt_portfolio_transactions_filter_body_allhistory"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Headline.14SP"
            id="@+id/tv_filter_cancel"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/common_page_edge_space"
            layout_marginTop="@dimen/common_page_edge_space"
            layout_marginRight="@dimen/common_page_edge_space"
            layout_marginBottom="8dp"
            text="@string/lt_portfolio_transactions_filter_btn_reset"
            drawablePadding="8dp"
            drawableStart="@drawable/_2131234472_res_0x7f080ea8"
            layout_marginHorizontal="@dimen/common_page_edge_space"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="14dp"
            layout_marginBottom="6dp">
            <TextView
                textColor="@color/okTradeBlack"
                gravity="0x11"
                id="@+id/tv_recent_7_days"
                background="@drawable/_2131231243_res_0x7f08020b"
                paddingLeft="14dp"
                paddingTop="10dp"
                paddingRight="14dp"
                paddingBottom="10dp"
                layout_width="0dp"
                android:layout_height="match_parent"
                text="@string/lt_portfolio_transactions_filter_chip_seven"
                maxLines="2"
                includeFontPadding="false"
                layout_weight="1"
                layout_marginStart="16dp"
                paddingHorizontal="14dp"
                paddingVertical="10dp"
                NOT_FOUND_0x21="14sp"
                NOT_FOUND_0x22="7sp"
                NOT_FOUND_0x23="1"
                style="@style/TextAppearance.Title.14SP.Medium"/>
            <TextView
                textColor="@color/okTradeBlack"
                gravity="0x11"
                id="@+id/tv_recent_30_days"
                background="@drawable/_2131231243_res_0x7f08020b"
                paddingLeft="14dp"
                paddingTop="10dp"
                paddingRight="14dp"
                paddingBottom="10dp"
                layout_width="0dp"
                android:layout_height="match_parent"
                text="@string/lt_portfolio_transactions_filter_chip_thirty"
                maxLines="2"
                includeFontPadding="false"
                layout_weight="1"
                layout_marginStart="16dp"
                layout_marginEnd="16dp"
                paddingHorizontal="14dp"
                paddingVertical="10dp"
                NOT_FOUND_0x21="14sp"
                NOT_FOUND_0x22="7sp"
                NOT_FOUND_0x23="1"
                style="@style/TextAppearance.Title.14SP.Medium"/>
            <TextView
                textColor="@color/okTradeG900"
                gravity="0x11"
                id="@+id/tv_recent_90_days"
                background="@drawable/_2131231243_res_0x7f08020b"
                paddingLeft="14dp"
                paddingTop="10dp"
                paddingRight="14dp"
                paddingBottom="10dp"
                layout_width="0dp"
                android:layout_height="match_parent"
                text="@string/lt_portfolio_transactions_filter_chip_ninety"
                maxLines="2"
                includeFontPadding="false"
                layout_weight="1"
                layout_marginEnd="16dp"
                paddingHorizontal="14dp"
                paddingVertical="10dp"
                NOT_FOUND_0x21="14sp"
                NOT_FOUND_0x22="7sp"
                NOT_FOUND_0x23="1"
                style="@style/TextAppearance.Title.14SP.Medium"/>
        </LinearLayout>
        <TextView
            textSize="12sp"
            textColor="@color/okTradeG400"
            id="@+id/tv_date_tips"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/common_page_edge_space"
            layout_marginTop="2dp"
            layout_marginRight="@dimen/common_page_edge_space"
            layout_marginBottom="8dp"
            text="@string/lt_portfolio_transactions_filter_period"
            layout_marginHorizontal="@dimen/common_page_edge_space"/>
        <LinearLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/common_page_edge_space"
            layout_marginTop="16dp"
            layout_marginRight="@dimen/common_page_edge_space"
            layout_marginHorizontal="@dimen/common_page_edge_space">
            <TextView
                textColor="@color/okTradeG900"
                id="@+id/time_start"
                tag="start"
                background="@drawable/_2131231242_res_0x7f08020a"
                paddingLeft="8dp"
                paddingTop="10dp"
                paddingRight="8dp"
                paddingBottom="10dp"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text=""
                layout_weight="1"
                paddingHorizontal="8dp"
                paddingVertical="10dp"
                style="@style/TextAppearance.Title.14SP"/>
            <View
                layout_gravity="0x10"
                background="@color/okTradeG300"
                layout_width="7dp"
                android:layout_height="1dp"
                layout_marginLeft="8dp"
                layout_marginRight="8dp"
                layout_marginHorizontal="8dp"/>
            <TextView
                textColor="@color/okTradeG900"
                id="@+id/time_end"
                tag="end"
                background="@drawable/_2131231242_res_0x7f08020a"
                paddingLeft="8dp"
                paddingTop="10dp"
                paddingRight="8dp"
                paddingBottom="10dp"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text=""
                layout_weight="1"
                paddingHorizontal="8dp"
                paddingVertical="10dp"
                style="@style/TextAppearance.Title.14SP"/>
        </LinearLayout>
        <FrameLayout
            id="@+id/select_content"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/common_page_edge_space"
            layout_marginTop="@dimen/common_page_edge_space"
            layout_marginRight="@dimen/common_page_edge_space"
            minHeight="150dp"
            layout_marginHorizontal="@dimen/common_page_edge_space"/>
        <View
            layout_marginTop="@dimen/common_page_edge_space"
            style="@style/WidgetDivisionLine"/>
        <LinearLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/common_page_edge_space"
            layout_marginTop="12dp"
            layout_marginRight="@dimen/common_page_edge_space"
            layout_marginBottom="@dimen/common_page_edge_space"
            layout_marginHorizontal="@dimen/common_page_edge_space">
            <o.C52794wYp
                id="@+id/time_reset"
                layout_width="0dp"
                android:layout_height="match_parent"
                text="@string/lt_portfolio_transactions_filter_btn_reset"
                layout_weight="1"
                textAllCaps="false"
                NOT_FOUND_0x24="44"
                NOT_FOUND_0x25="0x102"/>
            <o.C52794wYp
                id="@+id/time_confirm"
                layout_width="0dp"
                android:layout_height="match_parent"
                text="@string/lt_portfolio_transactions_filter_btn_apply"
                layout_weight="1"
                textAllCaps="false"
                layout_marginStart="16dp"
                NOT_FOUND_0x24="44"
                NOT_FOUND_0x25="0x101"/>
        </LinearLayout>
    </LinearLayout>
</view>
