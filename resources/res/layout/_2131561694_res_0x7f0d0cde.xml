<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/BasePrimary"
    paddingLeft="24dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp">
    <View
        id="@+id/viewBackground"
        background="@drawable/_2131233438_res_0x7f080a9e"
        layout_width="0dp"
        android:layout_height="0dp"
        layout_marginStart="39dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"/>
    <TextView
        textSize="10dp"
        textColor="@color/ContentContrast"
        id="@+id/time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        style="@style/Label_4_Regular"/>
    <ImageView
        id="@+id/icon"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginTop="12dp"
        src="@drawable/_2131232073_res_0x7f080549"
        layout_marginStart="12dp"
        NOT_FOUND_0x14="@+id/viewBackground"
        NOT_FOUND_0x16="@+id/viewBackground"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="4dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x10="@+id/icon"
        NOT_FOUND_0x12="@+id/reminderStatus"
        NOT_FOUND_0x13="@+id/icon"
        NOT_FOUND_0x16="@+id/icon"
        style="@style/Label_3_Medium"/>
    <o.pGS
        id="@+id/reminderStatus"
        visibility="2"
        layout_width="50dp"
        android:layout_height="28dp"
        layout_marginEnd="@dimen/dp_12"
        NOT_FOUND_0x10="@+id/title"
        NOT_FOUND_0x11="@+id/viewBackground"
        NOT_FOUND_0x13="@+id/title"
        NOT_FOUND_0x16="@+id/title"/>
    <TextView
        textSize="10dp"
        textColor="@color/ContentContrast"
        id="@+id/actualTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_trade_discover_title_actual"
        NOT_FOUND_0x12="@+id/previousTitle"
        NOT_FOUND_0x14="@+id/icon"
        NOT_FOUND_0x15="@+id/title"
        style="@style/Label_4_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/actualTitleValue"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x14="@+id/actualTitle"
        NOT_FOUND_0x15="@+id/actualTitle"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="10dp"
        textColor="@color/ContentContrast"
        id="@+id/previousTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_discover_title_previous"
        layout_marginStart="8dp"
        NOT_FOUND_0x12="@+id/consensusTitle"
        NOT_FOUND_0x13="@+id/actualTitle"
        NOT_FOUND_0x16="@+id/actualTitle"
        style="@style/Label_4_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/previousTitleValue"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x14="@+id/previousTitle"
        NOT_FOUND_0x15="@+id/previousTitle"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="10dp"
        textColor="@color/ContentContrast"
        id="@+id/consensusTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_discover_title_consensus"
        layout_marginStart="8dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x11="@+id/viewBackground"
        NOT_FOUND_0x13="@+id/previousTitle"
        NOT_FOUND_0x16="@+id/previousTitle"
        style="@style/Label_4_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/consensusTitleValue"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x14="@+id/consensusTitle"
        NOT_FOUND_0x15="@+id/consensusTitle"
        style="@style/Label_3_Regular"/>
    <androidx.constraintlayout.widget.Group
        id="@+id/detail_group"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xf="actualTitle,actualTitleValue,previousTitle,previousTitleValue,consensusTitle,consensusTitleValue"/>
    <Space
        id="@+id/bottom_space"
        layout_width="0dp"
        android:layout_height="@dimen/dp_12"
        NOT_FOUND_0x14="@+id/actualTitleValue"
        NOT_FOUND_0x15="@+id/actualTitleValue"/>
</androidx.constraintlayout.widget.ConstraintLayout>
