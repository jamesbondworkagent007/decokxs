<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/item_input_card_item_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/line"
        layout_width="-1"
        android:layout_height="16dp"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/content_constraint_layout"
        background="@drawable/_2131231183_res_0x7f0801cf"
        padding="16dp"
        visibility="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="@dimen/height_48dp">
        <ImageView
            id="@+id/id_card_icon"
            layout_width="@dimen/width_24dp"
            android:layout_height="@dimen/height_24dp"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            id="@+id/id_content_ly"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/margin_12dp">
            <TextView
                textSize="16sp"
                textColor="@color/ContentPrimary"
                id="@+id/item_content"
                layout_width="-1"
                android:layout_height="wrap_content"
                lineSpacingExtra="?attr/contentLineSpacingExtra"
                style="@style/Label_1_Regular"/>
            <TextView
                textSize="@dimen/text_size_12sp"
                textColor="@color/background_lv1"
                gravity="0x10"
                id="@+id/content_content_info"
                background="@drawable/_2131231181_res_0x7f0801cd"
                paddingLeft="@dimen/dp_4"
                paddingTop="1dp"
                paddingRight="@dimen/dp_4"
                paddingBottom="1dp"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_4"
                paddingHorizontal="@dimen/dp_4"
                paddingVertical="1dp"/>
            <TextView
                textSize="14sp"
                textColor="@color/ContentTertiary"
                gravity="0x10"
                id="@+id/item_subtitle"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_4"
                lineHeight="@dimen/height_16dp"
                style="@style/Label_2_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
