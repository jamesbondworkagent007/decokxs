<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/layoutContainer"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1">
        <ScrollView
            id="@+id/scrollView"
            visibility="2"
            scrollbars="horizontal"
            layout_width="-1"
            android:layout_height="match_parent"
            overScrollMode="2">
            <LinearLayout
                orientation="1"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_default"
                layout_marginRight="@dimen/margin_default"
                layout_marginHorizontal="@dimen/margin_default">
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/lbl_billing_cycle"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/xsm"
                    layout_marginBottom="@dimen/margin_8dp"
                    text="@string/pr_message_paid_group_input_title_billing_cycle"
                    style="@style/Label_2_Medium"/>
                <com.okinc.uilab.edit.OKEditText
                    enabled="false"
                    id="@+id/input_billing_cycle"
                    background="@drawable/_2131233594_res_0x7f080b3a"
                    padding="@dimen/xxsm"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    minHeight="44dp"
                    singleLine="true"
                    style="@style/Body_2"/>
                <TextView
                    id="@+id/inputLabel"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_16dp"
                    text="@string/pr_message_paid_group_input_label_membership_fee"
                    style="@style/Label_2_Medium"/>
                <com.okinc.im.imui.utils.OKIMStateAwareFrameLayout
                    orientation="0"
                    id="@+id/amountInputContainer"
                    background="@drawable/_2131232063_res_0x7f08053f"
                    layout_width="-1"
                    android:layout_height="48dp"
                    layout_marginTop="@dimen/margin_8dp">
                    <o.C55001xbh
                        textColor="@color/ContentPrimary"
                        textColorHint="@color/ContentDisabled"
                        gravity="0x800013"
                        id="@+id/memberFeeInput"
                        background="@null"
                        layout_width="0dp"
                        android:layout_height="wrap_content"
                        digits="0123456789,."
                        inputType="0x2002"
                        imeOptions="0x6"
                        paddingStart="@dimen/padding_12dp"
                        paddingEnd="@dimen/width_0dp"
                        NOT_FOUND_0x1e="0"
                        NOT_FOUND_0x20="@+id/menuChip"
                        NOT_FOUND_0x21="0"
                        NOT_FOUND_0x22="0"
                        style="@style/Body_2_Regular"/>
                    <FrameLayout
                        id="@+id/menuChip"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        paddingStart="0dp"
                        paddingEnd="@dimen/xxsm"
                        NOT_FOUND_0x1e="0"
                        NOT_FOUND_0x1f="0"
                        NOT_FOUND_0x22="0"/>
                </com.okinc.im.imui.utils.OKIMStateAwareFrameLayout>
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/rangeDescription"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_8dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
        </ScrollView>
        <o.C55173xeu
            layout_gravity="0x11"
            id="@+id/empty_view"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1d="8"
            NOT_FOUND_0x27="@string/pr_message_chat_emptystate_desc_check_connection"
            NOT_FOUND_0x28="@string/pr_message_chat_emptystate_title_youre_disconnected"/>
        <o.C55113xdn
            layout_gravity="0x11"
            id="@+id/view_loading"
            visibility="2"
            layout_width="@dimen/width_60dp"
            android:layout_height="@dimen/width_60dp"
            NOT_FOUND_0x23="true"
            NOT_FOUND_0x24="@raw/_2131886123_res_0x7f12002b"/>
    </FrameLayout>
    <o.C52794wYp
        id="@+id/saveButton"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="@dimen/xsm"
        layout_marginRight="@dimen/margin_default"
        layout_marginBottom="@dimen/xsm"
        text="@string/pr_commonall_resultpage_btn_save"
        layout_marginHorizontal="@dimen/margin_default"
        layout_marginVertical="@dimen/xsm"
        NOT_FOUND_0x25="52"
        NOT_FOUND_0x26="0x101"/>
</LinearLayout>
