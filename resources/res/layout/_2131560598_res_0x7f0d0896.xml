<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/cardView"
    tag="layout/item_im_sticker_message_send_0"
    layout_width="120dp"
    android:layout_height="120dp"
    backgroundTint="@color/transparent"
    NOT_FOUND_0x8="0dp"
    NOT_FOUND_0x9="0dp">
    <com.airbnb.lottie.LottieAnimationView
        id="@+id/lottiePlaceholder"
        layout_width="-1"
        android:layout_height="match_parent"
        NOT_FOUND_0xa="true"
        NOT_FOUND_0xb="true"/>
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/ivImage"
        visibility="1"
        layout_width="-1"
        android:layout_height="match_parent"
        scaleType="fitStart"
        adjustViewBounds="true"/>
</androidx.cardview.widget.CardView>
