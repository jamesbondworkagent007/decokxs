<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/item_message_layout"
    tag="layout/item_planet_common_message_content_0"
    background="?attr/selectableItemBackground"
    paddingTop="10dp"
    paddingBottom="10dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="24dp"
    paddingEnd="24dp">
    <ImageView
        id="@+id/ivAvatar"
        layout_width="40dp"
        android:layout_height="40dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"/>
    <TextView
        textSize="14sp"
        textColor="@color/ContentPrimary"
        id="@+id/tvTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0x15="@+id/tvBarrier"
        NOT_FOUND_0x16="@+id/ivAvatar"
        NOT_FOUND_0x19="@+id/ivAvatar"
        style="@style/Label_1_Medium"/>
    <TextView
        textSize="14sp"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvDesc"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="2"
        NOT_FOUND_0x14="@+id/tvTitle"
        NOT_FOUND_0x17="@+id/tvTitle"
        NOT_FOUND_0x18="@+id/tvTitle"
        style="@style/Label_2_Regular"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/tvBarrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="5"
        NOT_FOUND_0x13="tvTime,btnFollow"/>
    <TextView
        textSize="14sp"
        textColor="@color/ContentContrast"
        id="@+id/tvTime"
        layout_width="-2"
        android:layout_height="wrap_content"
        drawablePadding="4dp"
        layout_marginStart="8dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/tvTitle"
        NOT_FOUND_0x19="@+id/tvTitle"
        style="@style/Label_2_Regular"/>
    <o.C52794wYp
        id="@+id/btnFollow"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        minWidth="92dp"
        layout_marginStart="12dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/tvTitle"
        NOT_FOUND_0x19="@+id/ivAvatar"
        NOT_FOUND_0x1a="32"
        NOT_FOUND_0x1b="0x103"
        NOT_FOUND_0x1c="-1"/>
</androidx.constraintlayout.widget.ConstraintLayout>
