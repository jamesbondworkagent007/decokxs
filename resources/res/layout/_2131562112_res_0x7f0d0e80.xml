<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x1"
    orientation="1"
    paddingLeft="24dp"
    paddingRight="24dp"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="24dp">
    <ImageView
        id="@+id/header"
        layout_width="80dp"
        android:layout_height="80dp"
        src="@drawable/_2131233674_res_0x7f080b8a"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        text="@string/pr_orbit_upgrade_bttmsheet_desc_youre_able_to"
        style="@style/Headline_6_Medium"/>
    <LinearLayout
        orientation="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp">
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/time"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="Joined 25 Jun 2025"
            style="@style/Body_3_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            paddingLeft="6dp"
            paddingRight="6dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="·"
            paddingHorizontal="6dp"
            style="@style/Body_3_Regular"/>
        <TextView
            textColor="@color/ContentSecondary"
            layout_gravity="0x10"
            id="@+id/replies"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingEnd="2dp"
            style="@style/Label_1_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            layout_gravity="0x10"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_1_Regular"/>
    </LinearLayout>
</LinearLayout>
