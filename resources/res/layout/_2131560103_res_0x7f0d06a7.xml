<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/pageContainer"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="match_parent">
    <com.okinc.auth.impl.widget.SimpleToolBar
        id="@+id/appBar"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x24="@string/pr_account_fido2_mdltitle_security_veri"/>
    <View
        id="@+id/divider"
        background="@color/list_divider_color"
        layout_width="-1"
        android:layout_height="0.5dp"
        NOT_FOUND_0x1f="@+id/appBar"/>
    <LinearLayout
        orientation="1"
        id="@+id/vg_otp_input_item_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="@dimen/margin_20dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginHorizontal="@dimen/margin_16dp">
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Medium"
            textColor="@color/text_amplified"
            layout_gravity="0x800013"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="Verification"/>
        <RelativeLayout
            orientation="0"
            background="@drawable/_2131230868_res_0x7f080094"
            layout_width="-1"
            android:layout_height="44dp"
            layout_marginTop="@dimen/margin_4dp">
            <com.okinc.uilab.edit.OKEditText
                textAppearance="@style/TextAppearance.Text.15SP"
                textColorHint="@color/ContentContrast"
                layout_gravity="0x800013"
                id="@+id/otpInput"
                background="@null"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/padding_12dp"
                layout_marginRight="@dimen/padding_12dp"
                hint="@string/pr_createapi_input_smscode"
                maxLines="1"
                layout_centerVertical="true"
                inputType="0x2"
                textDirection="2"
                textAlignment="5"
                layout_toStartOf="@+id/deleteSendContainer"
                layout_marginHorizontal="@dimen/padding_12dp"/>
            <LinearLayout
                orientation="0"
                id="@+id/deleteSendContainer"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_centerVertical="true"
                layout_marginEnd="12dp"
                layout_alignParentEnd="true">
                <ImageView
                    layout_gravity="0x10"
                    id="@+id/deleteButton"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    src="@drawable/_2131230927_res_0x7f0800cf"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.14SP"
                    textColor="@color/okTradeBlue700"
                    gravity="0x11"
                    layout_gravity="0x10"
                    id="@+id/sendButton"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_login_changepwd_btn_sendcode"
                    contentDescription="sendCode"
                    layout_marginStart="16dp"/>
            </LinearLayout>
        </RelativeLayout>
        <TextView
            textAppearance="@style/TextAppearance.Red.14SP"
            id="@+id/error"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"/>
        <LinearLayout
            orientation="0"
            id="@+id/switchSmsContainer"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp">
            <TextView
                textAppearance="@style/TextAppearance.Text.14SP"
                textColor="@color/grey_g500"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_account_verification_label1_didnt_receive"/>
            <TextView
                textAppearance="@style/TextAppearance.Blue.14SP"
                id="@+id/switchSmsButton"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_account_phoneveri_linkbtn_try_another"/>
        </LinearLayout>
    </LinearLayout>
    <o.C52794wYp
        enabled="false"
        id="@+id/confirmButton"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        layout_marginBottom="@dimen/margin_20dp"
        text="@string/pr_account_fido2_btn_confirm"
        layout_marginStart="@dimen/margin_16dp"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x21="52"
        NOT_FOUND_0x22="0x101"
        NOT_FOUND_0x23="-2"/>
</LinearLayout>
