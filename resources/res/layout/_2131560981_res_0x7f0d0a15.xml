<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingTop="18dp"
    paddingRight="24dp"
    paddingBottom="18dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp"
    paddingVertical="18dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/logo"
        layout_width="20dp"
        android:layout_height="20dp"
        src="@drawable/_2131232929_res_0x7f0808a1"
        scaleType="fitEnd"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"/>
    <TextView
        textSize="14sp"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvGoToUrl"
        paddingLeft="8dp"
        paddingRight="8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        paddingHorizontal="8dp"
        NOT_FOUND_0x10="true"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="@+id/arrow"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="2"
        NOT_FOUND_0x16="@+id/logo"
        NOT_FOUND_0x18="0"
        style="@style/Label_2_Medium"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/arrow"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        scaleType="fitEnd"
        tint="@color/ContentPrimary"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x18="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
