<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        id="@+id/tv_title"
        tag="layout/layout_transfer_pay_with_coin_0"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_send_pay_with_crypto"
        layout_marginEnd="16dp"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xe="@+id/guideline"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="1"/>
    <androidx.constraintlayout.widget.Guideline
