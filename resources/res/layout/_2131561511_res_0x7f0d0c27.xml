        tag="layout/layout_transfer_pay_with_coin_4"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@color/ContentContrast"/>
