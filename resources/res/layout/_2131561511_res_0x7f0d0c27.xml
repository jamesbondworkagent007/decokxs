        id="@+id/guideline"
        tag="layout/layout_transfer_pay_with_coin_1"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xf="0.5"/>
    <ImageView
        id="@+id/iv_network"
        tag="layout/layout_transfer_pay_with_coin_2"
        layout_width="20dp"
        android:layout_height="20dp"
