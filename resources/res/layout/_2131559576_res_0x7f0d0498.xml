<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/edt_panel"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm">
        <o.C55008xbo
            id="@+id/edt_start"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            inputType="0x2002"
            NOT_FOUND_0xc="48"
            NOT_FOUND_0xd="1"
            NOT_FOUND_0xe="1"
            NOT_FOUND_0xf="2"/>
        <o.C55008xbo
            id="@+id/edt_end"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            inputType="0x2002"
            layout_marginStart="@dimen/margin_8dp"
            NOT_FOUND_0xc="48"
            NOT_FOUND_0xd="1"
            NOT_FOUND_0xe="1"
            NOT_FOUND_0xf="2"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/SemanticNegative"
        id="@+id/tv_error"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        text="@string/pr_swaptrade_market_select_error_min_max"
        style="@style/Label_3_Regular"/>
</androidx.appcompat.widget.LinearLayoutCompat>
