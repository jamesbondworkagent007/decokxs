<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="92dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/img_fav"
        paddingTop="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="@dimen/dp_32"
        android:layout_height="wrap_content"
        layout_marginTop="18dp"
        src="@drawable/_2131233467_res_0x7f080abb"
        scaleType="fitStart"
        paddingStart="0dp"
        paddingEnd="8dp"
        layout_marginStart="24dp"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@color/selector_star_content_constrast"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/img_token_icon"
        layout_width="28dp"
        android:layout_height="28dp"
        layout_marginTop="16dp"
        src="@drawable/_2131231677_res_0x7f0803bd"
        scaleType="6"
        NOT_FOUND_0x11="@+id/img_fav"
        NOT_FOUND_0x13="@+id/img_fav"
        NOT_FOUND_0x15="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/img_chain_icon"
        background="@drawable/_2131233406_res_0x7f080a7e"
        padding="0.5dp"
        layout_width="@dimen/dp_12"
        android:layout_height="@dimen/dp_12"
        src="@drawable/_2131233467_res_0x7f080abb"
        scaleType="fillCenter"
        translationX="2dp"
        translationY="2dp"
        NOT_FOUND_0x11="@+id/img_token_icon"
        NOT_FOUND_0x12="@+id/img_token_icon"/>
    <o.C42950rgA
        id="@+id/crypto_layout"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/img_token_icon"
        NOT_FOUND_0x15="@+id/img_token_icon"/>
</merge>
