<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content"
    baselineAligned="false">
    <FrameLayout
        id="@+id/fl_bottom_shared_area"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP"
        textColor="@color/ContentSecondary"
        ellipsize="3"
        id="@+id/tv_preview_tips"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        maxLines="3"
        layout_marginStart="24dp"
        layout_marginEnd="24dp"/>
    <FrameLayout
        id="@+id/fl_bottom_extra_area"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_social_share"
        paddingTop="24dp"
        paddingBottom="24dp"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="wrap_content"
        contentDescription="sharePlatformPanel"
        paddingStart="8dp"
        paddingEnd="8dp"
        nestedScrollingEnabled="false"/>
</LinearLayout>
