<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/Label_2_Regular"
        textSize="@dimen/sp_14"
        textColor="@color/color_content_static_subtle"
        id="@+id/groupTitle"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginBottom="@dimen/margin_16dp"/>
    <androidx.cardview.widget.CardView
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="@color/color_surface_structural_subBase"
        NOT_FOUND_0x1d="16dp"
        NOT_FOUND_0x1e="0dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/passkeyContainer"
            paddingLeft="16dp"
            paddingTop="16dp"
            paddingRight="16dp"
            paddingBottom="16dp"
            focusable="true"
            clickable="true"
            layout_width="-1"
            android:layout_height="wrap_content"
            minHeight="@dimen/height_72dp"
            paddingHorizontal="16dp"
            paddingVertical="16dp">
            <ImageView
                id="@+id/typeIcon"
                layout_width="@dimen/width_24dp"
                android:layout_height="@dimen/height_24dp"
                src="@drawable/_2131233634_res_0x7f080b62"
                NOT_FOUND_0x23="@+id/title"
                NOT_FOUND_0x2a="0"
                NOT_FOUND_0x2c="@+id/title"
                NOT_FOUND_0x30="@color/color_content_static_default"/>
            <TextView
                textAppearance="@style/Label_1_Medium"
                textColor="@color/color_content_static_default"
                ellipsize="3"
                id="@+id/title"
                layout_width="0dp"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginStart="@dimen/margin_12dp"
                NOT_FOUND_0x22="true"
                NOT_FOUND_0x24="@+id/statusContainer"
                NOT_FOUND_0x26="@+id/barrier"
                NOT_FOUND_0x27="0"
                NOT_FOUND_0x28="2"
                NOT_FOUND_0x29="@+id/typeIcon"
                NOT_FOUND_0x2c="0"
                NOT_FOUND_0x2d="2"
                NOT_FOUND_0x2e="1"/>
            <LinearLayout
                gravity="0x10"
                orientation="0"
                id="@+id/statusContainer"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                layout_marginEnd="@dimen/margin_8dp"
                NOT_FOUND_0x22="true"
                NOT_FOUND_0x24="@+id/desc"
                NOT_FOUND_0x26="@+id/barrier"
                NOT_FOUND_0x2a="@+id/title"
                NOT_FOUND_0x2b="@+id/title">
                <LinearLayout
                    orientation="0"
                    id="@+id/chainIconContainer"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginEnd="8dp"/>
                <TextView
                    textAppearance="@style/Label_3_Regular"
                    textColor="@color/color_content_static_subtle"
                    id="@+id/chainStatus"
                    layout_width="-2"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <TextView
                textAppearance="@style/Label_3_Regular"
                textColor="@color/color_content_static_subtler"
                gravity="0x10"
                id="@+id/desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                drawablePadding="4dp"
                layout_marginEnd="@dimen/margin_8dp"
                NOT_FOUND_0x20="@drawable/_2131233142_res_0x7f080976"
                NOT_FOUND_0x21="@color/ContentContrast"
                NOT_FOUND_0x23="0"
                NOT_FOUND_0x26="@+id/barrier"
                NOT_FOUND_0x27="0"
                NOT_FOUND_0x2a="@+id/title"
                NOT_FOUND_0x2b="@+id/statusContainer"
                NOT_FOUND_0x2f="4dp"/>
            <ImageView
                id="@+id/chainArrow"
                layout_width="@dimen/width_24dp"
                android:layout_height="@dimen/height_24dp"
                src="@drawable/_2131231647_res_0x7f08039f"
                NOT_FOUND_0x23="0"
                NOT_FOUND_0x25="0"
                NOT_FOUND_0x2c="0"
                NOT_FOUND_0x30="@color/color_content_static_subtle"/>
            <ImageView
                id="@+id/selector"
                visibility="2"
                layout_width="@dimen/width_24dp"
                android:layout_height="@dimen/height_24dp"
                src="@drawable/_2131230874_res_0x7f08009a"
                contentDescription="selector"
                NOT_FOUND_0x23="0"
                NOT_FOUND_0x25="0"
                NOT_FOUND_0x2c="0"
                NOT_FOUND_0x30="@color/color_content_static_subtle"/>
            <androidx.constraintlayout.widget.Barrier
                id="@+id/barrier"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1b="5"
                NOT_FOUND_0x1f="chainArrow,selector"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
