<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@drawable/_2131231407_res_0x7f0802af"
    paddingLeft="@dimen/xxsm"
    paddingTop="@dimen/xsm"
    paddingRight="@dimen/xxsm"
    paddingBottom="@dimen/xxsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="112dp"
    paddingHorizontal="@dimen/xxsm">
    <ImageView
        id="@+id/img_icon"
        layout_width="20dp"
        android:layout_height="20dp"
        importantForAccessibility="2"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/txt_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxsm"
        NOT_FOUND_0x12="@+id/img_icon"
        style="@style/Label_3_Regular"/>
    <ImageView
        id="@+id/img_red_dot"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="-2dp"
        src="@drawable/_2131234009_res_0x7f080cd9"
        importantForAccessibility="2"
        layout_marginEnd="-2dp"
        NOT_FOUND_0x10="@+id/img_icon"
        NOT_FOUND_0x13="@+id/img_icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
