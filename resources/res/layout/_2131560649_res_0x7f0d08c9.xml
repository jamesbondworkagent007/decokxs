<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_invest_bottomsheet_batch_claim_0"
    background="@drawable/_2131233965_res_0x7f080cad"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_16dp"
    minHeight="94dp">
    <ImageView
        id="@+id/platform_icon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginTop="31dp"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.Bold.16SP"
        textColor="@color/ContentPrimary"
        id="@+id/token_amount_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_28dp"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x1a="@+id/platform_icon"
        NOT_FOUND_0x1d="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        id="@+id/dollar_amount_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x1a="@+id/platform_icon"
        NOT_FOUND_0x1c="@+id/token_amount_text"/>
    <o.C52794wYp
        textAppearance="@style/TextAppearance.Text.12SP"
        textSize="12sp"
        ellipsize="3"
        gravity="0x11"
        id="@+id/btn_claim"
        layout_width="0dp"
        android:layout_height="28dp"
        layout_marginTop="35dp"
        maxWidth="80dp"
        minWidth="58dp"
        minHeight="52dp"
        text="@string/pr_picksforyoulist_div_btn_invest"
        maxLines="1"
        layout_marginEnd="16dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0x101"/>
    <LinearLayout
        orientation="0"
        id="@+id/desc_container"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_6dp"
        layout_marginBottom="@dimen/margin_12dp"
        NOT_FOUND_0x16="true"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/btn_claim"
        NOT_FOUND_0x19="1"
        NOT_FOUND_0x1b="@+id/platform_icon"
        NOT_FOUND_0x1c="@+id/dollar_amount_text">
        <ImageView
            id="@+id/info_icon"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131233141_res_0x7f080975"
            layout_marginEnd="@dimen/margin_2dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            id="@+id/description_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            lineHeight="16dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
