<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/container"
    tag="layout/bottom_sheet_available_balance_0"
    paddingLeft="@dimen/dp_24"
    paddingRight="@dimen/dp_24"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp_24">
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x11"
        id="@+id/title"
        paddingTop="@dimen/dp_8"
        paddingBottom="@dimen/dp_8"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/lt_unipay_magic_spend_avail_balance_bottomsheet_title_avail_balance"
        paddingVertical="@dimen/dp_8"
        NOT_FOUND_0x12="@+id/available_balance_container"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        style="@style/Label_1_Bold"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/available_balance_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_16"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/title">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/available_balance_amount"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="2"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="0"
            style="@style/Headline_3_Bold"/>
        <TextView
            textColor="@color/ContentSecondary"
            gravity="0x11"
            id="@+id/subtitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_4"
            text="@string/lt_unipay_magic_spend_avail_balance_bottomsheet_available_buy_dex"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="@+id/available_balance_amount"
            style="@style/Label_2_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/balance_details_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_24"
        layout_marginBottom="@dimen/dp_16"
        NOT_FOUND_0x12="@+id/unavailable_warning"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/available_balance_container">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/unavailable_container"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="0">
            <TextView
                textColor="@color/ContentTertiary"
                id="@+id/unavailable_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_8"
                layout_marginBottom="@dimen/dp_8"
                text="@string/lt_unipay_magic_spend_avail_balance_bottomsheet_title_unavailable"
                layout_marginVertical="@dimen/dp_8"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="0"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/unavailable_amount"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_8"
                layout_marginBottom="@dimen/dp_8"
                layout_marginVertical="@dimen/dp_8"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x17="0"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/total_balance_container"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_12"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="@+id/unavailable_container">
            <TextView
                textColor="@color/ContentTertiary"
                id="@+id/total_balance_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/lt_unipay_magic_spend_avail_balance_bottomsheet_title_total_balance"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="0"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/total_balance_amount"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x17="0"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.okinc.uilab.reminder.OKReminder
        id="@+id/unavailable_warning"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_12"
        layout_marginBottom="@dimen/dp_16"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/balance_details_container"/>
</androidx.constraintlayout.widget.ConstraintLayout>
