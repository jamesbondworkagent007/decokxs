<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/crypto_list_history_layout"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="@dimen/dp_8"
        NOT_FOUND_0x15="com.okinc.buysell.ui.bsc.cryptolist.BuySellSearchHistoryBehavior">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/crypto_list_history_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_12"
            layout_marginBottom="@dimen/dp_12"
            text="@string/lt_unipay_buy_selectcrypto_title_recent"
            layout_marginStart="@dimen/dp_24"
            layout_marginVertical="@dimen/dp_12"
            NOT_FOUND_0x17="@+id/history_list"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"
            style="@style/Label_1_Bold"/>
        <o.wYC
            id="@+id/iv_delete_history"
            layout_width="@dimen/dp_16"
            android:layout_height="@dimen/dp_16"
            src="@drawable/_2131234234_res_0x7f080dba"
            contentDescription="@null"
            layout_marginEnd="@dimen/dp_12"
            NOT_FOUND_0x16="@+id/crypto_list_history_title"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1b="@+id/crypto_list_history_title"/>
        <androidx.recyclerview.widget.RecyclerView
            orientation="0"
            id="@+id/history_list"
            paddingLeft="@dimen/cr_page_spacing_horizontal"
            paddingRight="@dimen/cr_page_spacing_horizontal"
            clipToPadding="false"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_8"
            paddingHorizontal="@dimen/cr_page_spacing_horizontal"
            NOT_FOUND_0x17="@+id/crypto_list_popular_title"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="@+id/crypto_list_history_title"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/crypto_list_popular_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/dp_24"
            layout_marginTop="@dimen/dp_12"
            layout_marginRight="@dimen/dp_24"
            layout_marginBottom="@dimen/dp_12"
            text="@string/lt_unipay_buy_selectcrypto_title_crypto"
            layout_marginHorizontal="@dimen/dp_24"
            layout_marginVertical="@dimen/dp_12"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="@+id/history_list"
            style="@style/Title_2_Bold"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/crypto_list_popular_list"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="com.okinc.buysell.ui.bsc.cryptolist.BuySellCryptoListBehavior"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/result_list"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
