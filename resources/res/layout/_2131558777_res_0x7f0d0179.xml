<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131230869_res_0x7f080095"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginTop="60dp">
    <FrameLayout
        paddingLeft="@dimen/common_page_edge_space"
        paddingRight="@dimen/common_page_edge_space"
        layout_width="-1"
        android:layout_height="48dp"
        paddingHorizontal="@dimen/common_page_edge_space">
        <o.wYC
            layout_gravity="0x800015"
            id="@+id/closeButton"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231675_res_0x7f0803bb"
            tint="@color/ContentContrast"/>
    </FrameLayout>
    <ScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_authlogin_passkey_bttmsheet_header_another_device"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Headline_4_Bold"/>
            <TextView
                textColor="@color/ContentTertiary"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                text="@string/pr_authlogin_passkey_bttmsheet_desc_another_device"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Label_1_Regular"/>
            <LinearLayout
                orientation="1"
                id="@+id/deviceList"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="32dp"
                divider="@drawable/_2131230873_res_0x7f080099"
                showDividers="middle"
                paddingHorizontal="@dimen/common_page_edge_space"/>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        orientation="1"
        paddingLeft="@dimen/common_page_edge_space"
        paddingTop="16dp"
        paddingRight="@dimen/common_page_edge_space"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/common_page_edge_space"
        paddingVertical="16dp">
        <o.C52794wYp
            id="@+id/continueButton"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_authlogin_passkey_bttmsheet_btn_continue"
            NOT_FOUND_0x15="52"
            NOT_FOUND_0x16="0x101"/>
        <o.C52794wYp
            id="@+id/cantFindRequestButton"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            text="@string/pr_authlogin_passkey_bttmsheet_btn_cant_find"
            NOT_FOUND_0x15="52"
            NOT_FOUND_0x16="0x102"/>
    </LinearLayout>
</LinearLayout>
