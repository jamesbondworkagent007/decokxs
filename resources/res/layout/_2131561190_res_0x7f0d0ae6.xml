<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x10"
        layout_gravity="0x1"
        layout_width="-2"
        android:layout_height="wrap_content">
        <TextView
            textAppearance="@style/TextAppearance.Text.Regular"
            textSize="@dimen/dp_10"
            textColor="@color/ContentContrast"
            layout_gravity="0x1"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="TVL"/>
        <ImageView
            id="@+id/arrow"
            visibility="2"
            layout_width="@dimen/dp_10"
            android:layout_height="@dimen/dp_10"
            src="@drawable/_2131233803_res_0x7f080c0b"
            layout_marginStart="4dp"
            backgroundTint="@color/ContentContrast"/>
    </LinearLayout>
    <TextView
        textAppearance="@style/TextAppearance.Text.Bold"
        textSize="@dimen/font_18"
        textColor="@color/ContentSecondary"
        layout_gravity="0x1"
        id="@+id/value"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        text="60.53K"/>
    <LinearLayout
        layout_gravity="0x1"
        orientation="0"
        id="@+id/scoreLayout"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8">
        <TextView
            textAppearance="@style/TextAppearance.Text.Bold"
            textSize="@dimen/font_18"
            textColor="@color/ContentPrimary"
            id="@+id/score"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="94"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.Regular"
            textSize="@dimen/font_12"
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="/100"
            layout_marginStart="@dimen/dp_4"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        layout_gravity="0x1"
        orientation="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8">
        <ImageView
            id="@+id/risk_icon"
            visibility="2"
            layout_width="@dimen/ok_dp_12"
            android:layout_height="@dimen/ok_dp_12"
            layout_marginEnd="@dimen/height_2dp"/>
        <TextView
            textSize="@dimen/font_12"
            gravity="0x11"
            layout_gravity="0x1"
            id="@+id/changeRate"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="50%"/>
    </LinearLayout>
</LinearLayout>
