<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/xxxsm"
    paddingBottom="@dimen/xxxsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/xxxsm"
    paddingVertical="@dimen/xxxsm">
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/tv_count"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_invest_smartmoney_bttmsheet_unit_alert_num"
        NOT_FOUND_0xf="@+id/tv_time"
        NOT_FOUND_0x10="1"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        style="@style/Label_2_Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800005"
        id="@+id/tv_time"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/xxxsm"
        layout_marginRight="@dimen/xxxsm"
        text="@string/pr_commonall_text_title_time"
        layout_marginHorizontal="@dimen/xxxsm"
        NOT_FOUND_0xd="@+id/tv_count"
        NOT_FOUND_0xf="@+id/tv_price"
        NOT_FOUND_0x10="2"
        NOT_FOUND_0x11="@+id/tv_count"
        NOT_FOUND_0x13="@+id/tv_count"
        style="@style/Label_2_Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800005"
        id="@+id/tv_price"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_commonall_modal_title_price"
        NOT_FOUND_0xd="@+id/tv_count"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="2"
        NOT_FOUND_0x11="@+id/tv_time"
        NOT_FOUND_0x13="@+id/tv_count"
        style="@style/Label_2_Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
