<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/buttonPanel"
    layout_width="-1"
    android:layout_height="wrap_content"
    fillViewport="true"
    scrollIndicators="0x3"
    style="?attr/buttonBarStyle">
    <androidx.appcompat.widget.ButtonBarLayout
        gravity="0x50"
        orientation="0"
        paddingLeft="?attr/dialogPreferredPadding"
        paddingTop="@dimen/m3_alert_dialog_action_top_padding"
        paddingRight="?attr/dialogPreferredPadding"
        paddingBottom="@dimen/m3_alert_dialog_action_bottom_padding"
        layout_width="-1"
        android:layout_height="wrap_content"
        layoutDirection="3">
        <Button
            id="@android:id/button3"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="?attr/buttonBarNeutralButtonStyle"/>
        <android.widget.Space
            id="@+id/spacer"
            visibility="?attr/materialAlertDialogButtonSpacerVisibility"
            layout_width="0dp"
            android:layout_height="0dp"
            layout_weight="1"/>
        <Button
            id="@android:id/button2"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="?attr/buttonBarNegativeButtonStyle"/>
        <Button
            id="@android:id/button1"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="?attr/buttonBarPositiveButtonStyle"/>
    </androidx.appcompat.widget.ButtonBarLayout>
</ScrollView>
