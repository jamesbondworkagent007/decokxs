<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="@+id/barrier"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="120dp"
        style="@style/Label_1_Medium"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/barrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x10="5"
        NOT_FOUND_0x11="ll_single_network,ll_double_network"/>
    <LinearLayout
        gravity="0x800015"
        orientation="0"
        id="@+id/ll_single_network"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="16dp"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/tv_title"
        NOT_FOUND_0x19="0">
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_network_name"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginEnd="6dp"
            style="@style/Label_1_Regular"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_network_icon"
            layout_width="24dp"
            android:layout_height="24dp"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_arrow_single"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131231651_res_0x7f0803a3"
            NOT_FOUND_0x1b="@color/ContentContrast"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x800015"
        orientation="0"
        id="@+id/ll_double_network"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="16dp"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/tv_title"
        NOT_FOUND_0x19="0">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_source_network"
            layout_width="20dp"
            android:layout_height="20dp"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_arrow_middle"
            layout_width="12dp"
            android:layout_height="12dp"
            layout_marginLeft="6dp"
            layout_marginRight="6dp"
            src="@drawable/_2131233694_res_0x7f080b9e"
            layout_marginHorizontal="6dp"
            NOT_FOUND_0x1b="@color/ContentContrast"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_target_network"
            layout_width="20dp"
            android:layout_height="20dp"/>
    </LinearLayout>
</merge>
