<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/contentPanel"
        clipToPadding="false"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <ImageView
            id="@+id/icon"
            visibility="2"
            layout_width="@dimen/width_24dp"
            android:layout_height="@dimen/height_24dp"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0"/>
        <LinearLayout
            gravity="0x10"
            id="@+id/labelPanel"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/margin_12dp"
            NOT_FOUND_0x10="@+id/description"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="@+id/icon"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0dp">
            <TextView
                textAppearance="@style/OKTextFont.Regular"
                textSize="16sp"
                textColor="@color/cell_title_color"
                ellipsize="3"
                id="@+id/label"
                layout_width="-2"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView
            textAppearance="@style/OKTextFont.Regular"
            textSize="@dimen/sp_14"
            textColor="@color/cell_description_color"
            ellipsize="3"
            id="@+id/description"
            visibility="2"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            textAlignment="5"
            layout_marginStart="@dimen/margin_12dp"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x11="0"
            NOT_FOUND_0x12="@+id/icon"
            NOT_FOUND_0x14="@+id/labelPanel"
            NOT_FOUND_0x16="0dp"
            NOT_FOUND_0x17="0dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
