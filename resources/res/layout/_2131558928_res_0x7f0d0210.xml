<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/status_icon"
        background="@drawable/_2131233818_res_0x7f080c1a"
        padding="@dimen/padding_8dp"
        layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        src="@drawable/_2131231633_res_0x7f080391"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/status"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/lt_unipay_depositwithdraw_details_label_status"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0xc="@+id/status_icon"
        NOT_FOUND_0xe="@+id/status_value"
        NOT_FOUND_0xf="@+id/status_icon"
        NOT_FOUND_0x12="@+id/status_icon"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentTertiary"
        gravity="0x800005"
        id="@+id/status_value"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="Completed"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0xc="@+id/status_icon"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="@+id/status"
        NOT_FOUND_0x12="@+id/status_icon"
        style="@style/Label_1_Regular"/>
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x800005"
        id="@+id/status_desc"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        text="Your assets have been added to your account."
        layout_marginStart="@dimen/margin_24dp"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="@+id/status"
        NOT_FOUND_0x11="@+id/status_icon"
        style="@style/Label_2_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
