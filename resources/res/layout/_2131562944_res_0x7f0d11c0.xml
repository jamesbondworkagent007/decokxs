<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/xxxsm"
    layout_marginBottom="@dimen/xxxsm"
    layout_marginVertical="@dimen/xxxsm">
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/token_logo"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@style/CircleStyle"/>
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/network_logo"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginTop="22dp"
        layout_marginStart="20dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@style/CircleStyle"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/container_token_info"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginStart="12dp"
        NOT_FOUND_0xe="true"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="@+id/network_logo"
        NOT_FOUND_0x17="0">
        <androidx.legacy.widget.Space
            id="@+id/space_center"
            layout_width="@dimen/margin_1dp"
            android:layout_height="@dimen/margin_1dp"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="0"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_token_name"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0xe="true"
            NOT_FOUND_0x11="@+id/tv_price"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="2"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x17="0"
            style="@style/Label_2_Medium"/>
        <ImageView
            id="@+id/riskyIcon"
            visibility="2"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/width_16dp"
            src="@drawable/_2131234330_res_0x7f080e1a"
            layout_marginStart="@dimen/margin_12dp"
            NOT_FOUND_0xf="@+id/tv_token_name"
            NOT_FOUND_0x14="@+id/tv_token_name"
            NOT_FOUND_0x17="@+id/tv_token_name"
            NOT_FOUND_0x19="@color/SemanticNegative"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_time"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            maxLines="1"
            NOT_FOUND_0xe="true"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x11="@+id/space_center"
            NOT_FOUND_0x15="@+id/tv_token_name"
            NOT_FOUND_0x16="@+id/tv_token_name"
            style="@style/Label_3_Medium"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            layout_gravity="0x800005"
            id="@+id/tv_price"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="@dimen/xxxsm"
            NOT_FOUND_0xe="true"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x12="1"
            NOT_FOUND_0x14="@+id/space_center"
            NOT_FOUND_0x17="0"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800005"
            layout_gravity="0x800005"
            id="@+id/tv_price_change"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            maxLines="1"
            layout_marginStart="@dimen/xxxsm"
            NOT_FOUND_0xe="true"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x12="1"
            NOT_FOUND_0x14="@+id/space_center"
            NOT_FOUND_0x16="@+id/tv_price"
            style="@style/Label_2_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
