<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingTop="4dp"
    paddingBottom="4dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="4dp">
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/tv_slippage_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_invest_placeorder_slippage_tooltip_title_slippage"
        style="@style/Label_1_Bold"/>
    <TextView
        textColor="@color/ContentSecondary"
        gravity="0x800003"
        id="@+id/tv_slippage_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        text="@string/pr_invest_placeorder_slippage_tooltip_desc_slippage"
        style="@style/Body_3_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/tv_dynamic_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xsm"
        text="@string/pr_invest_placeorder_slippage_tooltip_title_dynamic"
        style="@style/Label_1_Bold"/>
    <TextView
        textColor="@color/ContentSecondary"
        gravity="0x800003"
        id="@+id/tv_dynamic_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        text="@string/pr_invest_placeorder_slippage_tooltip_desc_dynamic"
        style="@style/Body_3_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/tv_fixed_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xsm"
        text="@string/pr_invest_placeorder_slippage_tooltip_title_fixed"
        style="@style/Label_1_Bold"/>
    <TextView
        textColor="@color/ContentSecondary"
        gravity="0x800003"
        id="@+id/tv_fixed_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"
        text="@string/pr_invest_placeorder_slippage_tooltip_desc_fixed"
        style="@style/Body_3_Regular"/>
</LinearLayout>
