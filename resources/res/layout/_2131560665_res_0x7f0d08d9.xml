<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    paddingTop="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="16dp"
    paddingEnd="16dp">
    <ImageView
        id="@+id/token_icon"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.Medium"
        textSize="18sp"
        textColor="@color/text_amplified"
        id="@+id/token_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        includeFontPadding="false"
        layout_marginStart="8dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/token_amount"
        NOT_FOUND_0x15="1"
        NOT_FOUND_0x16="@+id/token_icon"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="-4"
        NOT_FOUND_0x1a="-2"
        NOT_FOUND_0x1b="21.1dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.Medium"
        textSize="18sp"
        textColor="@color/text_amplified"
        ellipsize="3"
        gravity="0x800015"
        id="@+id/token_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        includeFontPadding="false"
        layout_marginStart="8dp"
        NOT_FOUND_0xf="18sp"
        NOT_FOUND_0x10="12sp"
        NOT_FOUND_0x11="1"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="@+id/token_name"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1b="21.1dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
