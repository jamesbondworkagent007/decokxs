<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_16dp"
    layout_marginBottom="@dimen/margin_16dp"
    layout_marginVertical="@dimen/margin_16dp">
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideStart"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x18="0.4"/>
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideEnd"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x18="0.7"/>
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/ivTokenLogo"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@style/CircleStyle"/>
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/ivNetworkLogo"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginTop="20dp"
        layout_marginStart="18dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="@style/CircleStyle"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800013"
        id="@+id/tvTokenName"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x10="@dimen/text_size_16sp"
        NOT_FOUND_0x11="7sp"
        NOT_FOUND_0x12="2sp"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x19="2"
        NOT_FOUND_0x1a="@+id/ivTokenLogo"
        NOT_FOUND_0x1d="0"
        style="@style/Label_1_Medium"/>
    <ImageView
        layout_gravity="0x10"
        id="@+id/riskyIcon"
        visibility="2"
        layout_width="@dimen/width_16dp"
        android:layout_height="@dimen/width_16dp"
        src="@drawable/_2131234330_res_0x7f080e1a"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x1a="@+id/tvTokenName"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="@color/SemanticNegative"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvPrice"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        NOT_FOUND_0x10="@dimen/text_size_12sp"
        NOT_FOUND_0x11="6sp"
        NOT_FOUND_0x12="1sp"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x17="@+id/guideStart"
        NOT_FOUND_0x1b="@+id/tvTokenName"
        NOT_FOUND_0x1c="@+id/tvTokenName"
        style="@style/Label_3_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800015"
        layout_gravity="0x800005"
        id="@+id/tvType"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0x10="@dimen/text_size_16sp"
        NOT_FOUND_0x11="7sp"
        NOT_FOUND_0x12="1sp"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="@+id/guideEnd"
        NOT_FOUND_0x1d="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        gravity="0x800005"
        layout_gravity="0x800005"
        id="@+id/tvTime"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        NOT_FOUND_0x10="@dimen/text_size_12sp"
        NOT_FOUND_0x11="7sp"
        NOT_FOUND_0x12="1sp"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="@+id/guideEnd"
        NOT_FOUND_0x1c="@+id/tvType"
        style="@style/Label_3_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800015"
        layout_gravity="0x800005"
        id="@+id/tvTotal"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0x10="@dimen/text_size_16sp"
        NOT_FOUND_0x11="7sp"
        NOT_FOUND_0x12="1sp"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x17="@+id/guideEnd"
        NOT_FOUND_0x1a="@+id/guideStart"
        NOT_FOUND_0x1d="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        gravity="0x800015"
        layout_gravity="0x800005"
        id="@+id/tvAmount"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        NOT_FOUND_0x10="@dimen/text_size_12sp"
        NOT_FOUND_0x11="7sp"
        NOT_FOUND_0x12="1sp"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x17="@+id/guideEnd"
        NOT_FOUND_0x1a="@+id/guideStart"
        NOT_FOUND_0x1c="@+id/tvTotal"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
