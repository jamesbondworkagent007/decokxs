<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    padding="@dimen/ok_dp_16"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guide1"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="0.6"/>
    <TextView
        textColor="@color/okTradeG900"
        id="@+id/botTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginEnd="4dp"
        NOT_FOUND_0x15="@+id/guide1"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        style="@style/LiteTextAppearance.Black.16SP.Medium"/>
    <o.C55251xgS
        id="@+id/botType"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="-5"
        NOT_FOUND_0x1d="6"/>
    <o.C55251xgS
        id="@+id/tvDirection"
        visibility="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="-5"
        NOT_FOUND_0x1d="14"/>
    <o.C55251xgS
        id="@+id/tvLever"
        visibility="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="-5"
        NOT_FOUND_0x1d="14"/>
    <androidx.constraintlayout.helper.widget.Flow
        id="@+id/botTagFlow"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        layout_marginEnd="4dp"
        NOT_FOUND_0xc="botType,tvDirection,tvLever"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@dimen/padding_4dp"
        NOT_FOUND_0xf="2"
        NOT_FOUND_0x10="@dimen/padding_4dp"
        NOT_FOUND_0x11="1"
        NOT_FOUND_0x15="@+id/guide1"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/botTitle"/>
    <TextView
        textColor="@color/grey_g900"
        gravity="0x800005"
        id="@+id/pnlValue"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/dp_8"
        NOT_FOUND_0x13="@+id/copyCount"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x17="@+id/guide1"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="2"
        style="@style/TextAppearance.Title.Medium.16SP"/>
    <TextView
        textAppearance="@style/Body_4"
        textSize="12sp"
        textColor="@color/grey_g400"
        id="@+id/copyCount"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/pnlValue"
        NOT_FOUND_0x19="@+id/pnlValue"/>
</androidx.constraintlayout.widget.ConstraintLayout>
