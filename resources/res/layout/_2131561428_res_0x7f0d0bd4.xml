<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_pay_wallet_coin_0"
    background="@drawable/_2131234055_res_0x7f080d07"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            orientation="1"
            id="@+id/title_layout"
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0">
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="44dp"
                paddingEnd="@dimen/ok_dp_16">
                <o.wYC
                    id="@+id/iv_close"
                    layout_width="-2"
                    android:layout_height="44dp"
                    src="@drawable/_2131232369_res_0x7f080671"
                    scaleType="fitEnd"
                    paddingStart="15dp"
                    NOT_FOUND_0x1f="?attr/st_color_g900"/>
                <TextView
                    textSize="16sp"
                    textColor="?attr/st_color_g900"
                    gravity="0x800013"
                    id="@+id/tv_title"
                    layout_width="0dp"
                    android:layout_height="match_parent"
                    text="@string/pr_nft_title_choose_wallet"
                    layout_weight="1"
                    fontFamily="@font/harmony_sans_bold"
                    paddingStart="6dp"/>
            </LinearLayout>
            <View
                id="@+id/divider"
                background="?attr/st_color_g100"
                layout_width="-1"
                android:layout_height="0.5dp"/>
        </LinearLayout>
        <TextView
            textSize="@dimen/text_size_12sp"
            textColor="?attr/st_color_g500"
            id="@+id/tv_des"
            background="@drawable/_2131234083_res_0x7f080d23"
            padding="12dp"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="24dp"
            text="@string/pr_nft_chain_balance_hint"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/title_layout"/>
        <ImageView
            id="@+id/wallet_img"
            layout_width="40dp"
            android:layout_height="40dp"
            layout_marginTop="16dp"
            layout_marginStart="16dp"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/tv_des"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP.Medium"
            textSize="@dimen/text_size_16sp"
            textColor="?attr/st_color_g900"
            ellipsize="3"
            id="@+id/tv_wallet_name"
            layout_width="0dp"
            android:layout_height="wrap_content"
            lines="1"
            layout_marginStart="12dp"
            layout_marginEnd="16dp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="@+id/wallet_img"
            NOT_FOUND_0x1e="@+id/wallet_img"/>
        <TextView
            textSize="@dimen/text_size_14sp"
            textColor="?attr/st_color_g500"
            id="@+id/tv_address"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x19="@+id/wallet_img"
            NOT_FOUND_0x1a="@+id/tv_wallet_name"
            NOT_FOUND_0x1c="@+id/tv_wallet_name"/>
        <TextView
            textSize="32sp"
            textStyle="0x1"
            textColor="?attr/st_color_g900"
            id="@+id/tv_account"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="18dp"
            layout_marginEnd="16dp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="@+id/wallet_img"
            NOT_FOUND_0x1d="@+id/wallet_img"/>
        <View
            id="@+id/line"
            background="?attr/st_color_g100"
            layout_width="-1"
            android:layout_height="0.5dp"
            layout_marginTop="34dp"
            NOT_FOUND_0x1d="@+id/tv_account"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/recy"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginTop="24dp"
            layout_marginBottom="20dp"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1d="@+id/line"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
