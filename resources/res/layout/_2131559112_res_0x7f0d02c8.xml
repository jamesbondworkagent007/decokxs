<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/ll_root_layout"
    layout_width="-1"
    android:layout_height="match_parent">
    <FrameLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <com.google.android.material.imageview.ShapeableImageView
            id="@+id/iv_guide_feature_introduce"
            layout_width="-1"
            android:layout_height="220dp"
            scaleType="6"
            NOT_FOUND_0x12="@style/RoundStyle"/>
        <ImageView
            layout_gravity="0x800005"
            id="@+id/iv_close"
            padding="@dimen/ok_dp_12"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232489_res_0x7f0806e9"
            NOT_FOUND_0x13="@color/grey_g400"/>
    </FrameLayout>
    <ScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textSize="32sp"
                textColor="@color/okTradeG900"
                id="@+id/title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="28dp"
                text="@string/pr_swaptrade_xrouting_single_chain_routes"
                fontFamily="@font/harmony_sans_bold"
                layout_marginStart="24dp"
                layout_marginEnd="24dp"/>
            <TextView
                textSize="16sp"
                textColor="@color/okTradeG900"
                id="@+id/depth_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="30dp"
                text="@string/pr_wallet_swap_notif_subtitle_depth"
                fontFamily="@font/harmony_sans_bold"
                layout_marginStart="24dp"
                layout_marginEnd="24dp"/>
            <TextView
                textSize="14sp"
                textColor="@color/grey_g500"
                gravity="0x800003"
                id="@+id/depth_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="@string/pr_wallet_swap_notif_smartrouter_howdepth"
                fontFamily="@font/harmony_sans_regular"
                layout_marginStart="24dp"
                layout_marginEnd="24dp"/>
            <TextView
                textSize="16sp"
                textColor="@color/okTradeG900"
                id="@+id/slip_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="20dp"
                text="@string/pr_wallet_swap_notif_subtitle_slippage"
                fontFamily="@font/harmony_sans_bold"
                layout_marginStart="24dp"
                layout_marginEnd="24dp"/>
            <TextView
                textSize="14sp"
                textColor="@color/grey_g500"
                gravity="0x800003"
                id="@+id/slip_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="@string/pr_wallet_swap_notif_smartrouter_howslippage"
                fontFamily="@font/harmony_sans_regular"
                layout_marginStart="24dp"
                layout_marginEnd="24dp"/>
            <TextView
                textSize="16sp"
                textColor="@color/okTradeG900"
                id="@+id/quote_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="20dp"
                text="@string/pr_wallet_swap_notif_subtitle_quotes"
                fontFamily="@font/harmony_sans_bold"
                layout_marginStart="24dp"
                layout_marginEnd="24dp"/>
            <TextView
                textSize="14sp"
                textColor="@color/grey_g500"
                gravity="0x800003"
                id="@+id/quote_desc"
                paddingBottom="28dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="@string/pr_wallet_swap_notif_smartrouter_howquotes"
                fontFamily="@font/harmony_sans_regular"
                layout_marginStart="24dp"
                layout_marginEnd="24dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
