<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_24dp"
    paddingRight="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp">
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/iv_head"
        layout_width="80dp"
        android:layout_height="80dp"
        layout_marginTop="32dp"
        src="@drawable/_2131231753_res_0x7f080409"
        scaleType="6"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0"/>
    <TextView
        textAppearance="@style/Title_2_Bold"
        gravity="0x11"
        id="@+id/tv_wallet_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginBottom="32dp"
        NOT_FOUND_0x18="true"
        NOT_FOUND_0x1a="@+id/ll_tee_status"
        NOT_FOUND_0x1c="@+id/iv_edit_name"
        NOT_FOUND_0x1d="2"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="@+id/iv_head"/>
    <ImageView
        id="@+id/iv_edit_name"
        layout_width="24dp"
        android:layout_height="24dp"
        src="@drawable/_2131232074_res_0x7f08054a"
        layout_marginStart="8dp"
        NOT_FOUND_0x19="@+id/tv_wallet_name"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1e="@+id/tv_wallet_name"
        NOT_FOUND_0x21="@+id/tv_wallet_name"
        NOT_FOUND_0x22="@color/ContentPrimary"/>
    <LinearLayout
        gravity="0x10"
        id="@+id/ll_tee_status"
        background="@drawable/_2131231223_res_0x7f0801f7"
        padding="16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="5dp"
        layout_marginBottom="24dp"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x20="@+id/tv_wallet_name">
        <ImageView
            id="@+id/iv_tee_status"
            padding="4dp"
            layout_width="26dp"
            android:layout_height="26dp"
            src="@drawable/_2131231512_res_0x7f080318"
            NOT_FOUND_0x19="@+id/ivAddressCopy"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x21="@+id/ivAddressCopy"/>
        <TextView
            textAppearance="@style/Label_2_Medium"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_account_details_type_smart_account"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="12dp"/>
        <TextView
            textAppearance="@style/Label_2_Medium"
            id="@+id/tv_tee_status"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="4dp"
            layout_marginRight="4dp"
            layout_marginHorizontal="4dp"/>
        <ImageView
            layout_width="18dp"
            android:layout_height="18dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0x22="@color/ContentContrast"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
