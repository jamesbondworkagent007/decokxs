<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_invest_subscription_process_invest_item_0"
    paddingTop="@dimen/xxxsm"
    paddingBottom="@dimen/xxxsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/xxxsm">
    <ImageView
        id="@+id/invest_with_img"
        layout_width="@dimen/width_32dp"
        android:layout_height="@dimen/width_32dp"
        scaleType="fitStart"
        adjustViewBounds="true"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1e="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800013"
        id="@+id/invest_with_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        includeFontPadding="false"
        textAlignment="5"
        layout_marginStart="@dimen/margin_8dp"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x14="20sp"
        NOT_FOUND_0x15="2sp"
        NOT_FOUND_0x16="2sp"
        NOT_FOUND_0x17="1"
        NOT_FOUND_0x18="@+id/invest_with_img"
        NOT_FOUND_0x1a="@+id/invest_with_input_amount"
        NOT_FOUND_0x1b="@+id/invest_with_img"
        NOT_FOUND_0x1e="@+id/invest_with_img"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/invest_with_input_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="@dimen/width_200dp"
        maxLines="1"
        includeFontPadding="false"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1e="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/invest_with_input_currency"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_2dp"
        includeFontPadding="false"
        drawablePadding="@dimen/padding_2dp"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="@+id/invest_with_input_amount"
        style="@style/Body_4_Regular_Invest"/>
</androidx.constraintlayout.widget.ConstraintLayout>
