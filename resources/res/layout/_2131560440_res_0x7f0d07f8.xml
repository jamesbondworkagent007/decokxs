<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/xsm"
    paddingBottom="@dimen/xxxxsm"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_label"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_invest_wallet_defi_label_total_investment"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        style="@style/Label_2_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_total_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxxsm"
        maxLines="1"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x11="@+id/llSubPnl"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="2"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/tv_label"
        style="@style/Title_1_Bold"/>
    <LinearLayout
        orientation="0"
        id="@+id/llSubPnl"
        layout_width="@dimen/width_0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xsm"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/tv_total_amount">
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginEnd="@dimen/xxxsm">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_invest_wallet_defi_label_yesterdays_earnings"
                style="@style/Label_2_Regular"/>
            <TextView
                id="@+id/tvYesterdayEarn"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxxsm"
                style="@style/Label_2_Regular"/>
        </LinearLayout>
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/xxxsm">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_invest_wallet_defi_label_lifetime_earnings"
                style="@style/Label_2_Regular"/>
            <TextView
                id="@+id/tvLifetimeEarn"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxxsm"
                style="@style/Label_2_Regular"/>
        </LinearLayout>
    </LinearLayout>
    <View
        id="@+id/divider"
        background="@color/BorderPrimary"
        layout_width="0dp"
        android:layout_height="0.5dp"
        layout_marginTop="@dimen/xsm"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/llSubPnl"/>
</androidx.constraintlayout.widget.ConstraintLayout>
