<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/customAddressParent"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8"
        layout_marginBottom="@dimen/dp_8"
        layout_marginStart="64dp"
        layout_marginEnd="20dp"
        layout_marginVertical="@dimen/dp_8"
        NOT_FOUND_0x17="true"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="@+id/right_barrier"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="0">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="0">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0">
                <TextView
                    textColor="@color/grey_g900"
                    ellipsize="3"
                    id="@+id/customAddressCoinName"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    layout_weight="1"
                    style="@style/TextAppearance.Title.16SP.Medium"/>
                <o.C55251xgS
                    id="@+id/customAddressCoinTag"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/margin_4dp"
                    NOT_FOUND_0x1f="1"
                    NOT_FOUND_0x20="-4"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            textSize="12sp"
            textColor="@color/grey_g400"
            id="@+id/customAddressCoinAddress"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            style="@style/Label_3_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/right_barrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="5"
        NOT_FOUND_0x16="customAddressCopy,customAddressActivate"/>
    <ImageView
        id="@+id/customAddressCopy"
        layout_width="20dp"
        android:layout_height="20dp"
        src="@drawable/_2131234345_res_0x7f080e29"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x21="@color/ContentPrimary"/>
    <o.C52794wYp
        id="@+id/customAddressActivate"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        text="@string/pr_wallet_popup_textbtn_activate"
        layout_marginHorizontal="16dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="24"
        NOT_FOUND_0x1e="0x104"/>
</merge>
