<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131231797_res_0x7f080435"
    padding="16dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_card_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_overview_bottom_header_defi"
            maxLines="1"
            layout_weight="1"
            style="@style/Label_1_Bold"/>
        <ImageView
            id="@+id/iv_chevron"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231647_res_0x7f08039f"/>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_details"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_16dp">
        <ImageView
            id="@+id/iv_token_logo"
            layout_width="32dp"
            android:layout_height="32dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"/>
        <ImageView
            id="@+id/iv_defi_logo"
            layout_width="16dp"
            android:layout_height="16dp"
            layout_marginBottom="-4dp"
            layout_marginEnd="-4dp"
            NOT_FOUND_0x12="@+id/iv_token_logo"
            NOT_FOUND_0x14="@+id/iv_token_logo"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_token_name"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/dp_4"
            maxLines="1"
            layout_marginStart="12dp"
            NOT_FOUND_0x13="@+id/tv_defi_platform"
            NOT_FOUND_0x15="@+id/tv_apy"
            NOT_FOUND_0x16="1"
            NOT_FOUND_0x17="@+id/iv_defi_logo"
            NOT_FOUND_0x19="@+id/iv_token_logo"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_apy"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginBottom="4dp"
            maxLines="1"
            layout_marginStart="12dp"
            NOT_FOUND_0x13="@+id/tv_defi_volume"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x17="@+id/tv_token_name"
            NOT_FOUND_0x19="@+id/iv_token_logo"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_defi_platform"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            maxLines="1"
            layout_marginStart="12dp"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x15="@+id/iv_defi_chain"
            NOT_FOUND_0x16="1"
            NOT_FOUND_0x17="@+id/iv_defi_logo"
            NOT_FOUND_0x1a="0dp"
            style="@style/Body_4"/>
        <ImageView
            id="@+id/iv_defi_chain"
            layout_width="14dp"
            android:layout_height="14dp"
            layout_marginStart="12dp"
            layout_marginEnd="4dp"
            NOT_FOUND_0x12="@+id/tv_defi_volume"
            NOT_FOUND_0x15="@+id/tv_defi_volume"
            NOT_FOUND_0x17="@+id/tv_defi_platform"
            NOT_FOUND_0x19="@+id/tv_defi_volume"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_defi_volume"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0x11="@color/ContentContrast"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x17="@+id/iv_defi_chain"
            NOT_FOUND_0x1a="0dp"
            style="@style/Body_4"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
