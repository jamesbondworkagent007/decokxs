<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/content"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        id="@+id/scrollview"
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            gravity="0x1"
            orientation="1"
            layout_width="-1"
            android:layout_height="match_parent">
            <ImageView
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_24dp"
                layout_marginBottom="@dimen/margin_24dp"
                src="@drawable/_2131232319_res_0x7f08063f"
                layout_marginVertical="@dimen/margin_24dp"/>
            <TextView
                textAppearance="@style/Headline_5_Bold"
                textColor="@color/grey_g900"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="28dp"
                layout_marginRight="@dimen/margin_24dp"
                text="@string/pr_metax_network_maintitle_welcome_custom"
                layout_marginHorizontal="@dimen/margin_24dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="40dp"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginBottom="@dimen/margin_40dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <TextView
                    textAppearance="@style/Label_1_Bold"
                    textColor="@color/grey_g900"
                    id="@+id/tv_num1_title"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_metax_network_title_add_evm"
                    NOT_FOUND_0x10="0"
                    NOT_FOUND_0x11="0"
                    NOT_FOUND_0x13="0"/>
                <TextView
                    textAppearance="@style/Label_2_Regular"
                    textColor="@color/grey_g500"
                    id="@+id/tv_num1_subtitle"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_4dp"
                    text="@string/pr_metax_network_subtitle_add_evm"
                    NOT_FOUND_0x10="0"
                    NOT_FOUND_0x11="@+id/tv_num1_title"
                    NOT_FOUND_0x12="@+id/tv_num1_title"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginBottom="@dimen/margin_20dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <TextView
                    textAppearance="@style/Label_1_Bold"
                    textColor="@color/grey_g900"
                    id="@+id/tv_num3_title"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_metax_network_title_manage_assets_onevm"
                    NOT_FOUND_0x10="0"
                    NOT_FOUND_0x11="0"
                    NOT_FOUND_0x13="0"/>
                <TextView
                    textAppearance="@style/Label_2_Regular"
                    textColor="@color/grey_g500"
                    id="@+id/tv_num3_subtitle"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_4dp"
                    text="@string/pr_metax_network_subtitle_manage_assets_onevm"
                    NOT_FOUND_0x10="0"
                    NOT_FOUND_0x11="@+id/tv_num3_title"
                    NOT_FOUND_0x12="@+id/tv_num3_title"/>
                <TextView
                    textAppearance="@style/Label_2_Regular"
                    textColor="@color/grey_g500"
                    id="@+id/tv_bottom_subtitle"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_24dp"
                    text="@string/pr_metax_network_notif_custom_network_tokens"
                    NOT_FOUND_0x10="0"
                    NOT_FOUND_0x11="@+id/tv_num3_title"
                    NOT_FOUND_0x12="@+id/tv_num3_subtitle"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
