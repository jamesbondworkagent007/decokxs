<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/background_lv3"
    padding="@dimen/ok_dp_16"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textStyle="0x1"
        textColor="@color/okTradeG900"
        id="@+id/tv_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_10"
        layout_marginBottom="@dimen/dp_10"
        layout_marginEnd="@dimen/dp_10"
        layout_marginVertical="@dimen/dp_10"
        NOT_FOUND_0x17="@+id/add_params"
        NOT_FOUND_0x18="0"
        style="@style/TextAppearance.Title.14SP"/>
    <LinearLayout
        orientation="0"
        id="@+id/tag_container"
        paddingTop="5dp"
        paddingBottom="5dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="5dp"
        NOT_FOUND_0x19="@+id/add_params">
        <o.C55251xgS
            textColor="@color/background_lv1"
            id="@+id/modeTag1"
            paddingLeft="5dp"
            paddingRight="5dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingHorizontal="5dp"
            NOT_FOUND_0x1b="-1"
            NOT_FOUND_0x1c="-3"
            NOT_FOUND_0x1d="1"
            NOT_FOUND_0x1e="4"/>
        <o.C55251xgS
            textColor="@color/background_lv1"
            id="@+id/modeTag2"
            paddingLeft="5dp"
            paddingRight="5dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/dp_10"
            paddingHorizontal="5dp"
            NOT_FOUND_0x1b="-1"
            NOT_FOUND_0x1c="-3"
            NOT_FOUND_0x1d="1"
            NOT_FOUND_0x1e="4"/>
        <o.C55251xgS
            textColor="@color/background_lv1"
            id="@+id/authTag"
            paddingLeft="5dp"
            paddingRight="5dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/dp_10"
            paddingHorizontal="5dp"
            NOT_FOUND_0x1b="-1"
            NOT_FOUND_0x1c="-3"
            NOT_FOUND_0x1d="1"
            NOT_FOUND_0x1e="4"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/link_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_10"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/tag_container"/>
    <ScrollView
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_10"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/link_container">
        <LinearLayout
            orientation="0"
            id="@+id/param_container"
            layout_width="-2"
            android:layout_height="wrap_content"/>
    </ScrollView>
    <TextView
        textColor="@color/blue"
        gravity="0x11"
        id="@+id/add_params"
        layout_width="-2"
        android:layout_height="24dp"
        text="Add Param"
        tintMode="src_over"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="0"
        style="@style/TextAppearance.Title.14SP"/>
</androidx.constraintlayout.widget.ConstraintLayout>
