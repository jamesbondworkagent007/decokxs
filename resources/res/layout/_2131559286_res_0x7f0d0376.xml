<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/margin_default"
    paddingRight="@dimen/margin_default"
    layout_width="-1"
    android:layout_height="@dimen/xlg"
    paddingHorizontal="@dimen/margin_default">
    <TextView
        gravity="0x800013"
        id="@+id/tv_rank_no"
        layout_width="24dp"
        android:layout_height="wrap_content"
        lines="1"
        NOT_FOUND_0x12="14sp"
        NOT_FOUND_0x13="8sp"
        NOT_FOUND_0x14="1sp"
        NOT_FOUND_0x15="1"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="0"
        style="@style/Label_2_Medium"/>
    <LinearLayout
        orientation="1"
        id="@+id/ll_address_tag"
        layout_width="@dimen/dp_108"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_8"
        NOT_FOUND_0x16="@+id/tv_rank_no"
        NOT_FOUND_0x18="@+id/ll_amount"
        NOT_FOUND_0x19="@+id/tv_rank_no"
        NOT_FOUND_0x1b="@+id/tv_rank_no">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_token_address"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            drawablePadding="@dimen/xxxxsm"
            transitionName="shared_holder_address"
            style="@style/Label_2_Medium"/>
        <o.C28067kNr
            id="@+id/layout_tag_container"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxWidth="@dimen/height_100dp"/>
    </LinearLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/ll_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="@+id/ll_source"
        NOT_FOUND_0x19="@+id/ll_address_tag"
        NOT_FOUND_0x1b="0">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_amount_hold"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0x12="14sp"
            NOT_FOUND_0x13="10sp"
            NOT_FOUND_0x14="1sp"
            NOT_FOUND_0x15="1"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_amount_percentage_or_value"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_4"
            maxLines="1"
            style="@style/Label_2_Regular"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <LinearLayout
        orientation="1"
        id="@+id/ll_source"
        layout_width="90dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="@+id/ll_amount"
        NOT_FOUND_0x1b="0">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_rate"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0x12="14sp"
            NOT_FOUND_0x13="10sp"
            NOT_FOUND_0x14="1sp"
            NOT_FOUND_0x15="1"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x1b="0"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/tv_timestamp"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_4"
            maxLines="1"
            NOT_FOUND_0x12="14sp"
            NOT_FOUND_0x13="10sp"
            NOT_FOUND_0x14="1sp"
            NOT_FOUND_0x15="1"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
