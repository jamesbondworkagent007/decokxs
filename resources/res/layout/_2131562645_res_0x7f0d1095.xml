<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/root_view"
    background="@color/white"
    padding="?attr/horizontalPaddingDimension"
    layout_width="-1"
    android:layout_height="wrap_content"
    backgroundTint="@color/crypto_cell_color_selector">
    <RelativeLayout
        gravity="0x10"
        id="@+id/crypto"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerInParent="true"
        layout_alignParentStart="true">
        <LinearLayout
            id="@+id/cryptoContainer"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_centerVertical="true"
            layout_marginEnd="12dp">
            <TextView
                textAppearance="@style/OKTextFont.Bold"
                textSize="16sp"
                textColor="@color/color_content_dataviz_categorical_3"
                gravity="0x800013"
                id="@+id/ranking"
                visibility="2"
                layout_width="24dp"
                android:layout_height="wrap_content"/>
            <o.C55389xiy
                layout_gravity="0x10"
                id="@+id/crypto_icon"
                layout_width="-2"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            gravity="0x10"
            orientation="1"
            id="@+id/crypto_content_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_centerInParent="true"
            layout_toEndOf="@+id/cryptoContainer">
            <o.C55070xcx
                textAppearance="@style/OKTextFont.Medium"
                textSize="16sp"
                textColor="@color/color_content_static_default"
                ellipsize="3"
                id="@+id/crypto_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                textAlignment="5"
                lineHeight="20dp"/>
            <com.google.android.material.textview.MaterialTextView
                textAppearance="@style/Label_2_Regular"
                textSize="12sp"
                textColor="@color/color_content_static_subtle"
                id="@+id/crypto_description"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                textAlignment="5"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        gravity="0x800005"
        orientation="0"
        id="@+id/price"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        layout_marginStart="8dp"
        layout_toStartOf="@+id/change"
        layout_toEndOf="@+id/crypto">
        <LinearLayout
            gravity="0x800015"
            orientation="1"
            layout_width="-2"
            android:layout_height="wrap_content">
            <com.google.android.material.textview.MaterialTextView
                textAppearance="@style/OKTextFont.Medium"
                textSize="16sp"
                textColor="@color/color_content_static_default"
                gravity="0x800015"
                id="@+id/price_main_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeStepGranularity="2sp"
                autoSizeMinTextSize="12sp"
                autoSizeMaxTextSize="16sp"/>
            <com.google.android.material.textview.MaterialTextView
                textAppearance="@style/OKTextFont.Regular"
                textSize="12sp"
                textColor="@color/color_content_static_subtle"
                id="@+id/price_sub_title"
                layout_width="-2"
                android:layout_height="16dp"
                layout_marginTop="4dp"
                maxLines="1"
                textAlignment="6"/>
        </LinearLayout>
        <RelativeLayout
            gravity="0x11"
            id="@+id/priceContainer"
            visibility="2"
            layout_width="-2"
            android:layout_height="match_parent"
            layout_marginStart="8dp"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/change"
        layout_width="84dp"
        android:layout_height="wrap_content"
        layout_centerVertical="true"
        layout_marginStart="24dp"
        layout_alignParentEnd="true">
        <o.C55071xcy
            textSize="16sp"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/change_main_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            autoSizeTextType="uniform"
            autoSizeStepGranularity="2sp"
            autoSizeMinTextSize="12sp"
            autoSizeMaxTextSize="16sp"/>
        <com.google.android.material.textview.MaterialTextView
            textAppearance="@style/Label_2_Regular"
            textSize="12sp"
            textColor="@color/color_content_static_subtle"
            gravity="0x800005"
            id="@+id/change_sub_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"/>
    </LinearLayout>
</RelativeLayout>
