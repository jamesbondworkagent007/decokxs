<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/chartContainer"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content">
        <FrameLayout
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                layout_gravity="0x30"
                orientation="0"
                id="@+id/max_value_container"
                layout_width="-1"
                android:layout_height="wrap_content"
                weightSum="100">
                <TextView
                    textColor="@color/ContentContrast"
                    gravity="0x800003"
                    id="@+id/tv_max_value"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_3_Regular"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                layout_gravity="0x50"
                orientation="0"
                id="@+id/min_value_container"
                layout_width="-1"
                android:layout_height="wrap_content"
                weightSum="100">
                <TextView
                    textColor="@color/ContentContrast"
                    gravity="0x800003"
                    id="@+id/tv_min_value"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_3_Regular"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <o.C27382juD
                id="@+id/chart_back"
                layout_width="-1"
                android:layout_height="252dp"
                layout_marginTop="@dimen/margin_16dp"
                layout_marginBottom="@dimen/margin_16dp"/>
            <o.C27382juD
                id="@+id/lineChart"
                layout_width="-1"
                android:layout_height="252dp"
                layout_marginTop="@dimen/margin_16dp"
                layout_marginBottom="@dimen/margin_16dp"/>
        </FrameLayout>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_bar_value"
            visibility="1"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginBottom="2dp"
            text=" "
            layout_marginStart="24dp"
            style="@style/Label_3_Regular"/>
        <o.C27424jut
            id="@+id/barChart"
            visibility="2"
            layout_width="-1"
            android:layout_height="40dp"/>
    </LinearLayout>
</FrameLayout>
