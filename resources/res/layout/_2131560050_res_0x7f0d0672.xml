<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textSize="16sp"
        textColor="@color/ContentPrimary"
        id="@+id/titleTV"
        paddingLeft="24dp"
        paddingRight="24dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingHorizontal="24dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        style="@style/Label_1_Bold"/>
    <androidx.recyclerview.widget.RecyclerView
        orientation="0"
        id="@+id/reaction_tabs_recycler_view"
        paddingLeft="24dp"
        paddingRight="24dp"
        scrollbars="horizontal"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginBottom="16dp"
        overScrollMode="2"
        layout_marginVertical="16dp"
        paddingHorizontal="24dp"
        NOT_FOUND_0x11="@+id/viewPager"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/titleTV"/>
    <androidx.viewpager2.widget.ViewPager2
        id="@+id/viewPager"
        layout_width="-1"
        android:layout_height="0dp"
        minHeight="360dp"
        overScrollMode="2"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/reaction_tabs_recycler_view"/>
</androidx.constraintlayout.widget.ConstraintLayout>
