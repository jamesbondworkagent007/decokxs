<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/contract_lever_item_layout"
    tag="layout/view_contract_lever_single_item_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="14sp"
        textColor="@color/okTradeG400"
        id="@+id/currentLeverageTitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        text="@string/pr_margin_title_actual_margin"
        layout_marginEnd="2dp"
        NOT_FOUND_0x2c="0"
        NOT_FOUND_0x2e="2"
        NOT_FOUND_0x30="0"
        NOT_FOUND_0x32="0"
        style="@style/TextAppearance"/>
    <ImageView
        id="@+id/iv_minus"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131234197_res_0x7f080d95"
        layout_marginEnd="34dp"
        NOT_FOUND_0x2b="@+id/edtLeverage"
        NOT_FOUND_0x2d="@+id/edtLeverage"
        NOT_FOUND_0x32="@+id/edtLeverage"/>
    <o.C55001xbh
        textAppearance="@style/OKTextFont.Medium"
        textSize="40sp"
        textStyle="0x1"
        textColor="@color/okTradeG900"
        gravity="0x1"
        id="@+id/edtLeverage"
        background="@null"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="5dp"
        maxWidth="200dp"
        maxLines="1"
        minEms="1"
        digits="0123456789,."
        inputType="0x2002"
        paddingEnd="4dp"
        NOT_FOUND_0x29="true"
        NOT_FOUND_0x2c="0"
        NOT_FOUND_0x2e="2"
        NOT_FOUND_0x30="0"
        NOT_FOUND_0x31="@+id/currentLeverageTitle"/>
    <ImageView
        id="@+id/iv_plus"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131234198_res_0x7f080d96"
        layout_marginStart="34dp"
        NOT_FOUND_0x2b="@+id/edtLeverage"
        NOT_FOUND_0x2f="@+id/edtLeverage"
        NOT_FOUND_0x32="@+id/edtLeverage"/>
    <TextView
        textSize="16sp"
        textColor="@color/okTradeG900"
        id="@+id/leverageUnit"
        tag="binding_1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="4dp"
        NOT_FOUND_0x2a="@+id/edtLeverage"
        NOT_FOUND_0x2f="@+id/edtLeverage"
        style="@style/TextAppearance"/>
    <androidx.cardview.widget.CardView
        id="@+id/msgLayout2"
        layout_width="-1"
        android:layout_height="36dp"
        layout_marginLeft="@dimen/common_page_edge_space"
        layout_marginTop="10dp"
        layout_marginRight="@dimen/common_page_edge_space"
        layout_marginHorizontal="@dimen/common_page_edge_space"
        NOT_FOUND_0x26="@color/color_surface_structural_elevated_default"
        NOT_FOUND_0x27="18dp"
        NOT_FOUND_0x28="0dp"
        NOT_FOUND_0x2c="0"
        NOT_FOUND_0x30="0"
        NOT_FOUND_0x31="@+id/edtLeverage">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rcv_leverage_select"
            layout_width="-1"
            android:layout_height="36dp"
            overScrollMode="2"
            paddingStart="2dp"/>
        <LinearLayout
            layout_gravity="0x800005"
            orientation="0"
            id="@+id/vp_more"
            visibility="2"
            layout_width="-2"
            android:layout_height="match_parent">
            <View
                layout_gravity="0x11"
                background="@drawable/_2131234155_res_0x7f080d6b"
                layout_width="16dp"
                android:layout_height="wrap_content"/>
            <ImageView
                layout_gravity="0x11"
                background="@color/white_background_color"
                layout_width="20dp"
                android:layout_height="20dp"
                src="@drawable/_2131231647_res_0x7f08039f"
                scaleType="7"
                NOT_FOUND_0x34="@color/color_content_static_default"/>
            <View
                background="@color/white_background_color"
                layout_width="8dp"
                android:layout_height="match_parent"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <View
        id="@+id/clip_view"
        background="@drawable/_2131230984_res_0x7f080108"
        layout_width="0dp"
        android:layout_height="0dp"
        NOT_FOUND_0x2b="@+id/msgLayout2"
        NOT_FOUND_0x2c="@+id/msgLayout2"
        NOT_FOUND_0x30="@+id/msgLayout2"
        NOT_FOUND_0x32="@+id/msgLayout2"/>
    <androidx.cardview.widget.CardView
        id="@+id/msgLayout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/ok_dp_24"
        layout_marginTop="@dimen/ok_dp_16"
        layout_marginRight="@dimen/ok_dp_24"
        layout_marginBottom="@dimen/ok_dp_16"
        layout_marginHorizontal="@dimen/ok_dp_24"
        layout_marginVertical="@dimen/ok_dp_16"
        NOT_FOUND_0x26="@color/color_surface_structural_layer_2"
        NOT_FOUND_0x27="4dp"
        NOT_FOUND_0x28="0dp"
        NOT_FOUND_0x31="@+id/clip_view">
        <LinearLayout
            orientation="1"
            id="@+id/contract_lever_info_layout"
            paddingTop="8dp"
            paddingBottom="12dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingStart="12dp"
            paddingEnd="8dp">
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textSize="12sp"
                    textColor="@color/okTradeG400"
                    id="@+id/maxAdditionalAmt"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    style="@style/TextAppearance"/>
                <TextView
                    textSize="12sp"
                    textColor="@color/okTradeG900"
                    gravity="0x800005"
                    id="@+id/maxAdditionalAmt_val"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    layout_marginStart="@dimen/margin_5dp"
                    style="@style/TextAppearance"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textSize="12sp"
                    textColor="@color/okTradeG400"
                    id="@+id/margin"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp"
                    layout_weight="1"
                    style="@style/TextAppearance"/>
                <TextView
                    textSize="12sp"
                    textColor="@color/okTradeG900"
                    gravity="0x800005"
                    id="@+id/margin_val"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp"
                    layout_weight="1"
                    layout_marginStart="@dimen/margin_5dp"
                    style="@style/TextAppearance"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textSize="12sp"
                    textColor="@color/okTradeG400"
                    id="@+id/liquidationPrice"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp"
                    layout_weight="1"
                    style="@style/TextAppearance"/>
                <TextView
                    textSize="12sp"
                    textColor="@color/okTradeG900"
                    gravity="0x800005"
                    id="@+id/liquidationPrice_val"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp"
                    layout_weight="1"
                    layout_marginStart="@dimen/margin_5dp"
                    style="@style/TextAppearance"/>
            </LinearLayout>
            <TextView
                textColor="@color/okTradeG400"
                layout_gravity="0x11"
                id="@+id/tip_follower"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_trade_adjustlvg_warning_sync_copy_manual_trade"
                style="@style/TextAppearance.Text.12SP.Regular"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        textSize="12sp"
        textColor="@color/critical"
        gravity="0x800003"
        id="@+id/errorTip"
        paddingLeft="@dimen/ok_dp_24"
        paddingRight="@dimen/ok_dp_24"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        paddingHorizontal="@dimen/ok_dp_24"
        NOT_FOUND_0x31="@+id/msgLayout"
        NOT_FOUND_0x33="16dp"
        style="@style/TextAppearance"/>
    <TextView
        textSize="12sp"
        textColor="@color/critical"
        gravity="0x800003"
        id="@+id/hintText"
        paddingLeft="@dimen/ok_dp_24"
        paddingRight="@dimen/ok_dp_24"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        paddingHorizontal="@dimen/ok_dp_24"
        NOT_FOUND_0x31="@+id/errorTip"
        NOT_FOUND_0x33="16dp"
        style="@style/TextAppearance"/>
    <com.okinc.uilab.reminder.OKReminder
        id="@+id/tradeCoreMarginUpgradeReminder"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/ok_dp_24"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginRight="@dimen/ok_dp_24"
        layout_marginHorizontal="@dimen/ok_dp_24"
        NOT_FOUND_0x31="@+id/hintText"/>
</androidx.constraintlayout.widget.ConstraintLayout>
