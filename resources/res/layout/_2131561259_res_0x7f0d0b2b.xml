<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/layout_hardware_wallet_bluetooth_guide_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        orientation="0"
        id="@+id/ll_guide_line_container"
        layout_width="-1"
        android:layout_height="2dp"
        layout_marginLeft="16dp"
        layout_marginTop="8dp"
        layout_marginRight="16dp"
        layout_marginHorizontal="16dp"/>
    <TextView
        textAppearance="@style/TextAppearance.MeDium"
        textSize="15sp"
        textColor="@color/grey_g900"
        layout_gravity="0x800005"
        id="@+id/skip"
        padding="10dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="22dp"
        text="@string/pr_wallet_hardwallet_textbtn_skip"
        layout_marginEnd="14dp"/>
    <androidx.viewpager2.widget.ViewPager2
        id="@+id/view_pager"
        layout_width="-1"
        android:layout_height="0dp"
        layout_marginTop="24dp"
        layout_weight="1"
        overScrollMode="2"/>
    <FrameLayout
        layout_width="-1"
        android:layout_height="64dp"
        layout_marginBottom="17dp">
        <ImageView
            layout_gravity="0x800005"
            id="@+id/next"
            background="@drawable/_2131233981_res_0x7f080cbd"
            padding="23dp"
            layout_width="64dp"
            android:layout_height="64dp"
            layout_marginBottom="24dp"
            src="@drawable/_2131232344_res_0x7f080658"
            layout_marginEnd="24dp"
            NOT_FOUND_0x18="@color/hardware_wallet_button_color"/>
        <o.C52794wYp
            textAppearance="@style/TextAppearance.Bold"
            gravity="0x11"
            layout_gravity="0x10"
            id="@+id/confirm"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="16dp"
            layout_marginRight="16dp"
            text="@string/pr_wallet_hardwallet_btn_connect_now"
            layout_marginHorizontal="16dp"
            NOT_FOUND_0x16="52"
            NOT_FOUND_0x17="0x101"/>
    </FrameLayout>
</LinearLayout>
