<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingLeft="@dimen/margin_default"
    paddingTop="8dp"
    paddingRight="@dimen/margin_default"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default">
    <TextView
        textColor="@color/ContentPrimary"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_smartarb_placeorder_checkbox_boost_investment"
        style="@style/Title_2_Bold"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/descriptionTv"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        style="@style/Body_3_Regular"/>
    <LinearLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_smartarb_botdetails_tooltips_your_investment"
            layout_weight="1"
            layout_marginEnd="16dp"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/investAmount"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
    <LinearLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_smartarb_botdetails_tooltips_boosted_investment"
            layout_weight="1"
            layout_marginEnd="16dp"
            style="@style/Label_2_Medium"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/boostedInvestAmount"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Label_2_Medium"/>
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
