<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/root_banner_view"
    tag="layout/im_media_call_notice_view_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="44dp">
    <androidx.cardview.widget.CardView
        layout_width="-1"
        android:layout_height="96dp"
        layout_marginLeft="@dimen/margin_12dp"
        layout_marginTop="@dimen/margin_4dp"
        layout_marginRight="@dimen/margin_12dp"
        layout_marginBottom="@dimen/margin_4dp"
        layout_centerInParent="true"
        layout_marginHorizontal="@dimen/margin_12dp"
        layout_marginVertical="@dimen/margin_4dp"
        NOT_FOUND_0x1a="@dimen/dp_8"
        NOT_FOUND_0x1b="@dimen/dp_4"
        NOT_FOUND_0x1c="false">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_gravity="0x11"
            background="@color/okim_audio_call_notice_view_bg"
            layout_width="-1"
            android:layout_height="match_parent">
            <LinearLayout
                orientation="1"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/margin_16dp"
                layout_marginEnd="@dimen/dp_8"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1f="@+id/deny_btn"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x21="0"
                NOT_FOUND_0x23="0">
                <TextView
                    id="@+id/tv_tag"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_message_feed_label_official"
                    singleLine="true"
                    translationX="-2dp"
                    NOT_FOUND_0x1d="@+id/user_name_tv"
                    NOT_FOUND_0x21="0"
                    NOT_FOUND_0x23="0"
                    style="@style/TagTextView"/>
                <TextView
                    textSize="@dimen/text_size_18sp"
                    textColor="@color/okTradeG900"
                    ellipsize="3"
                    id="@+id/user_name_tv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/dp_4"
                    maxWidth="240dp"
                    maxLines="1"
                    NOT_FOUND_0x1f="0"
                    NOT_FOUND_0x21="0"
                    NOT_FOUND_0x22="@+id/tv_tag"/>
                <TextView
                    textSize="@dimen/text_size_14sp"
                    textColor="@color/okTradeG400"
                    gravity="0x11"
                    id="@+id/call_type_tv"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/dp_4"
                    text="@string/pr_message_audiocall_text_invite_to_call"
                    NOT_FOUND_0x21="@+id/user_name_tv"
                    NOT_FOUND_0x22="@+id/user_name_tv"/>
            </LinearLayout>
            <ImageView
                id="@+id/accept_btn"
                background="@drawable/_2131233014_res_0x7f0808f6"
                layout_width="44dp"
                android:layout_height="44dp"
                layout_marginEnd="@dimen/margin_16dp"
                NOT_FOUND_0x1d="0"
                NOT_FOUND_0x1e="0"
                NOT_FOUND_0x23="0"/>
            <ImageView
                id="@+id/deny_btn"
                background="@drawable/_2131233015_res_0x7f0808f7"
                layout_width="44dp"
                android:layout_height="44dp"
                layout_marginEnd="@dimen/margin_16dp"
                NOT_FOUND_0x1f="@+id/accept_btn"
                NOT_FOUND_0x23="@+id/accept_btn"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>
