<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="0"
    paddingLeft="@dimen/padding_12dp"
    paddingTop="@dimen/padding_8dp"
    paddingRight="@dimen/padding_12dp"
    paddingBottom="@dimen/padding_8dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="36dp"
    paddingHorizontal="@dimen/padding_12dp"
    paddingVertical="@dimen/padding_8dp">
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/grey_g900_light"
        gravity="0x11"
        id="@+id/tv_voucher"
        tag="layout/layout_bot_loss_insurance_label_0"
        background="@drawable/_2131231246_res_0x7f08020e"
        padding="@dimen/padding_2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.Text.Bold"/>
    <TextView
        textColor="@color/ContentPrimary"
        tag="layout/layout_bot_loss_insurance_label_1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_4dp"
        layout_marginRight="@dimen/margin_4dp"
        text="@string/pr_fdcabot_simplebuy_title_loss_coverage_voucher"
        layout_weight="1"
        layout_marginHorizontal="@dimen/margin_4dp"
        style="@style/TextAppearance.Text.12SP.Medium"/>
    <TextView
        textColor="@color/ContentSecondary"
        id="@+id/tv_status"
        tag="layout/layout_bot_loss_insurance_label_2"
        layout_width="-2"
        android:layout_height="wrap_content"
        includeFontPadding="false"
        layout_marginStart="@dimen/margin_2dp"
        style="@style/TextAppearance.Text.12SP.Medium"/>
</merge>
