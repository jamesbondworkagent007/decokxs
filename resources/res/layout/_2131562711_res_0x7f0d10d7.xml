<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TableLayout
        gravity="0x10"
        orientation="0"
        id="@+id/tb_coin"
        tag="layout/view_arbitrage_coin_select_0"
        layout_width="-1"
        android:layout_height="wrap_content"
        shrinkColumns="0">
        <TableRow>
            <TextView
                textAppearance="@style/TextAppearance.Title.14SP.Medium"
                ellipsize="3"
                gravity="0x10"
                id="@+id/tv_arbitrage_price_idx"
                layout_width="-2"
                android:layout_height="wrap_content"
                singleLine="true"
                drawablePadding="2dp"/>
            <o.C55251xgS
                theme="@style/OKTheme"
                id="@+id/tv_arbitrage_margin_num"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="2dp"
                NOT_FOUND_0x1b="-5"
                NOT_FOUND_0x1c="2"/>
            <ImageView
                layout_gravity="0x10"
                id="@+id/iv_coin_name_arror"
                layout_width="12dp"
                android:layout_height="12dp"
                src="@drawable/_2131231589_res_0x7f080365"
                layout_marginStart="2dp"
                NOT_FOUND_0x1d="@color/ContentContrast"/>
        </TableRow>
    </TableLayout>
    <FrameLayout
        id="@+id/mode_container"
        tag="layout/view_arbitrage_coin_select_1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="14dp">
        <HorizontalScrollView
            id="@+id/hsv_mode_container"
            scrollbars="horizontal"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                orientation="1"
                layout_width="-2"
                android:layout_height="wrap_content">
                <LinearLayout
                    layout_width="-2"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        id="@+id/ll_arbitrage_price_position"
                        background="@drawable/_2131233964_res_0x7f080cac"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        layout_marginEnd="4dp">
                        <TextView
                            textAppearance="@style/TextAppearance.Title.12SP.Medium"
                            textColor="@color/selector_enable_g900_disable_g300"
                            gravity="0x10"
                            layout_gravity="0x10"
                            id="@+id/tv_arbitrage_price_position"
                            paddingLeft="@dimen/padding_8dp"
                            paddingTop="@dimen/padding_4dp"
                            paddingRight="@dimen/padding_8dp"
                            paddingBottom="@dimen/padding_4dp"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            text="@string/pr_demotrade_btn_margin_mode_cross"
                            layout_marginStart="2dp"
                            paddingHorizontal="@dimen/padding_8dp"
                            paddingVertical="@dimen/padding_4dp"/>
                    </LinearLayout>
                    <LinearLayout
                        id="@+id/ll_arbitrage_price_leverage"
                        background="@drawable/_2131233964_res_0x7f080cac"
                        layout_width="-2"
                        android:layout_height="wrap_content">
                        <TextView
                            textAppearance="@style/TextAppearance.Title.12SP.Medium"
                            textColor="@color/selector_enable_g900_disable_g300"
                            gravity="0x10"
                            id="@+id/tv_arbitrage_price_leverage"
                            paddingLeft="@dimen/padding_8dp"
                            paddingTop="@dimen/padding_4dp"
                            paddingRight="@dimen/padding_8dp"
                            paddingBottom="@dimen/padding_4dp"
                            layout_width="-2"
                            android:layout_height="wrap_content"
                            text="1x"
                            layout_marginStart="2dp"
                            paddingHorizontal="@dimen/padding_8dp"
                            paddingVertical="@dimen/padding_4dp"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    id="@+id/ll_arbitrage_price_margin"
                    background="@drawable/_2131233964_res_0x7f080cac"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp">
                    <TextView
                        textAppearance="@style/TextAppearance.Title.12SP.Medium"
                        textColor="@color/selector_enable_g900_disable_g300"
                        gravity="0x10"
                        id="@+id/tv_arbitrage_price_margin"
                        paddingLeft="@dimen/padding_8dp"
                        paddingTop="4dp"
                        paddingRight="@dimen/padding_8dp"
                        paddingBottom="4dp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        layout_marginStart="2dp"
                        paddingHorizontal="@dimen/padding_8dp"
                        paddingVertical="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>
    </FrameLayout>
</merge>
