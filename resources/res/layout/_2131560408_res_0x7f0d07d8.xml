<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    paddingTop="16dp"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="24dp"
    paddingEnd="24dp">
    <ImageView
        layout_gravity="0x10"
        layout_width="24dp"
        android:layout_height="24dp"
        src="@drawable/_2131233368_res_0x7f080a58"/>
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginStart="12dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP"
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_subtitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            maxLines="1"/>
    </LinearLayout>
</LinearLayout>
