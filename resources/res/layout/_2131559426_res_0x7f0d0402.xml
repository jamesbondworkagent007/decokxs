<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        paddingLeft="@dimen/padding_24dp"
        paddingRight="@dimen/padding_24dp"
        layout_width="-1"
        android:layout_height="44dp"
        paddingHorizontal="@dimen/padding_24dp">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/nav_back"
            background="?android:attr/selectableItemBackgroundBorderless"
            layout_width="@dimen/width_24dp"
            android:layout_height="@dimen/height_24dp"
            layout_marginTop="@dimen/margin_10dp"
            layout_marginBottom="@dimen/margin_10dp"
            src="@drawable/_2131231642_res_0x7f08039a"
            layout_marginVertical="@dimen/margin_10dp"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="@color/ContentPrimary"/>
        <TextView
            textAppearance="@style/Title_2_Bold"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x11"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="match_parent"
            text="@string/pr_invest_smartmoney_header_tab_title_signal"
            maxLines="1"
            contentDescription="web3_dex_market_signal_appbar_title_view"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="0"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_info"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131233141_res_0x7f080975"
            contentDescription="web3_dex_market_signal_info_btn"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="@color/ContentPrimary"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_alerts"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131234095_res_0x7f080d2f"
            layout_marginEnd="@dimen/margin_12dp"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="@+id/iv_info"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="@color/ContentPrimary"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.okinc.uilab.banner.OKAlertBanner
        id="@+id/banner_pause_notification"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="@string/pr_swaptrade_market_alertbanner_desc_noti_paused"
        NOT_FOUND_0x17="@string/pr_swaptrade_market_alertbanner_btn_enable"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@string/pr_swaptrade_market_alertbanner_title_noti_paused"
        NOT_FOUND_0x1a="4"/>
    <com.okinc.uilab.banner.OKAlertBanner
        id="@+id/banner_settings_notification"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1a="4"/>
    <o.C55254xgV
        id="@+id/signalTabs"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <o.C29629kxJ
        id="@+id/filter_bar"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxsm"/>
    <androidx.viewpager2.widget.ViewPager2
        id="@+id/viewPager"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"/>
</androidx.appcompat.widget.LinearLayoutCompat>
