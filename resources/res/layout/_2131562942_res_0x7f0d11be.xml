<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_default"
    layout_marginRight="@dimen/margin_default"
    layout_marginHorizontal="@dimen/margin_default"
    NOT_FOUND_0x15="@color/SurfacePrimary"
    NOT_FOUND_0x16="12dp"
    NOT_FOUND_0x17="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        paddingLeft="@dimen/padding_20dp"
        paddingTop="@dimen/padding_16dp"
        paddingRight="@dimen/padding_20dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_20dp"
        paddingVertical="@dimen/padding_16dp">
        <ImageView
            id="@+id/iv_banner_image"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131233632_res_0x7f080b60"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x21="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_banner_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="16dp"
            NOT_FOUND_0x19="@+id/countdown_container"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="@+id/iv_banner_image"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x20="2"
            style="@style/Label_2_Regular"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/countdown_container"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            layout_marginStart="16dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="@+id/iv_banner_image"
            NOT_FOUND_0x1d="@+id/tv_banner_title">
            <TextView
                textColor="@color/ContentBrand"
                gravity="0x11"
                id="@+id/tv_countdown_days"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                layout_width="-2"
                android:layout_height="wrap_content"
                text=" D : "
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentBrand"
                gravity="0x11"
                id="@+id/tv_countdown_hour"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                layout_width="-2"
                android:layout_height="wrap_content"
                text=" H : "
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentBrand"
                gravity="0x11"
                id="@+id/tv_countdown_minute"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                layout_width="-2"
                android:layout_height="wrap_content"
                text=" M : "
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentBrand"
                gravity="0x11"
                id="@+id/tv_countdown_second"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentPrimary"
                gravity="0x11"
                layout_width="-2"
                android:layout_height="wrap_content"
                text=" S"
                style="@style/Label_1_Medium"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
