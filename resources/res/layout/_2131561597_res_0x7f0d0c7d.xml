<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    tag="layout/lr_view_bottom_select_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="40dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/selectLayout"
        background="@drawable/_2131233859_res_0x7f080c43"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <TextView
            textAppearance="@style/TextAppearance.Silka"
            textSize="14sp"
            textColor="@color/okTradeG700"
            ellipsize="3"
            gravity="0x10"
            id="@+id/title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            paddingStart="@dimen/padding_12dp"
            NOT_FOUND_0x1c="true"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1f="@+id/selectedType"
            NOT_FOUND_0x20="0"
            NOT_FOUND_0x22="0"
            NOT_FOUND_0x23="0"/>
        <ImageView
            layout_gravity="0x10"
            id="@+id/contentHintIcon"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131233141_res_0x7f080975"
            layout_marginStart="5dp"
            layout_marginEnd="2dp"
            NOT_FOUND_0x1d="@+id/title"
            NOT_FOUND_0x21="@+id/title"
            NOT_FOUND_0x23="@+id/title"
            NOT_FOUND_0x24="@color/ContentContrast"/>
        <TextView
            textAppearance="@style/TextAppearance.Silka.MeDium"
            textColor="@color/okTradeG900"
            ellipsize="3"
            gravity="0x11"
            id="@+id/selectedType"
            paddingTop="@dimen/padding_10dp"
            paddingBottom="@dimen/padding_10dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            drawablePadding="7dp"
            layout_marginStart="10dp"
            layout_marginEnd="8dp"
            paddingVertical="@dimen/padding_10dp"
            NOT_FOUND_0x1a="@drawable/_2131233921_res_0x7f080c81"
            NOT_FOUND_0x1b="@color/ContentContrast"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x23="0"/>
        <TextView
            textAppearance="@style/TextAppearance.Silka.MeDium"
            textColor="@color/okTradeG900"
            ellipsize="3"
            gravity="0x800013"
            id="@+id/selectedTypeCopy"
            paddingTop="@dimen/padding_10dp"
            paddingBottom="@dimen/padding_10dp"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="12dp"
            layout_marginEnd="12dp"
            paddingVertical="@dimen/padding_10dp"
            NOT_FOUND_0x1a="@drawable/_2131233921_res_0x7f080c81"
            NOT_FOUND_0x1b="@color/ContentContrast"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x23="0"/>
        <androidx.constraintlayout.widget.Barrier
            id="@+id/barrier"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x18="3"
            NOT_FOUND_0x19="selectedTypeCopy,selectedType,contentHintIcon,title"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView
        layout_gravity="0x10"
        id="@+id/hintIcon"
        visibility="2"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131233141_res_0x7f080975"
        layout_marginStart="10dp"
        layout_marginEnd="2dp"
        NOT_FOUND_0x24="@color/ContentContrast"/>
</LinearLayout>
