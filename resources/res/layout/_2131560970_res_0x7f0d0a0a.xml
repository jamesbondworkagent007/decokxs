<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="12sp"
        gravity="0x10"
        id="@+id/command"
        layout_width="-2"
        android:layout_height="wrap_content"
        text=""/>
    <ImageView
        id="@+id/icon"
        padding="1dp"
        visibility="0"
        layout_width="14dp"
        android:layout_height="match_parent"
        layout_marginRight="3dp"
        src="@drawable/_2131233197_res_0x7f0809ad"
        scaleType="7"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/content"
        layout_width="-2"
        android:layout_height="wrap_content">
        <TextView
            textSize="12sp"
            gravity="0x10"
            id="@+id/key"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="key:"/>
        <TextView
            textSize="12sp"
            gravity="0x10"
            id="@+id/value"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginLeft="8dp"
            text="value"/>
    </LinearLayout>
</LinearLayout>
