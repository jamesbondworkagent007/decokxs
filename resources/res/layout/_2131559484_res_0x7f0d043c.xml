<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/grey_g900"
        gravity="0x800003"
        id="@+id/value_diff"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_card_text_value_difference_tips"
        lineSpacingMultiplier="1.1"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/grey_g900"
        layout_gravity="0x800003"
        id="@+id/value_diff_desc"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_swaptrade_card_text_value_difference_tips1"
        lineSpacingMultiplier="1.1"/>
</LinearLayout>
