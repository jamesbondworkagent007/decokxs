<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/mev_node_icon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_margin="@dimen/dp_4"
        src="@drawable/_2131232079_res_0x7f08054f"
        importantForAccessibility="2"
        NOT_FOUND_0xc="@+id/mev_node_title"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/mev_node_title"
        NOT_FOUND_0x11="@style/CircleStyle"/>
    <TextView
        ellipsize="3"
        gravity="0x10"
        id="@+id/mev_node_title"
        layout_width="0dp"
        android:layout_height="@dimen/height_56dp"
        layout_marginLeft="@dimen/margin_12dp"
        layout_marginRight="@dimen/margin_12dp"
        maxLines="1"
        layout_marginHorizontal="@dimen/margin_12dp"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/mev_node_icon"
        NOT_FOUND_0x10="0"
        style="@style/TextAppearance.Text.14SP.Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
