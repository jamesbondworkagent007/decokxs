<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_default"
    layout_marginTop="8dp"
    layout_marginRight="@dimen/margin_default"
    layout_marginBottom="24dp"
    layout_marginHorizontal="@dimen/margin_default">
    <com.google.android.exoplayer2.ui.PlayerView
        id="@+id/videoView"
        layout_width="200dp"
        android:layout_height="200dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x21="@color/color_surface_structural_elevated_default"
        NOT_FOUND_0x22="2"
        NOT_FOUND_0x23="false"/>
    <o.C55353xiO
        id="@+id/lottieView"
        layout_width="200dp"
        android:layout_height="200dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="false"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x11"
        id="@+id/mainTitleTv"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="@+id/lottieView"
        style="@style/Headline_5_Bold"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/botInfoContainer"
        background="@drawable/_2131231162_res_0x7f0801ba"
        paddingLeft="16dp"
        paddingTop="20dp"
        paddingRight="16dp"
        paddingBottom="20dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        backgroundTint="@color/SurfacePrimary"
        paddingHorizontal="16dp"
        paddingVertical="20dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="@+id/mainTitleTv">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/botTitleContainer"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0">
            <o.C51601vqB
                id="@+id/coinStackView"
                layout_width="24dp"
                android:layout_height="24dp"
                NOT_FOUND_0x13="@color/SurfacePrimary"
                NOT_FOUND_0x14="0dp"
                NOT_FOUND_0x15="true"
                NOT_FOUND_0x16="24dp"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1e="0"
                NOT_FOUND_0x20="2"/>
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/botNameTv"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="8dp"
                NOT_FOUND_0x18="true"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1b="@+id/coinStackView"
                NOT_FOUND_0x1e="0"
                style="@style/Label_1_Medium"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/subTitleTv"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/botTitleContainer"
            style="@style/Label_3_Regular"/>
        <TextView
            id="@+id/subValueTv"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/subTitleTv"
            style="@style/Headline_3_Bold"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
