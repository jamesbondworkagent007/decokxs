<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/kline_dex_balance_info_layout"
        paddingLeft="@dimen/margin_default"
        paddingTop="@dimen/xxxsm"
        paddingRight="@dimen/margin_default"
        paddingBottom="@dimen/margin_default"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_default">
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            gravity="0x10"
            id="@+id/limit_order_header"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xsm"
            text="@string/pr_swaptrade_limit_order_title_limit_asset"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x11="0"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/limit_order_body"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxsm"
            layout_marginBottom="@dimen/xsm"
            text="@string/pr_swaptrade_limit_order_desc_limit_asset"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/limit_order_header"
            style="@style/Body_3_Regular"/>
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            gravity="0x10"
            id="@+id/total_pnl_header"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xsm"
            text="@string/pr_swaptrade_market_bttmsheet_title_total_pnl"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/limit_order_body"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/total_pnl_body"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxsm"
            text="@string/pr_swaptrade_market_dialog_desc_total_pnl"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/total_pnl_header"
            style="@style/Body_3_Regular"/>
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            gravity="0x10"
            id="@+id/unrlz_pnl_header"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xsm"
            text="@string/pr_swaptrade_market_dialog_title_floating_pnl"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/total_pnl_body"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/unrlz_pnl_body"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxsm"
            text="@string/pr_swaptrade_market_dialog_desc_unrealized_pnl"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/unrlz_pnl_header"
            style="@style/Body_3_Regular"/>
        <TextView
            textSize="14sp"
            textColor="@color/ContentPrimary"
            gravity="0x10"
            id="@+id/rlz_pnl_header"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xsm"
            text="@string/pr_swaptrade_market_dialog_title_realized_pnl"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/unrlz_pnl_body"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/rlz_pnl_body"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxsm"
            text="@string/pr_swaptrade_market_dialog_desc_dex_realized_pnl"
            NOT_FOUND_0xf="0"
            NOT_FOUND_0x10="@+id/rlz_pnl_header"
            style="@style/Body_3_Regular"/>
        <androidx.constraintlayout.widget.Group
            id="@+id/limit_order_group"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0xe="limit_order_header,limit_order_body"/>
        <androidx.constraintlayout.widget.Group
            id="@+id/pnl_group"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0xe="total_pnl_header,total_pnl_body,unrlz_pnl_header,unrlz_pnl_body,rlz_pnl_header,rlz_pnl_body"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
