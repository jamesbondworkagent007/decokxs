<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.18SP.Semibold"
        textColor="@color/ContentPrimary"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_investredeem_mid_title_slippage_tolerance"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP.Medium"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_investredeem_mid_text_slippage_refers"
        lineSpacingExtra="@dimen/margin_4dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.18SP.Semibold"
        textColor="@color/ContentPrimary"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_investredeem_mid_title_auto_setting"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP.Medium"
        textColor="@color/okTradeG500"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_investredeem_mid_text_autosetting_slippageincrease"
        lineSpacingExtra="@dimen/margin_4dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.18SP.Semibold"
        textColor="@color/ContentPrimary"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_investredeem_mid_title_custom_setting"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP.Medium"
        textColor="@color/okTradeG500"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        text="@string/pr_investredeem_mid_text_high_slippage"
        lineSpacingExtra="@dimen/margin_4dp"/>
</LinearLayout>
