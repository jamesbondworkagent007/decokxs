<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_dapp_web_options_bar_0"
    layout_width="-1"
    android:layout_height="44dp">
    <View
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="0.5dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"/>
    <o.wYC
        id="@+id/back"
        layout_width="0dp"
        android:layout_height="match_parent"
        scaleType="7"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="@+id/forward"
        NOT_FOUND_0x14="2"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@color/okTradeG900"/>
    <o.wYC
        id="@+id/forward"
        layout_width="0dp"
        android:layout_height="match_parent"
        scaleType="7"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="@+id/switchPage"
        NOT_FOUND_0x16="@+id/back"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@color/okTradeG900"/>
    <FrameLayout
        id="@+id/switchPage"
        layout_width="@dimen/width_0dp"
        android:layout_height="match_parent"
        contentDescription="web3_discover_home_web_page_switch_tab"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="@+id/refresh"
        NOT_FOUND_0x16="@+id/forward"
        NOT_FOUND_0x18="0">
        <o.wYC
            layout_gravity="0x11"
            layout_width="@dimen/width_18dp"
            android:layout_height="@dimen/width_18dp"
            src="@drawable/_2131233112_res_0x7f080958"
            NOT_FOUND_0x19="@color/okTradeG900"/>
        <TextView
            textSize="@dimen/text_size_12sp"
            textColor="@color/okTradeG900"
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/page_count"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="30"
            fontFamily="@font/harmony_sans_regular"/>
    </FrameLayout>
    <o.wYC
        id="@+id/refresh"
        layout_width="0dp"
        android:layout_height="match_parent"
        src="@drawable/_2131233783_res_0x7f080bf7"
        scaleType="7"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="@+id/more"
        NOT_FOUND_0x16="@+id/switchPage"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@color/ContentPrimary"/>
    <o.wYC
        id="@+id/more"
        layout_width="0dp"
        android:layout_height="match_parent"
        src="@drawable/_2131233513_res_0x7f080ae9"
        scaleType="7"
        contentDescription="web3_discover_home_web_page_menu"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="@+id/refresh"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@color/ContentPrimary"/>
    <View
        id="@+id/redPoint"
        background="@drawable/_2131231336_res_0x7f080268"
        visibility="2"
        layout_width="@dimen/dp_6"
        android:layout_height="@dimen/dp_6"
        layout_marginTop="8.5dp"
        layout_marginEnd="18dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x18="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
