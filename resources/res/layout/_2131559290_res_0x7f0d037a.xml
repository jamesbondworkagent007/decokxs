<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="68dp">
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x11"
        id="@+id/icSelectedRadio"
        visibility="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_default"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@drawable/_2131232407_res_0x7f080697"
        NOT_FOUND_0x12="@color/ContentBrand"/>
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/avatar"
        layout_width="36dp"
        android:layout_height="36dp"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xe="@+id/icSelectedRadio"
        NOT_FOUND_0x10="0"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_address_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        layout_marginEnd="@dimen/sm"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xd="@+id/ic_alert"
        NOT_FOUND_0xe="@+id/avatar"
        NOT_FOUND_0x10="0"
        style="@style/Label_1_Medium"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/ic_alert"
        layout_width="-2"
        android:layout_height="match_parent"
        paddingEnd="@dimen/margin_default"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@drawable/_2131234096_res_0x7f080d30"
        NOT_FOUND_0x12="@color/ContentPrimary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
