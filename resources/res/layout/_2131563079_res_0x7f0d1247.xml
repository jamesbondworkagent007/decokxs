<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131230913_res_0x7f0800c1"
    paddingLeft="@dimen/dp_16"
    paddingTop="@dimen/dp_16"
    paddingRight="@dimen/dp_16"
    paddingBottom="@dimen/dp_16"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/dp_16"
    paddingVertical="@dimen/dp_16">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/text_size_10sp"
            textColor="@color/okTradeG400"
            ellipsize="3"
            gravity="0x10"
            layout_gravity="0x10"
            id="@+id/app_widget_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="@dimen/height_72dp"
            text="@string/pr_widgets_header_label_watchlist"
            singleLine="true"
            includeFontPadding="false"
            style="@style/TextAppearance.Text.10SP"/>
        <ImageView
            layout_width="0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
        <ImageView
            layout_gravity="0x800015"
            id="@+id/app_widget_setting"
            background="@drawable/_2131233932_res_0x7f080c8c"
            layout_width="@dimen/dp_16"
            android:layout_height="@dimen/dp_16"
            scaleType="fillCenter"
            layout_marginEnd="8dp"
            backgroundTint="@color/okTradeG400"/>
        <ImageView
            layout_gravity="0x800015"
            background="@mipmap/_2131689474_res_0x7f0f0002"
            layout_width="@dimen/dp_16"
            android:layout_height="@dimen/dp_16"/>
    </LinearLayout>
    <LinearLayout
        layout_gravity="0x50"
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="22dp">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/app_widget_item_one"
            layout_width="-1"
            android:layout_height="@dimen/height_36dp">
            <ImageView
                id="@+id/app_widget_icon_one"
                layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp24"/>
            <ImageView
                layout_width="0dp"
                android:layout_height="1dp"
                layout_weight="1"/>
            <LinearLayout
                gravity="0x800005"
                orientation="1"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textAppearance="@style/TextAppearance.Title.12SP.Semibold"
                    textStyle="0x1"
                    textColor="@color/okTradeG900"
                    id="@+id/app_widget_price_one"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Title.12SP.Semibold"/>
                <TextView
                    id="@+id/app_widget_percent_one"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Title.12SP"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/app_widget_item_two"
            layout_width="-1"
            android:layout_height="@dimen/height_36dp">
            <ImageView
                id="@+id/app_widget_icon_two"
                layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp24"/>
            <ImageView
                layout_width="0dp"
                android:layout_height="1dp"
                layout_weight="1"/>
            <LinearLayout
                gravity="0x800005"
                orientation="1"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textAppearance="@style/TextAppearance.Title.12SP.Semibold"
                    textStyle="0x1"
                    textColor="@color/okTradeG900"
                    id="@+id/app_widget_price_two"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Title.12SP.Semibold"/>
                <TextView
                    id="@+id/app_widget_percent_two"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Title.12SP"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/app_widget_item_three"
            layout_width="-1"
            android:layout_height="@dimen/height_36dp">
            <ImageView
                id="@+id/app_widget_icon_three"
                layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp24"/>
            <ImageView
                layout_width="0dp"
                android:layout_height="1dp"
                layout_weight="1"/>
            <LinearLayout
                gravity="0x800005"
                orientation="1"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textAppearance="@style/TextAppearance.Title.12SP.Semibold"
                    textStyle="0x1"
                    textColor="@color/okTradeG900"
                    id="@+id/app_widget_price_three"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Title.12SP.Semibold"/>
                <TextView
                    id="@+id/app_widget_percent_three"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Title.12SP"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
