<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <FrameLayout
        orientation="1"
        layout_width="-2"
        android:layout_height="@dimen/height_36dp">
        <ImageView
            id="@+id/iv_icon"
            background="@drawable/_2131231885_res_0x7f08048d"
            layout_width="32dp"
            android:layout_height="32dp"
            scaleType="7"/>
        <ImageView
            layout_gravity="0x50"
            id="@+id/iv_sub"
            background="@drawable/_2131231958_res_0x7f0804d6"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            scaleType="7"
            layout_marginStart="@dimen/margin_20dp"/>
    </FrameLayout>
    <TextView
        textAppearance="@style/TextAppearance.Title.Bold.20SP"
        textColor="@color/okTradeG900"
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_text_select"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="124dp"
        maxLines="1"
        drawableEnd="@drawable/_2131231588_res_0x7f080364"
        layout_marginStart="@dimen/margin_12dp"
        drawableTint="@color/ContentPrimary"/>
</merge>
