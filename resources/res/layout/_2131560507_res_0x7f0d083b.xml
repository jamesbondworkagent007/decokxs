<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="12dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/iv_appIcon"
        layout_width="40dp"
        android:layout_height="40dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x20="0"/>
    <TextView
        textAppearance="@style/Label_2_Bold"
        textSize="@dimen/text_size_14sp"
        textColor="@color/TextAmplifed"
        ellipsize="3"
        id="@+id/tv_appName"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="文本内容"
        maxLines="1"
        layout_marginStart="16dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x19="true"
        NOT_FOUND_0x1c="@+id/iv_riskIcon"
        NOT_FOUND_0x1d="@+id/iv_appIcon"
        NOT_FOUND_0x20="@+id/iv_appIcon"/>
    <ImageView
        id="@+id/iv_riskIcon"
        visibility="2"
        layout_width="@dimen/width_16dp"
        android:layout_height="@dimen/height_16dp"
        src="@drawable/_2131234342_res_0x7f080e26"
        NOT_FOUND_0x1a="@+id/tv_appName"
        NOT_FOUND_0x1c="@+id/btn_uninstallApp"
        NOT_FOUND_0x1d="@+id/tv_appName"
        NOT_FOUND_0x20="@+id/tv_appName"
        NOT_FOUND_0x26="@color/SemanticNotice"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_subInfo"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="com.example.app"
        maxLines="1"
        layout_marginStart="16dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x19="true"
        NOT_FOUND_0x1c="@+id/btn_uninstallApp"
        NOT_FOUND_0x1d="@+id/iv_appIcon"
        NOT_FOUND_0x1f="@+id/tv_appName"/>
    <o.C52794wYp
        id="@+id/btn_uninstallApp"
        focusable="true"
        clickable="true"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="72dp"
        minWidth="54dp"
        text="@string/pr_wallet_mid_regularcell_btn_uninstall"
        layout_marginEnd="8dp"
        NOT_FOUND_0x1a="@+id/iv_appIcon"
        NOT_FOUND_0x1c="@+id/selectCheckbox"
        NOT_FOUND_0x1d="@+id/iv_riskIcon"
        NOT_FOUND_0x20="@+id/iv_appIcon"
        NOT_FOUND_0x22="24"
        NOT_FOUND_0x23="0x104"
        NOT_FOUND_0x24="-2"/>
    <o.wYK
        gravity="0x11"
        id="@+id/selectCheckbox"
        layout_width="-2"
        android:layout_height="wrap_content"
        checked="true"
        scaleX="0.83"
        scaleY="0.83"
        layout_marginStart="2dp"
        buttonTint="@color/selector_checkbox_button_tint_negative"
        NOT_FOUND_0x1a="@+id/iv_appIcon"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="@+id/btn_uninstallApp"
        NOT_FOUND_0x20="@+id/iv_appIcon"
        NOT_FOUND_0x21="@drawable/_2131233866_res_0x7f080c4a"
        NOT_FOUND_0x25="-4"/>
</androidx.constraintlayout.widget.ConstraintLayout>
