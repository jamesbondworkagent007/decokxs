<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingTop="16dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp">
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentContrast"
        id="@+id/total_amount_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_trade_bttmsheet_label_total_amount"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentPrimary"
        id="@+id/total_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="@+id/total_amount_title"/>
    <o.C55258xgZ
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentContrast"
        id="@+id/slippage_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        text="@string/pr_metax_trade_modal_slippage_tolerance_title"
        textFontWeight="400"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/total_amount_title"
        NOT_FOUND_0x17="1"
        NOT_FOUND_0x18="0"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentPrimary"
        id="@+id/slippage"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingStart="0dp"
        paddingEnd="4dp"
        NOT_FOUND_0x13="@+id/slippage_arrow"
        NOT_FOUND_0x16="@+id/slippage_title"/>
    <ImageView
        id="@+id/slippage_arrow"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231647_res_0x7f08039f"
        NOT_FOUND_0x11="@+id/slippage"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="@+id/slippage"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentContrast"
        id="@+id/minimum_received_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        text="@string/pr_wallet_swap_confirm_transaction_text_minreceived"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/slippage_title"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentPrimary"
        id="@+id/minimum_received"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="@+id/minimum_received_title"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentContrast"
        id="@+id/est_network_fee_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        text="@string/pr_metax_trade_title_estimated_gas"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/minimum_received_title"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentPrimary"
        id="@+id/est_network_fee"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="@+id/est_network_fee_title"/>
    <o.C55258xgZ
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentContrast"
        id="@+id/service_fee_title"
        paddingBottom="@dimen/padding_24dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        text="@string/pr_wallet_trade_bttmsheet_label_service_fee"
        textFontWeight="400"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/est_network_fee_title"
        NOT_FOUND_0x17="1"
        NOT_FOUND_0x18="0"/>
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentPrimary"
        id="@+id/service_fee"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x16="@+id/service_fee_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
