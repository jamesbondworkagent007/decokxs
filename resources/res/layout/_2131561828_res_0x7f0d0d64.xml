<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/dp24"
    paddingRight="@dimen/dp24"
    layout_width="-1"
    android:layout_height="62dp"
    paddingHorizontal="@dimen/dp24">
    <androidx.appcompat.widget.AppCompatImageView
        gravity="0x10"
        id="@+id/img_icon"
        layout_width="32dp"
        android:layout_height="32dp"
        src="@drawable/_2131232981_res_0x7f0808d5"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.15SP.Medium"
        textColor="@color/okTradeG900"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        includeFontPadding="false"
        layout_marginStart="12dp"
        NOT_FOUND_0x12="@+id/tv_subtitle"
        NOT_FOUND_0x15="@+id/img_icon"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="2"
        style="@style/TextAppearance.Title.15SP.Medium"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/okTradeG500"
        id="@+id/tv_subtitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_2"
        includeFontPadding="false"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x16="@+id/tv_title"
        NOT_FOUND_0x17="@+id/tv_title"
        style="@style/TextAppearance.Text.12SP"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Title.14SP.Medium"
        textColor="@color/positive"
        id="@+id/tv_ratio"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_2"
        includeFontPadding="false"
        layout_marginEnd="@dimen/padding_22dp"
        NOT_FOUND_0x12="@+id/tv_desc"
        NOT_FOUND_0x14="@+id/arrow"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="2"
        style="@style/TextAppearance.Title.14SP.Medium"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/okTradeG500"
        id="@+id/tv_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_2"
        text="@string/pr_trade_general_title_backtest_apy"
        includeFontPadding="false"
        layout_marginEnd="@dimen/padding_22dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="@+id/arrow"
        NOT_FOUND_0x17="@+id/tv_ratio"
        style="@style/TextAppearance.Text.12SP"/>
    <View
        id="@+id/arrow"
        background="@drawable/_2131232353_res_0x7f080661"
        layout_width="@dimen/height_14dp"
        android:layout_height="@dimen/height_14dp"
        backgroundTint="@color/okTradeG300"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x18="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
