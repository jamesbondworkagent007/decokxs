<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x51"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent"
    contentDescription="web3_dex_trade_tab_pop_view">
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_mode"
        background="@drawable/_2131231810_res_0x7f080442"
        paddingLeft="12dp"
        paddingTop="@dimen/padding_10dp"
        paddingRight="12dp"
        paddingBottom="10dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        overScrollMode="2"
        paddingHorizontal="12dp"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="0"
        layout_width="-1"
        android:layout_height="23dp"
        layoutDirection="0">
        <View
            background="@drawable/_2131231852_res_0x7f08046c"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"/>
        <View
            background="@drawable/_2131231307_res_0x7f08024b"
            layout_width="123dp"
            android:layout_height="23dp"
            backgroundTint="@color/dex_trade_pull_up_bg_color"/>
        <View
            background="@drawable/_2131231853_res_0x7f08046d"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <LinearLayout
        gravity="0x1"
        orientation="1"
        id="@+id/ll_bottom"
        paddingBottom="26dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_close"
            layout_width="44dp"
            android:layout_height="44dp"
            src="@drawable/_2131231904_res_0x7f0804a0"
            contentDescription="web3_dex_trade_tab_pop_cancel_button"/>
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
