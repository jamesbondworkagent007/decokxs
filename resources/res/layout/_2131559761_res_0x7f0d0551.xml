<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.airbnb.lottie.LottieAnimationView
        id="@+id/lottie_drag"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginBottom="40dp"
        scaleType="fillCenter"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="0"
            id="@+id/chart_container"
            layout_width="-1"
            android:layout_height="230dp">
            <FrameLayout
                id="@+id/kline_layout"
                layout_width="-1"
                android:layout_height="match_parent"/>
            <com.airbnb.lottie.LottieAnimationView
                id="@+id/lottie_chart"
                visibility="2"
                layout_width="-1"
                android:layout_height="match_parent"
                scaleType="fillCenter"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <FrameLayout
            id="@+id/pull_refresh_group"
            layout_width="-1"
            android:layout_height="60dp">
            <o.C31699mAq
                id="@+id/refresh_view"
                layout_width="-1"
                android:layout_height="match_parent"/>
            <LinearLayout
                gravity="0x11"
                orientation="0"
                id="@+id/pull_to_load_kline"
                visibility="2"
                layout_width="-1"
                android:layout_height="match_parent">
                <o.C22309hct
                    id="@+id/loading_text_img"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    scaleType="6"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.12SP.Regular"
                    textColor="@color/grey_g900"
                    id="@+id/loading_text"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_cefimode_btn_pull_down_to_view"
                    layout_marginStart="@dimen/margin_6dp"/>
            </LinearLayout>
        </FrameLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
</FrameLayout>
