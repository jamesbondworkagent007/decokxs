<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/margin_16dp"
    layout_marginBottom="@dimen/margin_16dp"
    layout_marginVertical="@dimen/margin_16dp">
    <ImageView
        id="@+id/iv_token_logo"
        layout_width="36dp"
        android:layout_height="36dp"
        src="@drawable/_2131231887_res_0x7f08048f"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"/>
    <View
        id="@+id/center_anchor_view"
        layout_width="0dp"
        android:layout_height="2dp"
        layout_marginStart="@dimen/margin_12dp"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0xf="@+id/iv_token_logo"
        NOT_FOUND_0x13="@+id/iv_token_logo"
        NOT_FOUND_0x16="@+id/iv_token_logo"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        ellipsize="2"
        id="@+id/tv_token_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="Token Name"
        maxLines="1"
        layout_marginEnd="12dp"
        NOT_FOUND_0x10="@+id/center_anchor_view"
        NOT_FOUND_0x12="@+id/iv_chain_icon"
        NOT_FOUND_0x14="@+id/center_anchor_view"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_token_address"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        text="0xEQC9..Ajav"
        maxLines="1"
        layout_marginEnd="12dp"
        NOT_FOUND_0x12="@+id/iv_chain_icon"
        NOT_FOUND_0x14="@+id/center_anchor_view"
        NOT_FOUND_0x15="@+id/center_anchor_view"
        style="@style/Label_3_Regular"/>
    <ImageView
        id="@+id/iv_chain_icon"
        layout_width="16dp"
        android:layout_height="16dp"
        src="@drawable/_2131231603_res_0x7f080373"
        layout_marginStart="@dimen/margin_4dp"
        layout_marginEnd="@dimen/xxxsm"
        NOT_FOUND_0xf="@+id/tv_chain_name"
        NOT_FOUND_0x12="@+id/tv_chain_name"
        NOT_FOUND_0x16="@+id/tv_chain_name"/>
    <TextView
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/tv_chain_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        text=""
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x16="0"
        style="@style/Label_1_Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
