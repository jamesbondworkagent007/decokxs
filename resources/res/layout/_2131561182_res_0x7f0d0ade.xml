<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title_fee"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="36dp"
        text="@string/pr_wallet_function_label_network_fee"
        NOT_FOUND_0x8="0"
        NOT_FOUND_0xa="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_content_fee"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x6="@+id/tv_title_fee"
        NOT_FOUND_0x7="0"
        NOT_FOUND_0xa="@+id/tv_title_fee"
        style="@style/Label_1_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title_received"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        text="@string/pr_wallet_function_label_received"
        NOT_FOUND_0x8="0"
        NOT_FOUND_0x9="@+id/tv_title_fee"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_content_received"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x6="@+id/tv_title_received"
        NOT_FOUND_0x7="0"
        NOT_FOUND_0xa="@+id/tv_title_received"
        style="@style/Label_1_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title_failed_convert"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_24dp"
        text="@string/pr_wallet_function_label_unsuccessful"
        NOT_FOUND_0x8="0"
        NOT_FOUND_0x9="@+id/tv_title_received"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/SemanticNotice"
        id="@+id/tv_content_failed_convert"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x6="@+id/tv_title_failed_convert"
        NOT_FOUND_0x7="0"
        NOT_FOUND_0xa="@+id/tv_title_failed_convert"
        style="@style/Label_1_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
