<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        paddingLeft="?attr/horizontalPaddingDimension"
        paddingRight="?attr/horizontalPaddingDimension"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxsm"
        paddingHorizontal="?attr/horizontalPaddingDimension">
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_type"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_token_detail_tab_type"
            style="@style/Label_2_Bold"/>
        <o.C28055kNf
            id="@+id/widget_type_selection"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxsm"
            layout_marginBottom="36dp"/>
        <com.okinc.business.market.widget.time_range_selection.TimeSelectionWidget
            id="@+id/widget_time_selection"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x11"
            orientation="0"
            id="@+id/ll_price_turnover_switch"
            layout_width="-2"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatTextView
                id="@+id/tv_turnover_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_token_detail_textarea_transaction_amount"
                layout_marginEnd="@dimen/xxxxsm"
                style="@style/Label_2_Bold"/>
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/iv_price_turnover_switch"
                visibility="2"
                layout_width="@dimen/width_16dp"
                android:layout_height="@dimen/height_16dp"
                src="@drawable/_2131232098_res_0x7f080562"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentContrast"
            id="@+id/tv_turnover_price_desc"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            text="@string/pr_swaptrade_token_details_filter_desc_turnover_price"
            style="@style/Label_3_Regular"/>
        <FrameLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxsm"
            layout_marginBottom="36dp">
            <o.C28024kMb
                id="@+id/widget_price_range_selection"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <o.C28040kMr
                id="@+id/widget_price_filter_range_selection"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <o.C28044kMv
                id="@+id/widget_time_filter_range_selection"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <o.C28034kMl
                id="@+id/widget_num_filter_range_selection"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <o.C28029kMg
                id="@+id/widget_input_filter_range_selection"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"/>
        </FrameLayout>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_address"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_token_detail_textarea_address"
            style="@style/Label_2_Bold"/>
        <o.C28010kLo
            id="@+id/widget_address_filter"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxsm"
            layout_marginBottom="@dimen/sm"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
