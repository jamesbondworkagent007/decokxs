<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/trade_ui_dialog_contract_dca_make_order_confirm_content_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1">
        <androidx.constraintlayout.widget.ConstraintLayout
            paddingLeft="@dimen/common_page_edge_space"
            paddingTop="20dp"
            paddingRight="@dimen/common_page_edge_space"
            paddingBottom="20dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="@dimen/common_page_edge_space"
            paddingVertical="20dp">
            <TextView
                textAppearance="@style/TextAppearance.Title.14SP.Medium"
                id="@+id/instId"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1e="0"/>
            <o.C55251xgS
                id="@+id/type"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_bot_title_futures_dca"
                NOT_FOUND_0x1f="-5"
                NOT_FOUND_0x21="6"/>
            <o.C55251xgS
                id="@+id/tvDirection"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1f="-5"
                NOT_FOUND_0x21="14"/>
            <o.C55251xgS
                id="@+id/lever"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1f="-5"
                NOT_FOUND_0x21="6"/>
            <o.C55251xgS
                id="@+id/leadOrder"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_bot_tag_tape_sheet"
                NOT_FOUND_0x1f="-5"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x21="10"/>
            <androidx.constraintlayout.helper.widget.Flow
                id="@+id/botTagFlow"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                NOT_FOUND_0x16="type,tvDirection,lever,leadOrder"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="@dimen/padding_6dp"
                NOT_FOUND_0x19="2"
                NOT_FOUND_0x1a="@dimen/padding_4dp"
                NOT_FOUND_0x1b="1"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="@+id/instId"/>
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/contentRv"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_20dp"
                overScrollMode="2"
                NOT_FOUND_0x1d="@+id/botTagFlow"/>
            <LinearLayout
                orientation="1"
                id="@+id/reminderLay"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1d="@+id/contentRv">
                <View
                    id="@+id/view_line"
                    layout_marginTop="11dp"
                    style="@style/WidgetDivisionLine"/>
                <LinearLayout
                    orientation="1"
                    id="@+id/noticeContainerLay"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/ok_dp_16"
                    divider="@drawable/_2131234189_res_0x7f080d8d"
                    showDividers="middle"/>
                <TextView
                    textSize="@dimen/text_size_12sp"
                    textColor="@color/color_content_static_default"
                    id="@+id/expand"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="8dp"
                    text="@string/pr_trade_strategy_header_view_more"/>
            </LinearLayout>
            <o.wYK
                theme="@style/OKUITheme"
                textColor="@color/okTradeG900"
                id="@+id/check_no_show"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="14dp"
                text="@string/pr_options_alert_not_tips"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="@+id/reminderLay"
                NOT_FOUND_0x1f="-4"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
