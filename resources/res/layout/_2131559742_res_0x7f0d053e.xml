<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/header_layout"
    layout_width="-1"
    android:layout_height="wrap_content"
    baselineAligned="false">
    <ImageView
        id="@+id/iv_drawer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="6.5dp"
        layout_marginBottom="2.5dp"
        src="@drawable/_2131232048_res_0x7f080530"
        scaleType="fitEnd"/>
    <LinearLayout
        orientation="0"
        id="@+id/title_layout"
        paddingTop="12dp"
        paddingBottom="12dp"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="wrap_content"
        baselineAligned="false"
        paddingStart="16dp"
        paddingEnd="16dp">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_back"
            background="?attr/selectableItemBackgroundBorderless"
            padding="8dp"
            visibility="2"
            layout_width="40dp"
            android:layout_height="40dp"
            scaleType="fitStart"
            NOT_FOUND_0x1c="@drawable/_2131231642_res_0x7f08039a"
            NOT_FOUND_0x1d="@color/ContentPrimary"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x800013"
            layout_gravity="0x10"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            minHeight="28dp"
            lines="1"
            layout_weight="1"
            textAlignment="5"
            layout_marginStart="8dp"
            layout_marginEnd="8dp"
            style="@style/TextAppearance.Title.18SP.Semibold"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_edit"
            background="?attr/selectableItemBackgroundBorderless"
            padding="8dp"
            visibility="2"
            layout_width="40dp"
            android:layout_height="40dp"
            scaleType="fitStart"
            NOT_FOUND_0x1c="@drawable/_2131232074_res_0x7f08054a"
            NOT_FOUND_0x1d="@color/ContentPrimary"/>
    </LinearLayout>
</LinearLayout>
