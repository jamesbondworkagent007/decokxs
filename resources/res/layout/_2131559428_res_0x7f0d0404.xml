<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/parent_container"
    background="@drawable/_2131231799_res_0x7f080437"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/xxxsm"
    layout_marginBottom="@dimen/xxxxsm"
    clipToOutline="true">
    <ImageView
        id="@+id/iv_background_image"
        visibility="2"
        layout_width="-1"
        android:layout_height="0dp"
        scaleType="6"
        alpha="0.04"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x25="0"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        padding="@dimen/xxsm"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x25="0">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/ll_timestamp"
            paddingLeft="6dp"
            paddingTop="@dimen/xxxxxsm"
            paddingRight="6dp"
            paddingBottom="@dimen/xxxxxsm"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingHorizontal="6dp"
            paddingVertical="@dimen/xxxxxsm"
            NOT_FOUND_0x23="0"
            NOT_FOUND_0x25="0">
            <TextView
                textColor="?attr/defaultProfit"
                id="@+id/tv_signal_time_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_header_signal_time"
                includeFontPadding="false"
                style="@style/Label_3_Medium"/>
            <TextView
                textColor="?attr/defaultProfit"
                id="@+id/tv_timestamp"
                layout_width="-2"
                android:layout_height="wrap_content"
                includeFontPadding="false"
                layout_marginStart="@dimen/xxxxxsm"
                style="@style/Label_3_Medium"/>
        </LinearLayout>
        <o.C29580kwN
            id="@+id/token_icons"
            layout_width="40dp"
            android:layout_height="40dp"
            NOT_FOUND_0x1f="@+id/ll_details"
            NOT_FOUND_0x23="0"
            NOT_FOUND_0x25="@+id/tv_token_symbol"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_token_symbol"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxxsm"
            layout_marginStart="@dimen/xxsm"
            NOT_FOUND_0x20="@+id/ll_details"
            NOT_FOUND_0x22="@+id/token_icons"
            NOT_FOUND_0x24="@+id/ll_timestamp"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tv_token_name"
            layout_width="@dimen/width_0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="@dimen/xxxxsm"
            NOT_FOUND_0x1f="@+id/tv_token_symbol"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x22="@+id/tv_token_symbol"
            NOT_FOUND_0x25="@+id/tv_token_symbol"
            style="@style/Label_2_Regular"/>
        <com.google.android.flexbox.FlexboxLayout
            layout_gravity="0x800003"
            id="@+id/ll_details"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            NOT_FOUND_0x1b="2"
            NOT_FOUND_0x1c="@drawable/_2131231966_res_0x7f0804de"
            NOT_FOUND_0x1d="0"
            NOT_FOUND_0x1e="1"
            NOT_FOUND_0x21="0"
            NOT_FOUND_0x23="@+id/tv_token_symbol"
            NOT_FOUND_0x24="@+id/tv_token_symbol"
            NOT_FOUND_0x26="0x2">
            <TextView
                textColor="?attr/defaultProfit"
                gravity="0x800003"
                layout_gravity="0x10"
                id="@+id/tv_relative_time"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                style="@style/Label_2_Medium"/>
            <ImageView
                layout_gravity="0x10"
                id="@+id/iv_separator"
                layout_width="3dp"
                android:layout_height="3dp"
                src="@drawable/_2131232044_res_0x7f08052c"
                NOT_FOUND_0x27="@color/BorderSecondary"/>
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/tv_market_cap"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_common_label_mcap_abbreviated"
                maxLines="1"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentPrimary"
                layout_gravity="0x10"
                id="@+id/tv_market_cap_before_value"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/Label_2_Medium"/>
            <ImageView
                layout_gravity="0x10"
                layout_width="12dp"
                android:layout_height="12dp"
                src="@drawable/_2131233694_res_0x7f080b9e"
                NOT_FOUND_0x27="@color/ContentContrast"/>
            <LinearLayout
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentBrand"
                    layout_gravity="0x10"
                    id="@+id/tv_market_cap_after_value"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
                <ImageView
                    layout_gravity="0x10"
                    id="@+id/iv_market_cap_trending_logo"
                    layout_width="14dp"
                    android:layout_height="14dp"
                    src="@drawable/_2131234238_res_0x7f080dbe"
                    layout_marginStart="@dimen/xxxxxsm"/>
            </LinearLayout>
        </com.google.android.flexbox.FlexboxLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.compose.ui.platform.ComposeView
        id="@+id/multiplier_tag_compose"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x25="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
