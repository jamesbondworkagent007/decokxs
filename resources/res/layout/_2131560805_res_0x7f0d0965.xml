<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@android:color/transparent"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_default"
    layout_marginRight="@dimen/margin_default"
    layout_marginHorizontal="@dimen/margin_default">
    <com.google.android.material.card.MaterialCardView
        id="@+id/thumbnailCard"
        layout_width="120dp"
        android:layout_height="0dp"
        NOT_FOUND_0xe="4dp"
        NOT_FOUND_0xf="0dp"
        NOT_FOUND_0x10="16:9"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0dp">
        <ImageView
            id="@+id/ivThumbnail"
            background="@color/SurfacePrimary_Dark"
            layout_width="-1"
            android:layout_height="match_parent"
            scaleType="fitStart"/>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tvTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="3"
        layout_marginStart="12dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/thumbnailCard"
        NOT_FOUND_0x15="@+id/thumbnailCard"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tvMetadata"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginStart="12dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/thumbnailCard"
        NOT_FOUND_0x14="@+id/tvTitle"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
