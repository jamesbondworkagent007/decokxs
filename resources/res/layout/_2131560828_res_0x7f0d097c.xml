<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/parametersContainer"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp">
        <ImageView
            id="@+id/iv_coin"
            layout_width="20dp"
            android:layout_height="20dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/TextAppearance.Text.Medium"
            textSize="@dimen/text_size_14sp"
            textColor="@color/ContentPrimary"
            id="@+id/bot_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="5"
            includeFontPadding="false"
            layout_marginStart="4dp"
            NOT_FOUND_0x15="@+id/iv_coin"
            NOT_FOUND_0x17="@+id/iv_coin"
            NOT_FOUND_0x19="@+id/iv_coin"/>
        <TextView
            textAppearance="@style/Body_3"
            textColor="@color/BorderSecondary"
            layout_gravity="0x10"
            id="@+id/divider"
            layout_width="2dp"
            android:layout_height="wrap_content"
            text="|"
            layout_marginStart="8dp"
            NOT_FOUND_0x15="@+id/bot_title"
            NOT_FOUND_0x17="@+id/bot_title"
            NOT_FOUND_0x19="@+id/bot_title"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.Medium"
            textColor="@color/ContentPrimary"
            layout_gravity="0x10"
            id="@+id/percent_tv"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="8dp"
            NOT_FOUND_0x15="@+id/bot_title"
            NOT_FOUND_0x17="@+id/divider"
            NOT_FOUND_0x19="@+id/bot_title"/>
        <com.google.android.flexbox.FlexboxLayout
            id="@+id/current_price_layout"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="1"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x19="0">
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.12SP.Medium"
                textSize="@dimen/text_size_12sp"
                textColor="@color/ContentPrimary"
                layout_gravity="0x10"
                id="@+id/cur_price_value"
                layout_width="-2"
                android:layout_height="wrap_content"
                text=""
                maxLines="4"/>
            <o.wYD
                enabled="true"
                layout_gravity="0x10"
                id="@+id/cur_price_icon"
                visibility="0"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/margin_2dp"
                NOT_FOUND_0x1a="@drawable/_2131231584_res_0x7f080360"
                NOT_FOUND_0x1b="2"
                NOT_FOUND_0x1c="-4"/>
        </com.google.android.flexbox.FlexboxLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="0"
        id="@+id/param_row_1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp">
        <LinearLayout
            gravity="0x800003"
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="0.5">
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textSize="@dimen/text_size_12sp"
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_price_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_list_price_range"
                maxLines="3"
                includeFontPadding="false"/>
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.14SP.Medium"
                textSize="@dimen/text_size_14sp"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_price"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="5"
                includeFontPadding="false"/>
        </LinearLayout>
        <Space
            layout_width="12dp"
            android:layout_height="1dp"/>
        <LinearLayout
            gravity="0x800005"
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="0.5">
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textSize="@dimen/text_size_12sp"
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_cumulated_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_tab_bots_recurring_tractics_total_buy_amt"
                maxLines="3"
                includeFontPadding="false"/>
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.14SP.Medium"
                textSize="@dimen/text_size_14sp"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_cumulated"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="5"
                includeFontPadding="false"/>
        </LinearLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="0"
        id="@+id/param_row_2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="10dp">
        <LinearLayout
            gravity="0x800003"
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="0.5">
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textSize="@dimen/text_size_12sp"
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_pnl_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="3"
                includeFontPadding="false"/>
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.14SP.Medium"
                textSize="@dimen/text_size_14sp"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_pnl"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="5"
                includeFontPadding="false"/>
        </LinearLayout>
        <Space
            layout_width="12dp"
            android:layout_height="1dp"/>
        <LinearLayout
            gravity="0x800005"
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="0.5">
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textSize="@dimen/text_size_12sp"
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_average_price_Label"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="3"
                includeFontPadding="false"/>
            <o.C55320xhi
                textAppearance="@style/TextAppearance.Text.14SP.Medium"
                textSize="@dimen/text_size_14sp"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_average_price"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="5"
                includeFontPadding="false"/>
        </LinearLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <View
        id="@+id/v_line"
        layout_marginTop="16dp"
        style="@style/SingleLine"/>
</androidx.appcompat.widget.LinearLayoutCompat>
