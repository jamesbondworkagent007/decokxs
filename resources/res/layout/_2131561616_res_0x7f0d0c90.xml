<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/ll_view"
    background="@drawable/_2131233402_res_0x7f080a7a"
    paddingLeft="@dimen/dp_8"
    paddingTop="@dimen/dp_2"
    paddingRight="@dimen/dp_8"
    paddingBottom="@dimen/dp_2"
    layout_width="130dp"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/dp_8"
    paddingVertical="@dimen/dp_2">
    <TextView
        textSize="10sp"
        textColor="@color/okTradeG900"
        id="@+id/tv_time"
        layout_width="-2"
        android:layout_height="wrap_content"
        textAlignment="5"
        style="@style/TextAppearance"/>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_3">
        <TextView
            textSize="10sp"
            textColor="@color/okTradeG900"
            gravity="0x10"
            id="@+id/tv_ratio_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_tradechart_charts_label_ratio"
            layout_weight="1"
            style="@style/TextAppearance"/>
        <TextView
            textSize="10sp"
            textColor="@color/okTradeG900"
            gravity="0x10"
            id="@+id/tv_ratio"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="--"
            style="@style/TextAppearance"/>
    </LinearLayout>
</LinearLayout>
