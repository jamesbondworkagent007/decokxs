<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x800015"
        paddingLeft="@dimen/margin_default"
        paddingTop="@dimen/dp_8"
        paddingRight="@dimen/margin_default"
        paddingBottom="@dimen/dp_8"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_default"
        paddingVertical="@dimen/dp_8">
        <ImageView
            layout_width="12dp"
            android:layout_height="12dp"
            src="@drawable/_2131233701_res_0x7f080ba5"
            NOT_FOUND_0x10="@color/SemanticNotice"/>
        <TextView
            textColor="@color/ContentDisabled"
            id="@+id/tv_barline_value"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_vibes_details_textarea_price"
            layout_marginStart="4dp"
            style="@style/Label_3_Regular"/>
        <ImageView
            layout_width="12dp"
            android:layout_height="12dp"
            src="@drawable/_2131233148_res_0x7f08097c"
            layout_marginStart="10dp"
            NOT_FOUND_0x10="#9ade62"/>
        <TextView
            textColor="@color/ContentDisabled"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_vibes_details_title_vibe_score"
            layout_marginStart="4dp"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <o.kBK
        id="@+id/chart_vibes"
        paddingTop="@dimen/dp_8"
        paddingBottom="@dimen/dp_8"
        layout_width="-1"
        android:layout_height="325dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        paddingVertical="@dimen/dp_8"/>
</LinearLayout>
