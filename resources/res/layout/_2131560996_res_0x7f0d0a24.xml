<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/account_icon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginTop="@dimen/dp_12"
        layout_marginBottom="@dimen/dp_12"
        src="@drawable/_2131234113_res_0x7f080d41"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_1_Medium"
        textColor="?attr/wallet_switch_color_g700"
        ellipsize="3"
        id="@+id/account_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_10dp"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x13="@+id/account_address"
        NOT_FOUND_0x15="@+id/iv_tee_status"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="2"
        NOT_FOUND_0x18="@+id/account_icon"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1c="2"
        NOT_FOUND_0x1d="@dimen/margin_10dp"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_tee_status"
        visibility="2"
        layout_width="20dp"
        android:layout_height="20dp"
        layout_marginBottom="1dp"
        layout_marginStart="4dp"
        NOT_FOUND_0x12="@+id/account_name"
        NOT_FOUND_0x15="@+id/selected_icon"
        NOT_FOUND_0x18="@+id/account_name"
        NOT_FOUND_0x1b="@+id/account_name"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_2_Regular"
        textColor="?attr/wallet_switch_color_g400"
        id="@+id/account_address"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        layout_marginBottom="@dimen/margin_10dp"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="@+id/selected_icon"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x19="@+id/account_name"
        NOT_FOUND_0x1a="@+id/account_name"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/selected_icon"
        visibility="2"
        layout_width="34dp"
        android:layout_height="18dp"
        src="@drawable/_2131232891_res_0x7f08087b"
        paddingStart="16dp"
        paddingEnd="0dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x1b="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
