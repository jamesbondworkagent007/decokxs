<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="60dp"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_12dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_fav"
        paddingTop="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="@dimen/width_32dp"
        android:layout_height="wrap_content"
        src="@drawable/_2131233467_res_0x7f080abb"
        scaleType="7"
        paddingStart="0dp"
        paddingEnd="8dp"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="@color/selector_star_content_constrast"/>
    <TextView
        textSize="15sp"
        textColor="@color/title_color"
        gravity="0x800013"
        id="@+id/tv_strike"
        layout_width="-2"
        android:layout_height="match_parent"
        text="@string/pr_market_colheader_all_strike"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1a="@+id/iv_fav"
        NOT_FOUND_0x1d="0"
        style="@style/TextAppearance.MeDium"/>
    <TextView
        id="@+id/tv_trade_type"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_market_colheader_all_type"
        maxLines="2"
        layout_marginStart="100dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"
        style="@style/TextAppearance.Title.15SP.Medium"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.15SP.Medium"
        id="@+id/tv_mark_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_market_colheader_mark_price"
        NOT_FOUND_0x18="@+id/tv_percent"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="2"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.12SP.Medium"
        layout_gravity="0x800005"
        id="@+id/tv_percent"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="@string/pr_trade_perp_confirm_modal_label_change"
        maxLines="1"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1c="@+id/tv_mark_price"/>
</androidx.constraintlayout.widget.ConstraintLayout>
