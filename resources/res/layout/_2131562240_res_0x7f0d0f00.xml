<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        paddingLeft="@dimen/margin_default"
        paddingTop="6dp"
        paddingRight="@dimen/margin_default"
        paddingBottom="24dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_default">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/titleTv"
            layout_width="-1"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Title.Bold.20SP"/>
        <androidx.compose.ui.platform.ComposeView
            id="@+id/composeView"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="24dp"/>
        <o.uBL
            id="@+id/tradeWith"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"/>
        <o.C53539wnR
            id="@+id/availableTextView"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            NOT_FOUND_0x11="true"
            NOT_FOUND_0x12="@string/pr_marginbot_footer_data_available"
            NOT_FOUND_0x13="--"/>
        <o.wYE
            id="@+id/customParamTv"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            text="@string/pr_marketplace_botdetails_modaltitle_custom_parameter"
            NOT_FOUND_0x16="-5"
            NOT_FOUND_0x18="1"
            NOT_FOUND_0x19="1"/>
        <com.okinc.uilab.reminder.OKReminder
            id="@+id/reminder"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="24dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <FrameLayout
        id="@+id/loadingView"
        background="@color/background_BasePrimary_BaseSecondary"
        layout_width="-1"
        android:layout_height="match_parent">
        <o.C55113xdn
            layout_gravity="0x11"
            id="@+id/loading"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="true"
            NOT_FOUND_0x15="true"/>
    </FrameLayout>
    <o.C55173xeu
        id="@+id/emptyView"
        background="@color/background_BasePrimary_BaseSecondary"
        paddingTop="96dp"
        paddingBottom="96dp"
        layout_width="-1"
        android:layout_height="match_parent"
        paddingVertical="96dp"
        NOT_FOUND_0x10="9"
        NOT_FOUND_0x17="@string/pr_trade_empty_error_title"/>
</FrameLayout>
