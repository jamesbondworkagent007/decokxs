<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp">
    <ImageView
        id="@+id/icon"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginTop="12dp"
        importantForAccessibility="2"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="4dp"
        NOT_FOUND_0xf="@+id/icon"
        NOT_FOUND_0x13="@+id/icon"
        NOT_FOUND_0x16="@+id/icon"
        style="@style/Label_3_Medium"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/titleLayout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="@+id/icon"
        NOT_FOUND_0x15="@+id/icon">
        <TextView
            textSize="10dp"
            textColor="@color/ContentContrast"
            id="@+id/unlockedTitle"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_discover_title_unlocked"
            NOT_FOUND_0x11="@+id/nextUnlockTitle"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"
            style="@style/Label_4_Regular"/>
        <TextView
            textSize="10dp"
            textColor="@color/ContentContrast"
            id="@+id/nextUnlockTitle"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_discover_title_next_unlock"
            layout_marginStart="8dp"
            NOT_FOUND_0x11="@+id/lockedOrUntrackedTitle"
            NOT_FOUND_0x13="@+id/unlockedTitle"
            NOT_FOUND_0x16="@+id/unlockedTitle"
            style="@style/Label_4_Regular"/>
        <TextView
            textSize="10dp"
            textColor="@color/ContentContrast"
            id="@+id/lockedOrUntrackedTitle"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trade_discover_lockeduntracked"
            layout_marginStart="8dp"
            NOT_FOUND_0x10="0"
            NOT_FOUND_0x13="@+id/nextUnlockTitle"
            NOT_FOUND_0x16="@+id/nextUnlockTitle"
            style="@style/Label_4_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/unlockedTitleValue"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x11="@+id/nextUnlockTitleValue"
        NOT_FOUND_0x14="@+id/titleLayout"
        NOT_FOUND_0x15="@+id/titleLayout"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentSecondary"
        id="@+id/unlockedValuePercentage"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x14="@+id/unlockedTitleValue"
        NOT_FOUND_0x15="@+id/unlockedTitleValue"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/SemanticNotice"
        id="@+id/nextUnlockTitleValue"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginStart="8dp"
        NOT_FOUND_0x11="@+id/lockedOrUntrackedTitleValue"
        NOT_FOUND_0x13="@+id/unlockedTitleValue"
        NOT_FOUND_0x15="@+id/titleLayout"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/SemanticNotice"
        id="@+id/nextUnlockValuePercentage"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x14="@+id/nextUnlockTitleValue"
        NOT_FOUND_0x15="@+id/nextUnlockTitleValue"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentTertiary"
        id="@+id/lockedOrUntrackedTitleValue"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginStart="8dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="@+id/nextUnlockTitleValue"
        NOT_FOUND_0x15="@+id/titleLayout"
        style="@style/Label_3_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentTertiary"
        id="@+id/lockedOrUntrackedValuePercentage"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x14="@+id/lockedOrUntrackedTitleValue"
        NOT_FOUND_0x15="@+id/lockedOrUntrackedTitleValue"
        style="@style/Label_3_Regular"/>
    <View
        id="@+id/lockedOrUntrackedProgressView"
        background="@drawable/_2131233442_res_0x7f080aa2"
        layout_width="0dp"
        android:layout_height="4dp"
        layout_marginTop="4dp"
        layout_marginBottom="12dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="@+id/unlockedValuePercentage"
        NOT_FOUND_0x15="@+id/unlockedValuePercentage"/>
    <View
        id="@+id/nextUnlockedProgressView"
        background="@drawable/_2131233440_res_0x7f080aa0"
        layout_width="0dp"
        android:layout_height="4dp"
        NOT_FOUND_0x10="@+id/lockedOrUntrackedProgressView"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/lockedOrUntrackedProgressView"
        NOT_FOUND_0x16="@+id/lockedOrUntrackedProgressView"/>
    <View
        id="@+id/unlockedProgressView"
        background="@drawable/_2131233441_res_0x7f080aa1"
        layout_width="0dp"
        android:layout_height="4dp"
        NOT_FOUND_0x10="@+id/lockedOrUntrackedProgressView"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/nextUnlockedProgressView"
        NOT_FOUND_0x16="@+id/nextUnlockedProgressView"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentContrast"
        id="@+id/time"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginBottom="24dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x14="@+id/lockedOrUntrackedProgressView"
        NOT_FOUND_0x16="@+id/lockedOrUntrackedProgressView"
        style="@style/Label_4_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
