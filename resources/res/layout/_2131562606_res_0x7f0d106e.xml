<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.okinc.uilab.edit.OKEditText
        textAppearance="@style/TextAppearance.Text.14SP"
        textSize="@dimen/text_size_14sp"
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/etSearch"
        background="@drawable/_2131231357_res_0x7f08027d"
        paddingTop="@dimen/dp_10"
        paddingBottom="@dimen/dp_10"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="14dp"
        hint="@string/pr_trade_general_fieldtext_search_crypto"
        maxLines="1"
        drawablePadding="4dp"
        drawableStart="@drawable/search"
        paddingStart="12dp"
        paddingEnd="6dp"
        drawableTint="@color/okTradeG900"
        paddingVertical="@dimen/dp_10"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/coinListRv"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="@dimen/dp_8"
        overScrollMode="2"
        NOT_FOUND_0x14="androidx.recyclerview.widget.LinearLayoutManager"/>
</merge>
