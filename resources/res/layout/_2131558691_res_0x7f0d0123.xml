<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/activity_select_membership_fee_0"
    fitsSystemWindows="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        layout_gravity="0x37"
        id="@+id/toolbar"
        background="@color/BasePrimary"
        layout_width="-1"
        android:layout_height="wrap_content"
        elevation="0dp">
        <TextView
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/toolbar_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/Title_2_Bold"/>
    </androidx.appcompat.widget.Toolbar>
    <FrameLayout
        id="@+id/fragment_container"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"/>
</LinearLayout>
