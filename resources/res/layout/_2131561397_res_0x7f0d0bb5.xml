<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/item"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="16dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="16dp">
    <o.wYC
        id="@+id/ic_select"
        visibility="0"
        layout_width="22dp"
        android:layout_height="22dp"
        layout_marginEnd="@dimen/ok_dp_16"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/imgAccountIcon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginStart="8dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1e="@+id/ic_select"
        NOT_FOUND_0x21="0"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tvWalletReceiveAddressName"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="12dp"
        NOT_FOUND_0x17="true"
        NOT_FOUND_0x19="@+id/tvWalletReceiveAddress"
        NOT_FOUND_0x1b="@+id/tag_address"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="2"
        NOT_FOUND_0x1e="@+id/imgAccountIcon"
        NOT_FOUND_0x21="0"
        style="@style/Label_1_Medium"/>
    <LinearLayout
        id="@+id/tag_address"
        background="@drawable/_2131231406_res_0x7f0802ae"
        paddingTop="@dimen/padding_2dp"
        paddingBottom="@dimen/padding_2dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingStart="@dimen/dp_4"
        paddingEnd="@dimen/dp_4"
        layout_marginStart="6dp"
        paddingVertical="@dimen/padding_2dp"
        NOT_FOUND_0x18="@+id/tvWalletReceiveAddressName"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1e="@+id/tvWalletReceiveAddressName"
        NOT_FOUND_0x21="@+id/tvWalletReceiveAddressName">
        <TextView
            textSize="10sp"
            textColor="@color/ContentSecondary"
            id="@+id/tag_address_content"
            layout_width="-2"
            android:layout_height="wrap_content"
            textAlignment="4"
            style="@style/Label_4_Regular"/>
        <o.wYC
            layout_gravity="0x10"
            id="@+id/address_right_arrow"
            visibility="2"
            layout_width="12dp"
            android:layout_height="12dp"
            src="@drawable/_2131231647_res_0x7f08039f"
            layout_marginStart="2dp"
            NOT_FOUND_0x22="@color/ContentPrimary"/>
    </LinearLayout>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tvWalletReceiveAddress"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        maxLines="2"
        NOT_FOUND_0x17="true"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1f="@+id/tvWalletReceiveAddressName"
        NOT_FOUND_0x20="@+id/tvWalletReceiveAddressName"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
