<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        orientation="1"
        id="@+id/option_chain_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/option_chain_item"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginTop="-10dp"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/simple_mode_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/simple_mode_item"
            layout_width="-1"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <FrameLayout
        id="@+id/chance_reload_view"
        background="@color/white_background_color"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"/>
</LinearLayout>
