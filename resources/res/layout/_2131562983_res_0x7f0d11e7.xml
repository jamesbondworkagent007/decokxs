<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    background="@drawable/_2131231214_res_0x7f0801ee"
    layout_width="-1"
    android:layout_height="match_parent">
    <ImageView
        id="@+id/iv_search_icon"
        layout_width="20dp"
        android:layout_height="20dp"
        layout_marginStart="8dp"
        layout_marginEnd="6dp"
        NOT_FOUND_0x16="@drawable/search"
        NOT_FOUND_0x17="@color/ContentTertiary"/>
    <HorizontalScrollView
        id="@+id/scroll_view"
        scrollbars="horizontal"
        layout_width="0dp"
        android:layout_height="match_parent"
        fillViewport="true"
        layout_weight="1">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/chip_group"
            layout_width="-2"
            android:layout_height="match_parent">
            <o.C27275jsC
                theme="@style/OKUITheme.Alternative.Web3"
                textSize="@dimen/text_size_14sp"
                textColor="@color/ContentPrimary"
                textColorHint="@color/ContentDisabled"
                gravity="0x800013"
                id="@+id/edt_chip"
                background="@android:color/transparent"
                focusableInTouchMode="true"
                layout_width="-1"
                android:layout_height="match_parent"
                hint="@string/pr_investsearch_header_search_token_protocol"
                inputType="0x80001"
                imeOptions="0x10000006"
                textAlignment="5"/>
        </LinearLayout>
    </HorizontalScrollView>
    <View
        id="@+id/edt_expand"
        layout_width="8dp"
        android:layout_height="match_parent"/>
    <ImageView
        id="@+id/iv_clear"
        visibility="2"
        layout_width="24dp"
        android:layout_height="24dp"
        src="@drawable/_2131231668_res_0x7f0803b4"
        layout_marginEnd="12dp"
        NOT_FOUND_0x17="@color/ContentDisabled"/>
</LinearLayout>
