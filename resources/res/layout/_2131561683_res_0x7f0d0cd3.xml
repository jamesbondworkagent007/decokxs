<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@drawable/_2131233433_res_0x7f080a99"
    paddingLeft="12dp"
    paddingTop="11dp"
    paddingRight="12dp"
    paddingBottom="11dp"
    layout_width="260dp"
    android:layout_height="102dp"
    paddingHorizontal="12dp"
    paddingVertical="11dp">
    <ImageView
        id="@+id/icon"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentContrast"
        id="@+id/currencyName"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="8dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0x15="@+id/icon"
        NOT_FOUND_0x17="@+id/icon"
        NOT_FOUND_0x1a="@+id/icon"
        style="@style/Label_3_Regular"/>
    <TextView
        id="@+id/profit"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="4dp"
        NOT_FOUND_0x14="@+id/currencyName"
        NOT_FOUND_0x17="@+id/currencyName"
        style="@style/Label_2_Medium"/>
    <TextView
        textSize="10dp"
        textColor="@color/white"
        id="@+id/tag"
        background="@drawable/_2131233434_res_0x7f080a9a"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingHorizontal="4dp"
        paddingVertical="2dp"
        NOT_FOUND_0x15="@+id/icon"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="@+id/icon"
        style="@style/Label_4_Regular"/>
    <TextView
        textSize="14dp"
        textColor="@color/ContentSecondary"
        ellipsize="3"
        id="@+id/content"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        autoSizeTextType="uniform"
        autoSizeMinTextSize="10sp"
        NOT_FOUND_0x13="true"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="@+id/currencyName"
        NOT_FOUND_0x19="@+id/icon"
        style="@style/Label_2_Regular"/>
    <TextView
        textSize="12dp"
        textColor="@color/ContentContrast"
        id="@+id/timeDes"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x18="@+id/content"
        style="@style/Label_3_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
