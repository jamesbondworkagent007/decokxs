<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/container"
    tag="layout/layout_item_nft_audio_picker_0"
    layout_width="-1"
    android:layout_height="@dimen/height_72dp">
    <ImageView
        layout_gravity="0x10"
        id="@+id/icon"
        layout_width="32dp"
        android:layout_height="32dp"/>
    <LinearLayout
        layout_gravity="0x10"
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="48dp">
        <TextView
            textAppearance="@style/TextAppearance.Text.15SP.Medium"
            textColor="@color/grey_g900"
            id="@+id/name"
            layout_width="-2"
            android:layout_height="wrap_content"/>
        <LinearLayout
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_2dp">
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/grey_g400"
                id="@+id/time"
                layout_width="-2"
                android:layout_height="wrap_content"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP.Regular"
                textColor="@color/grey_g400"
                gravity="0x5"
                id="@+id/size"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="5dp"/>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        layout_gravity="0x15"
        id="@+id/choosed"
        visibility="2"
        layout_width="22dp"
        android:layout_height="22dp"
        src="@drawable/_2131232476_res_0x7f0806dc"/>
</FrameLayout>
