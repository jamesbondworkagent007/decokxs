<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_title_common_order_info"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_swaptrade_limit_colheader_executed_price"
        drawablePadding="@dimen/padding_4dp"
        NOT_FOUND_0xd="@color/ContentContrast"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="-4"/>
    <ImageView
        id="@+id/common_order_info_icon"
        visibility="2"
        layout_width="@dimen/ok_dp_16"
        android:layout_height="@dimen/ok_dp_16"
        src="@drawable/_2131231496_res_0x7f080308"
        layout_marginEnd="@dimen/margin_6dp"
        NOT_FOUND_0xe="@+id/tv_common_order_info"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/tv_common_order_info"/>
    <View
        id="@+id/icon_spacer"
        visibility="2"
        layout_width="6dp"
        android:layout_height="0dp"
        NOT_FOUND_0xe="@+id/common_order_info_icon"
        NOT_FOUND_0x11="@+id/common_order_info_icon"
        NOT_FOUND_0x14="@+id/common_order_info_icon"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_1_Regular"
        ellipsize="3"
        id="@+id/tv_common_order_info"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="3"
        NOT_FOUND_0xd="@color/ContentContrast"
        NOT_FOUND_0x11="@+id/icon_spacer"
        NOT_FOUND_0x13="@+id/tv_title_common_order_info"/>
</androidx.constraintlayout.widget.ConstraintLayout>
