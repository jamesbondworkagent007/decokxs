<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    padding="12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        id="@+id/ll_total"
        clickable="false"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/typeIcon"
            clickable="false"
            layout_width="16dp"
            android:layout_height="16dp"
            layout_marginEnd="8dp"/>
        <LinearLayout
            layout_gravity="0x800013"
            orientation="1"
            id="@+id/content"
            clickable="false"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginEnd="24dp">
            <TextView
                id="@+id/titleLabel"
                visibility="2"
                clickable="false"
                layout_width="-2"
                android:layout_height="wrap_content"
                includeFontPadding="false"
                textAlignment="5"
                breakStrategy="0"/>
            <TextView
                textSize="12sp"
                id="@+id/messageLabel"
                visibility="2"
                clickable="false"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                includeFontPadding="false"
                textAlignment="5"
                breakStrategy="0"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        id="@+id/functionContainer"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_below="@+id/ll_total"
        layout_marginStart="4dp">
        <o.C52794wYp
            id="@+id/primaryButton"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            NOT_FOUND_0x12="32"
            NOT_FOUND_0x13="0x31"/>
        <o.C52794wYp
            id="@+id/secondaryButton"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            NOT_FOUND_0x12="32"
            NOT_FOUND_0x13="0x31"/>
    </LinearLayout>
    <ImageView
        id="@+id/functionIcon"
        layout_width="20dp"
        android:layout_height="20dp"
        layout_alignParentEnd="true"/>
</merge>
