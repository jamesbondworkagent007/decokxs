<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/view_coin_detail_trade_pnl_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="20sp"
        textColor="@color/ContentPrimary"
        id="@+id/tvTitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="20dp"
        layout_marginRight="24dp"
        text="@string/pr_wallet_mid_title_trading_performance"
        layout_marginHorizontal="24dp"
        NOT_FOUND_0x11="true"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        style="@style/Title_1_Bold"/>
    <LinearLayout
        orientation="1"
        id="@+id/layoutTotal"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginStart="24dp"
        NOT_FOUND_0x14="@+id/space"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tvTitle">
        <TextView
            textSize="14sp"
            textColor="@color/ContentTertiary"
            ellipsize="3"
            id="@+id/tvTotalTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_assets_regularcell_label_tpnl"
            maxLines="1"
            style="@style/Label_2_Regular"/>
        <TextView
            textSize="18sp"
            textColor="@color/SemanticNegative"
            ellipsize="3"
            id="@+id/tvTotalPnl"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            maxLines="1"
            style="@style/Title_2_Medium"/>
        <TextView
            textSize="14sp"
            textColor="@color/SemanticNegative"
            ellipsize="3"
            id="@+id/tvTotalPnlPercentage"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            maxLines="1"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
    <View
        id="@+id/space"
        layout_width="24dp"
        android:layout_height="1dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/tvTitle"/>
    <LinearLayout
        orientation="1"
        id="@+id/layoutRealized"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="@+id/space"
        NOT_FOUND_0x17="@+id/tvTitle">
        <TextView
            textSize="14sp"
            textColor="@color/ContentTertiary"
            ellipsize="3"
            id="@+id/tvRealizedTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_assets_regularcell_label_realized_pnl"
            maxLines="1"
            style="@style/Label_2_Regular"/>
        <TextView
            textSize="18sp"
            textColor="@color/SemanticPositive"
            ellipsize="3"
            id="@+id/tvRealizedPnl"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            maxLines="1"
            style="@style/Title_2_Medium"/>
        <TextView
            textSize="14sp"
            textColor="@color/SemanticPositive"
            ellipsize="3"
            id="@+id/tvRealizedPnlPercentage"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            maxLines="1"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
    <View
        id="@+id/bottom_divider"
        background="@color/BorderSecondary"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="20dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x17="@+id/layoutTotal"/>
</androidx.constraintlayout.widget.ConstraintLayout>
