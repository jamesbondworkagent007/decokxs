<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/card"
    tag="layout/fragment_popup_announcement_dialog_0"
    background="@drawable/_2131230986_res_0x7f08010a"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.core.widget.NestedScrollView
        scrollbarStyle="insideOverlay"
        id="@+id/scroll_container"
        scrollbars="0x200"
        layout_width="0dp"
        android:layout_height="wrap_content"
        fillViewport="true"
        overScrollMode="2"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0">
        <LinearLayout
            orientation="1"
            id="@+id/scroll_content"
            paddingLeft="24dp"
            paddingTop="32dp"
            paddingRight="24dp"
            paddingBottom="32dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="24dp"
            paddingVertical="32dp">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                id="@+id/tag_container"
                background="@drawable/_2131231560_res_0x7f080348"
                paddingLeft="8dp"
                paddingTop="4dp"
                paddingRight="8dp"
                paddingBottom="4dp"
                layout_width="-2"
                android:layout_height="wrap_content"
                minHeight="24dp"
                paddingHorizontal="8dp"
                paddingVertical="4dp">
                <ImageView
                    id="@+id/tag_icon"
                    layout_width="16dp"
                    android:layout_height="16dp"
                    src="@drawable/_2131233378_res_0x7f080a62"
                    contentDescription="@null"
                    NOT_FOUND_0x21="@color/ContentAlwaysDark"/>
                <TextView
                    textColor="@color/color_global_fixed_alwaysDark"
                    id="@+id/tag_text"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_supportcenter_landing_tag_important_update"
                    maxLines="1"
                    layout_marginStart="2dp"
                    style="@style/Label_3_Bold"/>
            </LinearLayout>
            <TextView
                textColor="@color/color_content_static_default"
                id="@+id/tv_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                style="@style/Headline_5_Bold"/>
            <TextView
                textColor="@color/color_content_static_subtle"
                id="@+id/tv_content"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="12dp"
                style="@style/Body_2_Regular"/>
            <o.C52794wYp
                id="@+id/bt_cta"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                NOT_FOUND_0x1f="52"
                NOT_FOUND_0x20="0x103"/>
            <o.C52794wYp
                id="@+id/bt_got_it"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                text="@string/pr_supportcenter_landing_btn_got_it"
                NOT_FOUND_0x1f="52"
                NOT_FOUND_0x20="0x104"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <View
        id="@+id/top_gradient"
        background="@drawable/_2131231306_res_0x7f08024a"
        visibility="1"
        layout_width="0dp"
        android:layout_height="32dp"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="0"/>
    <View
        id="@+id/bottom_gradient"
        background="@drawable/_2131231304_res_0x7f080248"
        visibility="1"
        layout_width="0dp"
        android:layout_height="32dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"/>
    <LinearLayout
        gravity="0x11"
        orientation="0"
        id="@+id/btn_scroll_to_read_more"
        background="@drawable/_2131231305_res_0x7f080249"
        paddingLeft="12dp"
        paddingTop="8dp"
        paddingRight="12dp"
        paddingBottom="8dp"
        visibility="1"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingHorizontal="12dp"
        paddingVertical="8dp"
        NOT_FOUND_0x1b="@+id/bottom_gradient"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0">
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131233692_res_0x7f080b9c"
            NOT_FOUND_0x21="@color/color_content_static_inverse"
            NOT_FOUND_0x22="5"/>
        <TextView
            textColor="@color/color_content_static_inverse"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_landing_label_scroll_read"
            layout_marginStart="4dp"
            style="@style/Label_3_Medium"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
