<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_current_pair"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_colheader_sort_pair"
        maxLines="1"
        layout_marginStart="@dimen/margin_24dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        style="@style/TextAppearance.Text.12SP"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/tv_slash_symbol_turnover"
        paddingLeft="0dp"
        paddingRight="0dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="/"
        drawablePadding="0dp"
        paddingHorizontal="0dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="@+id/tv_current_pair"
        NOT_FOUND_0x14="0"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/tv_sort_turnover"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_cedefi_colheader_turnover"
        drawablePadding="0dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="@+id/tv_slash_symbol_turnover"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        style="@style/OkSortBar"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/tv_sort_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_colheader_last_price"
        drawablePadding="0dp"
        layout_marginStart="@dimen/margin_16dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="@+id/tv_slash_symbol"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        style="@style/OkSortBar"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x11"
        id="@+id/tv_slash_symbol"
        paddingLeft="2dp"
        paddingRight="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="/"
        drawablePadding="0dp"
        paddingHorizontal="2dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="@+id/tv_sort_change"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"/>
    <com.okinc.uilab.view.OKSortTextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textColor="@color/ContentContrast"
        gravity="0x800015"
        id="@+id/tv_sort_change"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_demotrade_colheader_change_today"
        drawablePadding="0dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        style="@style/OkSortBar"/>
</merge>
