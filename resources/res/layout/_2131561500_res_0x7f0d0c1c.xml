<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/layout_toolbar_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.Toolbar
        id="@+id/bar"
        background="@color/transparent"
        layout_width="-1"
        android:layout_height="44dp"
        elevation="0dp"
        NOT_FOUND_0x17="0dp"
        NOT_FOUND_0x18="0dp"
        NOT_FOUND_0x19="0dp"
        NOT_FOUND_0x1a="0dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="@null">
        <androidx.constraintlayout.widget.ConstraintLayout
            paddingLeft="?attr/pageMargin"
            paddingRight="?attr/pageMargin"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="?attr/pageMargin">
            <ImageButton
                layout_gravity="0x800003"
                id="@+id/back_button"
                background="@color/transparent"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="?attr/backButton"
                contentDescription="navigationIcon"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x22="?attr/primaryTextColor"/>
            <TextView
                textAppearance="@style/TextAppearance.Title.Bold.18SP"
                ellipsize="3"
                gravity="0x11"
                layout_gravity="0x11"
                id="@+id/title"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_16dp"
                layout_marginRight="@dimen/margin_16dp"
                maxLines="2"
                layout_marginHorizontal="@dimen/margin_16dp"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1d="@+id/close_button"
                NOT_FOUND_0x1e="@+id/back_button"
                NOT_FOUND_0x20="0"/>
            <ImageView
                layout_gravity="0x800005"
                id="@+id/close_button"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131232489_res_0x7f0806e9"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x20="0"/>
            <TextView
                textAppearance="@style/Label_1_Medium"
                id="@+id/tv_skip_cta"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x20="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>
    <o.C55172xet
        id="@+id/progressIndicator"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginLeft="?attr/pageMargin"
        layout_marginTop="?attr/indicator_marginTop"
        layout_marginRight="?attr/pageMargin"
        layout_marginBottom="20dp"
        layout_marginHorizontal="?attr/pageMargin"/>
</LinearLayout>
