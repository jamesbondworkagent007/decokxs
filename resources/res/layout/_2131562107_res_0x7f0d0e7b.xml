<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="130dp">
    <com.google.android.material.divider.MaterialDivider
        id="@+id/divider"
        layout_width="-1"
        android:layout_height="@dimen/dp_0.5"
        NOT_FOUND_0x11="@color/BorderPrimary"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"/>
    <LinearLayout
        gravity="0x1"
        orientation="1"
        id="@+id/add"
        paddingBottom="@dimen/padding_14dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_32"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0">
        <ImageView
            background="@drawable/_2131231071_res_0x7f08015f"
            layout_width="48dp"
            android:layout_height="48dp"
            src="@drawable/_2131231577_res_0x7f080359"
            scaleType="fitEnd"/>
        <TextView
            textAppearance="@style/Button"
            textSize="12sp"
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="@string/pr_social_post_btn_select_camera"
            maxLines="1"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x1"
        orientation="1"
        id="@+id/gallery"
        paddingBottom="@dimen/padding_14dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="40dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/add"
        NOT_FOUND_0x16="0">
        <ImageView
            background="@drawable/_2131231071_res_0x7f08015f"
            layout_width="48dp"
            android:layout_height="48dp"
            src="@drawable/_2131234272_res_0x7f080de0"
            scaleType="fitEnd"/>
        <TextView
            textAppearance="@style/Button"
            textSize="12sp"
            textColor="@color/ContentPrimary"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="@string/pr_social_post_btn_select_library"
            maxLines="1"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
