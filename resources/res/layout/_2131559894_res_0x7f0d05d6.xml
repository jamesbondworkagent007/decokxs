<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="327dp">
    <LinearLayout
        gravity="0x10"
        id="@+id/list_header"
        layout_marginTop="@dimen/margin_10dp"
        layout_marginBottom="@dimen/margin_10dp"
        style="@style/HLinearHFill">
        <LinearLayout
            layout_width="@dimen/width_0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textSize="12sp"
                textColor="@color/ContentContrast"
                gravity="0x800003"
                id="@+id/chart_deal_time"
                layout_width="@dimen/width_0dp"
                android:layout_height="wrap_content"
                text="@string/pr_spotchart_top_tips_time"
                layout_weight="1"
                layout_marginStart="@dimen/margin_16dp"/>
            <TextView
                textSize="12sp"
                textColor="@color/ContentContrast"
                gravity="0x800003"
                id="@+id/chart_deal_side"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_demotrade_colheader_side"
                layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            gravity="0x15"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textSize="12sp"
                textColor="@color/ContentContrast"
                gravity="0x800003"
                id="@+id/chart_deal_price"
                layout_width="0dp"
                android:layout_height="wrap_content"
                singleLine="true"
                layout_weight="1"
                layout_marginEnd="24dp"/>
            <LinearLayout
                gravity="0x800015"
                layout_gravity="0x800015"
                orientation="0"
                id="@+id/filter_data_layout"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textSize="12sp"
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    gravity="0x800005"
                    layout_gravity="0x800015"
                    id="@+id/chart_deal_amount"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"/>
                <ImageView
                    id="@+id/filter_area"
                    layout_width="12dp"
                    android:layout_height="15dp"
                    layout_marginTop="1dp"
                    src="@drawable/_2131232227_res_0x7f0805e3"
                    layout_marginStart="@dimen/margin_4dp"
                    layout_marginEnd="16dp"
                    backgroundTint="@color/ContentPrimary"/>
                <ImageView
                    id="@+id/filter_close"
                    visibility="2"
                    layout_width="12dp"
                    android:layout_height="15dp"
                    layout_marginTop="1dp"
                    src="@drawable/_2131231675_res_0x7f0803bb"
                    layout_marginStart="@dimen/margin_4dp"
                    layout_marginEnd="16dp"
                    backgroundTint="@color/ContentPrimary"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        layout_width="-2"
        android:layout_height="match_parent">
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/chart_deal"
            scrollbars="horizontal"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <o.C55173xeu
            id="@+id/empty_view"
            visibility="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="76dp"/>
        <o.C55173xeu
            id="@+id/empty_view_data"
            visibility="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="76dp"
            NOT_FOUND_0x15="6"/>
    </RelativeLayout>
</LinearLayout>
