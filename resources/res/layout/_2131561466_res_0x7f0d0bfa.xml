<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/layout_select_wallet_account_item_0"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/item"
        paddingTop="@dimen/margin_10dp"
        paddingBottom="@dimen/margin_10dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/accountImage"
            layout_width="32dp"
            android:layout_height="32dp"
            src="?attr/st_color_g400"
            layout_marginStart="16dp"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"/>
        <TextView
            textSize="16dp"
            textColor="?attr/st_color_g900"
            ellipsize="3"
            id="@+id/accountName"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_marginStart="16dp"
            NOT_FOUND_0x17="@+id/balance"
            NOT_FOUND_0x19="@+id/accountImage"
            NOT_FOUND_0x1c="0"
            style="@style/TextAppearance.Text.16SP.Medium"/>
        <TextView
            textSize="12dp"
            textColor="?attr/st_color_g400"
            gravity="0x11"
            id="@+id/accountType"
            background="@drawable/_2131234082_res_0x7f080d22"
            layout_width="-2"
            android:layout_height="@dimen/width_20dp"
            textAlignment="4"
            paddingStart="@dimen/dp_4"
            paddingEnd="@dimen/dp_4"
            layout_marginStart="6dp"
            NOT_FOUND_0x16="@+id/accountName"
            NOT_FOUND_0x19="@+id/accountName"
            NOT_FOUND_0x1c="@+id/accountName"/>
        <LinearLayout
            id="@+id/address_coniainer"
            background="@drawable/_2131234082_res_0x7f080d22"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingStart="@dimen/dp_4"
            paddingEnd="@dimen/dp_4"
            layout_marginStart="@dimen/dp_4"
            NOT_FOUND_0x16="@+id/accountName"
            NOT_FOUND_0x19="@+id/accountType"
            NOT_FOUND_0x1c="@+id/accountName">
            <TextView
                textSize="12dp"
                textColor="?attr/st_color_g400"
                id="@+id/address"
                layout_width="-2"
                android:layout_height="wrap_content"
                textAlignment="4"/>
            <o.wYC
                layout_gravity="0x10"
                id="@+id/address_right_arrow"
                layout_width="12dp"
                android:layout_height="12dp"
                src="@drawable/_2131231739_res_0x7f0803fb"
                layout_marginStart="2dp"
                NOT_FOUND_0x1d="?attr/st_color_g400"/>
        </LinearLayout>
        <TextView
            textSize="@dimen/text_size_14sp"
            textColor="?attr/st_color_g400"
            id="@+id/balance"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_2"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x1a="@+id/accountName"
            NOT_FOUND_0x1b="@+id/accountName"/>
        <ImageView
            id="@+id/check"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131234086_res_0x7f080d26"
            layout_marginEnd="@dimen/ok_dp_16"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1c="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <include
        id="@+id/ic_notice"
        visibility="2"
        layout="@layout/_2131561468_res_0x7f0d0bfc"/>
</LinearLayout>
