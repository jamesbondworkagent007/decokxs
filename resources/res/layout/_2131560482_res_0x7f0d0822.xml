<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    background="@drawable/_2131231228_res_0x7f0801fc"
    paddingLeft="@dimen/padding_16dp"
    paddingRight="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_16dp"
    layout_marginRight="@dimen/margin_16dp"
    layout_marginHorizontal="@dimen/margin_16dp"
    paddingHorizontal="@dimen/padding_16dp">
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/image"
        background="@color/white"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0x15="@+id/name"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1b="@+id/name"
        NOT_FOUND_0x1d="@style/CircleStyle"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.10SP.Regular"
        textColor="@color/grey_g700"
        id="@+id/added"
        background="@drawable/_2131231280_res_0x7f080230"
        paddingLeft="@dimen/padding_2dp"
        paddingTop="@dimen/padding_1dp"
        paddingRight="@dimen/padding_2dp"
        paddingBottom="@dimen/padding_1dp"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_14dp"
        layout_marginBottom="@dimen/margin_4dp"
        text="@string/pr_wallet_private_key_tab_added"
        paddingHorizontal="@dimen/padding_2dp"
        paddingVertical="@dimen/padding_1dp"
        NOT_FOUND_0x16="@+id/name"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1b="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.Bold.18SP"
        textColor="@color/text_amplified"
        id="@+id/name"
        layout_width="0dp"
        android:layout_height="@dimen/height_24dp"
        layout_marginTop="@dimen/margin_4dp"
        layout_marginBottom="@dimen/margin_14dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x18="@+id/image"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="@+id/added"
        NOT_FOUND_0x1c="@dimen/margin_14dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
