<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        paddingTop="@dimen/xxsm"
        paddingBottom="@dimen/xxsm"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/xxsm">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_lp_dex_token"
            layout_width="@dimen/width_24dp"
            android:layout_height="@dimen/height_24dp"
            src="@drawable/_2131231887_res_0x7f08048f"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="0"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/xxsm">
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                gravity="0x10"
                id="@+id/tv_lp_dex_name"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                NOT_FOUND_0x13="1sp"
                NOT_FOUND_0x14="1"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1a="0"
                style="@style/Label_1_Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                gravity="0x10"
                id="@+id/tv_liquidity_pool_pair_tickers"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxxsm"
                maxLines="1"
                NOT_FOUND_0x11="14sp"
                NOT_FOUND_0x12="10sp"
                NOT_FOUND_0x13="1sp"
                NOT_FOUND_0x14="1"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="@+id/tv_lp_dex_name"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            ellipsize="3"
            gravity="0x800015"
            id="@+id/tv_lp_amount"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            drawablePadding="@dimen/dp_8"
            layout_weight="1"
            layout_marginStart="@dimen/ok_dp_12"
            layout_marginEnd="@dimen/xxxsm"
            NOT_FOUND_0x15="@drawable/_2131231649_res_0x7f0803a1"
            NOT_FOUND_0x16="@color/ContentPrimary"
            style="@style/Label_1_Medium"/>
    </LinearLayout>
</LinearLayout>
