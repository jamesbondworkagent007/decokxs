<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingBottom="8dp"
    clipChildren="false"
    layout_width="-1"
    android:layout_height="wrap_content">
    <FrameLayout
        id="@+id/module_placeholder_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        elevation="1dp">
        <HorizontalScrollView
            id="@+id/multi_modules"
            visibility="2"
            scrollbars="horizontal"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                orientation="0"
                id="@+id/ll_multi_modules"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingStart="@dimen/margin_default"
                paddingEnd="@dimen/ok_dp_16"/>
        </HorizontalScrollView>
        <androidx.cardview.widget.CardView
            orientation="1"
            id="@+id/single_module"
            background="@drawable/_2131231257_res_0x7f080219"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_default"
            layout_marginRight="@dimen/margin_default"
            minWidth="120dp"
            backgroundTint="@color/BaseSecondary"
            layout_marginHorizontal="@dimen/margin_default"
            NOT_FOUND_0x1f="8dp"
            NOT_FOUND_0x20="0dp">
            <ImageView
                id="@+id/iv_single_banner"
                layout_width="-1"
                android:layout_height="116dp"
                scaleType="6"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                orientation="1"
                paddingLeft="@dimen/xxsm"
                paddingTop="@dimen/xsm"
                paddingRight="@dimen/xxsm"
                paddingBottom="@dimen/xsm"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingHorizontal="@dimen/xxsm"
                paddingVertical="@dimen/xsm">
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tv_single_title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_2_Medium"/>
                <TextView
                    textColor="@color/PreferenceProfitAlternative"
                    id="@+id/tv_single_change"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp"
                    style="@style/Label_1_Medium"/>
                <FrameLayout
                    id="@+id/fl_single_coins"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/sm"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.cardview.widget.CardView>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="0"
            id="@+id/dual_module"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_default"
            layout_marginRight="@dimen/margin_default"
            layout_marginHorizontal="@dimen/margin_default">
            <o.C28985klB
                id="@+id/first_module"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                layout_marginStart="0dp"
                layout_marginEnd="4dp"/>
            <o.C28985klB
                id="@+id/second_module"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="1"
                layout_marginStart="4dp"
                layout_marginEnd="0dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </FrameLayout>
    <HorizontalScrollView
        id="@+id/hsv_module_entry"
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/sm"
        fillViewport="false">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x30"
            orientation="0"
            id="@+id/ll_module_entry"
            paddingLeft="12dp"
            paddingRight="12dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingHorizontal="12dp"/>
    </HorizontalScrollView>
    <o.C29032klw
        layout_gravity="0x1"
        id="@+id/hsv_module_entry_indicator"
        visibility="2"
        layout_width="28dp"
        android:layout_height="2dp"
        layout_marginTop="12dp"/>
</androidx.appcompat.widget.LinearLayoutCompat>
