<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    fitsSystemWindows="true"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        id="@+id/toolbar"
        background="@android:color/transparent"
        NOT_FOUND_0x20="1"
        style="@style/AppTheme.Toolbar">
        <LinearLayout
            gravity="0x11"
            id="@+id/ll_back"
            layout_width="-2"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatImageView
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131232346_res_0x7f08065a"
                NOT_FOUND_0x21="@color/okTradeG900"/>
            <TextView
                textSize="@dimen/font_18"
                textColor="@color/debugbox_colorBlack"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_debug_text_requestdetails"
                maxLines="1"/>
        </LinearLayout>
        <ImageView
            layout_gravity="0x800005"
            id="@+id/iv_menu"
            visibility="2"
            layout_width="-2"
            android:layout_height="match_parent"/>
    </androidx.appcompat.widget.Toolbar>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <EditText
            textSize="10sp"
            textColorHint="@color/text_color"
            id="@+id/edit_query_flied"
            layout_width="0dp"
            android:layout_height="wrap_content"
            hint="Input field"
            layout_weight="1"
            layout_marginStart="20dp"
            layout_marginEnd="10dp"/>
        <TextView
            textColor="@color/okTradeBlue700"
            gravity="0x11"
            id="@+id/tv_find_text"
            background="@drawable/_2131232247_res_0x7f0805f7"
            layout_width="50dp"
            android:layout_height="wrap_content"
            text="Search"
            layout_marginEnd="10dp"/>
        <TextView
            textColor="@color/okTradeBlue700"
            gravity="0x11"
            id="@+id/tv_export_text"
            background="@drawable/_2131232247_res_0x7f0805f7"
            layout_width="50dp"
            android:layout_height="wrap_content"
            text="Export"
            layout_marginEnd="10dp"/>
    </LinearLayout>
    <FrameLayout
        id="@+id/fl_web"
        background="#cccccc"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1"/>
    <LinearLayout
        orientation="1"
        id="@+id/match_rule_root"
        background="@drawable/_2131233837_res_0x7f080c2d"
        padding="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="8dp"
        animateLayoutChanges="false">
        <LinearLayout
            gravity="0x11"
            paddingBottom="8dp"
            layout_width="-2"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/match_rule_back"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131232346_res_0x7f08065a"
                NOT_FOUND_0x21="@color/okTradeG900"/>
            <TextView
                textSize="16dp"
                textStyle="0x1"
                textColor="@color/debugbox_colorBlack"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="Match Rule (JSON)"
                maxLines="1"/>
        </LinearLayout>
        <EditText
            gravity="0x800033"
            id="@+id/match_rule_json"
            background="@color/transparent"
            padding="12dp"
            focusable="true"
            focusableInTouchMode="true"
            scrollbars="0x200"
            layout_width="-1"
            android:layout_height="200dp"
            inputType="0x20001"
            overScrollMode="0"/>
        <Button
            textColor="@color/white"
            id="@+id/match_button"
            background="@color/okTradeBlue700"
            padding="12dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="save and match"/>
        <TextView
            textSize="16sp"
            textStyle="0x1"
            textColor="@color/primary_text_color"
            gravity="0x800033"
            id="@+id/match_result"
            background="@color/text_light"
            padding="12dp"
            scrollbars="0x200"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            maxHeight="@dimen/height_150dp"
            text="Match result："
            scrollHorizontally="false"
            overScrollMode="0"/>
    </LinearLayout>
</LinearLayout>
