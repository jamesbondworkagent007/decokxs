<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/topPanel"
    paddingTop="20dp"
    clipChildren="false"
    clipToPadding="false"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        id="@+id/top_layout"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-1"
        android:layout_height="wrap_content"
        baselineAligned="false"
        paddingStart="24dp"
        paddingEnd="16dp">
        <LinearLayout
            orientation="0"
            id="@+id/icon_layout"
            layout_width="-1"
            android:layout_height="wrap_content">
            <ImageView
                id="@android:id/icon"
                visibility="2"
                layout_width="40dp"
                android:layout_height="40dp"
                scaleType="fitStart"/>
            <Space
                layout_width="0dp"
                android:layout_height="0dp"
                layout_weight="1"/>
            <ImageView
                layout_gravity="0x800015"
                id="@android:id/closeButton"
                background="?attr/selectableItemBackgroundBorderless"
                padding="4dp"
                visibility="2"
                layout_width="32dp"
                android:layout_height="32dp"
                src="@drawable/_2131232318_res_0x7f08063e"
                scaleType="fitStart"/>
        </LinearLayout>
        <LinearLayout
            gravity="0x800013"
            layout_gravity="0x10"
            orientation="1"
            id="@+id/title_template"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            baselineAligned="false">
            <androidx.appcompat.widget.DialogTitle
                textAppearance="@style/TextAppearance.Silka.Bold"
                textSize="18sp"
                textColor="@color/title_color"
                ellipsize="3"
                id="@+id/alertTitle"
                paddingTop="4dp"
                paddingBottom="4dp"
                layout_width="-1"
                android:layout_height="wrap_content"
                maxLines="@null"
                includeFontPadding="false"
                drawablePadding="8dp"
                layout_marginEnd="40dp"
                style="?android:attr/windowTitleStyle"/>
            <TextView
                ellipsize="3"
                id="@android:id/text2"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                includeFontPadding="false"
                layout_marginEnd="40dp"
                style="@style/TextAppearance.Text.12SP"/>
        </LinearLayout>
    </LinearLayout>
    <androidx.legacy.widget.Space
        id="@+id/titleDividerNoCustom"
        visibility="2"
        layout_width="-1"
        android:layout_height="@dimen/abc_dialog_title_divider_material"/>
    <Space
        id="@android:id/custom"
        visibility="2"
        layout_width="-1"
        android:layout_height="24dp"/>
</LinearLayout>
