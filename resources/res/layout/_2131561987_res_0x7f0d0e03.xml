<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x800005"
    orientation="0"
    id="@+id/date_picker_actions"
    paddingRight="@dimen/mtrl_calendar_action_padding"
    layout_width="-1"
    android:layout_height="@dimen/mtrl_calendar_action_height"
    paddingEnd="@dimen/mtrl_calendar_action_padding">
    <Button
        layout_gravity="0x10"
        id="@+id/cancel_button"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/mtrl_picker_cancel"
        style="?attr/buttonBarNegativeButtonStyle"/>
    <Button
        layout_gravity="0x10"
        id="@+id/confirm_button"
        layout_width="-2"
        android:layout_height="wrap_content"
        minWidth="@dimen/mtrl_calendar_action_confirm_button_min_width"
        text="@string/mtrl_picker_confirm"
        style="?attr/buttonBarPositiveButtonStyle"/>
</LinearLayout>
