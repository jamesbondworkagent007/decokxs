<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/margin_default"
    paddingRight="@dimen/margin_default"
    layout_width="-1"
    android:layout_height="@dimen/xlg"
    paddingHorizontal="@dimen/margin_default">
    <FrameLayout
        id="@+id/fl_token_rank"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1b="@+id/view_token_chain"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0">
        <ImageView
            layout_gravity="0x11"
            id="@+id/iv_rank_flag"
            visibility="2"
            layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"/>
        <TextView
            textColor="@color/ContentSecondary"
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/tv_rank"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            minWidth="@dimen/dp_24"
            style="@style/Label_2_Bold"/>
    </FrameLayout>
    <o.C24484ieh
        id="@+id/view_token_chain"
        layout_width="36dp"
        android:layout_height="36dp"
        layout_centerVertical="true"
        layout_marginStart="@dimen/ok_dp_12"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1c="@+id/fl_token_rank"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x21="0dp"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/parent_symbol_tag"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x19="@+id/ll_subtitle"
        NOT_FOUND_0x1b="@+id/tv_token_price"
        NOT_FOUND_0x1c="@+id/view_token_chain"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="2">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_token_symbol"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_1_Medium"/>
        <o.C28067kNr
            id="@+id/dex_tag"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="4dp"/>
    </LinearLayout>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_token_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x18="@+id/parent_symbol_tag"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="@+id/parent_symbol_tag"
        NOT_FOUND_0x1f="@+id/parent_symbol_tag"
        style="@style/Label_1_Medium"/>
    <LinearLayout
        orientation="0"
        id="@+id/ll_subtitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_4"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="@+id/view_token_chain"
        NOT_FOUND_0x1e="@+id/parent_symbol_tag">
        <LinearLayout
            layout_width="-2"
            android:layout_height="wrap_content"
            maxWidth="100dp">
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_token_volume"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                style="@style/Body_4"/>
            <View
                layout_gravity="0x10"
                background="@drawable/_2131232278_res_0x7f080616"
                layout_width="4dp"
                android:layout_height="4dp"
                layout_marginLeft="6dp"
                layout_marginRight="6dp"
                backgroundTint="@color/BorderSecondary"
                layout_marginHorizontal="6dp"/>
            <TextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_token_mcap"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                style="@style/Body_4"/>
        </LinearLayout>
        <TextView
            gravity="0x800005"
            layout_gravity="0x800005"
            id="@+id/tv_token_change"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="12dp"
            style="@style/Body_4"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
