<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/item_approve_risky_token_group_0"
    paddingTop="16dp"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="16dp">
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x3"
        id="@+id/risky_icon"
        visibility="2"
        layout_width="50dp"
        android:layout_height="50dp"
        layout_marginTop="24dp"
        src="@drawable/_2131234342_res_0x7f080e26"
        tint="@color/SemanticNotice"
        layout_marginStart="@dimen/padding_24dp"/>
    <TextView
        textAppearance="@style/Headline_4_Bold"
        textColor="@color/ContentSecondary"
        layout_gravity="0x800003"
        id="@+id/approval_title"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        layout_marginBottom="24dp"
        layout_marginStart="@dimen/padding_24dp"
        layout_marginEnd="@dimen/padding_24dp"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        layout_gravity="0x3"
        id="@+id/tv_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="@dimen/padding_8dp"
        layout_marginStart="26dp"
        layout_marginEnd="@dimen/padding_24dp"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/recycler"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x14="androidx.recyclerview.widget.LinearLayoutManager"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x1"
        orientation="0"
        id="@+id/layout_viewmore"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0">
        <TextView
            textAppearance="@style/Label_3_Regular"
            textColor="@color/ContentPrimary"
            id="@+id/tv_viewmore"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_wallet_btn_general_show"/>
        <ImageView
            id="@+id/iv_viewmore_arrow"
            layout_width="16dp"
            android:layout_height="16dp"
            layout_marginTop="2dp"
            src="@drawable/_2131232924_res_0x7f08089c"
            layout_marginStart="4dp"
            NOT_FOUND_0x17="@color/ContentPrimary"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
