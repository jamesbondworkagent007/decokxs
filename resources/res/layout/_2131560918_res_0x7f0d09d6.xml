<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/item_root_layout"
    tag="layout/item_system_notification_message_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    baselineAligned="false">
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        layout_gravity="0x1"
        id="@+id/tv_message_interval_time"
        visibility="0"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        layout_marginBottom="4dp"
        layout_marginStart="@dimen/common_page_edge_space"
        layout_marginEnd="@dimen/common_page_edge_space"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/item_content_layout"
        background="@drawable/_2131230993_res_0x7f080111"
        padding="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_margin="@dimen/margin_16dp">
        <TextView
            textSize="@dimen/text_size_15sp"
            textColor="@color/okTradeG900"
            gravity="0x13"
            id="@+id/tv_title"
            background="@null"
            layout_width="0dp"
            android:layout_height="wrap_content"
            fontFamily="@font/font_alpha_medium"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="0"/>
        <TextView
            textSize="@dimen/sp_14"
            textColor="@color/okTradeG400"
            gravity="0x13"
            id="@+id/tv_content"
            background="@null"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_4dp"
            fontFamily="@font/font_alpha_regular"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="@+id/tv_title"/>
        <View
            id="@+id/line_horizontal"
            background="@color/okTradeG100"
            layout_width="-1"
            android:layout_height="0.5dp"
            layout_marginTop="16dp"
            NOT_FOUND_0x16="@+id/tv_opt"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="@+id/tv_content"/>
        <TextView
            textSize="@dimen/text_size_15sp"
            textColor="@color/okTradeG400"
            gravity="0x13"
            id="@+id/tv_opt"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            text="@string/pr_message_function_view"
            fontFamily="@font/font_alpha_medium"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="@+id/line_horizontal"/>
        <ImageView
            id="@+id/arrow"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x15="@+id/tv_opt"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x1a="@+id/tv_opt"
            NOT_FOUND_0x1b="@drawable/_2131231649_res_0x7f0803a1"
            NOT_FOUND_0x1c="@color/grey_g300"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
