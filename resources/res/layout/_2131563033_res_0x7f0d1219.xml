<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_dualcoin_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xe="0"
        style="@style/Label_2_Regular"/>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_coin_amount_first"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        maxLines="1"
        NOT_FOUND_0xa="@+id/iv_asset_arrow"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="@+id/tv_dualcoin_title"
        style="@style/Label_1_Regular"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_asset_arrow"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131232356_res_0x7f080664"
        layout_marginStart="@dimen/margin_8dp"
        NOT_FOUND_0x9="@+id/tv_coin_amount_first"
        NOT_FOUND_0xb="@+id/tv_coin_amount_first"
        NOT_FOUND_0xe="@+id/tv_coin_amount_first"
        NOT_FOUND_0xf="@color/ContentSecondary"/>
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_coin_currency_first"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        maxLines="1"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="@+id/tv_coin_amount_first"
        style="@style/Label_2_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
