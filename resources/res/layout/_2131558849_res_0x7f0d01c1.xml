<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/bottom_sheet_legacy_pro_qp_convert_channel_page_0"
    background="@drawable/_2131231490_res_0x7f080302"
    layout_width="-1"
    android:layout_height="wrap_content">
    <RelativeLayout
        id="@+id/rr_qp_header"
        layout_width="-1"
        android:layout_height="50dp"
        layout_marginStart="@dimen/margin_16dp">
        <ImageView
            id="@+id/iv_coin_icon"
            visibility="1"
            layout_width="@dimen/width_28dp"
            android:layout_height="28dp"
            layout_centerVertical="true"/>
        <TextView
            textAppearance="@style/TextAppearance.Bold"
            textSize="@dimen/text_size_18sp"
            textColor="@color/okTradeG900"
            id="@+id/tv_coin_buy_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_centerVertical="true"
            layout_marginStart="@dimen/margin_12dp"
            layout_toEndOf="@+id/iv_coin_icon"/>
        <ImageView
            id="@+id/iv_dismiss_icon"
            layout_width="36dp"
            android:layout_height="44dp"
            src="@drawable/_2131232489_res_0x7f0806e9"
            scaleType="fitEnd"
            layout_centerVertical="true"
            layout_marginEnd="@dimen/margin_8dp"
            layout_alignParentEnd="true"
            NOT_FOUND_0x24="@color/grey_g400"/>
    </RelativeLayout>
    <View
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="@dimen/height_0.5dp"
        layout_marginTop="3dp"
        layout_marginBottom="@dimen/margin_12dp"/>
    <FrameLayout
        id="@+id/fl_price_fluctuation_message"
        background="@drawable/_2131230994_res_0x7f080112"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginStart="@dimen/margin_20dp"
        layout_marginEnd="@dimen/margin_20dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.14SP.Medium"
            textColor="@color/grey_g500"
            id="@+id/tv_price_fluctuation_message"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_margin="@dimen/margin_16dp"
            text="@string/lt_unipay_qp_drawer_text_exchangerate"/>
    </FrameLayout>
    <FrameLayout
        id="@+id/fl_main_container"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content">
            <ImageView
                id="@+id/iv_dot_stepper"
                paddingTop="6dp"
                paddingBottom="6dp"
                layout_width="8dp"
                android:layout_height="106dp"
                layout_marginStart="23dp"
                NOT_FOUND_0x1c="@+id/tv_auto_convert_title"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x21="@+id/tv_fiat_amount_title"/>
            <TextView
                textAppearance="@style/TextAppearance.Title.15SP"
                id="@+id/tv_fiat_amount_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="24dp"
                layout_marginStart="22dp"
                NOT_FOUND_0x1e="@+id/iv_dot_stepper"
                NOT_FOUND_0x21="0"/>
            <LinearLayout
                orientation="0"
                id="@+id/ll_fiat_crypto_container"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                NOT_FOUND_0x1f="@+id/tv_fiat_amount_title"
                NOT_FOUND_0x20="@+id/tv_fiat_amount_title">
                <TextView
                    textAppearance="@style/TextAppearance.Bold"
                    textSize="@dimen/text_size_20sp"
                    textColor="@color/okTradeG900"
                    id="@+id/tv_crypto_amount"
                    layout_width="-2"
                    android:layout_height="wrap_content"/>
                <TextView
                    textAppearance="@style/TextAppearance.Title.15SP"
                    id="@+id/tv_crypto_currency"
                    layout_width="-2"
                    android:layout_height="20dp"
                    layout_marginStart="4dp"/>
            </LinearLayout>
            <TextView
                textAppearance="@style/TextAppearance.Title.15SP"
                id="@+id/tv_auto_convert_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="32dp"
                text="@string/pr_expbuy_tutorials_text_subtitlautoconvert"
                NOT_FOUND_0x1f="@+id/ll_fiat_crypto_container"
                NOT_FOUND_0x20="@+id/ll_fiat_crypto_container"/>
            <LinearLayout
                orientation="0"
                id="@+id/ll_convert_container"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                NOT_FOUND_0x1f="@+id/tv_auto_convert_title"
                NOT_FOUND_0x20="@+id/tv_auto_convert_title">
                <TextView
                    textAppearance="@style/TextAppearance.Title.15SP"
                    textColor="@color/okTradeG900"
                    tag="binding_1"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    paddingStart="@dimen/dp_0"
                    paddingEnd="@dimen/padding_4dp"/>
                <TextView
                    textAppearance="@style/TextAppearance.Bold"
                    textSize="@dimen/text_size_20sp"
                    textColor="@color/okTradeG900"
                    id="@+id/tv_convert_crypto_amount"
                    layout_width="-2"
                    android:layout_height="wrap_content"/>
                <TextView
                    textAppearance="@style/TextAppearance.Title.15SP"
                    id="@+id/tv_convert_crypto_currency"
                    layout_width="-2"
                    android:layout_height="20dp"
                    layout_marginStart="4dp"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
    <com.okinc.uilab.reminder.OKReminder
        id="@+id/marginBalanceReminderInfo"
        visibility="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_40dp"
        layout_marginStart="@dimen/margin_20dp"
        layout_marginEnd="@dimen/margin_20dp"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1f="0"
        style="@style/TextAppearance.Text.12SP"/>
    <o.C52794wYp
        gravity="0x11"
        id="@+id/btn_confirm"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="60dp"
        layout_marginBottom="20dp"
        text="@string/lt_unipay_qp_drawer_btn_next"
        fontFamily="@font/harmony_sans_bold"
        layout_marginStart="20dp"
        layout_marginEnd="20dp"
        NOT_FOUND_0x1b="8"
        NOT_FOUND_0x22="52"
        NOT_FOUND_0x23="0x101"
        NOT_FOUND_0x25="6"
        style="@style/TextAppearance.Blue.16SP.Semibold"/>
</LinearLayout>
