<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    NOT_FOUND_0x16="@color/SurfacePrimary"
    NOT_FOUND_0x17="16dp"
    NOT_FOUND_0x18="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        paddingTop="16dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="match_parent"
        paddingStart="16dp"
        paddingVertical="16dp">
        <ImageView
            id="@+id/ivAvatar"
            layout_width="40dp"
            android:layout_height="40dp"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x20="0"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tvName"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            paddingEnd="@dimen/dp_16"
            layout_marginStart="12dp"
            NOT_FOUND_0x1b="@+id/ivAvatar"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/ivAvatar"
            NOT_FOUND_0x20="0"
            style="@style/Title_2_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/tvPnlLabel"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            NOT_FOUND_0x1c="@+id/tvPnl"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="@+id/ivAvatar"
            style="@style/Label_2_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/pnl_modern_profit_default"
            ellipsize="3"
            id="@+id/tvPnl"
            layout_width="168dp"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            maxLines="1"
            includeFontPadding="false"
            lineHeight="26sp"
            NOT_FOUND_0x12="22sp"
            NOT_FOUND_0x13="18sp"
            NOT_FOUND_0x14="1sp"
            NOT_FOUND_0x15="1"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="@+id/tvPnlLabel"
            style="@style/Title_1_Bold"/>
        <TextView
            textColor="@color/pnl_modern_profit_default"
            id="@+id/tvPct"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            layout_marginBottom="8dp"
            includeFontPadding="false"
            lineHeight="16sp"
            NOT_FOUND_0x1c="@+id/tvPnl"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="@+id/tvPnl"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/tvAssetsLabel"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            text="@string/pr_trade_orbit_title_assets"
            includeFontPadding="false"
            lineHeight="16sp"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x1f="@+id/tvPct"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tvAssets"
            layout_width="0dp"
            android:layout_height="wrap_content"
            includeFontPadding="false"
            layout_marginStart="4dp"
            lineHeight="16sp"
            NOT_FOUND_0x1c="@+id/tvPnl"
            NOT_FOUND_0x1d="@+id/tvAssetsLabel"
            NOT_FOUND_0x20="@+id/tvAssetsLabel"
            style="@style/Label_2_Regular"/>
        <o.C46496tWm
            id="@+id/ivChart"
            layout_width="0dp"
            android:layout_height="84dp"
            contentDescription="chart"
            layout_marginStart="8dp"
            NOT_FOUND_0x19="false"
            NOT_FOUND_0x1a="0dp"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/tvPnl"
            NOT_FOUND_0x20="@+id/tvPnlLabel"
            NOT_FOUND_0x21="2px"
            NOT_FOUND_0x22="0dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
