<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/component_okcr_token_list_item_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/pressed_background"
        background="@drawable/_2131230955_res_0x7f0800eb"
        focusable="false"
        focusableInTouchMode="false"
        layout_width="-1"
        android:layout_height="match_parent"
        alpha="0"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_gravity="0x10"
        id="@+id/item_root_container"
        paddingLeft="@dimen/dp_16"
        paddingRight="@dimen/dp_16"
        layout_width="-1"
        android:layout_height="@dimen/dp_72"
        paddingHorizontal="@dimen/dp_16">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/cl_left"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x17="true"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1b="@+id/cl_price_percentage"
            NOT_FOUND_0x1d="1"
            NOT_FOUND_0x1f="0"
            NOT_FOUND_0x21="0">
            <ImageView
                id="@+id/iv_icon"
                layout_width="@dimen/dp_32"
                android:layout_height="@dimen/dp_32"
                contentDescription="@null"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1b="@+id/cl_names"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x21="0"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/cl_names"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/dp_12"
                NOT_FOUND_0x17="true"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1e="@+id/iv_icon"
                NOT_FOUND_0x21="0">
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    id="@+id/tv_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="2"
                    NOT_FOUND_0x19="@+id/tv_name_full"
                    NOT_FOUND_0x1a="0"
                    NOT_FOUND_0x1c="0"
                    NOT_FOUND_0x1f="0"
                    NOT_FOUND_0x21="0"
                    style="@style/Label_1_Medium"/>
                <TextView
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    gravity="0x50"
                    id="@+id/tv_name_full"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/dp_4"
                    maxLines="1"
                    NOT_FOUND_0x18="0"
                    NOT_FOUND_0x1a="0"
                    NOT_FOUND_0x1c="0"
                    NOT_FOUND_0x1f="0"
                    NOT_FOUND_0x20="@+id/tv_name"
                    style="@style/Label_2_Regular"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/cl_price_percentage"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/dp_8"
            NOT_FOUND_0x17="true"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1e="@+id/cl_left"
            NOT_FOUND_0x21="0">
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="2"
                gravity="0x800015"
                id="@+id/tv_price"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeStepGranularity="1sp"
                autoSizeMinTextSize="10sp"
                autoSizeMaxTextSize="16sp"
                NOT_FOUND_0x19="@+id/tv_change_percent"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1c="1"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x21="0"
                style="@style/Label_1_Medium"/>
            <TextView
                ellipsize="2"
                gravity="0x800015"
                id="@+id/tv_change_percent"
                tag="binding_1"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_4"
                maxLines="1"
                autoSizeTextType="uniform"
                autoSizeStepGranularity="1sp"
                autoSizeMinTextSize="10sp"
                autoSizeMaxTextSize="14sp"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1c="1"
                NOT_FOUND_0x1f="0"
                NOT_FOUND_0x20="@+id/tv_price"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
