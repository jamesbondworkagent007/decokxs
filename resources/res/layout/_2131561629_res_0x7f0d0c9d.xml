<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatTextView
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="2"
        includeFontPadding="false"
        NOT_FOUND_0xf="@+id/tv_desc"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="2"
        NOT_FOUND_0x17="18dp"
        style="@style/TextAppearance.Title.16SP.Medium"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        gravity="0x10"
        id="@+id/tv_desc"
        layout_width="-2"
        android:layout_height="@dimen/dp_16"
        layout_marginTop="4dp"
        maxLines="1"
        includeFontPadding="false"
        lineHeight="@dimen/dp_16"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x12="@+id/tv_name"
        NOT_FOUND_0x13="@+id/tv_name"
        NOT_FOUND_0x16="@dimen/dp_0"
        style="@style/Label_3_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/okTradeG900"
        gravity="0x800015"
        layout_gravity="0x800015"
        id="@+id/tv_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        includeFontPadding="false"
        NOT_FOUND_0xf="@+id/tv_sub_price"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="2"
        style="@style/TextAppearance.Title.16SP.Medium"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/barrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xc="6"
        NOT_FOUND_0xd="tv_name, tv_desc"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/sp_14"
        ellipsize="3"
        gravity="0x800015"
        layout_gravity="0x800005"
        id="@+id/tv_sub_price"
        layout_width="0dp"
        android:layout_height="@dimen/dp_16"
        layout_marginTop="4dp"
        maxLines="1"
        includeFontPadding="false"
        lineHeight="@dimen/dp_16"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/barrier"
        NOT_FOUND_0x13="@+id/tv_price"
        style="@style/TextAppearance.Text.14SP.Regular"/>
</merge>
