<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        layout_width="-1"
        android:layout_height="@dimen/xlg">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1">
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/iv_kol"
                layout_width="@dimen/md"
                android:layout_height="@dimen/md"
                src="@drawable/_2131231887_res_0x7f08048f"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="0"/>
            <View
                id="@+id/guideline_center_image"
                layout_width="-2"
                android:layout_height="4dp"
                layout_marginStart="@dimen/margin_8dp"
                NOT_FOUND_0x13="@+id/iv_kol"
                NOT_FOUND_0x16="@+id/iv_kol"
                NOT_FOUND_0x19="@+id/iv_kol"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                gravity="0x10"
                id="@+id/tv_kol_name"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="--"
                maxLines="1"
                NOT_FOUND_0x14="@+id/guideline_center_image"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="@+id/guideline_center_image"
                style="@style/Label_1_Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                ellipsize="3"
                gravity="0x10"
                id="@+id/tv_kol_count"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="--"
                maxLines="1"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="@+id/guideline_center_image"
                NOT_FOUND_0x18="@+id/guideline_center_image"
                style="@style/Label_2_Regular"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x800015"
            layout_gravity="0x11"
            orientation="1"
            id="@+id/ll_engagement"
            layout_width="88dp"
            android:layout_height="match_parent"
            layout_marginStart="@dimen/xsm">
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="3"
                gravity="0x800015"
                id="@+id/tv_engagement_count"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="--"
                maxLines="1"
                NOT_FOUND_0xf="16sp"
                NOT_FOUND_0x10="8sp"
                NOT_FOUND_0x11="1sp"
                NOT_FOUND_0x12="1"
                style="@style/Label_1_Medium"/>
            <TextView
                textColor="@color/ContentContrast"
                gravity="0x800015"
                id="@+id/tv_engagement_rate"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/xxxxsm"
                maxWidth="100dp"
                text="--"
                maxLines="1"
                NOT_FOUND_0xf="14sp"
                NOT_FOUND_0x10="8sp"
                NOT_FOUND_0x11="1sp"
                NOT_FOUND_0x12="1"
                style="@style/Label_2_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
