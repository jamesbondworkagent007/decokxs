<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.helper.widget.Flow
        id="@+id/flow"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x9="firstContainer,secondContainer,thirdContainer"
        NOT_FOUND_0xa="16dp"
        NOT_FOUND_0xb="2"
        NOT_FOUND_0xc="4dp"
        NOT_FOUND_0xd="1"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/firstContainer"
        layout_width="-2"
        android:layout_height="wrap_content">
        <View
            id="@+id/bgFirst"
            background="@drawable/_2131231481_res_0x7f0802f9"
            layout_width="6dp"
            android:layout_height="6dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/ContentContrast"
            id="@+id/tvFirstTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/secondContainer"
        layout_width="-2"
        android:layout_height="wrap_content">
        <View
            id="@+id/bgSecond"
            background="@drawable/_2131231481_res_0x7f0802f9"
            layout_width="6dp"
            android:layout_height="6dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/ContentContrast"
            id="@+id/tvSecondTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/thirdContainer"
        layout_width="-2"
        android:layout_height="wrap_content">
        <View
            id="@+id/bgThird"
            background="@drawable/_2131231481_res_0x7f0802f9"
            layout_width="8dp"
            android:layout_height="2dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/ContentContrast"
            id="@+id/tvThirdTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="4dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
