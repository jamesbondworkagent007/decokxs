        paddingRight="24dp"
        paddingBottom="12dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_trade_discover_header_trade_radar"
        drawableEnd="@drawable/_2131231649_res_0x7f0803a1"
