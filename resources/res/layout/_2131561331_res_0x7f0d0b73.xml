    <FrameLayout
        id="@+id/empty_container"
        visibility="2"
        layout_width="-1"
        android:layout_height="0dp"
        minHeight="250dp"
        layout_weight="1">
        <o.C55173xeu
            layout_gravity="0x11"
            layout_width="-1"
            android:layout_height="wrap_content"
