    </androidx.appcompat.widget.LinearLayoutCompat>
    <FrameLayout
        id="@+id/error_container"
        visibility="2"
        layout_width="-1"
        android:layout_height="0dp"
        minHeight="250dp"
        layout_weight="1">
        <o.C55173xeu
