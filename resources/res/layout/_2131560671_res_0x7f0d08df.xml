<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/text_light"
        id="@+id/key"
        layout_width="-2"
        android:layout_height="wrap_content"
        includeFontPadding="false"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="16sp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/text_amplified"
        id="@+id/value"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        includeFontPadding="false"
        NOT_FOUND_0xe="@+id/vertical_divider"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="2"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@+id/key"
        NOT_FOUND_0x15="1"
        NOT_FOUND_0x16="20sp"/>
    <View
        id="@+id/vertical_divider"
        background="@color/LineMuted"
        layout_width="1dp"
        android:layout_height="16dp"
        layout_marginStart="12dp"
        NOT_FOUND_0xe="@+id/action_icon"
        NOT_FOUND_0x11="@+id/value"
        NOT_FOUND_0x14="@+id/value"/>
    <ImageView
        id="@+id/action_icon"
        layout_width="24dp"
        android:layout_height="24dp"
        layout_marginBottom="@dimen/margin_2dp"
        layout_marginStart="12dp"
        NOT_FOUND_0xc="@+id/value"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0x11="@+id/vertical_divider"
        NOT_FOUND_0x14="@+id/value"
        NOT_FOUND_0x17="@drawable/_2131231720_res_0x7f0803e8"
        NOT_FOUND_0x18="@color/text_amplified"/>
    <androidx.constraintlayout.widget.Group
        id="@+id/group_extra_action"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xb="vertical_divider,action_icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
