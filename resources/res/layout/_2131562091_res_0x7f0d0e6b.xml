<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="28dp"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/illustrationImage"
        layout_width="120dp"
        android:layout_height="120dp"
        src="@drawable/_2131233729_res_0x7f080bc1"
        contentDescription="@null"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x11="0"/>
    <TextView
        textAppearance="@style/Headline_5_Bold"
        textColor="@color/ContentPrimary"
        id="@+id/titleText"
        paddingLeft="@dimen/padding_24dp"
        paddingRight="@dimen/padding_24dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        text="Orbiter +"
        paddingHorizontal="@dimen/padding_24dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/illustrationImage"/>
    <TextView
        textAppearance="@style/Body_2_Regular"
        textColor="@color/ContentSecondary"
        id="@+id/descriptionText"
        paddingLeft="@dimen/padding_24dp"
        paddingRight="@dimen/padding_24dp"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="This trader is ranked as a Bronze lead trader."
        paddingHorizontal="@dimen/padding_24dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/titleText"/>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/feature1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/descriptionText"/>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/feature2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/feature1"/>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/feature3"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="@+id/feature2"/>
</androidx.constraintlayout.widget.ConstraintLayout>
