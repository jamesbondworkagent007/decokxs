<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/rootContainer"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/sectionTitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_trade_history_tab_bot_info"
            style="@style/Label_1_Bold"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            id="@+id/contentContainer"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp">
            <androidx.appcompat.widget.LinearLayoutCompat
                orientation="0"
                id="@+id/botAssetsContainer"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginBottom="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/botAssetsLabel"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_strategy_item_margin_balance"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="2"
                    gravity="0x800005"
                    id="@+id/botAssetsValue"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginLeft="5dp"
                    layout_marginRight="5dp"
                    maxLines="1"
                    layout_weight="1"
                    layout_marginHorizontal="5dp"
                    style="@style/Label_2_Medium"/>
                <o.wYD
                    layout_gravity="0x11"
                    id="@+id/botAssetsIcon"
                    layout_width="16dp"
                    android:layout_height="16dp"
                    NOT_FOUND_0x12="@drawable/_2131233626_res_0x7f080b5a"
                    NOT_FOUND_0x13="2"
                    NOT_FOUND_0x14="-4"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                id="@+id/botIdContainer"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/botIdTitle"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_smartarb_botdetails_header_bot_id"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="2"
                    gravity="0x800005"
                    id="@+id/botIdTv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginLeft="5dp"
                    layout_marginRight="5dp"
                    maxLines="1"
                    layout_weight="1"
                    layout_marginHorizontal="5dp"
                    style="@style/Label_2_Medium"/>
                <o.wYD
                    layout_gravity="0x11"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    NOT_FOUND_0x12="@drawable/_2131231720_res_0x7f0803e8"
                    NOT_FOUND_0x13="2"
                    NOT_FOUND_0x14="-4"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/creationTimeTitle"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_bot_sort_nearest_creation_time"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    gravity="0x800005"
                    id="@+id/botCreateTimeTv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                id="@+id/botStopTimeContainer"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="16dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/stoppedTimeTitle"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_strategy_item_stop_time"
                    layout_marginEnd="16dp"
                    style="@style/Label_2_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    gravity="0x800005"
                    id="@+id/botStopTimeTv"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_weight="1"
                    style="@style/Label_2_Medium"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</merge>
