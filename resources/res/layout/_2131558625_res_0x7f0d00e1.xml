<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/container"
    background="@color/grey_g50"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        id="@+id/toolbar"
        background="@android:color/transparent"
        layout_marginTop="40dp"
        NOT_FOUND_0x1a="1"
        style="@style/AppTheme.Toolbar">
        <RelativeLayout
            id="@+id/ll_back"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/image_back"
                layout_width="30dp"
                android:layout_height="50dp"
                src="@drawable/_2131232347_res_0x7f08065b"
                layout_centerVertical="true"
                layout_alignParentStart="true"
                NOT_FOUND_0x1e="@color/okTradeG900"/>
            <TextView
                textSize="@dimen/font_18"
                textColor="@color/title_color"
                gravity="0x11"
                layout_width="242dp"
                android:layout_height="match_parent"
                text="网络检测(Network diagnosis)"
                maxLines="1"
                layout_centerInParent="true"/>
        </RelativeLayout>
        <TextView
            textSize="@dimen/font_18"
            textStyle="0x1"
            textColor="@color/debugbox_colorPrimaryDark"
            layout_gravity="0x800005"
            id="@+id/toolbar_upload"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_margin="6dp"
            text="@string/pr_debuge_text_uploadalert"
            maxLines="1"
            paddingStart="18dp"/>
        <TextView
            textSize="@dimen/font_18"
            textStyle="0x1"
            textColor="@color/debugbox_colorPrimaryDark"
            layout_gravity="0x800005"
            id="@+id/toolbar_copy"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_margin="6dp"
            text="@string/pr_debug_text_copy"
            maxLines="1"/>
        <ImageView
            layout_gravity="0x800005"
            id="@+id/iv_menu"
            visibility="2"
            layout_width="-2"
            android:layout_height="match_parent"/>
    </androidx.appcompat.widget.Toolbar>
    <o.C52794wYp
        textSize="16sp"
        textColor="@color/white"
        gravity="0x11"
        id="@+id/start_diagnosis"
        layout_width="-1"
        android:layout_height="50dp"
        text="开始检测(start diagnosis)"
        layout_marginStart="15dp"
        layout_marginEnd="15dp"
        NOT_FOUND_0x1b="52"
        NOT_FOUND_0x1c="0x101"
        NOT_FOUND_0x1d="-2"
        NOT_FOUND_0x1f="2"
        style="@style/Button.Primary.Medium"/>
    <ScrollView
        background="@color/grey_g100"
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginLeft="3.5dp"
        layout_marginTop="10dp"
        layout_marginRight="3.5dp"
        layout_marginBottom="6dp">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textSize="16sp"
                textColor="@color/title_color"
                gravity="0x10"
                id="@+id/show_diagnosis"
                scrollbars="0x200"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginStart="15dp"
                layout_marginEnd="15dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
