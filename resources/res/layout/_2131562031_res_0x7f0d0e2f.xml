<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/rc_conversation_item"
    background="@color/BasePrimary"
    paddingLeft="@dimen/im_page_margin"
    paddingTop="12dp"
    paddingRight="@dimen/im_page_margin"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    foreground="?attr/selectableItemBackgroundBorderless"
    paddingHorizontal="@dimen/im_page_margin"
    paddingVertical="12dp">
    <o.C35893oHp
        id="@+id/okim_conversation_portrait"
        layout_width="52dp"
        android:layout_height="52dp"
        scaleType="6"
        layout_marginEnd="12dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_gravity="0x10"
        id="@+id/details_container"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <TextView
            textColor="@color/okTradeG900"
            ellipsize="3"
            id="@+id/rc_conversation_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="2dp"
            singleLine="true"
            NOT_FOUND_0x28="true"
            NOT_FOUND_0x2c="@+id/okim_conversation_tag"
            NOT_FOUND_0x2d="0"
            NOT_FOUND_0x2e="2"
            NOT_FOUND_0x30="0"
            NOT_FOUND_0x32="0"
            style="@style/Title_2_Medium"/>
        <TextView
            id="@+id/okim_conversation_tag"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_message_feed_label_official"
            singleLine="true"
            layout_marginStart="@dimen/margin_4dp"
            NOT_FOUND_0x2a="@+id/rc_conversation_title"
            NOT_FOUND_0x2c="@+id/okim_convo_icon_list"
            NOT_FOUND_0x2f="@+id/rc_conversation_title"
            NOT_FOUND_0x32="@+id/rc_conversation_title"
            style="@style/TagTextView"/>
        <ImageView
            id="@+id/iv_official"
            visibility="2"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131234290_res_0x7f080df2"
            importantForAccessibility="2"
            layout_marginStart="@dimen/xxxxsm"
            NOT_FOUND_0x2a="@+id/rc_conversation_title"
            NOT_FOUND_0x2b="0"
            NOT_FOUND_0x2d="0"
            NOT_FOUND_0x2f="@+id/rc_conversation_title"
            NOT_FOUND_0x32="@+id/rc_conversation_title"
            NOT_FOUND_0x34="@color/vip_color"/>
        <o.oIV
            id="@+id/okim_convo_icon_list"
            visibility="2"
            layout_width="-2"
            android:layout_height="@dimen/height_20dp"
            importantForAccessibility="2"
            layout_marginStart="@dimen/margin_4dp"
            NOT_FOUND_0x2a="@+id/rc_conversation_title"
            NOT_FOUND_0x2c="@+id/okim_conversation_date"
            NOT_FOUND_0x2f="@+id/okim_conversation_tag"
            NOT_FOUND_0x32="@+id/rc_conversation_title"/>
        <TextView
            textColor="@color/ContentContrast"
            gravity="0x800015"
            id="@+id/okim_conversation_date"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"
            drawablePadding="4dp"
            paddingStart="@dimen/sm"
            paddingEnd="0dp"
            NOT_FOUND_0x2a="@+id/rc_conversation_title"
            NOT_FOUND_0x2b="0"
            NOT_FOUND_0x32="@+id/rc_conversation_title"
            style="@style/TextAppearance.Text.14SP"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/content_indicator"
            layout_width="@dimen/ok_dp_16"
            android:layout_height="@dimen/ok_dp_16"
            scaleType="fitStart"
            tint="@color/okTradeG400"
            layout_marginEnd="@dimen/dp_4"
            NOT_FOUND_0x2a="@+id/okim_conversation_content_baseline"
            NOT_FOUND_0x2c="@+id/okim_conversation_content"
            NOT_FOUND_0x30="0"
            NOT_FOUND_0x32="@+id/okim_conversation_content_baseline"/>
        <TextView
            textColor="@color/okTradeG400"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/okim_conversation_content"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="2"
            lines="2"
            singleLine="false"
            textAlignment="5"
            layout_marginEnd="@dimen/margin_24dp"
            NOT_FOUND_0x2c="@+id/icon_flow"
            NOT_FOUND_0x2f="@+id/content_indicator"
            NOT_FOUND_0x31="@+id/rc_conversation_title"
            style="@style/Label_1_Regular"/>
        <TextView
            id="@+id/okim_conversation_content_baseline"
            visibility="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x29="@+id/okim_conversation_content"
            NOT_FOUND_0x2b="@+id/okim_conversation_content"
            NOT_FOUND_0x30="@+id/okim_conversation_content"
            NOT_FOUND_0x32="@+id/okim_conversation_content"/>
        <androidx.constraintlayout.helper.widget.Flow
            id="@+id/icon_flow"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x24="okim_conversation_no_disturb,okim_flag,okim_pin,tv_conversation_unread_count"
            NOT_FOUND_0x25="1"
            NOT_FOUND_0x26="4dp"
            NOT_FOUND_0x27="0"
            NOT_FOUND_0x2a="@+id/okim_conversation_content_baseline"
            NOT_FOUND_0x2b="0"
            NOT_FOUND_0x32="@+id/okim_conversation_content_baseline"/>
        <ImageView
            id="@+id/okim_conversation_no_disturb"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            NOT_FOUND_0x33="@drawable/_2131230978_res_0x7f080102"
            NOT_FOUND_0x34="@color/ContentDisabled"/>
        <ImageView
            id="@+id/okim_flag"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            minHeight="8dp"
            NOT_FOUND_0x33="@drawable/_2131231737_res_0x7f0803f9"
            NOT_FOUND_0x34="@color/ContentDisabled"/>
        <ImageView
            id="@+id/okim_pin"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            minHeight="8dp"
            NOT_FOUND_0x33="@drawable/_2131233656_res_0x7f080b78"
            NOT_FOUND_0x34="@color/ContentDisabled"/>
        <TextView
            textSize="@dimen/text_size_12sp"
            textColor="@color/white"
            gravity="0x11"
            id="@+id/tv_conversation_unread_count"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            minHeight="16dp"
            foregroundGravity="0x30"
            paddingStart="4dp"
            paddingEnd="4dp"
            style="@style/Label_3_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
