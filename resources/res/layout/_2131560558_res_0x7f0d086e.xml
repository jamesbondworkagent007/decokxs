<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@drawable/_2131234231_res_0x7f080db7"
    paddingLeft="4dp"
    paddingRight="4dp"
    paddingBottom="3dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="10sp"
        textStyle="0x1"
        textColor="@color/white"
        ellipsize="4"
        id="@+id/tv_method"
        background="@drawable/_2131231497_res_0x7f080309"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxWidth="96dp"
        text="GET"
        singleLine="true"
        marqueeRepeatLimit="-1"
        textAlignment="4"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"/>
    <TextView
        textSize="10sp"
        textStyle="0x1"
        textColor="@color/white"
        id="@+id/tv_is_cache"
        background="@drawable/_2131233623_res_0x7f080b57"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="cache"
        textAlignment="4"
        layout_marginStart="2dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/tv_method"
        NOT_FOUND_0x17="0"/>
    <TextView
        textSize="10sp"
        textStyle="0x1"
        textColor="@color/white"
        id="@+id/tv_code"
        background="@drawable/_2131232279_res_0x7f080617"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="200"
        textAlignment="4"
        layout_marginStart="2dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/tv_is_cache"
        NOT_FOUND_0x17="0"/>
    <TextView
        textSize="10sp"
        textStyle="0x1"
        textColor="@color/white"
        id="@+id/tv_time"
        background="@drawable/_2131233623_res_0x7f080b57"
        paddingLeft="4dp"
        paddingTop="2dp"
        paddingRight="4dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="100ms"
        textAlignment="4"
        layout_marginStart="2dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/tv_code"
        NOT_FOUND_0x17="0"/>
    <TextView
        textSize="10sp"
        textStyle="0x1"
        textColor="@color/white"
        id="@+id/tv_path"
        paddingTop="2dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        text="/base/login"
        textAlignment="4"
        paddingStart="4dp"
        layout_marginStart="2dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/tv_time"
        NOT_FOUND_0x17="0"/>
    <View
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/tv_path"
        NOT_FOUND_0x17="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
