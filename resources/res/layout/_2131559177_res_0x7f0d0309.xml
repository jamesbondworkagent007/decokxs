<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-2"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x11"
        orientation="0"
        id="@+id/favorite_panel"
        background="@drawable/_2131232014_res_0x7f08050e"
        paddingLeft="@dimen/ok_dp_12"
        paddingTop="@dimen/dp_8"
        paddingRight="@dimen/ok_dp_12"
        paddingBottom="@dimen/dp_8"
        layout_width="-2"
        android:layout_height="wrap_content"
        backgroundTint="@color/ContainerContrast"
        paddingHorizontal="@dimen/ok_dp_12"
        paddingVertical="@dimen/dp_8">
        <ImageView
            id="@+id/iv_favorite"
            layout_width="24dp"
            android:layout_height="@dimen/dp24"
            src="@drawable/_2131234087_res_0x7f080d27"
            scaleType="7"
            contentDescription="web3_dex_market_token_list_favorite_icon"/>
        <ImageView
            id="@+id/iv_pin"
            visibility="2"
            layout_width="24dp"
            android:layout_height="@dimen/dp24"
            src="@drawable/_2131230936_res_0x7f0800d8"
            scaleType="7"
            layout_marginStart="20dp"
            NOT_FOUND_0x13="@color/dex_market_star"/>
        <ImageView
            id="@+id/iv_edit"
            visibility="2"
            layout_width="24dp"
            android:layout_height="@dimen/dp24"
            src="@drawable/_2131232049_res_0x7f080531"
            scaleType="7"
            layout_marginStart="20dp"
            NOT_FOUND_0x13="@color/dex_market_star"/>
    </LinearLayout>
    <ImageView
        layout_gravity="0x1"
        id="@+id/container"
        layout_width="14dp"
        android:layout_height="5dp"
        src="@drawable/_2131231977_res_0x7f0804e9"/>
</LinearLayout>
