<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/container"
    tag="layout/component_token_pair_list_item_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/icon_group"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0">
        <androidx.cardview.widget.CardView
            id="@+id/base_token_card"
            layout_width="@dimen/dp_32"
            android:layout_height="@dimen/dp_32"
            NOT_FOUND_0x10="@android:color/transparent"
            NOT_FOUND_0x11="@dimen/dp_16"
            NOT_FOUND_0x12="0dp"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0">
            <ImageView
                id="@+id/base_token_image"
                layout_width="-1"
                android:layout_height="match_parent"
                scaleType="6"/>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            id="@+id/quote_token_card"
            layout_width="@dimen/dp_10"
            android:layout_height="@dimen/dp_10"
            NOT_FOUND_0x10="@android:color/transparent"
            NOT_FOUND_0x11="@dimen/dp_5"
            NOT_FOUND_0x12="0dp"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0">
            <ImageView
                id="@+id/quote_token_image"
                layout_width="-1"
                android:layout_height="match_parent"
                scaleType="6"/>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            id="@+id/dot_stroke"
            visibility="2"
            layout_width="@dimen/dp_8"
            android:layout_height="@dimen/dp_8"
            NOT_FOUND_0x10="@android:color/transparent"
            NOT_FOUND_0x11="4dp"
            NOT_FOUND_0x12="0dp"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x1c="0"/>
        <androidx.cardview.widget.CardView
            id="@+id/dot"
            visibility="2"
            layout_width="@dimen/dp_6"
            android:layout_height="@dimen/dp_6"
            NOT_FOUND_0x10="@color/reminder_error_title_color"
            NOT_FOUND_0x11="3dp"
            NOT_FOUND_0x12="0dp"
            NOT_FOUND_0x14="@+id/dot_stroke"
            NOT_FOUND_0x15="@+id/dot_stroke"
            NOT_FOUND_0x1a="@+id/dot_stroke"
            NOT_FOUND_0x1c="@+id/dot_stroke"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/title_layout"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_12"
        layout_marginEnd="@dimen/dp_8"
        NOT_FOUND_0x16="@+id/custom_frame"
        NOT_FOUND_0x19="@+id/icon_group"
        NOT_FOUND_0x1c="0">
        <TextView
            textColor="@color/color_content_static_default"
            ellipsize="3"
            id="@+id/title_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0x13="true"
            NOT_FOUND_0x16="@+id/quote_text"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="2"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"
            style="@style/Label_3_Medium"/>
        <TextView
            textColor="@color/color_content_static_subtle"
            id="@+id/quote_text"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="@+id/title_text"
            NOT_FOUND_0x16="@+id/tag_layout"
            NOT_FOUND_0x19="@+id/title_text"
            NOT_FOUND_0x1c="@+id/title_text"
            style="@style/Label_2_Medium"/>
        <LinearLayout
            orientation="0"
            id="@+id/tag_layout"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/dp_4"
            NOT_FOUND_0x14="@+id/title_text"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x19="@+id/quote_text"
            NOT_FOUND_0x1c="@+id/title_text"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        id="@+id/custom_frame"
        visibility="2"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginEnd="@dimen/dp_8"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/value_text"
        NOT_FOUND_0x19="@+id/title_layout"
        NOT_FOUND_0x1c="0"/>
    <TextView
        textColor="@color/color_content_static_subtle"
        id="@+id/subtitle_text"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/dp_8"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/subvalue_text"
        NOT_FOUND_0x1a="@+id/title_layout"
        NOT_FOUND_0x1b="@+id/title_layout"
        style="@style/Label_3_Regular"/>
    <TextView
        textColor="@color/color_content_static_subtle"
        ellipsize="3"
        id="@+id/value_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_weight="1"
        NOT_FOUND_0x14="@+id/title_layout"
        NOT_FOUND_0x16="@+id/function_container"
        NOT_FOUND_0x1c="@+id/title_layout"
        style="@style/Label_3_Medium"/>
    <TextView
        textColor="@color/color_content_static_subtle"
        ellipsize="3"
        id="@+id/subvalue_text"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0x16="@+id/function_container"
        NOT_FOUND_0x1c="@+id/subtitle_text"
        style="@style/Label_3_Regular"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/function_container"
        paddingLeft="@dimen/dp_16"
        paddingRight="@dimen/dp_16"
        visibility="2"
        layout_width="0dp"
        android:layout_height="0dp"
        paddingHorizontal="@dimen/dp_16"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x1c="0">
        <ImageView
            id="@+id/function_icon"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1c="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
