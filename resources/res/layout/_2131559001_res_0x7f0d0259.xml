<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    focusable="true"
    focusableInTouchMode="true"
    clickable="true"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginLeft="15dp"
    layout_marginTop="10dp"
    layout_marginRight="15dp"
    layout_marginBottom="10dp">
    <EditText
        textSize="15sp"
        id="@+id/issue_description"
        layout_width="-1"
        android:layout_height="match_parent"
        hint="@string/file_issue_hint"
        layout_above="@+id/file_issue_warning"
        inputType="0xa0001"
        autofillHints="no"/>
    <TextView
        textSize="15sp"
        textStyle="0x1"
        textColor="?android:attr/textColorPrimaryInverse"
        gravity="0x11"
        id="@+id/file_issue_warning"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        layout_marginBottom="10dp"
        text="@string/file_issue_warning_text"
        layout_above="@+id/issue_buttons"/>
    <LinearLayout
        orientation="0"
        id="@+id/issue_buttons"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_alignParentBottom="true"
        layout_centerHorizontal="true">
        <Button
            textSize="15sp"
            id="@+id/copy_issue"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/copy_issue_text"
            textAllCaps="false"
            layout_marginEnd="10dp"
            style="?android:attr/buttonBarButtonStyle"/>
        <Button
            textSize="15sp"
            id="@+id/file_issue"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/file_issue_button_title"
            textAllCaps="false"
            style="?android:attr/buttonBarButtonStyle"/>
    </LinearLayout>
</RelativeLayout>
