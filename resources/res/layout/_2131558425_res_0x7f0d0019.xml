<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    id="@+id/search_bar"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textAppearance="?android:attr/textAppearanceMedium"
        textColor="?android:attr/textColorPrimary"
        gravity="0x10"
        id="@+id/search_badge"
        visibility="2"
        layout_width="-2"
        android:layout_height="match_parent"
        layout_marginBottom="2dp"
        drawablePadding="0dp"/>
    <ImageView
        layout_gravity="0x10"
        id="@+id/search_button"
        focusable="true"
        layout_width="-2"
        android:layout_height="match_parent"
        contentDescription="@string/abc_searchview_description_search"
        style="?attr/actionButtonStyle"/>
    <LinearLayout
        orientation="0"
        id="@+id/search_edit_frame"
        layout_width="-2"
        android:layout_height="match_parent"
        layout_marginLeft="8dp"
        layout_marginRight="8dp"
        layout_weight="1"
        layoutDirection="3">
        <ImageView
            layout_gravity="0x10"
            id="@+id/search_mag_icon"
            visibility="2"
            layout_width="@dimen/abc_dropdownitem_icon_width"
            android:layout_height="wrap_content"
            scaleType="7"
            style="@style/RtlOverlay.Widget.AppCompat.SearchView.MagIcon"/>
        <LinearLayout
            layout_gravity="0x10"
            orientation="0"
            id="@+id/search_plate"
            layout_width="-2"
            android:layout_height="match_parent"
            layout_weight="1">
            <view
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/search_src_text"
                background="@null"
                paddingLeft="@dimen/abc_dropdownitem_text_padding_left"
                paddingRight="@dimen/abc_dropdownitem_text_padding_right"
                layout_width="0dp"
                android:layout_height="36dp"
                singleLine="true"
                layout_weight="1"
                inputType="0x90001"
                dropDownAnchor="@+id/search_edit_frame"
                imeOptions="0x3"
                dropDownHeight="-2"
                dropDownHorizontalOffset="0dp"
                dropDownVerticalOffset="0dp"
                class="androidx.appcompat.widget.SearchView$SearchAutoComplete"/>
            <ImageView
                layout_gravity="0x10"
                id="@+id/search_close_btn"
                background="?attr/selectableItemBackgroundBorderless"
                paddingLeft="8dp"
                paddingRight="8dp"
                focusable="true"
                layout_width="-2"
                android:layout_height="match_parent"
                contentDescription="@string/abc_searchview_description_clear"/>
        </LinearLayout>
        <LinearLayout
            orientation="0"
            id="@+id/submit_area"
            layout_width="-2"
            android:layout_height="match_parent">
            <ImageView
                layout_gravity="0x10"
                id="@+id/search_go_btn"
                background="?attr/selectableItemBackgroundBorderless"
                paddingLeft="16dp"
                paddingRight="16dp"
                focusable="true"
                visibility="2"
                layout_width="-2"
                android:layout_height="match_parent"
                contentDescription="@string/abc_searchview_description_submit"/>
            <ImageView
                layout_gravity="0x10"
                id="@+id/search_voice_btn"
                background="?attr/selectableItemBackgroundBorderless"
                paddingLeft="16dp"
                paddingRight="16dp"
                focusable="true"
                visibility="2"
                layout_width="-2"
                android:layout_height="match_parent"
                contentDescription="@string/abc_searchview_description_voice"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
