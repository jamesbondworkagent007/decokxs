<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/background_lv1"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="@dimen/height_40dp">
    <View
        id="@+id/line_top"
        background="@color/primary_white"
        visibility="2"
        layout_width="@dimen/width_1dp"
        android:layout_height="0dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/step_indicator_container"
        NOT_FOUND_0x13="@+id/step_indicator_container"
        NOT_FOUND_0x15="@+id/step_indicator_container"
        NOT_FOUND_0x17="0"/>
    <View
        id="@+id/line_bottom"
        background="@color/primary_white"
        layout_width="@dimen/width_1dp"
        android:layout_height="0dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="@+id/step_indicator_container"
        NOT_FOUND_0x15="@+id/step_indicator_container"
        NOT_FOUND_0x16="@+id/step_indicator_container"/>
    <FrameLayout
        id="@+id/step_indicator_container"
        background="@drawable/_2131232492_res_0x7f0806ec"
        layout_width="@dimen/width_20dp"
        android:layout_height="@dimen/width_20dp"
        layout_marginTop="@dimen/ok_dp_24"
        layout_marginStart="@dimen/ok_dp_24"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0">
        <ImageView
            layout_gravity="0x11"
            id="@+id/checkmark"
            padding="1dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232434_res_0x7f0806b2"
            contentDescription="@null"
            NOT_FOUND_0x18="@color/ContentDisabled"/>
        <TextView
            textAppearance="@style/Body_3"
            textColor="@color/grey_g900"
            gravity="0x11"
            id="@+id/step_indicator"
            visibility="2"
            layout_width="-1"
            android:layout_height="match_parent"/>
    </FrameLayout>
    <TextView
        textAppearance="@style/LiteTextAppearance.White.16SP.Medium"
        textColor="@color/primary_white"
        id="@+id/step_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/ok_dp_24"
        textAlignment="5"
        layout_marginStart="@dimen/ok_dp_16"
        layout_marginEnd="@dimen/ok_dp_24"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/step_indicator_container"
        NOT_FOUND_0x17="0"/>
    <TextView
        textAppearance="@style/LiteTextAppearance.White.14SP"
        textColor="@color/primary_white"
        id="@+id/step_subtitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        textAlignment="5"
        layout_marginEnd="@dimen/ok_dp_24"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="@+id/step_title"
        NOT_FOUND_0x16="@+id/step_title"/>
    <View
        background="@color/transparent"
        layout_width="-1"
        android:layout_height="@dimen/ok_dp_24"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="@+id/step_subtitle"/>
</androidx.constraintlayout.widget.ConstraintLayout>
