<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/padding_32dp"
    paddingBottom="@dimen/padding_32dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    contentDescription="web3_dex_dapp_token_info_view"
    paddingVertical="@dimen/padding_32dp">
    <LinearLayout
        gravity="0x1"
        orientation="1"
        id="@+id/ll_token_details"
        layout_width="146dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="@+id/pointer_right"
        NOT_FOUND_0x1d="0.5"
        NOT_FOUND_0x1e="2"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="0">
        <FrameLayout
            layout_width="@dimen/width_48dp"
            android:layout_height="@dimen/height_48dp">
            <ImageView
                id="@+id/token_image"
                layout_width="44dp"
                android:layout_height="44dp"
                scaleType="7"
                importantForAccessibility="2"/>
            <ImageView
                id="@+id/chain_image"
                background="@drawable/_2131231867_res_0x7f08047b"
                layout_width="22dp"
                android:layout_height="22dp"
                layout_marginTop="25dp"
                scaleType="7"
                importantForAccessibility="2"
                layout_marginStart="25dp"
                backgroundTint="@color/line_light"/>
        </FrameLayout>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x11"
            id="@+id/token_name"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/dp_4"
            layout_marginTop="@dimen/ok_dp_12"
            layout_marginRight="@dimen/dp_4"
            maxLines="1"
            layout_marginHorizontal="@dimen/dp_4"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x11"
            id="@+id/chain_name"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/dp_4"
            layout_marginTop="@dimen/dp_4"
            layout_marginRight="@dimen/dp_4"
            maxLines="1"
            layout_marginHorizontal="@dimen/dp_4"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="2"
            gravity="0x11"
            id="@+id/token_address"
            background="@drawable/_2131231804_res_0x7f08043c"
            padding="@dimen/dp_4"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/ok_dp_12"
            maxLines="1"
            drawableRight="@drawable/_2131231721_res_0x7f0803e9"
            drawablePadding="@dimen/dp_4"
            drawableTint="@color/ContentContrast"
            style="@style/Body_4"/>
    </LinearLayout>
    <ImageView
        id="@+id/pointer_right"
        layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"
        layout_marginLeft="@dimen/margin_8dp"
        layout_marginRight="@dimen/margin_8dp"
        src="@drawable/_2131233694_res_0x7f080b9e"
        importantForAccessibility="2"
        layout_marginHorizontal="@dimen/margin_8dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="@+id/ll_token_details_other"
        NOT_FOUND_0x1d="0.5"
        NOT_FOUND_0x1f="@+id/ll_token_details"
        NOT_FOUND_0x21="0"/>
    <LinearLayout
        gravity="0x1"
        orientation="1"
        id="@+id/ll_token_details_other"
        layout_width="146dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0.5"
        NOT_FOUND_0x1f="@+id/pointer_right"
        NOT_FOUND_0x21="0">
        <FrameLayout
            layout_width="@dimen/width_48dp"
            android:layout_height="@dimen/height_48dp">
            <ImageView
                id="@+id/token_image_other"
                layout_width="44dp"
                android:layout_height="44dp"
                scaleType="7"
                importantForAccessibility="2"/>
            <ImageView
                id="@+id/chain_image_other"
                background="@drawable/_2131231867_res_0x7f08047b"
                layout_width="22dp"
                android:layout_height="22dp"
                layout_marginTop="25dp"
                scaleType="7"
                importantForAccessibility="2"
                layout_marginStart="25dp"
                backgroundTint="@color/line_light"/>
        </FrameLayout>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            gravity="0x11"
            id="@+id/token_name_other"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/dp_4"
            layout_marginTop="@dimen/ok_dp_12"
            layout_marginRight="@dimen/dp_4"
            maxLines="1"
            layout_marginHorizontal="@dimen/dp_4"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x11"
            id="@+id/chain_name_other"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/dp_4"
            layout_marginTop="@dimen/dp_4"
            layout_marginRight="@dimen/dp_4"
            maxLines="1"
            layout_marginHorizontal="@dimen/dp_4"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="2"
            gravity="0x11"
            id="@+id/token_address_other"
            background="@drawable/_2131231804_res_0x7f08043c"
            padding="@dimen/dp_4"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/ok_dp_12"
            maxLines="1"
            drawableRight="@drawable/_2131231721_res_0x7f0803e9"
            drawablePadding="@dimen/dp_4"
            drawableTint="@color/ContentContrast"
            style="@style/Body_4"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
