<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_im_text_og_web_url_0"
    paddingBottom="4dp"
    layout_width="-2"
    android:layout_height="wrap_content">
    <View
        id="@+id/verticalLine"
        background="@drawable/_2131233578_res_0x7f080b2a"
        layout_width="4dp"
        android:layout_height="0dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <androidx.cardview.widget.CardView
        id="@+id/cardView"
        layout_width="205dp"
        android:layout_height="108dp"
        layout_marginStart="8dp"
        backgroundTint="@color/transparent"
        NOT_FOUND_0xc="8dp"
        NOT_FOUND_0xd="0dp"
        NOT_FOUND_0x10="@+id/verticalLine"
        NOT_FOUND_0x13="0">
        <com.airbnb.lottie.LottieAnimationView
            id="@+id/lottiePlaceholder"
            layout_width="-1"
            android:layout_height="match_parent"
            NOT_FOUND_0x14="true"
            NOT_FOUND_0x15="true"/>
        <com.google.android.material.imageview.ShapeableImageView
            id="@+id/ivImage"
            layout_width="-1"
            android:layout_height="match_parent"
            scaleType="fitStart"
            adjustViewBounds="true"/>
    </androidx.cardview.widget.CardView>
    <TextView
        textColor="@color/ContentTertiary"
        id="@+id/topTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0xf="@+id/cardView"
        NOT_FOUND_0x11="@+id/cardView"
        NOT_FOUND_0x12="@+id/cardView"
        style="@style/Label_3_Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/secondTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0xf="@+id/cardView"
        NOT_FOUND_0x11="@+id/cardView"
        NOT_FOUND_0x12="@+id/topTitle"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentTertiary"
        id="@+id/description"
        paddingBottom="4dp"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0xf="@+id/cardView"
        NOT_FOUND_0x11="@+id/cardView"
        NOT_FOUND_0x12="@+id/secondTitle"
        style="@style/Body_4"/>
</androidx.constraintlayout.widget.ConstraintLayout>
