<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/item_input_checkbox_select_item_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/group_divider"
        background="@color/line_light"
        visibility="2"
        layout_width="-1"
        android:layout_height="1dp"/>
    <TextView
        textColor="@color/Neutral90"
        id="@+id/group_title"
        paddingTop="@dimen/padding_16dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.Subtitle.12SP"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/choice_ly"
        paddingTop="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/padding_16dp">
        <ImageView
            id="@+id/choice_icon"
            visibility="2"
            layout_width="@dimen/width_32dp"
            android:layout_height="@dimen/height_32dp"
            layout_marginEnd="@dimen/margin_12dp"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="1"
            layout_width="@dimen/width_0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    gravity="0x800003"
                    id="@+id/choice_title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    textAlignment="5"
                    style="@style/TextAppearance.Title.14SP"/>
                <o.C55251xgS
                    ellipsize="3"
                    id="@+id/choice_badge"
                    paddingLeft="@dimen/padding_4dp"
                    paddingTop="@dimen/padding_2dp"
                    paddingRight="@dimen/padding_4dp"
                    paddingBottom="@dimen/padding_2dp"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"
                    layout_marginStart="@dimen/margin_2dp"
                    paddingHorizontal="@dimen/padding_4dp"
                    paddingVertical="@dimen/padding_2dp"/>
            </LinearLayout>
            <TextView
                textColor="@color/ContentTertiary"
                id="@+id/choice_subtitle"
                visibility="2"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp"
                style="@style/TextAppearance.Subtitle.12SP"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <TextView
            textColor="@color/ContentTertiary"
            id="@+id/choice_value"
            paddingLeft="@dimen/padding_8dp"
            paddingRight="@dimen/padding_8dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingHorizontal="@dimen/padding_8dp"
            style="@style/TextAppearance.Text.14SP"/>
        <o.wYK
            id="@+id/choice_checkbox"
            layout_width="-2"
            android:layout_height="wrap_content"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
