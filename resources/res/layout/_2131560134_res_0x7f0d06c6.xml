<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    scrollbars="horizontal"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x1"
        orientation="1"
        layout_width="-1"
        android:layout_height="match_parent">
        <androidx.appcompat.widget.AppCompatImageView
            layout_width="64dp"
            android:layout_height="64dp"
            src="@drawable/_2131234391_res_0x7f080e57"
            NOT_FOUND_0x16="@color/SemanticNegative"/>
        <TextView
            textAppearance="@style/Headline_5_Bold"
            textColor="@color/color_content_static_default"
            gravity="0x11"
            id="@+id/tv_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginRight="@dimen/margin_24dp"
            text="@string/pr_wallet_home_alert_header_security_reminder"
            layout_marginHorizontal="@dimen/margin_24dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginTop="@dimen/margin_16dp"
            layout_marginRight="@dimen/margin_24dp"
            layout_marginBottom="@dimen/margin_16dp"
            layout_marginHorizontal="@dimen/margin_24dp"
            layout_marginVertical="@dimen/margin_16dp">
            <TextView
                textAppearance="@style/Label_1_Medium"
                textSize="@dimen/text_size_16sp"
                textColor="@color/color_content_static_default"
                id="@+id/tv_num1_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_wallet_home_alert_title_reset_wallet"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x15="0"/>
            <TextView
                textAppearance="@style/Body_3_Regular"
                textSize="@dimen/text_size_14sp"
                textColor="@color/color_content_static_subtle"
                id="@+id/tv_num1_subtitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                text="@string/pr_wallet_home_alert_desc_reset_wallet_import"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x13="@+id/tv_num1_title"
                NOT_FOUND_0x14="@+id/tv_num1_title"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_24dp"
            layout_marginRight="@dimen/margin_24dp"
            layout_marginBottom="@dimen/margin_24dp"
            layout_marginHorizontal="@dimen/margin_24dp">
            <TextView
                textAppearance="@style/Label_1_Medium"
                textSize="@dimen/text_size_16sp"
                textColor="@color/color_content_static_default"
                id="@+id/tv_num2_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_wallet_home_alert_title_write_seed_phrase"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x13="0"
                NOT_FOUND_0x15="0"/>
            <TextView
                textAppearance="@style/Body_3_Regular"
                textSize="@dimen/text_size_14sp"
                textColor="@color/color_content_static_subtle"
                id="@+id/tv_num2_subtitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_8dp"
                text="@string/pr_wallet_home_alert_desc_reset_seed_phrase"
                NOT_FOUND_0x11="0"
                NOT_FOUND_0x12="0"
                NOT_FOUND_0x13="@+id/tv_num2_title"
                NOT_FOUND_0x14="@+id/tv_num2_title"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
