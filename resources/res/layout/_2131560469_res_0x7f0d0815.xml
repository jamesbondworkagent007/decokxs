<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="@color/BasePrimaryAlternative"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_12dp">
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guideline"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x13="0.5"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_3_Regular"
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        id="@+id/tvNameAmount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_home_colheader_name_amount"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@+id/guideline"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_3_Regular"
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        gravity="0x800005"
        id="@+id/tvValueUpnl"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_wallet_home_colheader_value_upnl"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="@+id/guideline"
        NOT_FOUND_0x16="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
