<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    id="@+id/action_container"
    layout_width="0dp"
    android:layout_height="48dp"
    layout_weight="1"
    paddingStart="4dp"
    style="@style/Widget.Compat.NotificationActionContainer">
    <ImageView
        layout_gravity="0x800013"
        id="@+id/action_image"
        layout_width="@dimen/notification_action_icon_size"
        android:layout_height="@dimen/notification_action_icon_size"
        scaleType="7"/>
    <TextView
        ellipsize="3"
        layout_gravity="0x800013"
        id="@+id/action_text"
        clickable="false"
        layout_width="-2"
        android:layout_height="wrap_content"
        singleLine="true"
        paddingStart="4dp"
        style="@style/Widget.Compat.NotificationActionText"/>
</LinearLayout>
