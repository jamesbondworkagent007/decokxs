<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    scrollbars="horizontal"
    layout_width="-1"
    android:layout_height="match_parent"
    overScrollMode="2">
    <LinearLayout
        orientation="1"
        id="@+id/content"
        paddingLeft="@dimen/margin_default"
        paddingTop="@dimen/padding_20dp"
        paddingRight="@dimen/margin_default"
        layout_width="-1"
        android:layout_height="match_parent"
        paddingHorizontal="@dimen/margin_default">
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            id="@+id/title"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_spotgrid_placeorder_tips_smart_earn_allocation"
            style="@style/TextAppearance.Text.16SP.Medium"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentTertiary"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="@string/pr_spotgrid_placeorder_tips_smart_earn_allocation_desc"
            style="@style/Body_3_Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentPrimary"
            id="@+id/secondTitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_24dp"
            text="@string/pr_spotgrid_placeorder_select_active_grid_range"
            style="@style/TextAppearance.Text.16SP.Medium"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/ContentTertiary"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_12dp"
            text="@string/pr_spotgrid_placeorder_select_active_grid_range_desc"
            style="@style/Body_3_Regular"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
