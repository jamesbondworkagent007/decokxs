<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="8dp"
    layout_marginBottom="8dp"
    layout_marginVertical="8dp">
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"/>
    <TextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/ContentContrast"
        id="@+id/tv_address"
        layout_width="-2"
        android:layout_height="wrap_content"/>
</LinearLayout>
