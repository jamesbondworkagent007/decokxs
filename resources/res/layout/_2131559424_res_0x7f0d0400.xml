<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="wrap_content"
    fillViewport="true">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginRight="@dimen/margin_default"
        layout_marginBottom="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default">
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_addresses"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_invest_smartmoney_filter_input_title_addresses"
            style="@style/Label_2_Medium"/>
        <o.C28034kMl
            id="@+id/widget_addresses_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_address_turnover"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_invest_smartmoney_filter_input_title_turnover"
            style="@style/Label_2_Medium"/>
        <o.C28024kMb
            id="@+id/widget_address_turnover_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_alert_market_cap"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_invest_smartmoney_filter_input_title_alert_mcap"
            style="@style/Label_2_Medium"/>
        <o.C28024kMb
            id="@+id/widget_alert_market_cap_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            id="@+id/tv_alert_liquidity"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/height_16dp"
            text="@string/pr_invest_smartmoney_filter_input_title_alert_liquidity"
            style="@style/Label_2_Medium"/>
        <o.C28024kMb
            id="@+id/widget_alert_liquidity_range"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="-4dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
