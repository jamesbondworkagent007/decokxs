<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/container"
    tag="layout/layout_dapp_web_options_0"
    paddingBottom="@dimen/height_14dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        paddingTop="8dp"
        paddingBottom="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        minWidth="148dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/padding_25dp"
            layout_marginStart="@dimen/ok_dp_16"
            layout_marginEnd="@dimen/ok_dp_16">
            <LinearLayout
                gravity="0x1"
                orientation="1"
                id="@+id/copy"
                layout_width="@dimen/height_72dp"
                android:layout_height="wrap_content"
                contentDescription="web3_discover_home_web_page_menu_copy"
                NOT_FOUND_0x19="@+id/add"
                NOT_FOUND_0x1a="1"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0">
                <FrameLayout
                    background="@drawable/_2131231090_res_0x7f080172"
                    layout_width="@dimen/height_56dp"
                    android:layout_height="@dimen/height_56dp">
                    <o.wYC
                        layout_gravity="0x11"
                        id="@+id/iv_copy"
                        layout_width="@dimen/margin_28dp"
                        android:layout_height="@dimen/margin_28dp"
                        src="@drawable/_2131231720_res_0x7f0803e8"
                        NOT_FOUND_0x1e="@color/ContentPrimary"/>
                </FrameLayout>
                <TextView
                    textSize="@dimen/text_size_12sp"
                    textColor="@color/grey_g900"
                    gravity="0x11"
                    layout_gravity="0x11"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/dp_10"
                    text="@string/pr_dapp_home_navigation_copy_url"/>
            </LinearLayout>
            <LinearLayout
                gravity="0x1"
                orientation="1"
                id="@+id/add"
                layout_width="@dimen/height_72dp"
                android:layout_height="wrap_content"
                contentDescription="web3_discover_home_web_page_favorite_button_option"
                NOT_FOUND_0x19="@+id/refreshLayout"
                NOT_FOUND_0x1b="@+id/copy"
                NOT_FOUND_0x1d="0">
                <FrameLayout
                    background="@drawable/_2131231090_res_0x7f080172"
                    layout_width="@dimen/height_56dp"
                    android:layout_height="@dimen/height_56dp">
                    <o.wYC
                        layout_gravity="0x11"
                        id="@+id/collect"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        src="@drawable/_2131234087_res_0x7f080d27"/>
                </FrameLayout>
                <TextView
                    textSize="@dimen/text_size_12sp"
                    textColor="@color/grey_g900"
                    gravity="0x11"
                    layout_gravity="0x11"
                    id="@+id/tv_add"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/dp_10"
                    text="@string/pr_discover_button_explorer_favorite"/>
            </LinearLayout>
            <LinearLayout
                gravity="0x1"
                orientation="1"
                id="@+id/refreshLayout"
                layout_width="@dimen/height_72dp"
                android:layout_height="wrap_content"
                NOT_FOUND_0x19="@+id/share"
                NOT_FOUND_0x1b="@+id/add"
                NOT_FOUND_0x1d="0">
                <FrameLayout
                    background="@drawable/_2131231090_res_0x7f080172"
                    layout_width="@dimen/height_56dp"
                    android:layout_height="@dimen/height_56dp">
                    <o.wYC
                        layout_gravity="0x11"
                        layout_width="@dimen/margin_24dp"
                        android:layout_height="@dimen/margin_24dp"
                        src="@drawable/_2131233783_res_0x7f080bf7"
                        NOT_FOUND_0x1e="@color/ContentPrimary"/>
                </FrameLayout>
                <TextView
                    textSize="@dimen/text_size_12sp"
                    textColor="@color/grey_g900"
                    gravity="0x11"
                    layout_gravity="0x11"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/dp_10"
                    text="@string/pr_commonall_enterfield_btn_refresh"/>
            </LinearLayout>
            <LinearLayout
                gravity="0x1"
                orientation="1"
                id="@+id/share"
                layout_width="@dimen/height_72dp"
                android:layout_height="wrap_content"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1b="@+id/refreshLayout"
                NOT_FOUND_0x1d="0">
                <FrameLayout
                    background="@drawable/_2131231090_res_0x7f080172"
                    layout_width="@dimen/height_56dp"
                    android:layout_height="@dimen/height_56dp">
                    <o.wYC
                        layout_gravity="0x11"
                        layout_width="@dimen/margin_24dp"
                        android:layout_height="@dimen/margin_24dp"
                        src="@drawable/_2131234035_res_0x7f080cf3"
                        NOT_FOUND_0x1e="@color/ContentPrimary"/>
                </FrameLayout>
                <TextView
                    textSize="@dimen/text_size_12sp"
                    textColor="@color/grey_g900"
                    gravity="0x11"
                    layout_gravity="0x11"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/dp_10"
                    text="@string/pr_dapp_home_navigation_share"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            background="@color/grey_g100"
            layout_width="-1"
            android:layout_height="0.5dp"
            layout_marginTop="18dp"/>
        <LinearLayout
            id="@+id/switch_network"
            layout_width="-1"
            android:layout_height="56dp"
            paddingStart="@dimen/width_20dp"
            paddingEnd="@dimen/width_20dp">
            <o.wYC
                layout_gravity="0x10"
                layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24"
                src="@drawable/_2131234381_res_0x7f080e4d"
                layout_marginEnd="@dimen/width_20dp"
                NOT_FOUND_0x1e="@color/ContentPrimary"/>
            <TextView
                textColor="@color/okTradeG900"
                ellipsize="3"
                layout_gravity="0x10"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_nft_explore_cell_title_switch_network"
                lines="1"
                style="@style/TextAppearance.Text.16SP.Medium"/>
        </LinearLayout>
        <LinearLayout
            id="@+id/translate"
            visibility="2"
            layout_width="-1"
            android:layout_height="56dp"
            paddingStart="@dimen/width_20dp"
            paddingEnd="@dimen/width_20dp">
            <o.wYC
                layout_gravity="0x10"
                layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24"
                src="@drawable/_2131234229_res_0x7f080db5"
                layout_marginEnd="@dimen/margin_20dp"
                NOT_FOUND_0x1e="@color/ContentPrimary"/>
            <TextView
                textColor="@color/okTradeG900"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/translate_btn"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_discover_explorer_textbtn_translate"
                lines="1"
                style="@style/TextAppearance.Text.16SP.Medium"/>
        </LinearLayout>
        <LinearLayout
            id="@+id/reminder"
            visibility="2"
            layout_width="-1"
            android:layout_height="56dp"
            contentDescription="web3_discover_home_web_page_menu_add_reminder"
            paddingStart="@dimen/width_20dp"
            paddingEnd="@dimen/width_20dp">
            <o.wYC
                layout_gravity="0x10"
                layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24"
                src="@drawable/_2131233769_res_0x7f080be9"
                layout_marginEnd="@dimen/margin_20dp"
                NOT_FOUND_0x1e="@color/ContentPrimary"/>
            <TextView
                textColor="@color/okTradeG900"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/reminder_btn"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_nft_list_subtitle_dapp_alarm"
                lines="1"
                style="@style/TextAppearance.Text.16SP.Medium"/>
        </LinearLayout>
        <LinearLayout
            id="@+id/mode_control"
            layout_width="-1"
            android:layout_height="56dp"
            paddingStart="@dimen/width_20dp"
            paddingEnd="@dimen/width_20dp">
            <o.wYC
                layout_gravity="0x10"
                id="@+id/mode_iv"
                layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24"
                src="@drawable/trading_data"
                layout_marginEnd="@dimen/width_20dp"
                NOT_FOUND_0x1e="@color/ContentPrimary"/>
            <TextView
                textColor="@color/okTradeG900"
                ellipsize="3"
                layout_gravity="0x10"
                id="@+id/mode_tv"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="切换到桌面模式"
                lines="1"
                style="@style/TextAppearance.Text.16SP.Medium"/>
        </LinearLayout>
        <LinearLayout
            id="@+id/history"
            visibility="2"
            layout_width="-1"
            android:layout_height="56dp"
            paddingStart="@dimen/width_20dp"
            paddingEnd="@dimen/width_20dp">
            <o.wYC
                layout_gravity="0x10"
                layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24"
                src="@drawable/history"
                layout_marginEnd="@dimen/width_20dp"
                NOT_FOUND_0x1e="@color/ContentPrimary"/>
            <TextView
                textColor="@color/okTradeG900"
                ellipsize="3"
                layout_gravity="0x10"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_metax_discover_browser_function_history"
                lines="1"
                style="@style/TextAppearance.Text.16SP.Medium"/>
        </LinearLayout>
        <LinearLayout
            id="@+id/detail"
            visibility="2"
            layout_width="-1"
            android:layout_height="56dp"
            contentDescription="web3_discover_home_web_page_menu_info_detail"
            paddingStart="@dimen/width_20dp"
            paddingEnd="@dimen/width_20dp">
            <o.wYC
                layout_gravity="0x10"
                layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24"
                src="@drawable/_2131231500_res_0x7f08030c"
                layout_marginEnd="@dimen/width_20dp"
                NOT_FOUND_0x1e="@color/ContentPrimary"/>
            <TextView
                textColor="@color/okTradeG900"
                ellipsize="3"
                layout_gravity="0x10"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_discover_button_view_datails_page"
                lines="1"
                style="@style/TextAppearance.Text.16SP.Medium"/>
        </LinearLayout>
        <LinearLayout
            id="@+id/clearCacheLayout"
            visibility="0"
            layout_width="-1"
            android:layout_height="56dp"
            contentDescription="web3_discover_home_web_page_menu_clear_cache"
            paddingStart="@dimen/width_20dp"
            paddingEnd="@dimen/width_20dp">
            <o.wYC
                layout_gravity="0x10"
                layout_width="@dimen/dp24"
                android:layout_height="@dimen/dp24"
                src="@drawable/_2131232481_res_0x7f0806e1"
                layout_marginEnd="@dimen/width_20dp"
                NOT_FOUND_0x1e="@color/ContentPrimary"/>
            <TextView
                textColor="@color/okTradeG900"
                ellipsize="3"
                layout_gravity="0x10"
                layout_width="-1"
                android:layout_height="wrap_content"
                text="@string/pr_discover_button_clear_cache_data"
                lines="1"
                style="@style/TextAppearance.Text.16SP.Medium"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
