<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/fragment_chart_kline_teach_0"
    paddingBottom="30dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        layout_gravity="0x1"
        background="@drawable/_2131232048_res_0x7f080530"
        layout_width="30dp"
        android:layout_height="3dp"
        layout_marginTop="6dp"/>
    <TextView
        textAppearance="@style/OKTextFont.Bold"
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        gravity="0x11"
        paddingLeft="@dimen/padding_16dp"
        paddingRight="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        text="@string/pr_trade_charts_header_title_chart_tutorials"
        paddingHorizontal="@dimen/padding_16dp"/>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/okcell_kline_function"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="@string/pr_trade_charts_cell_title_chart">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            layout_width="-2"
            android:layout_height="wrap_content">
            <ImageView
                layout_gravity="0x10"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131231647_res_0x7f08039f"
                layout_marginStart="4dp"
                NOT_FOUND_0x15="@color/cell_description_color"/>
        </LinearLayout>
    </com.okinc.uilab.item.OKRegularCell>
    <com.okinc.uilab.item.OKRegularCell
        id="@+id/okcell_kline_order"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="@string/pr_trade_charts_cell_title_display">
        <LinearLayout
            gravity="0x10"
            orientation="0"
            layout_width="-2"
            android:layout_height="wrap_content">
            <ImageView
                id="@+id/red_notice_order"
                visibility="2"
                layout_width="6dp"
                android:layout_height="6dp"
                layout_marginRight="@dimen/dp_6"
                src="@drawable/_2131232046_res_0x7f08052e"/>
            <ImageView
                layout_gravity="0x10"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131231647_res_0x7f08039f"
                layout_marginStart="4dp"
                NOT_FOUND_0x15="@color/cell_description_color"/>
        </LinearLayout>
    </com.okinc.uilab.item.OKRegularCell>
</LinearLayout>
