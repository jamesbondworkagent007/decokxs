<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_select_coin_search_0"
    paddingTop="12dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <ImageView
        id="@+id/icon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginStart="24dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        id="@+id/symbol"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="12dp"
        NOT_FOUND_0x10="true"
        NOT_FOUND_0x13="@+id/chain"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="2"
        NOT_FOUND_0x16="@+id/icon"
        NOT_FOUND_0x19="0"
        style="@style/TextAppearance.Title.16SP.Medium"/>
    <TextView
        textAppearance="@style/TextAppearance.Regular"
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginEnd="12dp"
        NOT_FOUND_0x13="@+id/checkView"
        NOT_FOUND_0x17="@+id/symbol"
        NOT_FOUND_0x18="@+id/symbol"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        id="@+id/contractAddress"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginEnd="12dp"
        NOT_FOUND_0x13="@+id/checkView"
        NOT_FOUND_0x17="@+id/symbol"
        NOT_FOUND_0x18="@+id/name"/>
    <o.C55251xgS
        textAppearance="@style/TextAppearance.Text.Medium"
        textSize="@dimen/text_size_10sp"
        textColor="@color/ContentContrast"
        id="@+id/chain"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingStart="4dp"
        paddingEnd="4dp"
        layout_marginStart="4dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x11="@+id/symbol"
        NOT_FOUND_0x13="@+id/checkView"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/symbol"
        NOT_FOUND_0x19="@+id/symbol"
        NOT_FOUND_0x1a="-4"
        NOT_FOUND_0x1b="6"/>
    <o.C10324bmM
        id="@+id/checkView"
        padding="4dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="24dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x19="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
