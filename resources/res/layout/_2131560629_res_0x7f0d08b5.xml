<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/item_input_card_select_item_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/line"
        layout_width="-1"
        android:layout_height="10dp"/>
    <FrameLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/choice_ly"
            background="@drawable/_2131231183_res_0x7f0801cf"
            paddingLeft="16dp"
            paddingTop="@dimen/padding_20dp"
            paddingRight="16dp"
            paddingBottom="@dimen/padding_20dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            minHeight="60dp"
            paddingHorizontal="16dp"
            paddingVertical="@dimen/padding_20dp">
            <ImageView
                id="@+id/choice_icon"
                layout_width="62dp"
                android:layout_height="40dp"
                layout_marginEnd="12dp"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                orientation="1"
                layout_width="-1"
                android:layout_height="wrap_content">
                <ImageView
                    id="@+id/choice_iv"
                    layout_width="-2"
                    android:layout_height="wrap_content"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/choice"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Text.16SP"/>
                <TextView
                    textColor="@color/ContentTertiary"
                    id="@+id/choice_content"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="8dp"
                    lineSpacingMultiplier="1.35"
                    style="@style/TextAppearance.Text.14SP"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <TextView
            layout_gravity="0x800005"
            id="@+id/choice_tag"
            paddingLeft="8dp"
            paddingTop="4dp"
            paddingRight="8dp"
            paddingBottom="4dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingHorizontal="8dp"
            paddingVertical="4dp"
            style="@style/Label_3_Bold"/>
    </FrameLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
