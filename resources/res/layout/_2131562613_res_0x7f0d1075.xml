<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_24dp"
    layout_marginTop="@dimen/margin_12dp"
    layout_marginRight="@dimen/margin_24dp"
    layout_marginBottom="@dimen/margin_12dp"
    layout_marginHorizontal="@dimen/margin_24dp">
    <TextView
        textAppearance="@style/Title_2_Bold"
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xd="0"/>
    <TextView
        textAppearance="@style/Label_1_Regular"
        textColor="@color/ContentContrast"
        id="@+id/sub_title"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0xa="0"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xc="@+id/title"
        NOT_FOUND_0xe="@dimen/width_0dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
