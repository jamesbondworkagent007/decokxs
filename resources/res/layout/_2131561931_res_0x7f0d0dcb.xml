<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.18SP.Medium"
        id="@+id/tv_type"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="20dp"
        text="@string/pr_trade_top_tab_title_derivatives"
        drawablePadding="12sp"
        layout_marginStart="24dp"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_upgrade_account"
        layout_width="-1"
        android:layout_height="50dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            id="@+id/tv_swap"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_datas_top_subtitle_perpetual"
            layout_marginStart="@dimen/dp24"/>
        <View
            background="@color/okTradeG900"
            layout_width="1dp"
            android:layout_height="16dp"
            layout_marginLeft="5dp"
            layout_marginRight="5dp"
            layout_marginHorizontal="5dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            id="@+id/tv_future"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_margintab_title_futures"/>
        <View
            background="@color/okTradeG900"
            layout_width="1dp"
            android:layout_height="16dp"
            layout_marginLeft="5dp"
            layout_marginRight="5dp"
            layout_marginHorizontal="5dp"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            id="@+id/tv_option"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_trade_margintab_title_options"/>
        <ImageView
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232356_res_0x7f080664"
            NOT_FOUND_0x13="@color/ContentPrimary"/>
    </LinearLayout>
    <o.C52794wYp
        textColor="@color/okTradeBlue700"
        id="@+id/btn_upgrade"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="68dp"
        layout_marginTop="33dp"
        layout_marginRight="68dp"
        layout_marginBottom="33dp"
        text="@string/pr_demotrade_maintitle_account_mode_upgrade"
        layout_marginHorizontal="68dp"
        layout_marginVertical="33dp"
        style="@style/Button.BabyBlue.Medium"/>
</LinearLayout>
