<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="8dp"
    paddingRight="8dp"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="8dp">
    <ImageView
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        src="@drawable/_2131232905_res_0x7f080889"/>
    <RadioGroup
        orientation="0"
        id="@+id/radio_group"
        paddingLeft="8dp"
        paddingRight="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="32dp"
        paddingHorizontal="8dp">
        <RadioButton
            textColor="@color/grey_g900"
            id="@+id/light_theme"
            background="@null"
            layout_width="-2"
            android:layout_height="wrap_content"
            button="@null"
            text="@string/pr_trade_chart_text_selectsettings"
            drawablePadding="8dp"
            drawableStart="@drawable/_2131233915_res_0x7f080c7b"
            style="@style/TextAppearance.Title.15SP"/>
        <RadioButton
            textColor="@color/grey_g900"
            id="@+id/dark_theme"
            background="@null"
            layout_width="-2"
            android:layout_height="wrap_content"
            button="@null"
            text="@string/pr_discover_crypto_market_monitor_bottomsheet_dark_mode"
            drawablePadding="8dp"
            drawableStart="@drawable/_2131233915_res_0x7f080c7b"
            layout_marginStart="36dp"
            style="@style/TextAppearance.Title.15SP"/>
    </RadioGroup>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        paddingLeft="8dp"
        paddingRight="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="32dp"
        paddingHorizontal="8dp">
        <TextView
            textColor="@color/grey_g900"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_discover_crypto_market_monitor_bottomsheet_window_transparency"
            layout_weight="1"
            layout_marginEnd="@dimen/margin_16dp"
            style="@style/TextAppearance.Headline.15SP"/>
        <TextView
            textColor="@color/grey_g900"
            id="@+id/transparent_percent"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Blue.16SP"/>
    </LinearLayout>
    <androidx.appcompat.widget.AppCompatSeekBar
        id="@+id/seek_bar"
        background="@null"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        maxHeight="4dp"
        progressDrawable="@drawable/_2131231137_res_0x7f0801a1"
        minHeight="4dp"
        thumb="@drawable/_2131234007_res_0x7f080cd7"
        splitTrack="false"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        paddingLeft="8dp"
        paddingRight="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="25dp"
        paddingHorizontal="8dp">
        <TextView
            textColor="@color/grey_g900"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_tradechart_list_label_font_size"
            layout_weight="1"
            style="@style/TextAppearance.Headline.14SP"/>
        <TextView
            textSize="15sp"
            textColor="@color/grey_g900"
            id="@+id/tv_text_level"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_tradechart_list_label_normal"
            layout_marginStart="10dp"/>
    </LinearLayout>
    <o.ViewOnClickListenerC39801pzG
        id="@+id/lv"
        paddingLeft="8dp"
        paddingRight="8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="10dp"
        paddingHorizontal="8dp"/>
    <LinearLayout
        gravity="0x10"
        paddingLeft="8dp"
        paddingRight="8dp"
        layout_width="-1"
        android:layout_height="50dp"
        layout_marginTop="20dp"
        paddingHorizontal="8dp">
        <TextView
            textColor="@color/grey_g900"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_discover_crypto_market_monitor_bottomsheet_show_change"
            layout_weight="1"
            style="@style/TextAppearance.Headline.15SP"/>
        <o.C33609mzg
            id="@+id/change_percent_switch"
            background="@drawable/_2131233716_res_0x7f080bb4"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x1a="@color/transparent"
            NOT_FOUND_0x1c="@color/transparent"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        id="@+id/ll_page_size"
        background="?attr/selectableItemBackground"
        paddingLeft="8dp"
        paddingRight="8dp"
        layout_width="-1"
        android:layout_height="50dp"
        paddingHorizontal="8dp">
        <TextView
            textColor="@color/grey_g900"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_discover_crypto_market_monitor_bottomsheet_items_per_page"
            layout_weight="1"
            style="@style/TextAppearance.Headline.15SP"/>
        <TextView
            textColor="@color/grey_g400"
            id="@+id/tv_page_size"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Text.14SP"/>
        <ImageView
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232357_res_0x7f080665"
            NOT_FOUND_0x1b="@color/grey_g400"/>
    </LinearLayout>
</LinearLayout>
