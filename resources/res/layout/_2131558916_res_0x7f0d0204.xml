<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/component_okcr_earn_card_horizontal_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/pressed_background"
        focusable="false"
        focusableInTouchMode="false"
        layout_width="-1"
        android:layout_height="match_parent"
        alpha="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/content_view"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/dp_16"
        layout_marginTop="@dimen/dp_20"
        layout_marginRight="@dimen/dp_16"
        layout_marginBottom="@dimen/dp_20"
        layout_marginHorizontal="@dimen/dp_16"
        layout_marginVertical="@dimen/dp_20">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/token_layout"
            layout_width="@dimen/dp_0"
            android:layout_height="wrap_content"
            layout_marginEnd="@dimen/dp_8"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x17="@+id/earn_percentage_layout"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1d="0">
            <ImageView
                id="@+id/token_image"
                layout_width="@dimen/dp_32"
                android:layout_height="@dimen/dp_32"
                contentDescription="@null"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x17="@+id/token_id_name_layout"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="2"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1d="0"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/token_id_name_layout"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/dp_12"
                NOT_FOUND_0x13="true"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x1a="@+id/token_image"
                NOT_FOUND_0x1d="0">
                <TextView
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    id="@+id/token_id"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    lines="1"
                    NOT_FOUND_0x15="@+id/token_name"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x18="0"
                    NOT_FOUND_0x1b="0"
                    NOT_FOUND_0x1d="0"
                    style="@style/Label_1_Medium"/>
                <TextView
                    textColor="@color/ContentContrast"
                    ellipsize="3"
                    id="@+id/token_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/dp_4"
                    lines="1"
                    NOT_FOUND_0x14="0"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x18="0"
                    NOT_FOUND_0x1b="0"
                    NOT_FOUND_0x1c="@+id/token_id"
                    style="@style/Label_2_Regular"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/earn_percentage_layout"
            layout_width="@dimen/dp_0"
            android:layout_height="wrap_content"
            NOT_FOUND_0x13="true"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x1a="@+id/token_layout"
            NOT_FOUND_0x1d="0">
            <TextView
                textColor="@color/ContentPrimary"
                ellipsize="2"
                id="@+id/earn_percentage"
                layout_width="-2"
                android:layout_height="wrap_content"
                lines="1"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x18="1"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1d="0"
                style="@style/Label_1_Medium"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
