<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/groupLayout"
    background="@color/BasePrimary"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/rl_not_official_arbitrage_tip_container"
        background="@color/okTradeOrange50"
        paddingTop="8dp"
        paddingBottom="8dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginRight="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default"
        paddingVertical="8dp">
        <ImageView
            id="@+id/iv_warning"
            layout_width="14dp"
            android:layout_height="14dp"
            src="@drawable/_2131234330_res_0x7f080e1a"
            NOT_FOUND_0x24="@color/okTradeOrange700"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            textColor="@color/okTradeOrange700"
            id="@+id/tv_not_official_tip_content"
            focusable="true"
            focusableInTouchMode="true"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_trading_overview_alert_arbiltrage_not_official_arbitrage_tip"
            layout_weight="1"
            layout_marginStart="10dp"
            layout_marginEnd="16dp"/>
        <ImageView
            id="@+id/iv_close_arbitrage_tip"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131233586_res_0x7f080b32"/>
    </LinearLayout>
    <FrameLayout
        id="@+id/fl_double_depth"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginRight="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default">
        <o.C53441wlZ
            id="@+id/arbitrage_coin_select_left"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginEnd="6dp"/>
        <o.C53441wlZ
            id="@+id/arbitrage_coin_select_right"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginStart="6dp"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default">
        <o.C53501wmg
            id="@+id/arbitrage_price_left"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginEnd="6dp"
            NOT_FOUND_0x19="@+id/arbitrage_price_right"
            NOT_FOUND_0x1b="0"
            NOT_FOUND_0x1c="@+id/ll_depth"/>
        <o.C53501wmg
            id="@+id/arbitrage_price_right"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginStart="6dp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="@+id/arbitrage_price_left"
            NOT_FOUND_0x1c="@+id/ll_depth"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/arb_set_price_layout"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginRight="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default">
        <LinearLayout
            gravity="0x10"
            id="@+id/ll_arbitrage_set_price"
            background="@drawable/_2131233964_res_0x7f080cac"
            layout_width="-2"
            android:layout_height="@dimen/height_24dp"
            NOT_FOUND_0x1b="@+id/arbitrage_price_left"
            NOT_FOUND_0x1c="@+id/arbitrage_price_left">
            <TextView
                textColor="@color/ContentSecondary"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_trade_dropdown_set_price"
                layout_weight="1"
                layout_marginStart="@dimen/margin_8dp"
                style="@style/TextAppearance.Text.12SP.Medium"/>
            <ImageView
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131231588_res_0x7f080364"
                layout_marginStart="8dp"
                layout_marginEnd="4dp"
                NOT_FOUND_0x24="@color/ContentDisabled"/>
        </LinearLayout>
        <o.C55258xgZ
            id="@+id/tv_arbitrage_spread_rate"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="12dp"
            NOT_FOUND_0x17="@+id/ll_arbitrage_set_price"
            NOT_FOUND_0x1a="@+id/ll_arbitrage_set_price"
            NOT_FOUND_0x1d="@+id/ll_arbitrage_set_price"
            NOT_FOUND_0x20="0"
            NOT_FOUND_0x21="@color/okTradeG500"
            NOT_FOUND_0x22="@dimen/text_size_12sp"
            NOT_FOUND_0x23="400"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        id="@+id/ll_balance"
        visibility="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="16dp"
        layout_marginRight="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default">
        <o.C53427wlL
            id="@+id/left_balance"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"/>
        <o.C53427wlL
            id="@+id/right_balance"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="12dp"/>
    </LinearLayout>
    <o.C53497wmc
        id="@+id/arbitrage_order"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="16dp"
        layout_marginRight="@dimen/margin_default"
        layout_marginHorizontal="@dimen/margin_default"/>
    <o.C52794wYp
        gravity="0x11"
        id="@+id/upLevelBtn"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_default"
        layout_marginTop="16dp"
        layout_marginRight="@dimen/margin_default"
        text="@string/pr_demotrade_btn_upgrade_for_trading"
        layout_marginHorizontal="@dimen/margin_default"
        NOT_FOUND_0x1c="@+id/ava"
        NOT_FOUND_0x1e="44"
        NOT_FOUND_0x1f="0x101"/>
</LinearLayout>
