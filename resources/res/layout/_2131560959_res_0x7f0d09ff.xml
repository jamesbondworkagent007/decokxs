<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_upload_log_attached_file_0"
    background="@drawable/_2131231020_res_0x7f08012c"
    paddingTop="@dimen/xxsm"
    paddingBottom="@dimen/xxsm"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_default"
    layout_marginRight="@dimen/margin_default"
    minHeight="@dimen/width_60dp"
    paddingStart="@dimen/xxsm"
    paddingEnd="0dp"
    layout_marginHorizontal="@dimen/margin_default"
    paddingVertical="@dimen/xxsm">
    <FrameLayout
        id="@+id/frame_attached_state"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1f="@+id/attachment_info_container"
        NOT_FOUND_0x21="0"
        NOT_FOUND_0x23="0">
        <ProgressBar
            id="@+id/img_loading"
            layout_width="@dimen/width_20dp"
            android:layout_height="@dimen/width_20dp"
            importantForAccessibility="2"
            indeterminateTint="@color/ContentPrimary"/>
        <ImageView
            id="@+id/img_success"
            visibility="2"
            layout_width="@dimen/width_20dp"
            android:layout_height="@dimen/width_20dp"
            src="@drawable/_2131233852_res_0x7f080c3c"
            scaleType="7"
            importantForAccessibility="2"
            NOT_FOUND_0x25="@color/SemanticPositive"/>
        <ImageView
            id="@+id/img_warning"
            visibility="2"
            layout_width="@dimen/width_20dp"
            android:layout_height="@dimen/width_20dp"
            src="@drawable/_2131234331_res_0x7f080e1b"
            scaleType="7"
            importantForAccessibility="2"
            NOT_FOUND_0x25="@color/SemanticNegative"/>
    </FrameLayout>
    <LinearLayout
        orientation="0"
        id="@+id/attachment_info_container"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x1d="@+id/txt_attachment_warning"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x20="@+id/frame_attached_state"
        NOT_FOUND_0x23="0"
        NOT_FOUND_0x24="2">
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="1"
            id="@+id/txt_attachment_filename"
            layout_width="0dp"
            android:layout_height="wrap_content"
            lines="1"
            layout_weight="1"
            style="@style/Label_1_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/txt_attachment_size"
            layout_width="-2"
            android:layout_height="wrap_content"
            lines="1"
            layout_marginStart="@dimen/lg"
            style="@style/Label_2_Regular"/>
        <ImageView
            id="@+id/btn_remove_attachment"
            background="?attr/selectableItemBackgroundBorderless"
            layout_width="@dimen/width_40dp"
            android:layout_height="match_parent"
            src="@drawable/_2131234234_res_0x7f080dba"
            scaleType="7"
            contentDescription="@string/pr_commonall_filter_btn_delete"
            paddingStart="@dimen/xxxsm"
            paddingEnd="@dimen/xxsm"/>
    </LinearLayout>
    <TextView
        textColor="@color/SemanticNegative"
        id="@+id/txt_attachment_warning"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/xxxxsm"
        text="@string/pr_supportcenter_errorlog_label_upload_failed"
        paddingStart="0dp"
        paddingEnd="@dimen/xxsm"
        layout_marginStart="@dimen/xxxsm"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x20="@+id/frame_attached_state"
        NOT_FOUND_0x22="@+id/attachment_info_container"
        style="@style/Label_2_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
