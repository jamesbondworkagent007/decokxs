<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        orientation="1"
        id="@+id/list_layout"
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            orientation="0"
            id="@+id/watch_list_tab_layout"
            layout_width="-1"
            android:layout_height="wrap_content">
            <o.C55254xgV
                id="@+id/market_cate_tabs"
                layout_width="-1"
                android:layout_height="wrap_content"
                NOT_FOUND_0xa="true"
                NOT_FOUND_0xb="36"
                NOT_FOUND_0xc="5"/>
        </LinearLayout>
        <o.C57596ylR
            id="@+id/market_cate_container"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginTop="@dimen/dp_8"/>
    </LinearLayout>
    <FrameLayout
        layout_gravity="0x11"
        id="@+id/recommend_layout"
        layout_width="-1"
        android:layout_height="match_parent"/>
    <FrameLayout
        id="@+id/reload_view"
        background="@color/BasePrimary"
        paddingTop="96dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="match_parent"
        elevation="5dp"/>
    <FrameLayout
        id="@+id/anim"
        layout_width="-1"
        android:layout_height="match_parent"/>
</FrameLayout>
