<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="16dp">
    <RelativeLayout
        gravity="0x10"
        id="@+id/rl_question_title"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textSize="16sp"
            textColor="@color/okTradeG900"
            gravity="0x800003"
            id="@+id/tv_question"
            paddingTop="8dp"
            paddingBottom="8dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            fontFamily="@font/harmony_sans_medium"
            layout_toStartOf="@+id/iv_arrow"
            layout_alignParentStart="true"
            paddingVertical="8dp"/>
        <ImageView
            id="@+id/iv_arrow"
            layout_width="16dp"
            android:layout_height="16dp"
            layout_marginTop="12dp"
            src="@drawable/_2131231637_res_0x7f080395"
            layout_marginStart="16dp"
            layout_alignParentEnd="true"
            NOT_FOUND_0x13="@color/ContentPrimary"/>
    </RelativeLayout>
    <TextView
        textSize="14sp"
        textColor="@color/okTradeG700"
        id="@+id/tv_answer"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        fontFamily="@font/harmony_sans_regular"/>
    <View
        id="@+id/divider"
        background="@color/okTradeG100"
        paddingTop="16dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="0.5dp"
        layout_marginTop="16dp"/>
</LinearLayout>
