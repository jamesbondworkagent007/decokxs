<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@drawable/_2131233226_res_0x7f0809ca"
    layout_width="-2"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        layout_width="155dp"
        android:layout_height="120dp">
        <ImageView
            layout_gravity="0x1"
            id="@+id/volume_image_tip"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="20dp"/>
        <TextView
            textSize="16sp"
            textColor="#ffffffff"
            gravity="0x1"
            layout_gravity="0x1"
            id="@+id/tv_volume"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"/>
        <ProgressBar
            layout_gravity="0x1"
            id="@+id/volume_progressbar"
            layout_width="-1"
            android:layout_height="3dp"
            layout_marginLeft="24dp"
            layout_marginTop="8dp"
            layout_marginRight="24dp"
            layout_marginBottom="20dp"
            max="100"
            progressDrawable="@drawable/_2131233225_res_0x7f0809c9"
            style="@android:style/Widget.ProgressBar.Horizontal"/>
    </LinearLayout>
</LinearLayout>
