<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent"
    fillViewport="true">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        paddingLeft="@dimen/common_page_edge_space"
        paddingRight="@dimen/common_page_edge_space"
        paddingBottom="32dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/common_page_edge_space">
        <androidx.compose.ui.platform.ComposeView
            id="@+id/botInfoComposeView"
            layout_width="-1"
            android:layout_height="wrap_content"/>
        <o.uII
            id="@+id/profitChangeChartView"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"/>
        <o.C48208uIz
            id="@+id/botAboutSection"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"
            NOT_FOUND_0x10="true"/>
        <TextView
            textAppearance="@style/Body_3_Regular"
            textColor="@color/color_content_static_subtle"
            id="@+id/disclaimer"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="24dp"
            layout_marginBottom="32dp"
            text="@string/pr_aitradingbot_placeorder_botsheet_reminder_backtest_data"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/eventHistoryTitle"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="32dp"
            text="@string/pr_trade_botdetails_colheader_historical_events"
            style="@style/Label_1_Bold"/>
        <androidx.fragment.app.FragmentContainerView
            name="o.uIG"
            id="@+id/botEventHistoryFragment"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_16dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
