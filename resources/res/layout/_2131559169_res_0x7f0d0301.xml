<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <include
        id="@+id/include_header_info"
        layout="@layout/_2131559128_res_0x7f0d02d8"/>
    <FrameLayout
        id="@+id/fl_tags"
        paddingTop="4dp"
        paddingBottom="8dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content">
        <HorizontalScrollView
            id="@+id/hsv_tags"
            paddingBottom="4dp"
            scrollbars="horizontal"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginLeft="@dimen/margin_default"
            layout_marginRight="@dimen/margin_default"
            layout_marginHorizontal="@dimen/margin_default">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                id="@+id/ll_tags_container"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingEnd="8dp">
                <LinearLayout
                    orientation="0"
                    id="@+id/ll_rwa_tag"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="match_parent"
                    layout_marginEnd="4dp"/>
                <LinearLayout
                    gravity="0x10"
                    orientation="0"
                    id="@+id/social_tag"
                    paddingLeft="4dp"
                    paddingTop="4dp"
                    paddingRight="4dp"
                    paddingBottom="4dp"
                    layout_width="-2"
                    android:layout_height="match_parent"
                    contentDescription="web3_dex_market_token_tags"
                    layout_marginEnd="4dp"
                    paddingHorizontal="4dp"
                    paddingVertical="4dp"/>
                <LinearLayout
                    gravity="0x10"
                    id="@+id/fee_tag"
                    paddingLeft="4dp"
                    paddingTop="4dp"
                    paddingRight="4dp"
                    paddingBottom="4dp"
                    layout_width="-2"
                    android:layout_height="match_parent"
                    layout_marginEnd="4dp"
                    paddingHorizontal="4dp"
                    paddingVertical="4dp">
                    <TextView
                        textColor="@color/ContentContrast"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_swaptrade_token_details_total_fees"
                        includeFontPadding="false"
                        style="@style/Label_4_Regular"/>
                    <ImageView
                        id="@+id/iv_fee_chain_logo"
                        background="@drawable/_2131231867_res_0x7f08047b"
                        layout_width="12dp"
                        android:layout_height="12dp"
                        layout_marginLeft="2dp"
                        layout_marginRight="2dp"
                        scaleType="7"
                        layout_marginHorizontal="2dp"/>
                    <TextView
                        textColor="@color/ContentPrimary"
                        id="@+id/tv_fee_value"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        includeFontPadding="false"
                        style="@style/Label_4_Regular"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    id="@+id/ll_token_tags"
                    layout_width="-2"
                    android:layout_height="match_parent"/>
            </LinearLayout>
        </HorizontalScrollView>
        <View
            layout_gravity="0x800015"
            id="@+id/fading_end"
            background="@drawable/_2131231417_res_0x7f0802b9"
            layout_width="16dp"
            android:layout_height="match_parent"
            layout_marginEnd="@dimen/margin_default"/>
    </FrameLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_event"
        paddingLeft="@dimen/margin_default"
        paddingTop="8dp"
        paddingRight="@dimen/margin_default"
        paddingBottom="8dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/margin_default"
        paddingVertical="8dp">
        <ImageView
            id="@+id/iv_event_icon"
            layout_width="16dp"
            android:layout_height="16dp"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/tv_event_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/dp_4"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_event_subtitle"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            layout_weight="1"
            layout_marginStart="@dimen/dp_4"
            style="@style/Label_3_Regular"/>
        <ImageView
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131231649_res_0x7f0803a1"/>
    </LinearLayout>
    <androidx.core.widget.NestedScrollView
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="4dp">
        <FrameLayout
            id="@+id/container_kline"
            layout_width="-1"
            android:layout_height="wrap_content"/>
    </androidx.core.widget.NestedScrollView>
</androidx.appcompat.widget.LinearLayoutCompat>
