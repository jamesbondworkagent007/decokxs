<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Semibold"
        textColor="@color/ContentPrimary"
        gravity="0x800003"
        id="@+id/title"
        paddingTop="@dimen/margin_12dp"
        paddingBottom="@dimen/margin_12dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginRight="@dimen/margin_16dp"
        text="@string/pr_account_fido2_mdltitle_rename_passkey"
        layout_marginHorizontal="@dimen/margin_16dp"
        paddingVertical="@dimen/margin_12dp"
        NOT_FOUND_0x22="0"/>
    <com.okinc.uilab.edit.OKEditText
        textSize="@dimen/font_14"
        textColor="@color/okTradeG900"
        textColorHint="@color/okTradeG300"
        layout_gravity="0x800013"
        id="@+id/input"
        background="@drawable/_2131231132_res_0x7f08019c"
        padding="@dimen/padding_12dp"
        longClickable="false"
        layout_width="-1"
        android:layout_height="0dp"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="@dimen/margin_4dp"
        layout_marginRight="@dimen/margin_16dp"
        hint="@string/pr_account_fido2_placehldr_enter_passkey_name"
        maxLines="1"
        lines="1"
        singleLine="true"
        maxLength="40"
        inputType="0x21"
        contentDescription="passkeyRenameInputField"
        fontFamily="@font/harmony_sans_regular"
        textDirection="2"
        textAlignment="5"
        layout_marginHorizontal="@dimen/margin_16dp"
        NOT_FOUND_0x21="@+id/title"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textColor="@color/ContentContrast"
        id="@+id/wordCount"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_16dp"
        layout_marginTop="@dimen/margin_8dp"
        layout_marginRight="@dimen/margin_16dp"
        layout_marginBottom="@dimen/height_24dp"
        text="passkeyRenameInputField"
        layout_marginHorizontal="@dimen/margin_16dp"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="0"
        NOT_FOUND_0x21="@+id/input"/>
</androidx.constraintlayout.widget.ConstraintLayout>
