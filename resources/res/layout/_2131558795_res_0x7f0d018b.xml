<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginLeft="@dimen/margin_default"
    layout_marginTop="8dp"
    layout_marginRight="@dimen/margin_default"
    layout_marginBottom="24dp"
    layout_marginHorizontal="@dimen/margin_default">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/titleTv"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="24dp"
        text="@string/pr_smartarb_botdetails_title_borrowing_interest"
        layout_alignParentTop="true"
        layout_alignParentStart="true"
        layout_alignParentEnd="true"
        style="@style/TextAppearance.Title.Bold.20SP"/>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/recyclerView"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_below="@+id/titleTv"
        layout_alignParentStart="true"
        layout_alignParentEnd="true"/>
    <LinearLayout
        id="@+id/stickyHeaderContainer"
        background="@color/background_BasePrimary_BaseSecondary"
        paddingTop="4dp"
        paddingBottom="4dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_below="@+id/titleTv"
        layout_alignParentStart="true"
        layout_alignParentEnd="true"
        paddingVertical="4dp">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_spot_general_label_time"
            layout_weight="1"
            style="@style/Label_3_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            gravity="0x800005"
            id="@+id/deductAmtTitle"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="12dp"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
</RelativeLayout>
