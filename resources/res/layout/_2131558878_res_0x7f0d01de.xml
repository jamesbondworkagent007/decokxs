<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/item_indicator"
        background="@drawable/_2131231601_res_0x7f080371"
        layout_width="@dimen/dp_8"
        android:layout_height="@dimen/dp_8"
        NOT_FOUND_0x7="@+id/item_label"
        NOT_FOUND_0xa="@+id/item_label"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xf="@+id/item_label"/>
    <TextView
        textColor="@color/ContainerInverse"
        id="@+id/item_label"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/dp_4"
        NOT_FOUND_0x8="@+id/item_price_title"
        NOT_FOUND_0xc="@+id/item_indicator"
        NOT_FOUND_0xf="0"
        style="@style/Label_4_Regular"/>
    <TextView
        textColor="@color/ContentSecondary"
        id="@+id/item_price_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/lt_trade_discover_category_chart_price"
        NOT_FOUND_0x8="@+id/item_change_title"
        NOT_FOUND_0xa="@+id/item_price_value"
        NOT_FOUND_0xb="1"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/item_label"
        style="@style/Label_4_Regular"/>
    <TextView
        textColor="@color/ContainerInverse"
        id="@+id/item_price_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x8="@+id/item_change_value"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xc="@+id/item_price_title"
        NOT_FOUND_0xe="@+id/item_label"
        style="@style/Label_4_Regular"/>
    <TextView
        textColor="@color/ContentSecondary"
        id="@+id/item_change_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/lt_trade_discover_category_chart_change"
        NOT_FOUND_0x7="0"
        NOT_FOUND_0xa="@+id/item_change_value"
        NOT_FOUND_0xb="1"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/item_price_title"
        style="@style/Label_4_Regular"/>
    <TextView
        id="@+id/item_change_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x7="0"
        NOT_FOUND_0x9="0"
        NOT_FOUND_0xc="@+id/item_change_title"
        NOT_FOUND_0xe="@+id/item_price_value"
        style="@style/Label_4_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
