<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        layout_gravity="0x11"
        id="@+id/exo_center_view"
        layout_width="-1"
        android:layout_height="match_parent"
        layoutDirection="0">
        <View
            layout_gravity="0x11"
            id="@+id/exo_center_view_background"
            background="@color/exo_black_opacity_30"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <include
            layout_gravity="0x11"
            id="@+id/exo_embedded_transport_controls"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout="@layout/_2131559683_res_0x7f0d0503"/>
    </FrameLayout>
    <FrameLayout
        layout_gravity="0x50"
        id="@+id/exo_bottom_bar"
        background="@color/exo_bottom_bar_background"
        paddingBottom="@dimen/exo_bottom_bar_padding_bottom"
        layout_width="-1"
        android:layout_height="@dimen/exo_bottom_bar_height"
        layoutDirection="0">
        <LinearLayout
            layout_gravity="0x800053"
            id="@+id/exo_time"
            paddingLeft="@dimen/exo_time_view_padding"
            paddingRight="@dimen/exo_time_view_padding"
            layout_width="@dimen/exo_time_view_width"
            android:layout_height="@dimen/exo_small_icon_height"
            layoutDirection="0"
            paddingStart="@dimen/exo_time_view_padding"
            paddingEnd="@dimen/exo_time_view_padding">
            <TextView
                id="@+id/exo_position"
                style="@style/ExoStyledControls.TimeText.Position"/>
            <TextView style="@style/ExoStyledControls.TimeText.Separator"/>
            <TextView
                id="@+id/exo_duration"
                style="@style/ExoStyledControls.TimeText.Duration"/>
        </LinearLayout>
        <LinearLayout
            layout_gravity="0x800055"
            orientation="0"
            id="@+id/exo_basic_controls"
            layout_width="-2"
            android:layout_height="wrap_content"
            layoutDirection="0">
            <ImageButton
                id="@+id/exo_shuffle"
                style="@style/ExoStyledControls.Button.Bottom.Shuffle"/>
            <ImageButton
                id="@+id/exo_repeat_toggle"
                style="@style/ExoStyledControls.Button.Bottom.RepeatToggle"/>
            <ImageButton
                id="@+id/exo_vr"
                style="@style/ExoStyledControls.Button.Bottom.VR"/>
            <ImageButton
                id="@+id/exo_subtitle"
                scaleType="fitStart"
                alpha="0.5"
                style="@style/ExoStyledControls.Button.Bottom.CC"/>
            <ImageButton
                id="@+id/exo_fullscreen"
                style="@style/ExoStyledControls.Button.Bottom.FullScreen"/>
            <ImageButton
                id="@+id/exo_overflow_show"
                style="@style/ExoStyledControls.Button.Bottom.OverflowShow"/>
        </LinearLayout>
        <HorizontalScrollView
            layout_gravity="0x800055"
            id="@+id/exo_extra_controls_scroll_view"
            visibility="1"
            layout_width="-2"
            android:layout_height="wrap_content">
            <LinearLayout
                layout_gravity="0x800055"
                orientation="0"
                id="@+id/exo_extra_controls"
                layout_width="-2"
                android:layout_height="wrap_content"
                layoutDirection="0">
                <ImageButton
                    id="@+id/exo_settings"
                    style="@style/ExoStyledControls.Button.Bottom.Settings"/>
                <ImageButton
                    id="@+id/exo_overflow_hide"
                    style="@style/ExoStyledControls.Button.Bottom.OverflowHide"/>
            </LinearLayout>
        </HorizontalScrollView>
    </FrameLayout>
    <LinearLayout
        layout_gravity="0x800055"
        orientation="1"
        id="@+id/exo_minimal_controls"
        visibility="1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginBottom="@dimen/exo_styled_progress_layout_height"/>
    <View
        layout_gravity="0x50"
        id="@+id/exo_progress_placeholder"
        layout_width="-1"
        android:layout_height="@dimen/exo_styled_progress_layout_height"
        layout_marginBottom="@dimen/exo_styled_progress_margin_bottom"/>
</merge>
