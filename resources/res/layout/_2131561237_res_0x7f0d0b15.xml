<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/layout_dual_mode_toolbar_0"
    layout_width="-1"
    android:layout_height="52dp">
    <FrameLayout
        id="@+id/closeLayout"
        layout_width="-2"
        android:layout_height="match_parent"
        paddingStart="@dimen/sm"
        paddingEnd="12dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1a="0">
        <o.wYC
            layout_gravity="0x10"
            id="@+id/closeButton"
            layout_width="24dp"
            android:layout_height="24dp"
            src="@drawable/_2131232980_res_0x7f0808d4"
            scaleType="fitEnd"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="@color/ContentPrimary"/>
    </FrameLayout>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/leftLayoutBarrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x13="6"
        NOT_FOUND_0x14="closeLayout"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/urlContainer"
        background="@drawable/_2131231147_res_0x7f0801ab"
        visibility="2"
        layout_width="0dp"
        android:layout_height="40dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="@+id/rightLayoutBarrier"
        NOT_FOUND_0x18="@+id/leftLayoutBarrier"
        NOT_FOUND_0x1a="0">
        <ImageView
            id="@+id/backButton"
            layout_width="36dp"
            android:layout_height="match_parent"
            src="@drawable/_2131232985_res_0x7f0808d9"
            scaleType="7"
            contentDescription="Back"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="0"
            NOT_FOUND_0x1b="@color/ContentPrimary"/>
        <TextView
            textSize="14sp"
            textColor="@color/ContentContrast"
            ellipsize="3"
            gravity="0x10"
            id="@+id/tv_title"
            layout_width="-1"
            android:layout_height="40dp"
            maxLines="1"
            contentDescription="web3_discover_home_web_page_title"
            style="@style/TextAppearance.Silka"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/browserModeRightLayout"
        visibility="2"
        layout_width="-2"
        android:layout_height="match_parent"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="0">
        <FrameLayout
            id="@+id/wallet_wrapper"
            visibility="2"
            layout_width="-2"
            android:layout_height="match_parent"
            paddingStart="12dp"
            paddingEnd="0dp">
            <ImageView
                layout_gravity="0x10"
                id="@+id/wallet"
                background="@drawable/_2131231240_res_0x7f080208"
                padding="@dimen/margin_1dp"
                layout_width="@dimen/dp_22"
                android:layout_height="@dimen/dp_22"
                src="@drawable/_2131231743_res_0x7f0803ff"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/tabCountLayout"
            layout_width="-2"
            android:layout_height="match_parent"
            paddingStart="12dp"
            paddingEnd="6dp">
            <TextView
                textSize="@dimen/text_size_12sp"
                textColor="@color/ContentPrimary"
                gravity="0x11"
                layout_gravity="0x11"
                id="@+id/tabCount"
                background="@drawable/_2131231416_res_0x7f0802b8"
                layout_width="20dp"
                android:layout_height="20dp"
                style="@style/Label_3_Bold"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/moreOptionsLayout"
            layout_width="-2"
            android:layout_height="match_parent"
            contentDescription="web3_discover_home_web_page_menu"
            paddingStart="6dp"
            paddingEnd="@dimen/sm">
            <ImageView
                layout_gravity="0x11"
                layout_width="@dimen/sm"
                android:layout_height="@dimen/sm"
                src="@drawable/_2131232708_res_0x7f0807c4"
                scaleType="7"/>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/historyModeRightLayout"
        visibility="2"
        layout_width="-2"
        android:layout_height="match_parent"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1a="0">
        <FrameLayout
            id="@+id/addButtonLayout"
            layout_width="-2"
            android:layout_height="match_parent"
            paddingStart="@dimen/sm"
            paddingEnd="6dp">
            <ImageView
                layout_gravity="0x10"
                id="@+id/addButton"
                layout_width="@dimen/sm"
                android:layout_height="@dimen/sm"
                src="@drawable/_2131234363_res_0x7f080e3b"
                scaleType="fitEnd"
                contentDescription="Add"
                NOT_FOUND_0x1b="@color/ContentPrimary"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/deleteButtonLayout"
            layout_width="-2"
            android:layout_height="match_parent"
            paddingStart="6dp"
            paddingEnd="@dimen/sm">
            <ImageView
                layout_gravity="0x10"
                id="@+id/deleteButton"
                layout_width="@dimen/sm"
                android:layout_height="@dimen/sm"
                src="@drawable/_2131232481_res_0x7f0806e1"
                scaleType="7"
                contentDescription="Delete"/>
        </FrameLayout>
    </LinearLayout>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/rightLayoutBarrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x13="5"
        NOT_FOUND_0x14="historyModeRightLayout,browserModeRightLayout"/>
</androidx.constraintlayout.widget.ConstraintLayout>
