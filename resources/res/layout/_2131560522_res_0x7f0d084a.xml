<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/padding_16dp"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="@dimen/xxsm"
    paddingEnd="@dimen/margin_default"
    paddingVertical="@dimen/padding_16dp">
    <ImageView
        id="@+id/filter_selection_icon"
        visibility="2"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginStart="@dimen/xxsm"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="@drawable/_2131232323_res_0x7f080643"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textSize="16sp"
        textColor="@color/ContentPrimary"
        id="@+id/filter_selection_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/xxsm"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="@+id/filter_selection_icon"
        NOT_FOUND_0x12="0"/>
    <ImageView
        id="@+id/filter_selection_check"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        src="@drawable/_2131233582_res_0x7f080b2e"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
