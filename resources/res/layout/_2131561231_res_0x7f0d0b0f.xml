<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="0"
    paddingLeft="@dimen/margin_16dp"
    paddingRight="@dimen/margin_16dp"
    paddingBottom="@dimen/margin_5dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_16dp">
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/token_label"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_invest_dex_main_page_token"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        style="@style/Label_3_Medium"/>
    <View
        id="@+id/token_label_divider"
        background="@color/ContentDisabled"
        layout_width="@dimen/height_1dp"
        android:layout_height="@dimen/dp_10"
        layout_marginLeft="@dimen/margin_6dp"
        NOT_FOUND_0xe="@+id/token_label"
        NOT_FOUND_0x11="@+id/token_label"
        NOT_FOUND_0x13="@+id/token_label"
        NOT_FOUND_0x14="0"/>
    <TextView
        textColor="@color/ContentContrast"
        gravity="0x10"
        id="@+id/protocol_label"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_6dp"
        text="@string/pr_invest_dex_main_page_protocol"
        NOT_FOUND_0x11="@+id/token_label_divider"
        NOT_FOUND_0x14="0"
        style="@style/Label_3_Medium"/>
    <com.okinc.uilab.view.OKSortTextView
        textColor="@color/ContentContrast"
        id="@+id/apy_sort"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginRight="@dimen/margin_6dp"
        text="@string/pr_invest_dex_main_page_apy"
        NOT_FOUND_0x10="@+id/token_sort_divider"
        NOT_FOUND_0x14="0"
        style="@style/OKSortTextView_Dex_Market"/>
    <View
        id="@+id/token_sort_divider"
        background="@color/ContentDisabled"
        layout_width="@dimen/height_1dp"
        android:layout_height="@dimen/dp_10"
        layout_marginRight="@dimen/margin_6dp"
        NOT_FOUND_0xe="@+id/tvl_sort"
        NOT_FOUND_0x10="@+id/tvl_sort"
        NOT_FOUND_0x14="@+id/tvl_sort"/>
    <com.okinc.uilab.view.OKSortTextView
        textColor="@color/ContentContrast"
        id="@+id/tvl_sort"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_invest_dex_main_page_tvl"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x14="0"
        style="@style/OKSortTextView_Dex_Market"/>
</androidx.constraintlayout.widget.ConstraintLayout>
