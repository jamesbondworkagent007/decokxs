<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131233507_res_0x7f080ae3"/>
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginStart="12dp">
            <TextView
                textAppearance="@style/Label_2_Bold"
                textColor="@color/ContentPrimary"
                id="@+id/title"
                layout_width="-2"
                android:layout_height="wrap_content"/>
            <TextView
                textAppearance="@style/Body_3_Regular"
                textColor="@color/ContentTertiary"
                id="@+id/date"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>
    <View
        layout_width="-1"
        android:layout_height="16dp"/>
</LinearLayout>
