                    textAppearance="@style/TextAppearance.Text.14SP.Regular"
                    textSize="@dimen/text_size_12sp"
                    textColor="@color/ContentContrast"
                    gravity="0x800033"
                    layout_gravity="0x800003"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
