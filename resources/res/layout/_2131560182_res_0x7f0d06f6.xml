                    gravity="0x800005"
                    id="@+id/reserved_value"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    maxLines="5"
                    includeFontPadding="false"
                    textAlignment="3"
                    NOT_FOUND_0x1c="0"
                    NOT_FOUND_0x1f="@+id/guide_line_second"
                    NOT_FOUND_0x22="0"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
