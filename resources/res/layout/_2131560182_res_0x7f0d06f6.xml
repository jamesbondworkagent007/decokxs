                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_20dp">
                <o.wYK
                    gravity="0x11"
                    id="@+id/reinvest_check_box"
                    layout_width="18dp"
                    android:layout_height="18dp"
                    checked="true"
                    NOT_FOUND_0x20="0"
                    NOT_FOUND_0x22="0"
                    NOT_FOUND_0x24="-5"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.12SP.Regular"
                    textSize="@dimen/text_size_12sp"
                    textColor="@color/ContentSecondary"
                    gravity="0x800003"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="@string/pr_spotgrid_botdetails_checkbox_plow_back_profits"
                    maxLines="5"
                    includeFontPadding="false"
                    textAlignment="2"
                    layout_marginStart="5dp"
                    NOT_FOUND_0x1b="@+id/reinvest_check_box"
                    NOT_FOUND_0x1c="0"
                    NOT_FOUND_0x1f="@+id/reinvest_check_box"
                    NOT_FOUND_0x22="@+id/reinvest_check_box"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
