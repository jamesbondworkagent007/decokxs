<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <ImageView
        layout_gravity="0x1"
        id="@+id/navigation_bar_item_icon_view"
        duplicateParentState="true"
        layout_width="24dp"
        android:layout_height="24dp"
        layout_marginTop="@dimen/mtrl_navigation_bar_item_default_margin"
        layout_marginBottom="@dimen/mtrl_navigation_bar_item_default_margin"
        contentDescription="@null"/>
    <com.google.android.material.internal.BaselineLayout
        layout_gravity="0x51"
        id="@+id/navigation_bar_item_labels_group"
        paddingBottom="@dimen/test_navigation_bar_label_padding"
        duplicateParentState="true"
        clipChildren="false"
        clipToPadding="false"
        layout_width="-2"
        android:layout_height="wrap_content">
        <TextView
            textSize="@dimen/test_navigation_bar_text_size"
            ellipsize="3"
            id="@+id/navigation_bar_item_small_label_view"
            duplicateParentState="true"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"/>
        <TextView
            textSize="@dimen/test_navigation_bar_active_text_size"
            ellipsize="3"
            id="@+id/navigation_bar_item_large_label_view"
            visibility="1"
            duplicateParentState="true"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="1"/>
    </com.google.android.material.internal.BaselineLayout>
</merge>
