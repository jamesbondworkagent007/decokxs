<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_creator_centre_earnings_0"
    paddingLeft="24dp"
    paddingTop="16dp"
    paddingRight="24dp"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp"
    paddingVertical="16dp">
    <FrameLayout
        id="@+id/ivSourceIconLy"
        background="@drawable/_2131231070_res_0x7f08015e"
        layout_width="40dp"
        android:layout_height="40dp"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1e="0">
        <ImageView
            layout_gravity="0x11"
            id="@+id/ivSourceIcon"
            background="@drawable/_2131231070_res_0x7f08015e"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131232916_res_0x7f080894"
            NOT_FOUND_0x20="@color/ContentTertiary"/>
    </FrameLayout>
    <TextView
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tvTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        layout_marginStart="12dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x17="@+id/subLayout"
        NOT_FOUND_0x19="@+id/tvAmount"
        NOT_FOUND_0x1b="@+id/ivSourceIconLy"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="2"
        style="@style/Label_1_Medium"/>
    <LinearLayout
        orientation="1"
        id="@+id/subLayout"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        layout_marginStart="12dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x19="@+id/tvAmountUsd"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="@+id/ivSourceIconLy"
        NOT_FOUND_0x1d="@+id/tvTitle">
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tvFrom"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="4dp"
            maxLines="2"
            style="@style/Label_2_Regular"/>
        <TextView
            textColor="@color/ContentContrast"
            ellipsize="3"
            id="@+id/tvDate"
            layout_width="-1"
            android:layout_height="wrap_content"
            maxLines="1"
            style="@style/Label_2_Regular"/>
    </LinearLayout>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tvAmount"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1e="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tvAmountUsd"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="1"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1d="@+id/tvAmount"
        style="@style/Label_2_Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
