<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP.Medium"
        tag="layout/trade_ui_signal_bot_edit_view_0"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_signalbot_placeorder_title_signal_name"/>
    <com.okinc.uilab.edit.OKEditText
        textSize="14sp"
        textColor="@color/grey_g900"
        textColorHint="@color/grey_g300"
        gravity="0x800033"
        id="@+id/signNameInput"
        tag="layout/trade_ui_signal_bot_edit_view_1"
        background="@drawable/_2131231429_res_0x7f0802c5"
        padding="12dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        hint="@string/pr_signalbot_placeorder_title_input_signal_name"
        maxLines="3"
        maxLength="30"/>
    <o.C55258xgZ
        textAppearance="@style/TextAppearance.Text.14SP"
        id="@+id/nameLengthNotify"
        tag="layout/trade_ui_signal_bot_edit_view_2"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        NOT_FOUND_0x13="2"
        NOT_FOUND_0x14="@color/RubyRed500"
        NOT_FOUND_0x15=""/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP"
        textColor="@color/grey_g400"
        layout_gravity="0x800005"
        id="@+id/nameCount"
        tag="layout/trade_ui_signal_bot_edit_view_3"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP.Medium"
        tag="layout/trade_ui_signal_bot_edit_view_4"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        text="@string/pr_signalbot_placeorder_title_signal_profile"/>
    <com.okinc.uilab.edit.OKEditText
        textSize="14sp"
        textColor="@color/grey_g900"
        textColorHint="@color/grey_g300"
        gravity="0x800033"
        id="@+id/signIntroInput"
        tag="layout/trade_ui_signal_bot_edit_view_5"
        background="@drawable/_2131231429_res_0x7f0802c5"
        padding="10dp"
        layout_width="-1"
        android:layout_height="@dimen/height_120dp"
        layout_marginTop="8dp"
        maxLength="500"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP"
        textColor="@color/grey_g400"
        layout_gravity="0x800005"
        id="@+id/desCount"
        tag="layout/trade_ui_signal_bot_edit_view_6"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/dp_8"/>
</merge>
