<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/item_lifecycle_recommend_0"
    background="@drawable/_2131231332_res_0x7f080264"
    paddingLeft="12dp"
    paddingRight="12dp"
    layout_width="-1"
    android:layout_height="136dp"
    paddingHorizontal="12dp">
    <ImageView
        id="@+id/iv_icon"
        layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32"
        layout_marginTop="@dimen/dp_16"/>
    <TextView
        textAppearance="@style/TextAppearance.Medium"
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_token_short_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        singleLine="true"
        NOT_FOUND_0xf="16sp"
        NOT_FOUND_0x10="8sp"
        NOT_FOUND_0x11="1sp"
        NOT_FOUND_0x12="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Medium"
        textSize="@dimen/text_size_10sp"
        textColor="@color/ContentSecondary"
        id="@+id/tv_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0xf="10sp"
        NOT_FOUND_0x10="5sp"
        NOT_FOUND_0x11="1sp"
        NOT_FOUND_0x12="1"/>
    <TextView
        textAppearance="@style/TextAppearance.Medium"
        textSize="@dimen/text_size_16sp"
        id="@+id/tv_percent"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        singleLine="true"/>
</LinearLayout>
