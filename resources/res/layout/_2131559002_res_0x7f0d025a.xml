<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    focusable="true"
    focusableInTouchMode="true"
    clickable="true"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginLeft="20dp"
    layout_marginTop="10dp"
    layout_marginRight="20dp"
    layout_marginBottom="20dp">
    <SearchView
        textSize="15sp"
        id="@+id/search_logs_field"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_alignParentTop="true"
        inputType="0x80001"
        iconifiedByDefault="false"
        queryHint="@string/search_logs_hint"
        paddingStart="-55dp"
        paddingEnd="0dp"
        layout_toStartOf="@+id/filter_logs"
        layout_alignParentStart="true"/>
    <Button
        id="@+id/filter_logs"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/log_level_filter"
        layout_marginStart="5dp"
        layout_alignParentEnd="true"/>
    <ScrollView
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginTop="10dp"
        layout_below="@+id/search_logs_field">
        <HorizontalScrollView
            fadingEdgeLength="70dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            requiresFadingEdge="0x1000">
            <TextView
                textSize="15sp"
                textColor="?android:attr/textColorPrimaryInverse"
                id="@+id/logs_text"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/placeholder_logs"
                lineSpacingExtra="3dp"/>
        </HorizontalScrollView>
    </ScrollView>
</RelativeLayout>
