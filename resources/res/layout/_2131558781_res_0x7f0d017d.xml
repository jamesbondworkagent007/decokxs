<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131230869_res_0x7f080095"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginTop="60dp">
    <LinearLayout
        orientation="0"
        paddingLeft="@dimen/common_page_edge_space"
        paddingRight="@dimen/common_page_edge_space"
        layout_width="-1"
        android:layout_height="48dp"
        paddingHorizontal="@dimen/common_page_edge_space">
        <o.wYC
            layout_gravity="0x800015"
            id="@+id/backButton"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232719_res_0x7f0807cf"
            tint="@color/ContentContrast"/>
        <android.widget.Space
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"/>
        <o.wYC
            layout_gravity="0x800015"
            id="@+id/closeButton"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131231675_res_0x7f0803bb"
            tint="@color/ContentContrast"/>
    </LinearLayout>
    <ScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        layout_weight="1">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentPrimary"
                id="@+id/title"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                text="@string/pr_authlogin_passkey_bttmsheet_header_request_sent"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Headline_4_Bold"/>
            <TextView
                textColor="@color/ContentTertiary"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                text="@string/pr_authlogin_passkey_bttmsheet_desc_approve_request"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Label_1_Regular"/>
            <o.C55317xhf
                id="@+id/resendLink"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp"
                text="@string/pr_authlogin_passkey_bttmsheet_btn_resend"
                paddingHorizontal="@dimen/common_page_edge_space"
                NOT_FOUND_0x18="1"
                style="@style/Label_1_Medium"/>
            <ImageView
                layout_gravity="0x1"
                id="@+id/deviceImage"
                layout_width="216dp"
                android:layout_height="160dp"
                layout_marginLeft="@dimen/common_page_edge_space"
                layout_marginTop="48dp"
                layout_marginRight="@dimen/common_page_edge_space"
                layout_marginHorizontal="@dimen/common_page_edge_space"/>
            <TextView
                textColor="@color/ContentPrimary"
                layout_gravity="0x1"
                id="@+id/deviceName"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Label_1_Bold"/>
            <TextView
                textColor="@color/ContentTertiary"
                layout_gravity="0x1"
                id="@+id/lastUsedTime"
                paddingLeft="@dimen/common_page_edge_space"
                paddingRight="@dimen/common_page_edge_space"
                layout_width="-2"
                android:layout_height="wrap_content"
                paddingHorizontal="@dimen/common_page_edge_space"
                style="@style/Label_2_Regular"/>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        orientation="1"
        paddingLeft="@dimen/common_page_edge_space"
        paddingTop="16dp"
        paddingRight="@dimen/common_page_edge_space"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/common_page_edge_space"
        paddingVertical="16dp">
        <o.C52794wYp
            id="@+id/completeVerificationButton"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_authlogin_passkey_bttmsheet_btn_completed"
            NOT_FOUND_0x16="52"
            NOT_FOUND_0x17="0x101"/>
        <o.C52794wYp
            id="@+id/cantFindRequestButton"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            text="@string/pr_authlogin_passkey_bttmsheet_btn_cant_find"
            NOT_FOUND_0x16="52"
            NOT_FOUND_0x17="0x102"/>
    </LinearLayout>
</LinearLayout>
