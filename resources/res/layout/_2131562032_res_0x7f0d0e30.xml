<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    id="@+id/rc_conversation_item"
    background="@color/BasePrimary"
    paddingLeft="@dimen/im_page_margin"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/im_page_margin"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    foreground="?attr/selectableItemBackgroundBorderless"
    paddingHorizontal="@dimen/im_page_margin"
    paddingVertical="@dimen/padding_12dp">
    <ImageView
        id="@+id/okim_conversation_portrait"
        background="@drawable/_2131231340_res_0x7f08026c"
        padding="12dp"
        layout_width="52dp"
        android:layout_height="52dp"
        src="@drawable/_2131230975_res_0x7f0800ff"
        scaleType="6"
        layout_marginEnd="12dp"
        NOT_FOUND_0x2d="@color/BrandPrimaryAlternative"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/details_container"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <TextView
            textAppearance="@style/TextAppearance.Title.15SP.Medium"
            textColor="@color/okTradeG900"
            ellipsize="3"
            id="@+id/notification_conversation_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            singleLine="true"
            layout_marginEnd="@dimen/margin_24dp"
            NOT_FOUND_0x20="true"
            NOT_FOUND_0x24="@+id/notification_conversation_date"
            NOT_FOUND_0x25="0"
            NOT_FOUND_0x26="2"
            NOT_FOUND_0x27="0"
            NOT_FOUND_0x29="0"
            style="@style/Title_2_Medium"/>
        <TextView
            textColor="@color/ContentContrast"
            gravity="0x800015"
            id="@+id/notification_conversation_date"
            layout_width="-2"
            android:layout_height="wrap_content"
            singleLine="true"
            drawablePadding="4dp"
            NOT_FOUND_0x22="@+id/notification_conversation_title"
            NOT_FOUND_0x23="0"
            NOT_FOUND_0x29="@+id/notification_conversation_title"
            style="@style/TextAppearance.Text.14SP"/>
        <TextView
            textColor="@color/okTradeG400"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/notification_conversation_content"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_2dp"
            maxLines="2"
            lines="2"
            singleLine="false"
            drawablePadding="4dp"
            textAlignment="5"
            layout_marginEnd="@dimen/margin_24dp"
            NOT_FOUND_0x24="@+id/tv_conversation_unread_count"
            NOT_FOUND_0x27="0"
            NOT_FOUND_0x28="@+id/notification_conversation_title"
            style="@style/Label_1_Regular"/>
        <TextView
            id="@+id/notification_conversation_content_baseline"
            visibility="1"
            layout_width="0dp"
            android:layout_height="0dp"
            NOT_FOUND_0x21="@+id/notification_conversation_content"
            NOT_FOUND_0x27="@+id/notification_conversation_content"
            NOT_FOUND_0x29="@+id/notification_conversation_content"/>
        <ImageView
            id="@+id/okim_pin"
            visibility="2"
            layout_width="16dp"
            android:layout_height="16dp"
            minHeight="8dp"
            layout_marginEnd="4dp"
            NOT_FOUND_0x22="@+id/notification_conversation_content_baseline"
            NOT_FOUND_0x24="@+id/tv_conversation_unread_count"
            NOT_FOUND_0x29="@+id/notification_conversation_content_baseline"
            NOT_FOUND_0x2a="0dp"
            NOT_FOUND_0x2c="@drawable/_2131232605_res_0x7f08075d"
            NOT_FOUND_0x2d="@color/ContentDisabled"/>
        <TextView
            textSize="@dimen/text_size_12sp"
            textColor="@color/white"
            gravity="0x11"
            id="@+id/tv_conversation_unread_count"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_6"
            minHeight="16dp"
            paddingStart="4dp"
            paddingEnd="4dp"
            NOT_FOUND_0x21="@+id/notification_conversation_content_baseline"
            NOT_FOUND_0x23="0"
            NOT_FOUND_0x2b="0dp"
            style="@style/Label_3_Regular"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
