<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        paddingTop="8dp"
        paddingBottom="24dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/ll_pin_to_chat"
            background="?android:attr/selectableItemBackground"
            paddingLeft="24dp"
            paddingTop="16dp"
            paddingRight="24dp"
            paddingBottom="16dp"
            focusable="true"
            clickable="true"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="24dp"
            paddingVertical="16dp">
            <ImageView
                layout_width="32dp"
                android:layout_height="32dp"
                src="@drawable/_2131233658_res_0x7f080b7a"
                layout_marginEnd="12dp"
                NOT_FOUND_0x13="@color/ContentPrimary"/>
            <TextView
                textColor="@color/ContentPrimary"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_message_notice_cell_btn_pin_to_chat"
                layout_weight="1"
                style="@style/Title_2_Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/ll_edit_notice"
            background="?android:attr/selectableItemBackground"
            paddingLeft="24dp"
            paddingTop="16dp"
            paddingRight="24dp"
            paddingBottom="16dp"
            focusable="true"
            clickable="true"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="24dp"
            paddingVertical="16dp">
            <ImageView
                layout_width="32dp"
                android:layout_height="32dp"
                src="@drawable/_2131232506_res_0x7f0806fa"
                layout_marginEnd="12dp"
                NOT_FOUND_0x13="@color/ContentPrimary"/>
            <TextView
                textColor="@color/ContentPrimary"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_message_notice_cell_btn_edit_notice"
                layout_weight="1"
                style="@style/Title_2_Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="0"
            id="@+id/ll_remove_notice"
            background="?android:attr/selectableItemBackground"
            paddingLeft="24dp"
            paddingTop="16dp"
            paddingRight="24dp"
            paddingBottom="16dp"
            focusable="true"
            clickable="true"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingHorizontal="24dp"
            paddingVertical="16dp">
            <ImageView
                layout_width="32dp"
                android:layout_height="32dp"
                src="@drawable/_2131234234_res_0x7f080dba"
                layout_marginEnd="12dp"
                NOT_FOUND_0x13="@color/SemanticNegative"/>
            <TextView
                textColor="@color/SemanticNegative"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_message_notice_btn_remove_notice"
                layout_weight="1"
                style="@style/Title_2_Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
