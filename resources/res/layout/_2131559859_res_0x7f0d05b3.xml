<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    scrollbars="horizontal"
    layout_width="-1"
    android:layout_height="match_parent"
    layout_marginTop="10dp">
    <LinearLayout
        orientation="1"
        id="@+id/root_layout"
        paddingBottom="@dimen/margin_20dp"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textAppearance="@style/TextAppearance.Title.16SP.Medium"
                id="@+id/quickBuyTitle"
                paddingLeft="@dimen/ok_dp_16"
                paddingRight="@dimen/ok_dp_16"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                paddingHorizontal="@dimen/ok_dp_16"
                style="@style/TextAppearance.Title.16SP.Medium"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/quickBuyLayout"
                background="@drawable/_2131231009_res_0x7f080121"
                visibility="2"
                layout_width="-1"
                android:layout_height="70dp"
                layout_marginLeft="@dimen/ok_dp_16"
                layout_marginTop="@dimen/dp_10"
                layout_marginRight="@dimen/ok_dp_16"
                layout_marginHorizontal="@dimen/ok_dp_16">
                <ImageView
                    id="@+id/icon"
                    tag="icon"
                    layout_width="@dimen/width_24dp"
                    android:layout_height="@dimen/height_24dp"
                    src="@drawable/_2131232649_res_0x7f080789"
                    layout_marginStart="@dimen/ok_dp_16"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x1a="0"
                    NOT_FOUND_0x1c="0"/>
                <TextView
                    textAppearance="@style/TextAppearance.Title.15SP.Medium"
                    id="@+id/title"
                    tag="title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/ok_dp_12"
                    NOT_FOUND_0x17="@+id/subTitle"
                    NOT_FOUND_0x19="@+id/icon"
                    NOT_FOUND_0x1c="0"
                    NOT_FOUND_0x1d="2"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.12SP"
                    id="@+id/subTitle"
                    tag="subTitle"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    layout_marginStart="@dimen/ok_dp_12"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x19="@+id/icon"
                    NOT_FOUND_0x1b="@+id/title"/>
                <View
                    background="@drawable/_2131232353_res_0x7f080661"
                    layout_width="@dimen/height_14dp"
                    android:layout_height="@dimen/height_14dp"
                    layout_marginEnd="@dimen/ok_dp_16"
                    backgroundTint="@color/okTradeG300"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x18="0"
                    NOT_FOUND_0x1c="0"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/convertLayout"
                background="@drawable/_2131231009_res_0x7f080121"
                layout_width="-1"
                android:layout_height="70dp"
                layout_marginLeft="@dimen/ok_dp_16"
                layout_marginTop="@dimen/dp_10"
                layout_marginRight="@dimen/ok_dp_16"
                layout_marginHorizontal="@dimen/ok_dp_16">
                <ImageView
                    id="@+id/icon2"
                    tag="icon"
                    layout_width="@dimen/width_24dp"
                    android:layout_height="@dimen/height_24dp"
                    src="@drawable/_2131232650_res_0x7f08078a"
                    layout_marginStart="@dimen/ok_dp_16"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x1a="0"
                    NOT_FOUND_0x1c="0"/>
                <TextView
                    textAppearance="@style/TextAppearance.Title.15SP.Medium"
                    id="@+id/title2"
                    tag="title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/ok_dp_12"
                    NOT_FOUND_0x17="@+id/subTitle2"
                    NOT_FOUND_0x19="@+id/icon2"
                    NOT_FOUND_0x1c="0"
                    NOT_FOUND_0x1d="2"/>
                <TextView
                    textAppearance="@style/TextAppearance.Text.12SP"
                    id="@+id/subTitle2"
                    tag="subTitle"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    layout_marginStart="@dimen/ok_dp_12"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x19="@+id/icon2"
                    NOT_FOUND_0x1b="@+id/title2"/>
                <View
                    background="@drawable/_2131232353_res_0x7f080661"
                    layout_width="@dimen/height_14dp"
                    android:layout_height="@dimen/height_14dp"
                    layout_marginEnd="@dimen/ok_dp_16"
                    backgroundTint="@color/okTradeG300"
                    NOT_FOUND_0x16="0"
                    NOT_FOUND_0x18="0"
                    NOT_FOUND_0x1c="0"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                textAppearance="@style/TextAppearance.Title.16SP.Medium"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/ok_dp_16"
                layout_marginTop="@dimen/margin_24dp"
                layout_marginRight="@dimen/ok_dp_16"
                text="@string/pr_trade_card_maintitle_markets"
                layout_marginHorizontal="@dimen/ok_dp_16"
                style="@style/TextAppearance.Title.16SP.Medium"/>
            <androidx.recyclerview.widget.RecyclerView
                id="@+id/marketTradeList"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/padding_2dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
