<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/ll_total"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x800013"
        orientation="1"
        id="@+id/ll_label_layout"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="8dp"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/ll_content_layout"
        layout_width="-1"
        android:layout_height="wrap_content"/>
    <LinearLayout
        orientation="1"
        id="@+id/helperErrorViewGroup"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="4dp">
        <RelativeLayout
            gravity="0x10"
            id="@+id/rl_helper_layout"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"/>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/ll_error_layout"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</merge>
