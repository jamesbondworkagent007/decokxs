<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    tag="layout/okt_dex_header_view_refactored_0"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="44dp"
    paddingEnd="@dimen/padding_24dp">
    <LinearLayout
        gravity="0x10"
        layout_width="0dp"
        android:layout_height="match_parent"
        layout_weight="1"
        paddingStart="@dimen/padding_24dp">
        <o.C49658ush
            id="@+id/token_icon_view"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginEnd="@dimen/margin_6dp"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x10"
            orientation="1"
            id="@+id/okt_dex_search_coin_ll"
            layout_width="-2"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="0"
                id="@+id/okt_dex_search_coin"
                layout_width="-2"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatTextView
                    textAppearance="@style/TextAppearance.Title.18SP.Semibold"
                    textSize="@dimen/text_size_18sp"
                    textColor="@color/ContentPrimary"
                    ellipsize="3"
                    gravity="0x800013"
                    id="@+id/token_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text=""
                    maxLines="1"
                    includeFontPadding="false"
                    layout_weight="8"
                    NOT_FOUND_0x1d="@dimen/text_size_18sp"
                    NOT_FOUND_0x1e="@dimen/text_size_14sp"
                    NOT_FOUND_0x1f="1sp"/>
                <o.C55251xgS
                    gravity="0x10"
                    id="@+id/okte_dex_token_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_trade_cedefi_tag_dex"
                    layout_marginStart="@dimen/margin_4dp"
                    NOT_FOUND_0x24="-4"
                    NOT_FOUND_0x25="6"/>
                <androidx.appcompat.widget.AppCompatImageView
                    id="@+id/securityIcon"
                    visibility="2"
                    layout_width="16dp"
                    android:layout_height="16dp"
                    src="@drawable/_2131234401_res_0x7f080e61"
                    layout_marginStart="3dp"
                    NOT_FOUND_0x27="@color/SemanticHighlight"/>
                <ImageView
                    id="@+id/mIvArrow"
                    layout_width="16dp"
                    android:layout_height="16dp"
                    src="@drawable/_2131231589_res_0x7f080365"
                    layout_centerInParent="true"
                    layout_marginStart="2dp"
                    NOT_FOUND_0x27="@color/ContentPrimary"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                orientation="0"
                id="@+id/ll_address"
                layout_width="-2"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentContrast"
                    layout_gravity="0x800013"
                    id="@+id/token_address"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    textDirection="5"
                    textAlignment="5"
                    style="@style/Label_4_Regular"/>
                <androidx.appcompat.widget.AppCompatImageView
                    layout_gravity="0x800013"
                    id="@+id/iv_high_risk"
                    visibility="2"
                    layout_width="16dp"
                    android:layout_height="16dp"
                    src="@drawable/_2131231936_res_0x7f0804c0"
                    layout_marginStart="4dp"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </LinearLayout>
    <LinearLayout
        gravity="0x800015"
        id="@+id/ll_right"
        layout_width="-2"
        android:layout_height="match_parent">
        <ImageView
            id="@+id/mIvTradeMarket"
            background="@drawable/_2131231584_res_0x7f080360"
            layout_width="-2"
            android:layout_height="wrap_content"
            contentDescription="TradeShowKLineBtn"
            layout_marginStart="12dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            gravity="0x10"
            layout_width="-2"
            android:layout_height="match_parent">
            <com.google.android.material.imageview.ShapeableImageView
                id="@+id/red_point"
                background="@color/Critical"
                padding="0.5dp"
                visibility="2"
                layout_width="6dp"
                android:layout_height="6dp"
                NOT_FOUND_0x21="@+id/okt_dex_more"
                NOT_FOUND_0x23="@+id/okt_dex_more"
                NOT_FOUND_0x26="@style/circleStyle"/>
            <ImageView
                id="@+id/okt_dex_more"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131233513_res_0x7f080ae9"
                contentDescription="trade_header_menu_button"
                importantForAccessibility="2"
                layout_marginStart="12dp"
                NOT_FOUND_0x20="0"
                NOT_FOUND_0x21="0"
                NOT_FOUND_0x22="0"
                NOT_FOUND_0x23="0"
                NOT_FOUND_0x27="@color/okTradeG900"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</LinearLayout>
