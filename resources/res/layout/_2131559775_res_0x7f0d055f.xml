<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x1"
    orientation="1"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        scrollbars="horizontal"
        layout_width="-1"
        android:layout_height="0dp"
        fillViewport="true"
        layout_weight="1">
        <LinearLayout
            gravity="0x1"
            orientation="1"
            layout_width="-1"
            android:layout_height="match_parent">
            <ImageView
                id="@+id/image_top"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="48dp"/>
            <TextView
                textAppearance="@style/Headline_4_Bold"
                textStyle="0x1"
                textColor="@color/grey_g900"
                gravity="0x11"
                id="@+id/tv_title"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="20dp"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginTop="@dimen/margin_48dp"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginBottom="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <TextView
                    textAppearance="@style/Title_2_Bold"
                    textColor="@color/grey_g900"
                    id="@+id/tv_num1_title"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    NOT_FOUND_0x13="0"
                    NOT_FOUND_0x14="0"
                    NOT_FOUND_0x16="0"/>
                <TextView
                    textAppearance="@style/Label_2_Regular"
                    textColor="@color/grey_g400"
                    id="@+id/tv_num1_subtitle"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_16dp"
                    NOT_FOUND_0x13="0"
                    NOT_FOUND_0x14="0"
                    NOT_FOUND_0x15="@+id/tv_num1_title"
                    NOT_FOUND_0x17="@dimen/width_0dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginLeft="@dimen/margin_24dp"
                layout_marginRight="@dimen/margin_24dp"
                layout_marginBottom="@dimen/margin_24dp"
                layout_marginHorizontal="@dimen/margin_24dp">
                <TextView
                    textAppearance="@style/Title_2_Bold"
                    textColor="@color/grey_g900"
                    id="@+id/tv_num2_title"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    NOT_FOUND_0x13="0"
                    NOT_FOUND_0x14="0"
                    NOT_FOUND_0x16="0"/>
                <TextView
                    textAppearance="@style/Label_2_Regular"
                    textColor="@color/grey_g400"
                    id="@+id/tv_num2_subtitle"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="@dimen/margin_16dp"
                    NOT_FOUND_0x13="0"
                    NOT_FOUND_0x14="0"
                    NOT_FOUND_0x15="@+id/tv_num2_title"
                    NOT_FOUND_0x17="@dimen/width_0dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <o.C52794wYp
        textSize="16sp"
        id="@+id/btn"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginTop="16dp"
        layout_marginRight="24dp"
        layout_marginBottom="16dp"
        text="@string/pr_commonall_text_btn_ok_passive"
        layout_marginHorizontal="24dp"
        layout_marginVertical="16dp"
        NOT_FOUND_0x18="52"
        NOT_FOUND_0x19="0x101"/>
</LinearLayout>
