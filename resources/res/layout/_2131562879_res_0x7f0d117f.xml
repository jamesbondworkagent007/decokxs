<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/root_layout"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="1"
        id="@+id/title_layout"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x14="@+id/rv_list"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0">
        <LinearLayout
            orientation="0"
            layout_width="-1"
            android:layout_height="50dp">
            <TextView
                textAppearance="@style/TextAppearance.Title.18SP.Semibold"
                gravity="0x800013"
                id="@+id/tv_title"
                layout_width="-2"
                android:layout_height="match_parent"
                layout_weight="1"
                fontFamily="sans-serif-medium"
                layout_marginStart="16dp"/>
            <ImageView
                gravity="0x10"
                id="@+id/iv_close"
                layout_width="44dp"
                android:layout_height="50dp"
                src="@drawable/_2131232722_res_0x7f0807d2"
                scaleType="fitEnd"/>
        </LinearLayout>
        <View
            id="@+id/titleViewDivider"
            background="@color/okTradeG200"
            layout_width="-1"
            android:layout_height="1px"
            layout_marginTop="8dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rv_list"
        background="@color/okTradeBackground1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x14="@+id/divider"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/title_layout"/>
    <View
        id="@+id/divider"
        background="@color/okTradeG200"
        layout_width="-1"
        android:layout_height="1px"
        layout_marginTop="8dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0x14="@+id/btn_cancel"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="@+id/rv_list"/>
    <TextView
        textSize="16sp"
        textColor="@color/okTradeG900"
        gravity="0x11"
        id="@+id/btn_cancel"
        background="?attr/selectableItemBackground"
        layout_width="0dp"
        android:layout_height="50dp"
        textAllCaps="false"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
