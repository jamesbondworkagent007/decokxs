<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/rootContainer"
        layout_width="-1"
        android:layout_height="wrap_content">
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/titleText"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_trade_history_title_detail_profitchange"
            style="@style/Label_1_Bold"/>
        <TextView
            textAppearance="@style/TextAppearance.Text.14SP.Regular"
            textColor="@color/ContentContrast"
            id="@+id/subtitleText"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp"
            text="@string/pr_smartarb_botdetails_header_total_pnl_rate"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/totalPnlValue"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp"
            style="@style/Label_1_Bold"/>
        <o.C55237xgE
            id="@+id/chartStatefulLayout"
            clipChildren="false"
            clipToPadding="false"
            layout_width="-1"
            android:layout_height="180dp"
            layout_marginTop="2dp">
            <o.C51348vlN
                id="@+id/chartView"
                clipChildren="false"
                clipToPadding="false"
                layout_width="-1"
                android:layout_height="match_parent"
                animateLayoutChanges="true"/>
        </o.C55237xgE>
    </androidx.appcompat.widget.LinearLayoutCompat>
</merge>
