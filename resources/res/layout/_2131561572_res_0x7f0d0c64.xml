<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <TextView
        textSize="14sp"
        textColor="@android:color/darker_gray"
        layout_gravity="0x800035"
        id="@+id/tv_version"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_margin="@dimen/ok_dp_16"
        text="v2.0.0"/>
    <ScrollView
        layout_width="-1"
        android:layout_height="match_parent">
        <LinearLayout
            orientation="1"
            padding="8dp"
            layout_width="-1"
            android:layout_height="wrap_content">
            <o.C52794wYp
                id="@+id/btn_start_liveness"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="開始活體檢測"
                NOT_FOUND_0x16="44"
                NOT_FOUND_0x17="0x101"
                NOT_FOUND_0x18="-2"/>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="10dp"
                text="视频输出方法"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="0"
                id="@+id/rg_video_output_way"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    id="@+id/rb_full_video"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="完整视频"/>
                <o.wYP
                    id="@+id/rb_segment_video"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="分块视频"/>
            </RadioGroup>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="是否啟用QC檢測"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="0"
                id="@+id/rg_enable_qc"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    id="@+id/rb_enable_qc"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="啟用"/>
                <o.wYP
                    id="@+id/rb_disable_qc"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="關閉"/>
            </RadioGroup>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="API选择"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="0"
                id="@+id/rg_api"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_api_jwst"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="JWST"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_api_collection"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="DATA_COLLECTION"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_api_model"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="MODEL_PREDICTION"/>
            </RadioGroup>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="JWST Env （直连LCA的JWST服务）"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="0"
                id="@+id/rg_jwst_env"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_jwst_env_swimlane"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="swimlane"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_jwst_env_okx"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="OKX App Env (使用OKX App现在的环境。 比如要预发环境，先切换app env到&apos;LCA-Pre-Production&apos;)"/>
            </RadioGroup>
            <o.C52794wYp
                id="@+id/btn_trigger_face_guard"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="測試阿里人臉保鑣"
                NOT_FOUND_0x16="44"
                NOT_FOUND_0x17="0x101"
                NOT_FOUND_0x18="-2"/>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="大橢圓引導動畫"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="0"
                id="@+id/rg_face_oval_guide_animation"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_face_oval_guide_animation_default"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="關閉"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_face_oval_guide_animation_a"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="方案A（上引導動畫）"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_face_oval_guide_animation_b"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="默認方案B（人臉引導遮罩）"/>
            </RadioGroup>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="Move Close提示文案是否显示"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="0"
                id="@+id/rg_move_close_tip_visibility"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_move_close_tip_show"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="顯示"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_move_close_tip_hide"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="關閉"/>
            </RadioGroup>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="Data Sign"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="0"
                id="@+id/rg_data_sign"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_data_sign_no"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="No"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_data_sign_yes"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="Yes"/>
            </RadioGroup>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="Data Obfuscation"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="0"
                id="@+id/rg_data_obfuscation"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_data_obfuscation_no"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="No"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_data_obfuscation_yes"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="Yes"/>
            </RadioGroup>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="Subdomain Strategy (WebSocket Header)"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <RadioGroup
                orientation="1"
                id="@+id/rg_subdomain_strategy"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_subdomain_none"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="None (No custom header)"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_subdomain_auto"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="Auto (Use global if not logged in, site domain if logged in)"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_subdomain_global"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="Global (Always use www.okx.com)"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_subdomain_subdomain"
                    padding="@dimen/dp_8"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="Subdomain (Force specific site domain)"/>
            </RadioGroup>
            <LinearLayout
                orientation="0"
                id="@+id/ll_subdomain_site_input"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginStart="@dimen/dp_8">
                <TextView
                    textSize="14sp"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="Site: "/>
                <com.okinc.uilab.edit.OKEditText
                    id="@+id/et_subdomain_site"
                    layout_width="200dp"
                    android:layout_height="wrap_content"
                    hint="Enter site name (e.g. sg, hk)"
                    inputType="0x1"/>
            </LinearLayout>
            <LinearLayout
                orientation="1"
                visibility="2"
                layout_width="-1"
                android:layout_height="wrap_content">
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="18sp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="超时处理时长(ms)"/>
                    <com.okinc.uilab.edit.OKEditText
                        id="@+id/et_retry_timeout_duration"
                        layout_width="100dp"
                        android:layout_height="wrap_content"
                        hint="单位"
                        inputType="0x2"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="18sp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="前置透明帧时长(ms)"/>
                    <com.okinc.uilab.edit.OKEditText
                        id="@+id/et_prefix_duration"
                        layout_width="100dp"
                        android:layout_height="wrap_content"
                        hint="单位"
                        inputType="0x2"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="18sp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="黑色固定色时长(ms)"/>
                    <com.okinc.uilab.edit.OKEditText
                        id="@+id/et_start_black_duration"
                        layout_width="100dp"
                        android:layout_height="wrap_content"
                        hint="单位"
                        inputType="0x2"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="18sp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="中间炫彩时长(ms)"/>
                    <com.okinc.uilab.edit.OKEditText
                        id="@+id/et_duration"
                        layout_width="100dp"
                        android:layout_height="wrap_content"
                        hint="单位"
                        inputType="0x2"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="18sp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="后置透明帧时长(ms)"/>
                    <com.okinc.uilab.edit.OKEditText
                        id="@+id/et_suffix_duration"
                        layout_width="100dp"
                        android:layout_height="wrap_content"
                        hint="单位"
                        inputType="0x2"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="18sp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="椭圆宽"/>
                    <com.okinc.uilab.edit.OKEditText
                        id="@+id/et_with"
                        layout_width="100dp"
                        android:layout_height="wrap_content"
                        hint="椭圆宽"
                        inputType="0x2"/>
                    <TextView
                        textSize="18sp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="高"/>
                    <com.okinc.uilab.edit.OKEditText
                        id="@+id/et_height"
                        layout_width="100dp"
                        android:layout_height="wrap_content"
                        hint="椭圆高"
                        inputType="0x2"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="18sp"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="视频码率(bits/sec)"/>
                    <com.okinc.uilab.edit.OKEditText
                        id="@+id/et_bitrate"
                        layout_width="100dp"
                        android:layout_height="wrap_content"
                        hint="单位"
                        inputType="0x2"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_10"
                text="颜色池子"
                style="@style/TextAppearance.Title.18SP.Medium"/>
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    gravity="0x11"
                    id="@+id/tv_color1"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="(255, 0, 0)"
                    layout_weight="1"
                    style="@style/TextAppearance.AppCompat.Body1"/>
                <TextView
                    gravity="0x11"
                    id="@+id/tv_color2"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginLeft="10dp"
                    layout_marginRight="10dp"
                    text="(255, 0, 0)"
                    layout_weight="1"
                    layout_marginHorizontal="10dp"
                    style="@style/TextAppearance.AppCompat.Body1"/>
                <TextView
                    gravity="0x11"
                    id="@+id/tv_color3"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="(255, 0, 0)"
                    layout_weight="1"
                    style="@style/TextAppearance.AppCompat.Body1"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="10dp">
                <TextView
                    gravity="0x11"
                    id="@+id/tv_color4"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="(255, 0, 0)"
                    layout_weight="1"
                    style="@style/TextAppearance.AppCompat.Body1"/>
                <TextView
                    gravity="0x11"
                    id="@+id/tv_color5"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginLeft="10dp"
                    layout_marginRight="10dp"
                    text="(255, 255, 0)"
                    layout_weight="1"
                    layout_marginHorizontal="10dp"
                    style="@style/TextAppearance.AppCompat.Body1"/>
                <TextView
                    gravity="0x11"
                    id="@+id/tv_color6"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    text="(255, 0, 0)"
                    layout_weight="1"
                    style="@style/TextAppearance.AppCompat.Body1"/>
            </LinearLayout>
            <TextView
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="20dp"
                text="颜色序列：前置和后置固定颜色，中间炫彩可以修改 (JWST直接用后端下发的随机颜色，不支持手动设置)"
                style="@style/TextAppearance.AppCompat.Caption"/>
            <TextView
                textColor="@android:color/black"
                gravity="0x13"
                background="@color/white"
                paddingLeft="30dp"
                layout_width="-1"
                android:layout_height="50dp"
                text="前置透明帧"
                style="@style/TextAppearance.Title.16SP"/>
            <TextView
                textColor="@color/white"
                gravity="0x13"
                background="@android:color/black"
                paddingLeft="30dp"
                layout_width="-1"
                android:layout_height="40dp"
                text="固定黑色 (0, 0, 0)"
                style="@style/TextAppearance.Title.16SP"/>
            <RadioGroup
                id="@+id/rg_color_sequence"
                layout_width="-1"
                android:layout_height="wrap_content">
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_color1"
                    padding="@dimen/dp_8"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    text="静止"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_color2"
                    padding="@dimen/dp_8"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    text="静止"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_color3"
                    padding="@dimen/dp_8"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    text="静止"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_color4"
                    padding="@dimen/dp_8"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    text="静止"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_color5"
                    padding="@dimen/dp_8"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    text="静止"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_color6"
                    padding="@dimen/dp_8"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    text="静止"/>
                <o.wYP
                    textSize="@dimen/font_12"
                    id="@+id/rb_color7"
                    padding="@dimen/dp_8"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    text="静止"/>
            </RadioGroup>
            <TextView
                textColor="@android:color/black"
                gravity="0x13"
                background="@color/white"
                paddingLeft="30dp"
                layout_width="-1"
                android:layout_height="50dp"
                text="后置透明帧"
                style="@style/TextAppearance.Title.16SP"/>
            <View
                layout_width="-1"
                android:layout_height="80dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
