        foregroundGravity="0x77"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.12SP"
        ellipsize="3"
        gravity="0x11"
        id="@+id/tv_name"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        lines="1"
        paddingStart="4dp"
        paddingEnd="4dp"/>
</LinearLayout>
