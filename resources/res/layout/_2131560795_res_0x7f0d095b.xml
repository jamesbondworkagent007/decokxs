<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingLeft="6dp"
    paddingTop="@dimen/dp_8"
    paddingRight="6dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="6dp">
    <TextView
        ellipsize="3"
        id="@+id/tv_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        singleLine="true"
        fontFamily="@font/font_alpha_medium"
        style="@style/TextAppearance.Title.12SP"/>
    <TextView
        ellipsize="3"
        id="@+id/tv_type"
        layout_width="-2"
        android:layout_height="wrap_content"
        singleLine="true"
        fontFamily="@font/font_alpha_medium"
        style="@style/TextAppearance.Title.12SP"/>
    <TextView
        textStyle="0x1"
        id="@+id/tv_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="- -"
        fontFamily="@font/font_alpha_bold"
        style="@style/TextAppearance.Green.12SP"/>
    <TextView
        textSize="10sp"
        id="@+id/tv_change_percent"
        layout_width="-2"
        android:layout_height="wrap_content"
        fontFamily="@font/font_alpha_regular"
        style="@style/TextAppearance.Green"/>
</LinearLayout>
