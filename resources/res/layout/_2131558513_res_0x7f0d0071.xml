<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/activity_debug_language_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <o.C33537myN
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x11="@string/pr_debug_text_language"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        id="@+id/tv_info"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"/>
    <EditText
        id="@+id/et_key"
        layout_width="-1"
        android:layout_height="wrap_content"
        hint="input key"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"/>
    <Button
        id="@+id/btn_search"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="Search value in language map"
        layout_marginStart="16dp"
        style="@style/Button.Primary.Medium"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        id="@+id/tv_result"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"/>
    <View
        background="@color/list_divider_color"
        layout_width="-1"
        android:layout_height="2dp"
        layout_marginTop="10dp"
        layout_marginBottom="10dp"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="48dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="Enable Long Click(Warning:Affect Click)"
            layout_weight="1"/>
        <androidx.appcompat.widget.SwitchCompat
            layout_gravity="0x10"
            id="@+id/long_click_switch"
            background="@drawable/_2131233716_res_0x7f080bb4"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="@color/transparent"
            NOT_FOUND_0x16="@color/transparent"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="1"
        id="@+id/click_to_check_language"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="48dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp">
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="Version(Click to update)"
            layout_weight="1"/>
        <TextView
            textAppearance="@style/TextAppearance.Title.16SP"
            id="@+id/language_version"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
