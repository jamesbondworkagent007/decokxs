<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/rl_coin_name_container"
    tag="layout/view_recurring_coin_config_item_0"
    background="@drawable/_2131233847_res_0x7f080c37"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="8dp"
    minHeight="@dimen/height_40dp">
    <ImageView
        id="@+id/iv_coin_avatar"
        layout_width="20dp"
        android:layout_height="20dp"
        layout_marginStart="12dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1e="0"
        NOT_FOUND_0x1f="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/tv_coin_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_centerVertical="true"
        layout_marginStart="6dp"
        NOT_FOUND_0x19="true"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="@+id/et_coin_ratio"
        NOT_FOUND_0x1d="@+id/iv_coin_avatar"
        NOT_FOUND_0x1f="0"/>
    <o.C55001xbh
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/ContentPrimary"
        gravity="0x800015"
        id="@+id/et_coin_ratio"
        background="@null"
        layout_width="0dp"
        android:layout_height="match_parent"
        hint="0"
        digits="0123456789,."
        layout_centerVertical="true"
        inputType="0x2"
        layout_marginStart="16dp"
        layout_marginEnd="@dimen/dp_4"
        layout_alignParentEnd="true"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="@+id/symbol_percent"
        NOT_FOUND_0x1d="@+id/tv_coin_name"
        NOT_FOUND_0x1f="0"
        NOT_FOUND_0x20="50dp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Medium"
        textColor="@color/ContentPrimary"
        id="@+id/symbol_percent"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="%"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="@+id/fl_delete"
        NOT_FOUND_0x1f="0"/>
    <FrameLayout
        id="@+id/fl_delete"
        paddingLeft="@dimen/padding_12dp"
        paddingRight="@dimen/padding_12dp"
        layout_width="-2"
        android:layout_height="0dp"
        layout_marginStart="8dp"
        layout_alignParentEnd="true"
        paddingHorizontal="@dimen/padding_12dp"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1f="0">
        <ImageView
            layout_gravity="0x11"
            id="@+id/iv_delete"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131231675_res_0x7f0803bb"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
