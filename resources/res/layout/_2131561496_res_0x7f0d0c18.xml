<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    layout_width="-2"
    android:layout_height="wrap_content">
    <o.C7938atK
        id="@+id/tab_title_scale_layout_lua"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_centerVertical="true">
        <TextView
            textSize="15sp"
            textColor="#323333"
            id="@+id/tab_title_lua"
            layout_width="-2"
            android:layout_height="wrap_content"/>
    </o.C7938atK>
    <TextView
        textSize="11sp"
        textColor="#ffffff"
        id="@+id/tab_hint_lua"
        background="@drawable/_2131231277_res_0x7f08022d"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_alignTop="@+id/tab_title_scale_layout_lua"
        lineSpacingExtra="0dp"
        marqueeRepeatLimit="1"
        paddingStart="4.5dp"
        paddingEnd="4.5dp"
        layout_marginStart="-2dp"
        layout_toEndOf="@+id/tab_title_scale_layout_lua"/>
    <View
        id="@+id/tab_dot_lua"
        background="@drawable/_2131231278_res_0x7f08022e"
        visibility="2"
        layout_width="7dp"
        android:layout_height="7dp"
        layout_marginTop="1dp"
        layout_alignTop="@+id/tab_title_scale_layout_lua"
        layout_marginStart="-2dp"
        layout_toEndOf="@+id/tab_title_scale_layout_lua"/>
</RelativeLayout>
