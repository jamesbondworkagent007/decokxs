<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_16dp">
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_18sp"
        textColor="@color/ContentPrimary"
        id="@+id/title"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        style="@style/Title_2_Medium"/>
    <o.pYT
        id="@+id/coin_stack"
        paddingLeft="@dimen/padding_8dp"
        paddingRight="@dimen/padding_8dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginEnd="@dimen/margin_16dp"
        paddingHorizontal="@dimen/padding_8dp"
        NOT_FOUND_0x11="@+id/title"
        NOT_FOUND_0x13="@+id/title"
        NOT_FOUND_0x15="@+id/title"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/edit"
        visibility="2"
        layout_width="@dimen/dp_16"
        android:layout_height="@dimen/dp_16"
        src="@drawable/_2131232074_res_0x7f08054a"
        NOT_FOUND_0x11="@+id/coin_stack"
        NOT_FOUND_0x13="@+id/coin_stack"
        NOT_FOUND_0x15="@+id/coin_stack"
        NOT_FOUND_0x16="@color/ContentContrast"/>
    <androidx.appcompat.widget.AppCompatTextView
        id="@+id/item_select"
        layout_width="-2"
        android:layout_height="wrap_content"
        drawableStart="@drawable/_2131233428_res_0x7f080a94"
        layout_marginStart="@dimen/margin_4dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
