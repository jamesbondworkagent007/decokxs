<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        paddingLeft="@dimen/sm"
        paddingTop="@dimen/sm"
        paddingRight="@dimen/sm"
        paddingBottom="@dimen/sm"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/sm"
        paddingVertical="@dimen/sm">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginBottom="@dimen/margin_16dp">
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x11"
                id="@+id/iv_lp_dex_token"
                layout_width="@dimen/height_36dp"
                android:layout_height="@dimen/height_36dp"
                src="@drawable/_2131231887_res_0x7f08048f"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1c="0"/>
            <androidx.appcompat.widget.AppCompatTextView
                textSize="@dimen/font_14"
                textColor="@color/ContentContrast"
                ellipsize="3"
                id="@+id/tv_lp_dex_name"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginBottom="@dimen/margin_4dp"
                maxLines="1"
                layout_marginStart="@dimen/margin_12dp"
                NOT_FOUND_0x16="@+id/tv_lp_amt_usd"
                NOT_FOUND_0x19="@+id/iv_lp_dex_token"
                NOT_FOUND_0x1c="0"
                style="@style/Label_2_Regular"/>
            <androidx.appcompat.widget.AppCompatTextView
                textSize="@dimen/font_18"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/tv_lp_amt_usd"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="1"
                layout_marginStart="@dimen/margin_12dp"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x19="@+id/iv_lp_dex_token"
                NOT_FOUND_0x1b="@+id/tv_lp_dex_name"
                style="@style/Title_2_Medium"/>
            <ImageView
                id="@+id/iv_copy_address"
                layout_width="@dimen/width_20dp"
                android:layout_height="@dimen/width_20dp"
                src="@drawable/_2131234345_res_0x7f080e29"
                scaleType="7"
                layout_marginStart="@dimen/margin_12dp"
                layout_marginEnd="@dimen/margin_16dp"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x18="@+id/iv_open_link"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="@color/ContentPrimary"/>
            <ImageView
                id="@+id/iv_open_link"
                layout_width="@dimen/width_20dp"
                android:layout_height="@dimen/width_20dp"
                src="@drawable/_2131233620_res_0x7f080b54"
                scaleType="7"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="@color/ContentPrimary"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            paddingTop="@dimen/padding_4dp"
            paddingBottom="@dimen/padding_4dp"
            layout_width="-1"
            android:layout_height="wrap_content"
            paddingVertical="@dimen/padding_4dp">
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_history_assets_colheader_token"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1c="0"
                style="@style/Body_4"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/ContentContrast"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_swaptrade_market_colheader_amount"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x1c="0"
                style="@style/Body_4"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.recyclerview.widget.RecyclerView
            orientation="1"
            id="@+id/token_detail_rv"
            layout_width="-1"
            android:layout_height="wrap_content"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
