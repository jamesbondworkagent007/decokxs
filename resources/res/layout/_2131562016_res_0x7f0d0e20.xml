<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/buttonPanel"
    layout_width="-1"
    android:layout_height="wrap_content"
    fillViewport="true"
    scrollIndicators="0x3"
    style="?attr/buttonBarStyle">
    <LinearLayout
        gravity="0x50"
        orientation="0"
        background="@drawable/_2131231425_res_0x7f0802c1"
        paddingTop="0x7f0703c9"
        layout_width="-1"
        android:layout_height="wrap_content"
        divider="@drawable/_2131232027_res_0x7f08051b"
        showDividers="middle"
        layoutDirection="3">
        <Button
            textColor="@color/subtitle_text_color"
            id="@android:id/button2"
            background="?attr/selectableItemBackground"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            contentDescription="button2"
            textAllCaps="false"
            style="@style/Button.Borderless"/>
        <Space
            id="@+id/spacer"
            visibility="2"
            layout_width="0dp"
            android:layout_height="0dp"
            layout_weight="1"/>
        <Button
            id="@android:id/button3"
            background="?attr/selectableItemBackground"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            contentDescription="button3"
            textAllCaps="false"
            style="@style/Button.Borderless"/>
        <Button
            textColor="@color/blue_text_color"
            id="@android:id/button1"
            background="?attr/selectableItemBackground"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            contentDescription="button1"
            textAllCaps="false"
            style="@style/Button.Borderless.Colored"/>
    </LinearLayout>
</ScrollView>
