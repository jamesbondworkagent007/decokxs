<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    nestedScrollingEnabled="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        paddingLeft="@dimen/dp_24"
        paddingTop="@dimen/dp_8"
        paddingRight="@dimen/dp_24"
        paddingBottom="@dimen/dp_24"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/dp_24">
        <androidx.appcompat.widget.AppCompatTextView
            textSize="@dimen/text_size_14sp"
            textColor="@color/ContentTertiary"
            id="@+id/event_time"
            layout_width="0dp"
            android:layout_height="wrap_content"
            lineHeight="@dimen/text_size_16sp"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="0"
            style="@style/Label_2_Regular"/>
        <LinearLayout
            orientation="1"
            id="@+id/event_content_layout"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_8"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="@+id/event_time"
            NOT_FOUND_0x19="@+id/event_time">
            <androidx.appcompat.widget.AppCompatTextView
                textSize="@dimen/text_size_16sp"
                textColor="@color/ContentPrimary"
                ellipsize="3"
                id="@+id/event_title"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="@+id/event_time"
                NOT_FOUND_0x19="@+id/event_time"
                NOT_FOUND_0x1c="@dimen/text_size_22sp"
                style="@style/Label_3_Medium"/>
            <androidx.appcompat.widget.AppCompatTextView
                textSize="@dimen/text_size_16sp"
                textColor="@color/ContentTertiary"
                id="@+id/event_desc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_8"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="@+id/event_time"
                NOT_FOUND_0x19="@+id/event_time"
                NOT_FOUND_0x1c="@dimen/text_size_22sp"
                style="@style/Label_3_Regular"/>
        </LinearLayout>
        <LinearLayout
            orientation="1"
            id="@+id/eventTypeLayout"
            background="@drawable/_2131231162_res_0x7f0801ba"
            padding="@dimen/dp_16"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_20"
            backgroundTint="@color/SurfacePrimary"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="@+id/event_content_layout">
            <androidx.appcompat.widget.AppCompatTextView
                textSize="@dimen/text_size_16sp"
                textColor="@color/ContentPrimary"
                id="@+id/eventTypeTitle"
                layout_width="-2"
                android:layout_height="wrap_content"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="@+id/event_time"
                NOT_FOUND_0x19="@+id/event_time"
                NOT_FOUND_0x1c="@dimen/text_size_20sp"
                style="@style/Label_1_Bold"/>
            <androidx.appcompat.widget.AppCompatTextView
                textSize="@dimen/text_size_16sp"
                textColor="@color/ContentTertiary"
                ellipsize="3"
                id="@+id/eventTypeDesc"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/dp_8"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x18="@+id/event_time"
                NOT_FOUND_0x19="@+id/event_time"
                NOT_FOUND_0x1c="@dimen/text_size_24sp"
                style="@style/Body_2_Regular"/>
        </LinearLayout>
        <LinearLayout
            gravity="0x10"
            orientation="0"
            id="@+id/avatar_container"
            paddingLeft="@dimen/dp_4"
            paddingRight="@dimen/dp_4"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_8"
            paddingHorizontal="@dimen/dp_4"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="@+id/eventTypeLayout"
            NOT_FOUND_0x1b="@dimen/dp_8">
            <ImageView
                id="@+id/avatar1"
                layout_width="@dimen/dp_14"
                android:layout_height="@dimen/dp_14"
                src="@drawable/_2131232465_res_0x7f0806d1"/>
            <ImageView
                id="@+id/avatar2"
                layout_width="@dimen/dp_14"
                android:layout_height="@dimen/dp_14"
                src="@drawable/_2131232465_res_0x7f0806d1"
                layout_marginStart="-6dp"/>
            <ImageView
                id="@+id/avatar3"
                layout_width="@dimen/dp_14"
                android:layout_height="@dimen/dp_14"
                src="@drawable/_2131232465_res_0x7f0806d1"
                layout_marginStart="-6dp"/>
            <TextView
                textAppearance="@style/Label_3_Regular"
                textColor="@color/ContentContrast"
                id="@+id/avatar_count"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="4dp"/>
        </LinearLayout>
        <androidx.appcompat.widget.AppCompatTextView
            textSize="@dimen/text_size_12sp"
            textColor="@color/ContentTertiary"
            ellipsize="3"
            id="@+id/prompt"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_20"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="@+id/avatar_container"
            NOT_FOUND_0x19="@+id/avatar_container"
            NOT_FOUND_0x1b="@dimen/dp_20"
            NOT_FOUND_0x1c="@dimen/text_size_18sp"
            style="@style/Body_4"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
