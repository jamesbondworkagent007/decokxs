<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    paddingLeft="@dimen/padding_24dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_24dp"
    layout_width="-1"
    android:layout_height="match_parent"
    paddingHorizontal="@dimen/padding_24dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/header_section"
        paddingTop="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="@+id/divider"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="0">
        <FrameLayout
            layout_width="48dp"
            android:layout_height="48dp">
            <androidx.appcompat.widget.AppCompatImageView
                id="@+id/token_icon"
                layout_width="48dp"
                android:layout_height="48dp"/>
            <androidx.appcompat.widget.AppCompatImageView
                layout_gravity="0x800055"
                id="@+id/platform_icon"
                layout_width="16dp"
                android:layout_height="16dp"/>
        </FrameLayout>
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/margin_12dp">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content">
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/token_symbol"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_1_Medium"/>
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/token_name"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/margin_4dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_4dp">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/token_time_label"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Label_3_Regular"/>
                <o.C55064xcr
                    layout_gravity="0x10"
                    id="@+id/dot_view"
                    background="@color/BorderSecondary"
                    layout_width="3dp"
                    android:layout_height="3dp"
                    layout_marginStart="4dp"/>
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/token_mcap_label"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_common_label_mcap_abbreviated"
                    layout_marginStart="@dimen/margin_4dp"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/SemanticNotice"
                    id="@+id/token_mcap_value"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="@dimen/margin_4dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <View
        id="@+id/divider"
        background="@drawable/_2131232011_res_0x7f08050b"
        layout_width="-1"
        android:layout_height="1dp"
        layout_marginTop="@dimen/margin_16dp"
        layout_marginBottom="@dimen/margin_16dp"
        layout_marginVertical="@dimen/margin_16dp"
        NOT_FOUND_0x16="@+id/title_section"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/header_section"/>
    <LinearLayout
        orientation="0"
        id="@+id/title_section"
        paddingLeft="@dimen/padding_4dp"
        paddingRight="@dimen/padding_4dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_4dp"
        NOT_FOUND_0x16="@+id/trader_list"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/divider">
        <TextView
            textColor="@color/ContentContrast"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_asset_withdrawal_addressbook_details_address"
            style="@style/Label_3_Regular"/>
        <View
            layout_width="@dimen/width_0dp"
            android:layout_height="1dp"
            layout_weight="1"/>
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/pnl_position_text"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_swaptrade_position_and_pnl"
            style="@style/Label_3_Regular"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/trader_list"
        layout_width="-1"
        android:layout_height="wrap_content"
        overScrollMode="2"
        NOT_FOUND_0x14="true"
        NOT_FOUND_0x16="@+id/trade_button"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/title_section"/>
    <o.C52794wYp
        id="@+id/trade_button"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_wallet_profile_cell_tag_buy"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@+id/trader_list"
        NOT_FOUND_0x1b="52"
        NOT_FOUND_0x1c="0x105"/>
</androidx.constraintlayout.widget.ConstraintLayout>
