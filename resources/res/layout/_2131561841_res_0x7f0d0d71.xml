<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    background="?attr/selectableItemBackground"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_12dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="60dp"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_12dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_fav_nav"
        paddingTop="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        layout_width="@dimen/width_32dp"
        android:layout_height="wrap_content"
        src="@drawable/_2131233467_res_0x7f080abb"
        scaleType="7"
        paddingStart="0dp"
        paddingEnd="8dp"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="@color/selector_star_content_constrast"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_icon_nav"
        layout_width="@dimen/margin_28dp"
        android:layout_height="@dimen/margin_28dp"
        scaleType="fitStart"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="@+id/iv_fav_nav"
        NOT_FOUND_0x16="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_chain_nav"
        layout_width="@dimen/margin_12dp"
        android:layout_height="@dimen/margin_12dp"
        scaleType="fitStart"
        translationX="2dp"
        translationY="2dp"
        NOT_FOUND_0x12="@+id/iv_icon_nav"
        NOT_FOUND_0x13="@+id/iv_icon_nav"/>
    <o.C40358qSx
        id="@+id/nav_crypto_layout"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="@+id/iv_chain_nav"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x17="0dp"/>
