<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="24dp"
    paddingRight="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="24dp">
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        gravity="0x10"
        id="@+id/tvTitle"
        layout_width="-1"
        android:layout_height="44dp"
        text="@string/pr_wallet_search_subtitle_my_assets"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"
        style="@style/TextAppearance.Medium"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/clAssetCount"
        paddingTop="@dimen/padding_16dp"
        paddingBottom="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingVertical="@dimen/padding_16dp"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="@+id/tvTitle">
        <com.google.android.material.imageview.ShapeableImageView
            id="@+id/ivFirst"
            layout_width="@dimen/height_32dp"
            android:layout_height="@dimen/height_32dp"
            src="@drawable/_2131231677_res_0x7f0803bd"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1a="@style/CircleStyle"/>
        <com.google.android.material.imageview.ShapeableImageView
            id="@+id/ivSecond"
            layout_width="@dimen/height_32dp"
            android:layout_height="@dimen/height_32dp"
            src="@drawable/_2131231677_res_0x7f0803bd"
            layout_marginStart="-10dp"
            NOT_FOUND_0x14="@+id/ivFirst"
            NOT_FOUND_0x16="@+id/ivFirst"
            NOT_FOUND_0x19="@+id/ivFirst"
            NOT_FOUND_0x1a="@style/CircleStyle"/>
        <ImageView
            id="@+id/ivMore"
            background="@drawable/_2131234026_res_0x7f080cea"
            padding="@dimen/padding_8dp"
            layout_width="@dimen/height_32dp"
            android:layout_height="@dimen/height_32dp"
            src="@drawable/_2131233513_res_0x7f080ae9"
            layout_marginStart="-10dp"
            NOT_FOUND_0x14="@+id/ivSecond"
            NOT_FOUND_0x16="@+id/ivSecond"
            NOT_FOUND_0x19="@+id/ivSecond"
            NOT_FOUND_0x1b="@color/ContentInverse"/>
        <o.C55068xcv
            textSize="@dimen/text_size_16sp"
            textColor="@color/ContentPrimary"
            id="@+id/tvAssetCount"
            layout_width="-2"
            android:layout_height="wrap_content"
            drawablePadding="8dp"
            NOT_FOUND_0x12="@drawable/_2131231647_res_0x7f08039f"
            NOT_FOUND_0x13="@color/ContentPrimary"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x19="0"
            style="@style/TextAppearance.Medium"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
