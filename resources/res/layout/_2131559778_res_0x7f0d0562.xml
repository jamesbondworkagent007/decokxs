<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/fragment_arbitrage_content_0"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/tradeTypeLay"
        layout_width="-1"
        android:layout_height="48dp"
        layout_marginLeft="@dimen/ok_dp_16"
        layout_marginRight="@dimen/ok_dp_16"
        layout_marginHorizontal="@dimen/ok_dp_16">
        <FrameLayout
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            paddingEnd="@dimen/dp_10">
            <o.C52708wVk
                id="@+id/tradeTypeView"
                paddingTop="12dp"
                paddingBottom="8dp"
                layout_width="-1"
                android:layout_height="wrap_content"/>
            <View
                layout_gravity="0x800015"
                background="@drawable/_2131230935_res_0x7f0800d7"
                layout_width="30dp"
                android:layout_height="match_parent"/>
        </FrameLayout>
        <o.C48157uHb
            textSize="@dimen/text_size_12sp"
            textColor="@color/okTradeG900"
            id="@+id/groupSelView"
            visibility="2"
            layout_width="-2"
            android:layout_height="wrap_content"
            style="@style/TextSelector.AutoScale"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="16dp"
        layout_marginRight="16dp"
        minHeight="36dp"
        layout_marginHorizontal="16dp">
        <TextView
            textAppearance="@style/TextAppearance.Text.12SP"
            layout_gravity="0x800013"
            id="@+id/tv_arbitrage_portfolio"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_datas_bot_theader_pairs"/>
        <RelativeLayout
            layout_gravity="0x800015"
            orientation="0"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="16dp">
            <com.okinc.uilab.view.OKSortTextView
                textSize="12sp"
                textColor="@color/okTradeG400"
                id="@+id/stv_rate_apy"
                clickable="true"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_datas_bot_theader_rate"
                drawablePadding="0dp"
                layout_toStartOf="@+id/tv_divider"
                NOT_FOUND_0x1b="0"
                style="@style/OkSortBar"/>
            <TextView
                textAppearance="@style/TextAppearance.Text.12SP"
                layout_gravity="0x800013"
                id="@+id/tv_divider"
                layout_width="-2"
                android:layout_height="wrap_content"
                text=" / "
                layout_toStartOf="@+id/stv_rate"/>
            <com.okinc.uilab.view.OKSortTextView
                textSize="12sp"
                textColor="@color/okTradeG400"
                id="@+id/stv_rate"
                clickable="true"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_datas_bot_theader_spread"
                layout_alignParentEnd="true"
                NOT_FOUND_0x1b="0"
                style="@style/OkSortBar"/>
        </RelativeLayout>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/rcv_arbitrage"
        layout_width="-1"
        android:layout_height="match_parent"
        overScrollMode="2"/>
</LinearLayout>
