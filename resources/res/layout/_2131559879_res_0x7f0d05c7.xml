<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content"
    baselineAligned="false">
    <LinearLayout
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/tv_membership_label"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_orbit_creatorcenter_title_membership_change"
            style="@style/Label_2_Regular"/>
        <LinearLayout
            gravity="0x50"
            orientation="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp">
            <TextView
                textColor="@color/ContentSecondary"
                id="@+id/tv_membership_value"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/Title_2_Medium"/>
            <TextView
                id="@+id/tv_membership_change"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="6dp"
                style="@style/Label_3_Regular"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <TextView
            textColor="@color/ContentContrast"
            id="@+id/tv_messages_label"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="@string/pr_orbit_creatorcenter_title_messages"
            style="@style/Label_2_Regular"/>
        <LinearLayout
            gravity="0x50"
            orientation="0"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp">
            <TextView
                textColor="@color/ContentSecondary"
                id="@+id/tv_messages_value"
                layout_width="-2"
                android:layout_height="wrap_content"
                style="@style/Title_2_Medium"/>
            <TextView
                id="@+id/tv_messages_change"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="6dp"
                style="@style/Label_3_Regular"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
