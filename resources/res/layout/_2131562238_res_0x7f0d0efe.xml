<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="20dp"
    paddingBottom="20dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <View
        id="@+id/header"
        layout_width="0dp"
        android:layout_height="38dp"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <View
        id="@+id/row2_left"
        layout_width="0dp"
        android:layout_height="38dp"
        layout_marginTop="16dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0xd="@+id/row2_right"
        NOT_FOUND_0xf="1"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/header"/>
    <View
        id="@+id/row2_right"
        layout_width="0dp"
        android:layout_height="38dp"
        layout_marginTop="16dp"
        layout_marginStart="16dp"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="1"
        NOT_FOUND_0x10="@+id/row2_left"
        NOT_FOUND_0x12="@+id/header"/>
    <View
        id="@+id/row3_left"
        layout_width="0dp"
        android:layout_height="32dp"
        layout_marginTop="12dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0xd="@+id/row3_right"
        NOT_FOUND_0xf="1"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/row2_left"/>
    <View
        id="@+id/row3_right"
        layout_width="0dp"
        android:layout_height="32dp"
        layout_marginTop="12dp"
        layout_marginStart="16dp"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="1"
        NOT_FOUND_0x10="@+id/row3_left"
        NOT_FOUND_0x12="@+id/row2_right"/>
    <View
        id="@+id/row4_left"
        layout_width="0dp"
        android:layout_height="32dp"
        layout_marginTop="12dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0xd="@+id/row4_right"
        NOT_FOUND_0xf="1"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/row3_left"/>
    <View
        id="@+id/row4_right"
        layout_width="0dp"
        android:layout_height="32dp"
        layout_marginTop="12dp"
        layout_marginStart="16dp"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="1"
        NOT_FOUND_0x10="@+id/row4_left"
        NOT_FOUND_0x12="@+id/row3_right"/>
    <View
        id="@+id/btn1"
        tag="skeleton_radius_18"
        layout_width="0dp"
        android:layout_height="32dp"
        layout_marginTop="16dp"
        layout_marginEnd="8dp"
        NOT_FOUND_0xd="@+id/btn2"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/row4_left"/>
    <View
        id="@+id/btn2"
        tag="skeleton_radius_18"
        layout_width="0dp"
        android:layout_height="32dp"
        layout_marginLeft="8dp"
        layout_marginTop="16dp"
        layout_marginRight="8dp"
        layout_marginHorizontal="8dp"
        NOT_FOUND_0xd="@+id/btn3"
        NOT_FOUND_0x10="@+id/btn1"
        NOT_FOUND_0x12="@+id/row4_left"/>
    <View
        id="@+id/btn3"
        tag="skeleton_radius_18"
        layout_width="0dp"
        android:layout_height="32dp"
        layout_marginTop="16dp"
        layout_marginStart="8dp"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0x10="@+id/btn2"
        NOT_FOUND_0x12="@+id/row4_right"/>
</androidx.constraintlayout.widget.ConstraintLayout>
