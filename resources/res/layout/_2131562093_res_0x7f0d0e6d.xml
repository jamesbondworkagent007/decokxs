<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/planet_bottomsheet_x_data_0"
    paddingTop="24dp"
    paddingBottom="48dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/followingCell"
        layout_width="0dp"
        android:layout_height="wrap_content"
        minHeight="56dp"
        paddingStart="12dp"
        paddingEnd="12dp"
        layout_marginStart="24dp"
        layout_marginEnd="12dp"
        NOT_FOUND_0x11="@+id/followersCell"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0">
        <TextView
            textAppearance="@style/Label_1_Medium"
            textColor="@color/ContentSecondary"
            id="@+id/followingCountText"
            tag="binding_1"
            layout_width="-2"
            android:layout_height="wrap_content"
            includeFontPadding="false"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0"/>
        <TextView
            textAppearance="@style/Label_2_Regular"
            textColor="@color/ContentTertiary"
            id="@+id/followingLabelText"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="@string/pr_orbit_profile_cell_desc_following_x"
            includeFontPadding="false"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="@+id/followingCountText"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/followersCell"
        layout_width="0dp"
        android:layout_height="wrap_content"
        minHeight="56dp"
        paddingStart="12dp"
        paddingEnd="12dp"
        layout_marginStart="12dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@+id/followingCell"
        NOT_FOUND_0x15="0">
        <TextView
            textAppearance="@style/Label_1_Medium"
            textColor="@color/ContentSecondary"
            id="@+id/followersCountText"
            tag="binding_2"
            layout_width="-2"
            android:layout_height="wrap_content"
            includeFontPadding="false"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0"/>
        <TextView
            textAppearance="@style/Label_2_Regular"
            textColor="@color/ContentTertiary"
            id="@+id/followersLabelText"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            text="@string/pr_orbit_profile_cell_desc_followers_x"
            includeFontPadding="false"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x14="@+id/followersCountText"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
