<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/item_card"
        background="@drawable/_2131231399_res_0x7f0802a7"
        paddingLeft="@dimen/xsm"
        paddingTop="@dimen/sm"
        paddingRight="@dimen/xsm"
        paddingBottom="@dimen/sm"
        layout_width="-2"
        android:layout_height="match_parent"
        elevation="@dimen/xxxxsm"
        paddingHorizontal="@dimen/xsm"
        paddingVertical="@dimen/sm"
        clipToOutline="true">
        <ImageView
            id="@+id/iv_calendar"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/width_16dp"
            scaleType="fitStart"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1e="0"/>
        <TextView
            ellipsize="3"
            id="@+id/tv_label"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_supportcenter_landing_label_scheduled_call"
            maxLines="1"
            layout_marginStart="@dimen/xxxxsm"
            NOT_FOUND_0x17="@+id/iv_calendar"
            NOT_FOUND_0x1a="@+id/tv_badge"
            NOT_FOUND_0x1b="@+id/iv_calendar"
            NOT_FOUND_0x1e="@+id/iv_calendar"
            style="@style/Label_3_Regular"/>
        <o.C55251xgS
            id="@+id/tv_badge"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1e="0"
            NOT_FOUND_0x22="-5"/>
        <TextView
            ellipsize="3"
            id="@+id/tv_title"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/xxsm"
            maxLines="2"
            NOT_FOUND_0x18="@+id/tv_datetime"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/iv_calendar"
            style="@style/Title_2_Medium"/>
        <com.google.android.material.textview.MaterialTextView
            textColor="@color/color_content_static_subtle"
            ellipsize="3"
            id="@+id/tv_datetime"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="4dp"
            layout_marginBottom="8dp"
            maxLines="3"
            NOT_FOUND_0x18="@+id/content_bottom_barrier"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/tv_title"
            style="@style/Body_3_Regular"/>
        <androidx.constraintlayout.widget.Barrier
            id="@+id/content_bottom_barrier"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x14="false"
            NOT_FOUND_0x15="3"
            NOT_FOUND_0x16="tv_datetime"/>
        <o.C52794wYp
            id="@+id/btn_join"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="16dp"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x19="0"
            NOT_FOUND_0x1c="0"
            NOT_FOUND_0x1d="@+id/content_bottom_barrier"
            NOT_FOUND_0x1f="1"
            NOT_FOUND_0x20="36"
            NOT_FOUND_0x21="0x103"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
