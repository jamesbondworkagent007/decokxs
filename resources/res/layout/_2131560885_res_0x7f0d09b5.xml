<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="12dp"
    paddingBottom="12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="12dp">
    <o.wYK
        id="@+id/check_box"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="-5"/>
    <ImageView
        id="@+id/image"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginStart="12dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x14="@+id/check_box"
        NOT_FOUND_0x17="0"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/token"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="12dp"
        layout_marginEnd="24dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@+id/barrier"
        NOT_FOUND_0x14="@+id/image"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x18="30dp"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/barrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xd="5"
        NOT_FOUND_0xe="amount,currency"/>
    <TextView
        textAppearance="@style/Label_1_Medium"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="@+id/token"
        NOT_FOUND_0x17="0"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/currency"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="1"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="1"
        NOT_FOUND_0x14="@+id/token"
        NOT_FOUND_0x16="@+id/amount"/>
</androidx.constraintlayout.widget.ConstraintLayout>
