<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="16dp"
    paddingEnd="16dp">
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP.Regular"
        textColor="@color/text_light"
        id="@+id/key"
        layout_width="-2"
        android:layout_height="wrap_content"
        includeFontPadding="false"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="16sp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/text_amplified"
        id="@+id/value"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        includeFontPadding="false"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/key"
        NOT_FOUND_0x13="240dp"
        NOT_FOUND_0x14="20sp"/>
    <ImageView
        id="@+id/action_icon"
        layout_width="24dp"
        android:layout_height="24dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x12="@+id/value"
        NOT_FOUND_0x15="@drawable/_2131231720_res_0x7f0803e8"
        NOT_FOUND_0x16="@color/text_amplified"/>
    <androidx.constraintlayout.helper.widget.Flow
        id="@+id/chips"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        NOT_FOUND_0xb="0"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xd="4dp"
        NOT_FOUND_0xe="2"
        NOT_FOUND_0xf="@+id/value"
        NOT_FOUND_0x10="@+id/value"
        NOT_FOUND_0x11="@+id/value"/>
</androidx.constraintlayout.widget.ConstraintLayout>
