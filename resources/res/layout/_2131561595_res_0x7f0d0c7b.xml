<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/llm_order_fragment_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginLeft="@dimen/margin_default"
    layout_marginTop="16dp"
    layout_marginRight="@dimen/margin_default"
    layout_marginHorizontal="@dimen/margin_default">
    <TextView
        textColor="@color/ContentPrimary"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_aitradingbot_placeorder_title_ai_model"
        style="@style/Label_2_Medium"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        id="@+id/aiContainer"
        background="@drawable/_2131230992_res_0x7f080110"
        paddingLeft="12dp"
        paddingTop="14dp"
        paddingRight="12dp"
        paddingBottom="14dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        paddingHorizontal="12dp"
        paddingVertical="14dp">
        <com.google.android.material.imageview.ShapeableImageView
            id="@+id/aiIv"
            padding="0.5dp"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231512_res_0x7f080318"
            NOT_FOUND_0x1f="@style/circleStyle"
            NOT_FOUND_0x20="@color/color_border_static_default"
            NOT_FOUND_0x21="1dp"/>
        <TextView
            textColor="@color/ContentPrimary"
            id="@+id/aiNameTv"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="8dp"
            layout_marginEnd="20dp"
            style="@style/TextAppearance.Text.14SP.Medium"/>
        <ImageView
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131231588_res_0x7f080364"
            contentDescription="@null"
            NOT_FOUND_0x22="@color/ContentTertiary"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp">
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_demotrade_dropdown_transaction_type"
            layout_weight="1"
            layout_marginEnd="16dp"
            style="@style/Label_2_Medium"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            gravity="0x11"
            id="@+id/newCryptoContainer"
            layout_width="-2"
            android:layout_height="wrap_content">
            <ImageView
                layout_width="16dp"
                android:layout_height="16dp"
                src="@drawable/_2131233688_res_0x7f080b98"
                layout_marginEnd="4dp"/>
            <TextView
                textColor="@color/ContentPrimary"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_trade_recurbot_detail_tunbibao_add_new_coin"
                style="@style/Label_2_Medium"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        id="@+id/instOptionContainer"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp">
        <TextView
            id="@+id/spotInstTv"
            background="@drawable/_2131233755_res_0x7f080bdb"
            paddingLeft="8dp"
            paddingTop="5dp"
            paddingRight="8dp"
            paddingBottom="5dp"
            layout_width="-2"
            android:layout_height="match_parent"
            text="@string/pr_market_tab_colheader_spot"
            drawablePadding="2dp"
            backgroundTint="@color/SurfacePrimary"
            paddingHorizontal="8dp"
            paddingVertical="5dp"
            style="@style/TextAppearance.Text.12SP.Medium"/>
        <TextView
            id="@+id/swapInstTv"
            background="@drawable/_2131233755_res_0x7f080bdb"
            paddingLeft="8dp"
            paddingTop="5dp"
            paddingRight="8dp"
            paddingBottom="5dp"
            visibility="2"
            layout_width="-2"
            android:layout_height="match_parent"
            text="@string/pr_market_tab_colheader_contracts"
            drawablePadding="2dp"
            layout_marginStart="8dp"
            backgroundTint="@color/SurfacePrimary"
            paddingHorizontal="8dp"
            paddingVertical="5dp"
            style="@style/TextAppearance.Text.12SP.Medium"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/cryptoRv"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        overScrollMode="2"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x11"
        id="@+id/editSignalContainer"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp">
        <TextView
            textColor="@color/ContentPrimary"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="@string/pr_aitradingbot_placeorder_title_market_signals"
            layout_weight="1"
            style="@style/Label_2_Medium"/>
        <ImageView
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131232049_res_0x7f080531"
            contentDescription="@null"
            layout_marginStart="2dp"
            NOT_FOUND_0x22="@color/ContentContrast"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        background="@drawable/_2131230992_res_0x7f080110"
        paddingLeft="10dp"
        paddingTop="16dp"
        paddingRight="10dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        paddingHorizontal="10dp"
        paddingVertical="16dp">
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_aitradingbot_placeorder_title_ai_thinking_interval"
                layout_weight="1"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentSecondary"
                ellipsize="3"
                gravity="0x800005"
                id="@+id/intervalTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_trade_spotgrid_title_not_set"
                maxLines="3"
                layout_weight="1"
                style="@style/Label_2_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_dcabot_placeorder_rsichart_chart_timeframe"
                layout_weight="1"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentSecondary"
                ellipsize="3"
                gravity="0x800005"
                id="@+id/timeframeTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_trade_spotgrid_title_not_set"
                maxLines="3"
                layout_weight="1"
                style="@style/Label_2_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="12dp">
            <TextView
                textColor="@color/ContentContrast"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_aitradingbot_placeorder_title_technical_indicators"
                layout_weight="1"
                style="@style/Label_2_Regular"/>
            <TextView
                textColor="@color/ContentSecondary"
                ellipsize="3"
                gravity="0x800005"
                id="@+id/indicatorTv"
                layout_width="0dp"
                android:layout_height="wrap_content"
                text="@string/pr_trade_spotgrid_title_not_set"
                maxLines="3"
                layout_weight="1"
                style="@style/Label_2_Regular"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        textColor="@color/ContentPrimary"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="24dp"
        text="@string/pr_aitradingbot_placeorder_title_define_strategy"
        style="@style/Label_2_Medium"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x11"
        id="@+id/aiPromptContainer"
        background="@drawable/_2131230992_res_0x7f080110"
        paddingLeft="10dp"
        paddingTop="16dp"
        paddingRight="10dp"
        paddingBottom="16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="8dp"
        paddingHorizontal="10dp"
        paddingVertical="16dp">
        <ImageView
            layout_width="18dp"
            android:layout_height="18dp"
            src="@drawable/_2131230898_res_0x7f0800b2"
            contentDescription="@null"
            NOT_FOUND_0x22="@color/SurfaceBrand"/>
        <TextView
            ellipsize="3"
            id="@+id/aiPromptTv"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="2"
            layout_weight="1"
            layout_marginStart="8dp"
            layout_marginEnd="16dp"
            style="@style/Body_4"/>
        <ImageView
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131231649_res_0x7f0803a1"
            contentDescription="@null"
            NOT_FOUND_0x22="@color/grey_g400"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
