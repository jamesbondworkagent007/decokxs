<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/dp_10">
    <View
        id="@+id/view_icon"
        background="@drawable/_2131232958_res_0x7f0808be"
        layout_width="6dp"
        android:layout_height="6dp"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/grey_g700"
        id="@+id/tv_title"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/dp_6"
        layout_marginRight="@dimen/dp_6"
        maxLines="2"
        layout_marginHorizontal="@dimen/dp_6"/>
    <RelativeLayout
        layout_width="0dp"
        android:layout_height="@dimen/dp_16"
        layout_weight="1">
        <o.C35139npg
            id="@+id/percent"
            layout_width="-1"
            android:layout_height="match_parent"/>
        <TextView
            textSize="@dimen/text_size_12sp"
            ellipsize="3"
            gravity="0x10"
            id="@+id/tv_vol"
            layout_width="-2"
            android:layout_height="match_parent"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
