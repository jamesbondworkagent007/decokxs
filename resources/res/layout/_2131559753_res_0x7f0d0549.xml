<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131231494_res_0x7f080306"
    paddingLeft="8dp"
    paddingRight="8dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <RelativeLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="30dp">
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_close"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231675_res_0x7f0803bb"
            layout_centerVertical="true"
            layout_alignParentStart="true"
            NOT_FOUND_0x1c="@color/white"/>
        <androidx.appcompat.widget.AppCompatImageView
            id="@+id/iv_copy"
            layout_width="20dp"
            android:layout_height="20dp"
            src="@drawable/_2131231720_res_0x7f0803e8"
            layout_centerVertical="true"
            layout_alignParentEnd="true"
            NOT_FOUND_0x1c="@color/white"/>
        <TextView
            textColor="@color/white"
            id="@+id/tv_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="Recent Requests"
            layout_centerInParent="true"/>
        <TextView
            textColor="@color/white"
            id="@+id/tv_count_title"
            visibility="1"
            layout_width="-2"
            android:layout_height="wrap_content"
            text="Recent Requests"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <com.okinc.core.widget.OKSlidingTabLayout
        id="@+id/float_tab"
        layout_width="-1"
        android:layout_height="26dp"
        NOT_FOUND_0x1d="@color/primary_blue_color"
        NOT_FOUND_0x1e="2dp"
        NOT_FOUND_0x1f="true"
        NOT_FOUND_0x20="false"
        NOT_FOUND_0x21="true"
        NOT_FOUND_0x22="@color/white"
        NOT_FOUND_0x23="@color/text_color"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        android:layout_height="30dp">
        <RelativeLayout
            gravity="0x10"
            id="@+id/http_parent"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_centerVertical="true">
                <TextView
                    textColor="@color/white"
                    id="@+id/http_type_filter"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="http过滤:"/>
                <LinearLayout
                    gravity="0x10"
                    orientation="1"
                    id="@+id/http_click"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="10sp"
                        textStyle="0x1"
                        textColor="@color/white"
                        textColorHint="@color/text_color"
                        gravity="0x11"
                        id="@+id/tv_http_filter"
                        layout_width="-2"
                        android:layout_height="0dp"
                        layout_marginTop="2dp"
                        layout_marginBottom="2dp"
                        hint="Http请求过滤"
                        lines="1"
                        layout_weight="1"
                        layout_marginStart="5dp"
                        layout_marginEnd="60dp"/>
                    <View
                        background="@color/okTradeBlue700"
                        layout_width="-1"
                        android:layout_height="1dp"
                        layout_marginStart="5dp"
                        layout_marginEnd="60dp"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                textColor="@color/okTradeBlue700"
                gravity="0x11"
                id="@+id/http_clear"
                background="@drawable/_2131232247_res_0x7f0805f7"
                layout_width="50dp"
                android:layout_height="wrap_content"
                text="清除"
                layout_centerVertical="true"
                layout_alignParentEnd="true"/>
        </RelativeLayout>
        <RelativeLayout
            gravity="0x10"
            id="@+id/ws_parent"
            visibility="2"
            layout_width="-1"
            android:layout_height="wrap_content">
            <LinearLayout
                gravity="0x10"
                orientation="0"
                layout_width="-1"
                android:layout_height="wrap_content"
                layout_centerVertical="true">
                <TextView
                    textColor="@color/white"
                    id="@+id/ws_type_filter"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="ws过滤:"/>
                <LinearLayout
                    gravity="0x10"
                    orientation="1"
                    id="@+id/ws_click"
                    layout_width="-1"
                    android:layout_height="wrap_content">
                    <TextView
                        textSize="10sp"
                        textStyle="0x1"
                        textColor="@color/white"
                        textColorHint="@color/text_color"
                        gravity="0x11"
                        id="@+id/tv_ws_tab"
                        layout_width="-2"
                        android:layout_height="0dp"
                        layout_marginTop="2dp"
                        layout_marginBottom="2dp"
                        hint="ws信息过滤"
                        lines="1"
                        layout_weight="1"
                        layout_marginStart="5dp"
                        layout_marginEnd="60dp"/>
                    <View
                        background="@color/okTradeBlue700"
                        layout_width="-1"
                        android:layout_height="1dp"
                        layout_marginStart="5dp"
                        layout_marginEnd="60dp"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                textColor="@color/okTradeBlue700"
                gravity="0x11"
                id="@+id/ws_clear"
                background="@drawable/_2131232247_res_0x7f0805f7"
                layout_width="50dp"
                android:layout_height="wrap_content"
                text="清除"
                layout_centerVertical="true"
                layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="200dp">
        <androidx.viewpager.widget.ViewPager
            id="@+id/float_vp"
            layout_width="-1"
            android:layout_height="match_parent"
            overScrollMode="2"/>
    </LinearLayout>
    <RelativeLayout
        layout_width="-1"
        android:layout_height="wrap_content">
        <ImageView
            id="@+id/iv_zoom"
            layout_width="30dp"
            android:layout_height="30dp"
            src="@drawable/_2131231656_res_0x7f0803a8"
            tint="@color/white"
            layout_centerVertical="true"
            layout_alignParentStart="true"/>
        <ImageView
            layout_width="30dp"
            android:layout_height="30dp"
            src="@drawable/_2131232291_res_0x7f080623"
            tint="@color/white"
            layout_centerInParent="true"/>
        <ImageView
            id="@+id/iv_delete"
            layout_width="30dp"
            android:layout_height="30dp"
            src="@drawable/_2131234234_res_0x7f080dba"
            tint="@color/white"
            layout_centerVertical="true"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
