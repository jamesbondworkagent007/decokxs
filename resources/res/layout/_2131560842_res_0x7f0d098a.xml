<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="@dimen/padding_16dp"
    clipChildren="false"
    clipToPadding="false"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp"
    paddingVertical="@dimen/padding_16dp">
    <ImageView
        id="@+id/iv_img"
        layout_width="32dp"
        android:layout_height="32dp"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"/>
    <com.google.android.material.imageview.ShapeableImageView
        id="@+id/iv_network_logo"
        visibility="2"
        layout_width="16dp"
        android:layout_height="16dp"
        layout_marginBottom="-1dp"
        layout_marginEnd="-1dp"
        translationZ="1dp"
        NOT_FOUND_0x16="@+id/iv_img"
        NOT_FOUND_0x18="@+id/iv_img"
        NOT_FOUND_0x1f="@style/CircleStyle"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800003"
        id="@+id/tv_name"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        layout_marginStart="12dp"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x19="@+id/tv_total_value"
        NOT_FOUND_0x1a="@+id/iv_img"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="2"
        style="@style/TextAppearance.Medium"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_detail_name"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        NOT_FOUND_0x1b="@+id/tv_name"
        NOT_FOUND_0x1c="@+id/tv_name"
        NOT_FOUND_0x1e="2"
        style="@style/TextAppearance.Regular"/>
    <TextView
        textSize="@dimen/text_size_16sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_total_value"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x17="@+id/tv_total_sub_value"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="2"
        style="@style/TextAppearance.Title.16SP.Medium"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/ContentContrast"
        id="@+id/tv_total_sub_value"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1c="@+id/tv_total_value"
        NOT_FOUND_0x1e="2"
        style="@style/TextAppearance.Regular"/>
</androidx.constraintlayout.widget.ConstraintLayout>
