<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/BasePrimary"
    layout_width="-1"
    android:layout_height="match_parent">
    <com.okinc.uilab.reminder.OKReminder
        id="@+id/liqReminder"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginRight="24dp"
        layout_marginHorizontal="24dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        id="@+id/cl_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginLeft="24dp"
        layout_marginRight="24dp"
        layout_marginHorizontal="24dp">
        <TextView
            textAppearance="@style/TextAppearance.Text.16SP.Medium"
            textSize="@dimen/text_size_16sp"
            textColor="@color/ContentPrimary"
            ellipsize="3"
            id="@+id/tv_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            maxLines="2"
            includeFontPadding="false"
            NOT_FOUND_0x13="@color/okTradeG300"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x19="0"/>
        <o.C55372xih
            id="@+id/tag_label_layout"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_marginTop="1dp"
            layout_marginStart="@dimen/margin_6dp"
            NOT_FOUND_0x14="true"
            NOT_FOUND_0x15="@+id/tv_title"
            NOT_FOUND_0x16="0"
            NOT_FOUND_0x17="@+id/tv_title"
            NOT_FOUND_0x19="@+id/tv_title"
            NOT_FOUND_0x1a="6dp"
            NOT_FOUND_0x1b="6dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/list_rcy_record"
        descendantFocusability="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        overScrollMode="2"/>
</androidx.appcompat.widget.LinearLayoutCompat>
