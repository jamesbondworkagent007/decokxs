<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_hardware_evm_network_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingStart="@dimen/common_page_edge_space"
    paddingEnd="@dimen/common_page_edge_space">
    <ImageView
        id="@+id/iv_icon"
        layout_width="32dp"
        android:layout_height="32dp"
        layout_marginTop="22dp"
        layout_marginBottom="22dp"
        layout_marginVertical="22dp"
        NOT_FOUND_0xc="0"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.16SP.Medium"
        id="@+id/tv_network"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0xc="@+id/iv_icon"
        NOT_FOUND_0xe="@+id/iv_icon"
        NOT_FOUND_0x10="@+id/iv_icon"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        gravity="0x800005"
        id="@+id/tv_amount"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0xc="@+id/iv_icon"
        NOT_FOUND_0xd="0"
        NOT_FOUND_0xe="@+id/tv_network"
        NOT_FOUND_0x10="@+id/iv_icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
