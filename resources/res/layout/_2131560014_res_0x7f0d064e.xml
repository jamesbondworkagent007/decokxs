<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    tag="layout/fragment_kline_market_deal_filter_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textSize="@dimen/text_size_16sp"
        id="@+id/coin_pair_name"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/ok_dp_16"
        text="BTC/USDC"
        layout_marginStart="@dimen/ok_dp_16"/>
    <TextView
        textColor="@color/positive"
        id="@+id/coin_latest_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="31861.40"
        layout_marginStart="@dimen/ok_dp_16"/>
    <com.okinc.uilab.edit.OKEditText
        textSize="@dimen/text_size_14sp"
        textColor="@color/okTradeG900"
        textColorHint="@color/okTradeG300"
        id="@+id/price_et"
        background="@drawable/_2131233271_res_0x7f0809f7"
        layout_width="-1"
        android:layout_height="@dimen/height_40dp"
        layout_marginTop="@dimen/ok_dp_12"
        hint="@string/pr_trade_modal_hint_min_amount"
        inputType="0x2002"
        textCursorDrawable="@drawable/_2131233288_res_0x7f080a08"
        paddingStart="@dimen/ok_dp_12"
        layout_marginStart="@dimen/ok_dp_16"
        layout_marginEnd="@dimen/ok_dp_16"/>
    <TextView
        textSize="@dimen/text_size_12sp"
        textColor="@color/critical"
        id="@+id/alert_info"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_4dp"
        layout_marginBottom="@dimen/ok_dp_16"
        text="@string/pr_trade_modal_input_enter_amount"
        layout_marginStart="@dimen/ok_dp_16"/>
</LinearLayout>
