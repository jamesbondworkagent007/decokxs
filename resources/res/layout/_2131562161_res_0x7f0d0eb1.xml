<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/Label_2_Regular"
        textColor="@color/ContentTertiary"
        id="@+id/label_text"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1"/>
    <TextView
        textAppearance="@style/Label_2_Medium"
        textColor="@color/ContentPrimary"
        id="@+id/label_content"
        layout_width="-2"
        android:layout_height="wrap_content"/>
</LinearLayout>
