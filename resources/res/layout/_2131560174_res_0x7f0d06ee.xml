<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingLeft="@dimen/margin_default"
    paddingTop="8dp"
    paddingRight="@dimen/margin_default"
    paddingBottom="24dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/margin_default">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/tv_title"
        layout_width="-1"
        android:layout_height="wrap_content"
        text="@string/pr_smartarb_placeorder_checkbox_boost_investment"
        style="@style/Title_2_Bold"/>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_content"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        text="@string/pr_smartarb_placeorder_tooltips_boost_your_investment_desc"
        style="@style/Body_3_Regular"/>
</LinearLayout>
