<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingTop="@dimen/padding_12dp"
    paddingBottom="@dimen/padding_12dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingVertical="@dimen/padding_12dp">
    <ImageView
        id="@+id/delete"
        layout_width="@dimen/width_24dp"
        android:layout_height="@dimen/height_24dp"
        src="@drawable/_2131233151_res_0x7f08097f"
        layout_marginStart="@dimen/margin_24dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@color/SemanticNegative"/>
    <TextView
        textAppearance="@style/Title_2_Bold"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/wallet_name"
        layout_width="-1"
        android:layout_height="wrap_content"
        maxLines="1"
        layout_marginStart="@dimen/margin_12dp"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x11="@+id/wallet_asset"
        NOT_FOUND_0x13="@+id/icon_detail"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="@+id/delete"
        NOT_FOUND_0x18="0"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/Label_2_Regular"
        textSize="14sp"
        textColor="@color/color_content_static_subtle"
        id="@+id/wallet_asset"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        NOT_FOUND_0xf="true"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="@+id/icon_detail"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x16="@+id/wallet_name"
        NOT_FOUND_0x17="@+id/wallet_name"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/icon_detail"
        layout_width="@dimen/width_24dp"
        android:layout_height="@dimen/height_24dp"
        src="@drawable/_2131233513_res_0x7f080ae9"
        layout_marginEnd="@dimen/margin_16dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="@+id/sort_icon"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@color/ContentPrimary"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/sort_icon"
        layout_width="@dimen/width_24dp"
        android:layout_height="@dimen/height_24dp"
        src="@drawable/_2131232291_res_0x7f080623"
        layout_marginEnd="@dimen/margin_24dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@color/ContentPrimary"/>
</androidx.constraintlayout.widget.ConstraintLayout>
