<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        textAppearance="@style/Label_3_Regular"
        ellipsize="3"
        gravity="0x800003"
        layout_gravity="0x10"
        id="@+id/tv_state"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_trade_strategy_strategy_status_end"
        maxLines="2"
        contentDescription="botStatus"/>
    <View
        id="@+id/state_divider"
        background="@color/BorderPrimary"
        visibility="2"
        layout_width="1dp"
        android:layout_height="12dp"
        layout_marginLeft="8dp"
        layout_marginTop="2dp"
        layout_marginRight="8dp"
        layout_marginBottom="2dp"
        layout_marginHorizontal="8dp"
        layout_marginVertical="2dp"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/ContentTertiary"
        id="@+id/tv_running_duration"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"/>
    <View
        id="@+id/view_divider"
        background="@color/BorderPrimary"
        visibility="2"
        layout_width="1dp"
        android:layout_height="12dp"
        layout_marginTop="2dp"
        layout_marginBottom="2dp"
        layout_marginStart="8dp"
        layout_marginEnd="4dp"
        layout_marginVertical="2dp"/>
</merge>
