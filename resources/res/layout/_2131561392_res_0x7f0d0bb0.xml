<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    orientation="0"
    background="@drawable/_2131230992_res_0x7f080110"
    paddingLeft="16dp"
    paddingRight="16dp"
    layout_width="-2"
    android:layout_height="48dp"
    minWidth="144dp"
    paddingHorizontal="16dp">
    <ImageView
        id="@+id/menu_item_icon"
        visibility="2"
        layout_width="24dp"
        android:layout_height="24dp"
        layout_marginEnd="12dp"/>
    <TextView
        textSize="16sp"
        textColor="@color/ContentPrimary"
        id="@+id/menu_item_text"
        layout_width="-2"
        android:layout_height="wrap_content"/>
</LinearLayout>
