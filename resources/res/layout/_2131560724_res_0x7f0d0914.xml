<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content"
    minHeight="60dp"
    paddingStart="@dimen/dp24"
    paddingEnd="@dimen/dp24">
    <TextView
        textAppearance="@style/TextAppearance.Title.15SP.Medium"
        id="@+id/strike"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxWidth="@dimen/width_80dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        layout_width="-1"
        android:layout_height="match_parent"
        layout_marginStart="86dp"
        layout_marginEnd="100dp"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0">
        <FrameLayout
            layout_width="@dimen/width_0dp"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x14="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0.48">
            <TextView
                textAppearance="@style/TextAppearance.Title.15SP.Medium"
                ellipsize="3"
                id="@+id/type"
                layout_width="-2"
                android:layout_height="wrap_content"
                maxLines="2"
                NOT_FOUND_0xf="@dimen/sp_15"
                NOT_FOUND_0x10="@dimen/text_size_10sp"
                NOT_FOUND_0x11="1"/>
        </FrameLayout>
        <TextView
            textAppearance="@style/TextAppearance.Title.15SP.Medium"
            gravity="0x800005"
            id="@+id/price"
            layout_width="0dp"
            android:layout_height="wrap_content"
            maxLines="1"
            NOT_FOUND_0xf="@dimen/sp_15"
            NOT_FOUND_0x10="8sp"
            NOT_FOUND_0x11="1"
            NOT_FOUND_0x12="0"
            NOT_FOUND_0x13="0"
            NOT_FOUND_0x15="0"
            NOT_FOUND_0x16="0.48"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Title.14SP.Medium"
        textSize="14sp"
        textColor="@color/okTradeW900"
        ellipsize="3"
        gravity="0x11"
        id="@+id/change"
        layout_width="80dp"
        android:layout_height="32dp"
        maxLines="1"
        NOT_FOUND_0xf="@dimen/sp_14"
        NOT_FOUND_0x10="@dimen/sp_12"
        NOT_FOUND_0x11="1"
        NOT_FOUND_0x12="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x15="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
