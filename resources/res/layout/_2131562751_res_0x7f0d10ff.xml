<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    background="@drawable/_2131231413_res_0x7f0802b5"
    paddingLeft="12dp"
    paddingTop="16dp"
    paddingRight="12dp"
    paddingBottom="16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    rowCount="2"
    columnCount="3"
    useDefaultMargins="true"
    paddingHorizontal="12dp"
    paddingVertical="16dp">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_columnWeight="4">
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_3_Regular"
            textColor="@color/ContentContrast"
            id="@+id/tv_avg_arbitrage_title"
            layout_width="-1"
            android:layout_height="match_parent"
            text="@string/pr_smartarb_placeorder_tips_daily_arbitrage"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_1_Bold"
            textColor="@color/ContentPrimary"
            id="@+id/tv_avg_arbitrage_content"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginTop="2dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_columnWeight="4">
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_3_Regular"
            textColor="@color/ContentContrast"
            id="@+id/tv_execution_title"
            layout_width="-1"
            android:layout_height="match_parent"
            text="idoasndaksndkanddnksndlakdnlandsakdnalkdsndlaksdnl"
            layout_columnWeight="3"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_1_Bold"
            textColor="@color/ContentPrimary"
            id="@+id/tv_avg_execution_content"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginTop="2dp"
            layout_columnWeight="3"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_columnWeight="4">
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_3_Regular"
            textColor="@color/ContentContrast"
            gravity="0x800005"
            id="@+id/tv_arbitrage_count_title"
            layout_width="-1"
            android:layout_height="match_parent"
            text="@string/pr_trade_strategy_item_arbitrage_time"
            layout_columnWeight="3"/>
        <androidx.appcompat.widget.AppCompatTextView
            textAppearance="@style/Label_1_Bold"
            textColor="@color/ContentPrimary"
            gravity="0x800005"
            id="@+id/tv_arbitrage_count_content"
            layout_width="-1"
            android:layout_height="match_parent"
            layout_marginTop="2dp"
            layout_columnWeight="3"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</GridLayout>
