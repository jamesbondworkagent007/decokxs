<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/container"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textSize="14sp"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        id="@+id/initialTitle"
        layout_width="0dp"
        android:layout_height="wrap_content"
        lineHeight="18sp"
        NOT_FOUND_0x10="@+id/countBarrier"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Title.14SP"
        textSize="14sp"
        textColor="@color/ContentPrimary"
        id="@+id/votedTitle"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_trade_feed_title_survey_result"
        lineHeight="18sp"
        NOT_FOUND_0x10="@+id/countBarrier"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/countBarrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xd="5"
        NOT_FOUND_0xe="jointCount"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.12SP"
        textSize="12sp"
        textColor="@color/ContentContrast"
        id="@+id/jointCount"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="1dp"
        paddingStart="12dp"
        paddingEnd="0dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x13="0"/>
    <androidx.constraintlayout.widget.Barrier
        id="@+id/titleBarrier"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0xd="3"
        NOT_FOUND_0xe="initialTitle, votedTitle, jointCount"/>
    <o.tUZ
        id="@+id/voteView"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="12dp"
        NOT_FOUND_0x12="@+id/titleBarrier"/>
</androidx.constraintlayout.widget.ConstraintLayout>
