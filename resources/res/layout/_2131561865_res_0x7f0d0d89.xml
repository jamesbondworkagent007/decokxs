<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatTextView
        gravity="0x10"
        id="@+id/tv_name"
        paddingTop="2dp"
        paddingBottom="2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="2"
        includeFontPadding="false"
        paddingVertical="2dp"
        NOT_FOUND_0xf="@+id/tv_desc"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="2"
        NOT_FOUND_0x15="18dp"
        style="@style/TextAppearance.Title.15SP.Medium"/>
    <androidx.appcompat.widget.AppCompatTextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_desc"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="2dp"
        maxLines="1"
        includeFontPadding="false"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x11="@+id/tv_name"
        NOT_FOUND_0x12="@+id/tv_name"
        style="@style/Label_3_Regular"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="15sp"
        textColor="@color/okTradeG900"
        gravity="0x800015"
        layout_gravity="0x800015"
        id="@+id/tv_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        includeFontPadding="false"
        NOT_FOUND_0xf="@+id/tv_sub_price"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="2"
        style="@style/TextAppearance.Title.15SP.Medium"/>
    <androidx.appcompat.widget.AppCompatTextView
        layout_gravity="0x800005"
        id="@+id/tv_sub_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="4dp"
        maxLines="1"
        includeFontPadding="false"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@+id/tv_price"
        style="@style/TextAppearance.Text.12SP.Regular"/>
</merge>
