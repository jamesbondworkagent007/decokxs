<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-2"
    android:layout_height="wrap_content">
    <CheckBox
        id="@+id/test_checkbox_android_button_tint"
        background="?android:attr/colorBackground"
        layout_width="-2"
        android:layout_height="wrap_content"
        buttonTint="@color/checkbox_themeable_attribute_color"/>
    <CheckBox
        id="@+id/test_checkbox_app_button_tint"
        background="?android:attr/colorBackground"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x5="@color/checkbox_themeable_attribute_color"/>
</LinearLayout>
