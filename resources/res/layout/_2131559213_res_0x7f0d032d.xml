<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    paddingLeft="16dp"
    paddingTop="14dp"
    paddingRight="16dp"
    layout_width="-1"
    android:layout_height="74dp"
    paddingHorizontal="16dp">
    <FrameLayout
        layout_width="36dp"
        android:layout_height="match_parent"
        layout_alignParentStart="true">
        <View
            background="@drawable/_2131231870_res_0x7f08047e"
            layout_width="-2"
            android:layout_height="match_parent"/>
        <ImageView
            layout_gravity="0x1"
            id="@+id/arrow_start_down"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            layout_marginTop="38dp"
            src="@drawable/_2131231865_res_0x7f080479"
            scaleType="7"/>
        <o.C24484ieh
            id="@+id/exchange_from_coin"
            layout_width="36dp"
            android:layout_height="36dp"/>
    </FrameLayout>
    <FrameLayout
        layout_width="36dp"
        android:layout_height="match_parent"
        layout_alignParentEnd="true">
        <View
            background="@drawable/_2131231870_res_0x7f08047e"
            layout_width="-2"
            android:layout_height="match_parent"/>
        <ImageView
            layout_gravity="0x1"
            id="@+id/arrow_start_up"
            layout_width="@dimen/width_16dp"
            android:layout_height="@dimen/height_16dp"
            layout_marginTop="38dp"
            src="@drawable/_2131231866_res_0x7f08047a"
            scaleType="7"/>
        <o.C24484ieh
            id="@+id/exchange_to_coin"
            layout_width="36dp"
            android:layout_height="36dp"/>
    </FrameLayout>
</RelativeLayout>
