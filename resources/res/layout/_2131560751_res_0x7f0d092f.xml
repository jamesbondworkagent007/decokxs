<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/item_my_wallet_major_0"
    background="@drawable/_2131233990_res_0x7f080cc6"
    padding="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="@dimen/padding_8dp"
    layout_marginBottom="@dimen/padding_8dp"
    layout_marginStart="@dimen/padding_16dp"
    layout_marginEnd="@dimen/padding_16dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/wallet_icon"
        layout_width="@dimen/padding_24dp"
        android:layout_height="@dimen/padding_24dp"
        NOT_FOUND_0x1b="0"
        NOT_FOUND_0x1d="0"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.Medium"
        textSize="@dimen/text_size_15sp"
        textColor="@color/ContentPrimary"
        id="@+id/wallet_name"
        tag="binding_1"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/padding_8dp"
        NOT_FOUND_0x1a="@+id/wallet_icon"
        NOT_FOUND_0x1d="0"/>
    <TextView
        textAppearance="@style/Label_4_Medium"
        textColor="@color/trade_tab_text_uncolor"
        id="@+id/wallet_state"
        tag="binding_2"
        background="@drawable/_2131231474_res_0x7f0802f2"
        paddingTop="@dimen/padding_2dp"
        paddingBottom="@dimen/padding_2dp"
        layout_width="-2"
        android:layout_height="wrap_content"
        paddingStart="@dimen/dp_4"
        paddingEnd="@dimen/dp_4"
        layout_marginStart="@dimen/padding_8dp"
        NOT_FOUND_0x16="@+id/wallet_name"
        NOT_FOUND_0x1a="@+id/wallet_name"
        NOT_FOUND_0x1d="@+id/wallet_name"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/okTradeDividerGray"
        id="@+id/total_value_hint"
        tag="binding_3"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_20dp"
        NOT_FOUND_0x1b="@+id/wallet_icon"
        NOT_FOUND_0x1c="@+id/wallet_icon"/>
    <TextView
        textAppearance="@style/Label_1_Bold"
        textColor="@color/ContentPrimary"
        id="@+id/total_value"
        tag="binding_4"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_2dp"
        NOT_FOUND_0x1b="@+id/wallet_icon"
        NOT_FOUND_0x1c="@+id/total_value_hint"/>
    <TextView
        textAppearance="@style/Label_3_Regular"
        textColor="@color/okTradeDividerGray"
        id="@+id/wallet_type"
        tag="binding_5"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/padding_2dp"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x1d="@+id/total_value_hint"/>
    <androidx.constraintlayout.widget.Guideline
        orientation="1"
        id="@+id/guide_line"
        layout_width="-2"
        android:layout_height="wrap_content"
        NOT_FOUND_0x18="0.344"/>
    <TextView
        textAppearance="@style/Label_3_Medium"
        textColor="@color/ContentPrimary"
        ellipsize="2"
        gravity="0x800005"
        id="@+id/first_trade_number"
        tag="binding_6"
        layout_width="0dp"
        android:layout_height="wrap_content"
        singleLine="true"
        NOT_FOUND_0x15="@+id/total_value"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1e="0.4"/>
</androidx.constraintlayout.widget.ConstraintLayout>
