<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="layout/view_doh_input_0"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginTop="15dp"
    layout_marginStart="10dp"
    layout_marginEnd="10dp">
    <EditText
        textAppearance="@style/TextAppearance.Title.18SP"
        id="@+id/et_domain"
        background="@null"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="40dp"
        hint="domain"/>
    <View
        background="@color/list_divider_color"
        layout_width="-1"
        android:layout_height="1dp"/>
    <EditText
        textAppearance="@style/TextAppearance.Title.18SP"
        id="@+id/et_ip"
        background="@null"
        layout_width="-1"
        android:layout_height="wrap_content"
        minHeight="40dp"
        hint="ip"/>
    <View
        background="@color/list_divider_color"
        layout_width="-1"
        android:layout_height="1dp"/>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="20dp">
        <Button
            textSize="13dp"
            id="@+id/btn_cancel"
            background="@drawable/_2131231165_res_0x7f0801bd"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="取消(Cancel)"
            layout_weight="1"
            style="@style/Button.Borderless"/>
        <Button
            textSize="13dp"
            id="@+id/btn_confirm"
            layout_width="0dp"
            android:layout_height="wrap_content"
            text="完成(Finish)"
            layout_weight="1"
            layout_marginStart="5dp"
            style="@style/Button.Primary"/>
    </LinearLayout>
</LinearLayout>
