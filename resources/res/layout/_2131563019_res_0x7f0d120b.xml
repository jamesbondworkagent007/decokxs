<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        textColor="@color/text_light"
        gravity="0x10"
        id="@+id/rewarding_address"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginTop="16dp"
        layout_marginBottom="8dp"
        text="@string/pr_investdetails_mid_toast_rewarding_address"
        drawablePadding="4dp"
        layout_marginStart="16dp"
        NOT_FOUND_0x13="@color/text_light"
        NOT_FOUND_0x15="@+id/address"
        NOT_FOUND_0x17="@+id/status"
        NOT_FOUND_0x18="1"
        NOT_FOUND_0x1a="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"
        NOT_FOUND_0x1e="2"
        NOT_FOUND_0x1f="-2"
        NOT_FOUND_0x20="32dp"
        NOT_FOUND_0x21="20sp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP.Medium"
        textColor="@color/Warning"
        id="@+id/status"
        layout_width="0dp"
        android:layout_height="wrap_content"
        text="@string/pr_investdetails_mid_toast_pending"
        drawablePadding="4dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0x12="@drawable/_2131232353_res_0x7f080661"
        NOT_FOUND_0x13="@color/text_amplified"
        NOT_FOUND_0x14="@+id/rewarding_address"
        NOT_FOUND_0x16="0"
        NOT_FOUND_0x19="@+id/rewarding_address"
        NOT_FOUND_0x1c="@+id/rewarding_address"
        NOT_FOUND_0x1f="-2"
        NOT_FOUND_0x21="20sp"/>
    <TextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/text_amplified"
        id="@+id/address"
        background="@drawable/_2131233965_res_0x7f080cad"
        paddingTop="12dp"
        paddingBottom="12dp"
        visibility="2"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="16dp"
        paddingStart="12dp"
        paddingEnd="12dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x1b="@+id/rewarding_address"/>
</merge>
