<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    orientation="0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        id="@+id/feed_header"
        visibility="2"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <ImageView
            layout_gravity="0x11"
            id="@+id/okxLogo"
            layout_width="-2"
            android:layout_height="wrap_content"
            src="@drawable/_2131232783_res_0x7f08080f"
            contentDescription="@null"/>
        <TextView
            textAppearance="@style/Title_1_Bold"
            textColor="@color/ContentPrimary_Dark"
            id="@+id/planet_title"
            layout_width="-1"
            android:layout_height="wrap_content"
            text="@string/pr_trade_sharingcard_header_okx_planet"
            layout_marginStart="12dp"
            layout_marginEnd="12dp"/>
    </LinearLayout>
    <FrameLayout
        orientation="0"
        id="@+id/userLy"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_weight="1">
        <LinearLayout
            orientation="0"
            id="@+id/user_head"
            paddingTop="6dp"
            paddingBottom="6dp"
            layout_width="-2"
            android:layout_height="wrap_content"
            paddingStart="6dp"
            paddingEnd="12dp"
            paddingVertical="6dp">
            <ImageView
                layout_gravity="0x11"
                id="@+id/avatar"
                layout_width="28dp"
                android:layout_height="28dp"
                contentDescription="@null"/>
            <LinearLayout
                layout_gravity="0x11"
                orientation="1"
                id="@+id/tvContainer"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginStart="6dp">
                <LinearLayout
                    orientation="0"
                    layout_width="-2"
                    android:layout_height="wrap_content">
                    <TextView
                        textAppearance="@style/Label_1_Regular"
                        textColor="@color/ContentPrimary_Dark"
                        ellipsize="3"
                        id="@+id/tvUsername"
                        layout_width="0dp"
                        android:layout_height="wrap_content"
                        maxWidth="138dp"
                        maxLines="1"
                        layout_weight="1"
                        layout_marginEnd="6dp"/>
                    <View
                        layout_gravity="0x11"
                        id="@+id/tvMiddleDividerView"
                        background="#616161"
                        layout_width="0.5dp"
                        android:layout_height="12dp"
                        layout_marginEnd="6dp"/>
                    <TextView
                        textAppearance="@style/Label_2_Medium"
                        textColor="@color/ContentPrimary_Dark"
                        id="@+id/tvVip"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        text="@string/pr_trade_vip_label_vip"/>
                </LinearLayout>
                <TextView
                    textAppearance="@style/Label_2_Regular"
                    textColor="@color/ContentContrast"
                    id="@+id/tvRole"
                    visibility="2"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    maxLines="1"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
    <TextView
        textAppearance="@style/Label_4_Regular"
        textColor="@color/ContentContrast"
        id="@+id/tvTimestamp"
        layout_width="0dp"
        android:layout_height="wrap_content"
        maxLines="2"
        layout_weight="0.35"
        textAlignment="3"/>
</LinearLayout>
