<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x30"
    layout_width="-1"
    android:layout_height="wrap_content"
    layout_marginBottom="@dimen/margin_8dp">
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.12SP.Medium"
        textColor="@color/ContentContrast"
        id="@+id/tv_content"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_toStartOf="@+id/img_panel"
        layout_alignParentStart="true"/>
    <FrameLayout
        id="@+id/img_panel"
        layout_width="40dp"
        android:layout_height="wrap_content"
        layout_alignParentEnd="true">
        <androidx.appcompat.widget.AppCompatImageView
            layout_gravity="0x800035"
            id="@+id/img_tag"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131233620_res_0x7f080b54"
            tint="@color/ContentContrast"
            layout_marginStart="@dimen/margin_8dp"/>
    </FrameLayout>
</RelativeLayout>
