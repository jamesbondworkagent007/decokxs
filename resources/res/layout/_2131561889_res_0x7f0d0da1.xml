<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/ll_mark"
    background="@drawable/_2131231402_res_0x7f0802aa"
    paddingLeft="4dp"
    paddingTop="2dp"
    paddingRight="4dp"
    paddingBottom="2dp"
    layout_width="-2"
    android:layout_height="wrap_content"
    paddingHorizontal="4dp"
    paddingVertical="2dp">
    <TextView
        textSize="12sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_time"
        layout_width="-2"
        android:layout_height="wrap_content"
        style="@style/TextAppearance"/>
    <TextView
        textSize="12sp"
        textColor="@color/ContentPrimary"
        id="@+id/tv_ratio"
        layout_width="-2"
        android:layout_height="wrap_content"
        style="@style/TextAppearance"/>
</LinearLayout>
