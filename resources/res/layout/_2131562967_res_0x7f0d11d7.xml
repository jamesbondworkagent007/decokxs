<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    tag="layout/widget_available_balance_layout_0"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentContrast"
        ellipsize="3"
        id="@+id/tv_available_amount"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="1"
        includeFontPadding="false"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"
        style="@style/Label_1_Medium"/>
    <TextView
        textColor="@color/brand_feature_1"
        id="@+id/tv_add_founds"
        paddingLeft="@dimen/padding_8dp"
        paddingTop="@dimen/padding_8dp"
        paddingRight="@dimen/padding_8dp"
        paddingBottom="@dimen/padding_8dp"
        focusable="true"
        clickable="true"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_invest_defi_v2_place_common_link_add_funds"
        includeFontPadding="false"
        paddingHorizontal="@dimen/padding_8dp"
        paddingVertical="@dimen/padding_8dp"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/tv_available_amount"
        NOT_FOUND_0x14="0"
        style="@style/Label_1_Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
