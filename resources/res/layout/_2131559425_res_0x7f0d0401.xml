<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/parent_container"
    background="@drawable/_2131231895_res_0x7f080497"
    paddingLeft="@dimen/xxsm"
    paddingTop="8dp"
    paddingRight="@dimen/xxsm"
    paddingBottom="8dp"
    layout_width="-2"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/xxsm"
    paddingVertical="8dp">
    <ImageView
        layout_gravity="0x11"
        id="@+id/anim_fire"
        layout_width="20dp"
        android:layout_height="20dp"
        scaleType="fillCenter"
        adjustViewBounds="true"
        layout_centerInParent="true"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="0"
        NOT_FOUND_0x14="0"/>
    <TextView
        textColor="@color/BrandPrimaryAlternative"
        id="@+id/tv_multiplier"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginStart="@dimen/xxxxsm"
        NOT_FOUND_0x10="@+id/anim_fire"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x12="@+id/anim_fire"
        NOT_FOUND_0x14="@+id/anim_fire"
        style="@style/Title_1_Bold"/>
</androidx.constraintlayout.widget.ConstraintLayout>
