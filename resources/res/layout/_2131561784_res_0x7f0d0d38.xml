<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x10"
    layout_gravity="0x10"
    orientation="0"
    id="@+id/item_root_layout"
    paddingLeft="@dimen/dp24"
    paddingRight="@dimen/dp24"
    clipChildren="false"
    layout_width="-1"
    android:layout_height="@dimen/width_60dp"
    foreground="?attr/selectableItemBackground"
    baselineAligned="true"
    elevation="0dp"
    paddingHorizontal="@dimen/dp24">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/iv_icon"
        layout_width="@dimen/margin_28dp"
        android:layout_height="@dimen/margin_28dp"
        scaleType="6"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1c="0"
        NOT_FOUND_0x1d="0"/>
    <o.C42989rgn
        id="@+id/crypto_layout"
        clipChildren="false"
        layout_width="0dp"
        android:layout_height="wrap_content"
        layout_marginLeft="@dimen/margin_12dp"
        layout_marginRight="@dimen/margin_12dp"
        layout_marginHorizontal="@dimen/margin_12dp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x1a="@+id/tv_change_percent"
        NOT_FOUND_0x1b="@+id/iv_icon"
        NOT_FOUND_0x1d="0"/>
    <o.C55071xcy
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tv_change_percent"
        layout_width="80dp"
        android:layout_height="32dp"
        maxLines="1"
        layout_marginStart="12dp"
        autoSizeTextType="uniform"
        autoSizeStepGranularity="1sp"
        autoSizeMinTextSize="9sp"
        autoSizeMaxTextSize="14sp"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="0"
        NOT_FOUND_0x1d="0"
        style="@style/TextAppearance.Text.14SP.Medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
