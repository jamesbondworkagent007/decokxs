<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content">
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tv_streams_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_orbit_creatorcenter_title_streams"
                style="@style/Label_2_Regular"/>
            <LinearLayout
                gravity="0x50"
                orientation="0"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp">
                <TextView
                    textColor="@color/ContentSecondary"
                    id="@+id/tv_streams_value"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Title_2_Medium"/>
                <TextView
                    id="@+id/tv_streams_change"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="6dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tv_views_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_orbit_creatorcenter_title_views"
                style="@style/Label_2_Regular"/>
            <LinearLayout
                gravity="0x50"
                orientation="0"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp">
                <TextView
                    textColor="@color/ContentSecondary"
                    id="@+id/tv_views_value"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Title_2_Medium"/>
                <TextView
                    id="@+id/tv_views_change"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="6dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="16dp">
        <LinearLayout
            orientation="1"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1">
            <TextView
                textColor="@color/ContentContrast"
                id="@+id/tv_shares_label"
                layout_width="-2"
                android:layout_height="wrap_content"
                text="@string/pr_orbit_creatorcenter_title_shares"
                style="@style/Label_2_Regular"/>
            <LinearLayout
                gravity="0x50"
                orientation="0"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="4dp">
                <TextView
                    textColor="@color/ContentSecondary"
                    id="@+id/tv_shares_value"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    style="@style/Title_2_Medium"/>
                <TextView
                    id="@+id/tv_shares_change"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginStart="6dp"
                    style="@style/Label_3_Regular"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
