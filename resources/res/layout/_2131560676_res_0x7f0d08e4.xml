<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    padding="@dimen/padding_16dp"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textAppearance="@style/TextAppearance.Text.16SP"
        textColor="@color/okTradeG400"
        ellipsize="3"
        id="@+id/tvTitle"
        layout_width="-2"
        android:layout_height="wrap_content"
        text="@string/pr_investorderdetails_mid_text_remaining_repayment"
        maxLines="1"
        layout_marginEnd="@dimen/margin_12dp"
        NOT_FOUND_0xf="0"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="0"/>
    <TextView
        textAppearance="@style/Body_2"
        textColor="@color/ContentPrimary"
        id="@+id/tvValueBelow"
        visibility="2"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x11="@+id/tvTitle"/>
    <TextView
        textAppearance="@style/Body_2"
        textColor="@color/ContentPrimary"
        ellipsize="3"
        gravity="0x800005"
        id="@+id/tvValue"
        layout_width="-2"
        android:layout_height="wrap_content"
        maxLines="2"
        lineSpacingExtra="@dimen/margin_8dp"
        NOT_FOUND_0xe="0"
        NOT_FOUND_0xf="1"
        NOT_FOUND_0x12="0"/>
</androidx.constraintlayout.widget.ConstraintLayout>
