<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    paddingLeft="@dimen/padding_24dp"
    paddingTop="@dimen/padding_16dp"
    paddingRight="@dimen/padding_24dp"
    paddingBottom="48dp"
    layout_width="-1"
    android:layout_height="wrap_content"
    paddingHorizontal="@dimen/padding_24dp">
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/candle_up"
        layout_width="-2"
        android:layout_height="96dp"
        src="@drawable/_2131233256_res_0x7f0809e8"
        NOT_FOUND_0x11="0"
        NOT_FOUND_0x13="0"/>
    <androidx.appcompat.widget.AppCompatImageView
        layout_gravity="0x11"
        id="@+id/candle_down"
        layout_width="-2"
        android:layout_height="96dp"
        src="@drawable/_2131233254_res_0x7f0809e6"
        NOT_FOUND_0xf="@+id/candle_up"
        NOT_FOUND_0x11="@+id/candle_up"
        NOT_FOUND_0x13="@+id/candle_up"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/order_buy"
        layout_width="-2"
        android:layout_height="96dp"
        src="@drawable/_2131233253_res_0x7f0809e5"
        NOT_FOUND_0x11="@+id/candle_up"
        NOT_FOUND_0x13="@+id/candle_up"/>
    <androidx.appcompat.widget.AppCompatImageView
        id="@+id/order_sell"
        layout_width="-2"
        android:layout_height="96dp"
        src="@drawable/_2131233255_res_0x7f0809e7"
        NOT_FOUND_0x11="@+id/candle_up"
        NOT_FOUND_0x13="@+id/candle_up"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_10sp"
        textColor="@color/ContentTertiary"
        id="@+id/top_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_10dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x13="@+id/candle_up"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_10sp"
        textColor="@color/ContentTertiary"
        id="@+id/middle_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@+id/top_price"/>
    <androidx.appcompat.widget.AppCompatTextView
        textSize="@dimen/text_size_10sp"
        textColor="@color/ContentTertiary"
        id="@+id/bottom_price"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        NOT_FOUND_0x10="0"
        NOT_FOUND_0x12="@+id/middle_price"/>
    <androidx.appcompat.widget.AppCompatTextView
        textAppearance="@style/TextAppearance.Text.14SP.Regular"
        textColor="@color/ContentTertiary"
        id="@+id/historical_desc"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_16dp"
        text="@string/pr_options_function_notif_executed_orders"
        NOT_FOUND_0x12="@+id/candle_up"/>
</androidx.constraintlayout.widget.ConstraintLayout>
