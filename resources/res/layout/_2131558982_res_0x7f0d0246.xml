<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        paddingLeft="@dimen/padding_32dp"
        paddingRight="@dimen/padding_32dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        paddingHorizontal="@dimen/padding_32dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/vg_swap_content"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/grey_g900"
                ellipsize="3"
                gravity="0x10"
                layout_gravity="0x10"
                id="@+id/mev_protect_main_title"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_marginTop="17dp"
                text="@string/pr_swaptrade_transfer_maintitle_mev_protect"
                maxLines="1"
                NOT_FOUND_0x14="28sp"
                NOT_FOUND_0x15="24sp"
                NOT_FOUND_0x16="2sp"
                NOT_FOUND_0x17="1"
                NOT_FOUND_0x19="@+id/image"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1c="0"
                style="@style/TextAppearance.Text.Bold.28SP"/>
            <androidx.appcompat.widget.AppCompatTextView
                textColor="@color/grey_g900"
                id="@+id/tv_mev_status_for_tx"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="@dimen/margin_12dp"
                layout_marginBottom="17dp"
                text="@string/pr_swaptrade_transfer_text_disabled"
                NOT_FOUND_0x1a="0"
                NOT_FOUND_0x1b="@+id/mev_protect_main_title"
                style="@style/TextAppearance.Text.Bold.16SP"/>
            <ImageView
                id="@+id/image"
                layout_width="-2"
                android:layout_height="wrap_content"
                src="@drawable/_2131232706_res_0x7f0807c2"
                scaleType="7"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1c="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            id="@+id/transactionSwapDivider"
            background="@color/line_light"
            layout_width="-1"
            android:layout_height="0.5dp"
            layout_marginTop="@dimen/margin_24dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/grey_g900"
            id="@+id/tv_mev_nodes_list_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_24dp"
            text="@string/pr_swaptrade_transfer_title_mev_provider"
            layout_below="@+id/tv_mev"
            style="@style/TextAppearance.Text.Bold.16SP"/>
        <androidx.recyclerview.widget.RecyclerView
            id="@+id/rv_mev_nodes_list"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_8dp"
            nestedScrollingEnabled="false"/>
        <View
            id="@+id/transactionSwapDivider2"
            background="@color/line_light"
            layout_width="-1"
            android:layout_height="0.5dp"
            layout_marginTop="@dimen/margin_24dp"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/grey_g900"
            id="@+id/tv_mev_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_24dp"
            text="@string/pr_wallet_mev_title_mev_meaning"
            layout_below="@+id/tv_mev"
            style="@style/TextAppearance.Text.Bold.16SP"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/grey_g500"
            id="@+id/tv_mev_content"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_4"
            text="@string/pr_wallet_mev_desc_mev_meaning"
            layout_below="@+id/tv_mev"
            style="@style/TextAppearance.Text.14SP.Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/grey_g900"
            id="@+id/tv_mev_sub_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_24dp"
            text="@string/pr_wallet_mev_title_mev_avoid"
            layout_below="@+id/tv_mev"
            style="@style/TextAppearance.Text.Bold.16SP"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/grey_g500"
            id="@+id/tv_mev_sub_content"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_4"
            text="@string/pr_wallet_mev_desc_mev_avoid"
            layout_below="@+id/tv_mev"
            style="@style/TextAppearance.Text.14SP.Regular"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/grey_g900"
            id="@+id/tv_mev_why_attach_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/margin_24dp"
            text="@string/pr_wallet_mev_title_why_attack"
            layout_below="@+id/tv_mev"
            style="@style/TextAppearance.Text.Bold.16SP"/>
        <androidx.appcompat.widget.AppCompatTextView
            textColor="@color/grey_g500"
            id="@+id/tv_mev_why_attack_content"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginTop="@dimen/dp_4"
            text="@string/pr_wallet_mev_desc_why_attack"
            layout_below="@+id/tv_mev"
            style="@style/TextAppearance.Text.14SP.Regular"/>
        <View
            layout_width="-1"
            android:layout_height="@dimen/height_40dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
