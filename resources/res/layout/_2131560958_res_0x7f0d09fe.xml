<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    focusable="true"
    clickable="true"
    layout_width="-1"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        layout_width="-1"
        android:layout_height="wrap_content"
        NOT_FOUND_0x11="@android:color/transparent"
        NOT_FOUND_0x12="12dp"
        NOT_FOUND_0x13="0dp"
        NOT_FOUND_0x14="0"
        NOT_FOUND_0x15="0"
        NOT_FOUND_0x17="0"
        NOT_FOUND_0x19="0">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_width="-1"
            android:layout_height="wrap_content">
            <ImageView
                id="@+id/backgroundImage"
                layout_width="0dp"
                android:layout_height="0dp"
                src="@drawable/_2131231373_res_0x7f08028d"
                scaleType="6"
                contentDescription="@null"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="0"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                id="@+id/contentContainer"
                paddingTop="16dp"
                paddingBottom="16dp"
                layout_width="0dp"
                android:layout_height="wrap_content"
                paddingStart="16dp"
                layout_marginEnd="28dp"
                paddingVertical="16dp"
                NOT_FOUND_0x16="@+id/chevronIcon"
                NOT_FOUND_0x17="0"
                NOT_FOUND_0x19="0">
                <TextView
                    textAppearance="@style/Label_1_Medium"
                    textColor="@color/ContentPrimary"
                    id="@+id/titleText"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    NOT_FOUND_0x15="0"
                    NOT_FOUND_0x17="0"
                    NOT_FOUND_0x19="0"/>
                <TextView
                    textAppearance="@style/Label_2_Regular"
                    textSize="14sp"
                    textColor="@color/ContentTertiary"
                    id="@+id/descriptionText"
                    layout_width="0dp"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp"
                    NOT_FOUND_0x15="0"
                    NOT_FOUND_0x17="0"
                    NOT_FOUND_0x18="@+id/titleText"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <ImageView
                id="@+id/chevronIcon"
                layout_width="24dp"
                android:layout_height="24dp"
                src="@drawable/_2131231648_res_0x7f0803a0"
                layout_marginEnd="12dp"
                NOT_FOUND_0x14="0"
                NOT_FOUND_0x15="0"
                NOT_FOUND_0x19="0"
                NOT_FOUND_0x1a="@color/ContentContrast"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
