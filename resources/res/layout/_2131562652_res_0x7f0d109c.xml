<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/color_surface_structural_base"
    layout_width="-1"
    android:layout_height="match_parent">
    <View
        id="@+id/topLine"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="1dp"
        layout_alignParentTop="true"/>
    <LinearLayout
        orientation="0"
        id="@+id/contentGroup"
        padding="16dp"
        layout_width="-1"
        android:layout_height="150dp"
        baselineAligned="false"
        layout_below="@+id/topLine">
        <androidx.constraintlayout.widget.ConstraintLayout
            layout_gravity="0x10"
            layout_width="0dp"
            android:layout_height="match_parent"
            layout_weight="1"
            layout_marginEnd="20dp">
            <TextView
                textAppearance="@style/Label_3_Regular"
                textSize="12sp"
                textColor="@color/color_content_static_subtle"
                id="@+id/title"
                layout_width="-2"
                android:layout_height="wrap_content"
                lineHeight="16dp"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x1a="0"/>
            <TextView
                textAppearance="@style/OKTextFont.Medium"
                textSize="14sp"
                textColor="@color/color_content_static_default"
                ellipsize="3"
                id="@+id/content"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="8dp"
                maxLines="3"
                lineHeight="22dp"
                NOT_FOUND_0x18="0"
                NOT_FOUND_0x19="@+id/title"/>
            <TextView
                textAppearance="@style/Label_3_Bold"
                textSize="12sp"
                textColor="@color/ContentPrimary"
                id="@+id/button"
                layout_width="-2"
                android:layout_height="wrap_content"
                layout_marginTop="16dp"
                drawablePadding="4dp"
                NOT_FOUND_0x14="@drawable/_2131233695_res_0x7f080b9f"
                NOT_FOUND_0x16="0"
                NOT_FOUND_0x18="0"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <ImageView
            layout_gravity="0x10"
            id="@+id/imageView"
            layout_width="88dp"
            android:layout_height="88dp"
            NOT_FOUND_0x15="true"
            NOT_FOUND_0x17="0"
            NOT_FOUND_0x18="0"
            NOT_FOUND_0x1a="0"/>
    </LinearLayout>
    <View
        id="@+id/bottomLine"
        background="@color/BorderPrimary"
        layout_width="-1"
        android:layout_height="1dp"
        layout_marginTop="8dp"
        layout_below="@+id/contentGroup"/>
</RelativeLayout>
