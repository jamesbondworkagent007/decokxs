<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        gravity="0x10"
        orientation="0"
        id="@+id/total_pnl_container"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="4dp">
        <o.C55258xgZ
            textColor="@color/ContentContrast"
            id="@+id/tv_unrealized_pnl_title"
            layout_width="-2"
            android:layout_height="wrap_content"
            NOT_FOUND_0x12="2"
            NOT_FOUND_0x14="@dimen/text_size_14sp"
            NOT_FOUND_0x15="@string/pr_swaptrade_common_unrealized_pnl"
            NOT_FOUND_0x16="@style/Label_2_Regular"
            NOT_FOUND_0x17="400"
            NOT_FOUND_0x19="0"/>
        <TextView
            id="@+id/tv_unrealized_pnl"
            layout_width="-2"
            android:layout_height="wrap_content"
            layout_marginStart="@dimen/xxxxsm"
            style="@style/Label_2_Regular"/>
        <o.wYC
            layout_gravity="0x11"
            id="@+id/icon_pnl_toggle"
            layout_width="16dp"
            android:layout_height="16dp"
            src="@drawable/_2131231588_res_0x7f080364"
            layout_marginStart="@dimen/xxxxsm"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <TextView
        textColor="@color/ContentContrast"
        id="@+id/tv_limit_order_assets"
        layout_width="-2"
        android:layout_height="wrap_content"
        layout_marginTop="7dp"
        text="@string/pr_swaptrade_limit_order_textarea_limit_asset"
        style="@style/Body_3_Regular"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        orientation="1"
        id="@+id/pnl_details_container"
        paddingTop="@dimen/margin_default"
        layout_width="-1"
        android:layout_height="wrap_content"
        animateLayoutChanges="true">
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="1"
                id="@+id/container_total_pnl"
                background="@drawable/_2131231797_res_0x7f080435"
                padding="12dp"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="0.5">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tv_total_pnl_title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_market_title_tpnl_roi"
                    style="@style/Label_3_Regular"/>
                <TextView
                    id="@+id/tv_total_pnl_amount"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp"
                    style="@style/Label_2_Medium"/>
                <TextView
                    id="@+id/tv_total_pnl_percentage"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    style="@style/Label_3_Regular"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <View
                layout_width="8dp"
                android:layout_height="match_parent"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="1"
                id="@+id/container_realized"
                background="@drawable/_2131231797_res_0x7f080435"
                padding="12dp"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="0.5">
                <TextView
                    textColor="@color/ContentContrast"
                    id="@+id/tv_realized_pnl_title"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_common_realized_pnl_short"
                    style="@style/Label_3_Regular"/>
                <TextView
                    textColor="@color/ContentPrimary"
                    id="@+id/tv_realized_pnl_amount"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="4dp"
                    style="@style/Label_2_Medium"/>
                <TextView
                    id="@+id/tv_realized_pnl_percentage"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp"
                    style="@style/Label_3_Regular"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            orientation="0"
            layout_width="-1"
            android:layout_height="wrap_content"
            layout_marginTop="8dp">
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="1"
                id="@+id/container_const_sell"
                background="@drawable/_2131231797_res_0x7f080435"
                padding="12dp"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="0.5">
                <o.C55258xgZ
                    id="@+id/tv_avg_cost_sell"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_token_detail_item_avg_cost_sell"
                    NOT_FOUND_0x12="1"
                    NOT_FOUND_0x13="@color/ContentContrast"
                    NOT_FOUND_0x16="@style/TextAppearance.Text.12SP.Regular"
                    NOT_FOUND_0x18="@color/BorderSecondary"
                    NOT_FOUND_0x19="0"
                    style="@style/TextAppearance.Text.12SP.Regular"/>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="6dp">
                    <TextView
                        textColor="?attr/tradeRiseDefault"
                        gravity="0x11"
                        background="@drawable/_2131231813_res_0x7f080445"
                        layout_width="@dimen/xsm"
                        android:layout_height="@dimen/xsm"
                        text="@string/pr_swaptrade_token_detail_label_buy"
                        maxLines="1"
                        layout_marginEnd="@dimen/xxxxsm"
                        style="@style/Label_3_Medium"/>
                    <TextView
                        textColor="@color/ContentPrimary"
                        id="@+id/tv_avg_bought"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        style="@style/Label_3_Medium"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp">
                    <TextView
                        textColor="?attr/tradeFallDefault"
                        gravity="0x11"
                        background="@drawable/_2131231809_res_0x7f080441"
                        layout_width="@dimen/xsm"
                        android:layout_height="@dimen/xsm"
                        text="@string/pr_swaptrade_token_detail_label_sell"
                        maxLines="1"
                        layout_marginEnd="@dimen/xxxxsm"
                        style="@style/Label_3_Medium"/>
                    <TextView
                        textColor="@color/ContentPrimary"
                        id="@+id/tv_avg_sold"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        style="@style/Label_3_Medium"/>
                </LinearLayout>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <View
                layout_width="8dp"
                android:layout_height="match_parent"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                gravity="0x10"
                orientation="1"
                id="@+id/container_bought_sold"
                background="@drawable/_2131231797_res_0x7f080435"
                padding="12dp"
                layout_width="0dp"
                android:layout_height="wrap_content"
                layout_weight="0.5">
                <o.C55258xgZ
                    id="@+id/tv_bought_sold"
                    layout_width="-2"
                    android:layout_height="wrap_content"
                    text="@string/pr_swaptrade_common_value_bought_sold"
                    NOT_FOUND_0x12="1"
                    NOT_FOUND_0x13="@color/ContentContrast"
                    NOT_FOUND_0x16="@style/TextAppearance.Text.12SP.Regular"
                    NOT_FOUND_0x18="@color/BorderSecondary"
                    NOT_FOUND_0x19="0"
                    style="@style/TextAppearance.Text.12SP.Regular"/>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="6dp">
                    <TextView
                        textColor="?attr/tradeRiseDefault"
                        gravity="0x11"
                        background="@drawable/_2131231813_res_0x7f080445"
                        layout_width="@dimen/xsm"
                        android:layout_height="@dimen/xsm"
                        text="@string/pr_swaptrade_token_detail_label_buy"
                        maxLines="1"
                        layout_marginEnd="@dimen/xxxxsm"
                        style="@style/Label_3_Medium"/>
                    <TextView
                        textColor="@color/ContentPrimary"
                        id="@+id/tv_total_bought"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        style="@style/Label_3_Medium"/>
                </LinearLayout>
                <LinearLayout
                    orientation="0"
                    layout_width="-1"
                    android:layout_height="wrap_content"
                    layout_marginTop="2dp">
                    <TextView
                        textColor="?attr/tradeFallDefault"
                        gravity="0x11"
                        background="@drawable/_2131231809_res_0x7f080441"
                        layout_width="@dimen/xsm"
                        android:layout_height="@dimen/xsm"
                        text="@string/pr_swaptrade_token_detail_label_sell"
                        maxLines="1"
                        layout_marginEnd="@dimen/xxxxsm"
                        style="@style/Label_3_Medium"/>
                    <TextView
                        textColor="@color/ContentPrimary"
                        id="@+id/tv_total_sold_amount"
                        layout_width="-2"
                        android:layout_height="wrap_content"
                        style="@style/Label_3_Medium"/>
                </LinearLayout>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
