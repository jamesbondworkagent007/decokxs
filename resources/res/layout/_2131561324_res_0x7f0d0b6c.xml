        paddingRight="@dimen/padding_16dp"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginTop="@dimen/margin_12dp"
        paddingHorizontal="@dimen/padding_16dp"/>
    <o.C27228jrI
        id="@+id/univ3_redeem_input_dualcoin_view"
