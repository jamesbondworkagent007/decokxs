<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    background="#fff"
    layout_width="-1"
    android:layout_height="match_parent">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        android:layout_height="match_parent">
        <TextView
            textSize="24sp"
            textColor="#000000"
            gravity="0x11"
            layout_gravity="0x1"
            layout_width="-2"
            android:layout_height="44dp"
            text="@string/pr_safemode_home_title_safe_mode"/>
        <TextView
            textSize="14sp"
            textColor="#000000"
            id="@+id/tv_content"
            padding="5dp"
            visibility="0"
            scrollbars="0x200"
            layout_width="-1"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <Button
        textColor="@color/safe_mode_btn_color_selector"
        layout_gravity="0x50"
        background="@drawable/_2131233825_res_0x7f080c21"
        focusable="true"
        clickable="true"
        layout_width="-1"
        android:layout_height="52dp"
        layout_marginLeft="16dp"
        layout_marginTop="12dp"
        layout_marginRight="16dp"
        layout_marginBottom="20dp"
        text="@string/pr_safemode_home_btn_export_log"
        onClick="exportLog"/>
</FrameLayout>
