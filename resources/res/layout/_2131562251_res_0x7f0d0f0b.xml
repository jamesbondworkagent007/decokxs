<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    android:layout_height="wrap_content">
    <TextView
        textColor="@color/ContentPrimary"
        id="@+id/titleTv"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="12dp"
        style="@style/Label_2_Medium"/>
    <LinearLayout
        layout_width="-1"
        android:layout_height="wrap_content"
        baselineAligned="false">
        <o.C55372xih
            id="@+id/leftTag"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            NOT_FOUND_0x9="4dp"
            NOT_FOUND_0xa="4dp"/>
        <o.C55372xih
            id="@+id/rightTag"
            layout_width="0dp"
            android:layout_height="wrap_content"
            layout_weight="1"
            layout_marginStart="@dimen/margin_16dp"
            NOT_FOUND_0x9="4dp"
            NOT_FOUND_0xa="4dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        id="@+id/recyclerView"
        layout_width="-1"
        android:layout_height="wrap_content"
        layout_marginBottom="32dp"/>
</androidx.appcompat.widget.LinearLayoutCompat>
