<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item id="@android:id/background">
        <shape>
            <solid color="@color/ContentDisabled"/>
            <corners radius="8dp"/>
        </shape>
    </item>
    <item id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <solid color="@color/SemanticNegative"/>
                <corners radius="8dp"/>
            </shape>
        </clip>
    </item>
    <item id="@android:id/progress">
        <clip>
            <shape>
                <solid color="@color/SemanticPositive"/>
                <corners radius="8dp"/>
            </shape>
        </clip>
    </item>
</layer-list>
