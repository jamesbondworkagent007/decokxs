<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" color="?attr/colorControlHighlight">
    <item>
        <selector>
            <item state_enabled="false">
                <shape shape="0">
                    <solid color="@color/widget_disable_color"/>
                    <corners radius="@dimen/btn_default_radius"/>
                </shape>
            </item>
            <item state_pressed="true">
                <shape shape="0">
                    <solid color="@color/primary_green_color"/>
                    <corners radius="@dimen/btn_default_radius"/>
                </shape>
            </item>
            <item>
                <shape shape="0">
                    <solid color="@color/primary_green_color"/>
                    <corners radius="@dimen/btn_default_radius"/>
                </shape>
            </item>
        </selector>
    </item>
</ripple>
