<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item state_selected="false">
        <shape>
            <solid color="@color/background_lv1"/>
            <corners radius="8dp"/>
            <stroke
                width="1dp"
                color="@color/grey_g100"/>
        </shape>
    </item>
    <item state_selected="true">
        <shape>
            <solid color="@color/background_lv1"/>
            <corners radius="8dp"/>
            <stroke
                width="1dp"
                color="@color/okTradeG900"/>
        </shape>
    </item>
</selector>
