<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item state_enabled="false">
        <layer-list>
            <item>
                <shape shape="0">
                    <solid color="@color/white_background_color"/>
                    <size
                        height="40dp"
                        width="360dp"/>
                </shape>
            </item>
            <item gravity="0x50">
                <shape shape="0">
                    <solid color="@color/widget_disable_color"/>
