<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item state_pressed="false">
        <shape>
            <solid color="@color/grey_g900_blue_lv2"/>
            <corners radius="2dp"/>
        </shape>
    </item>
    <item state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid color="@color/grey_g900_blue_lv2"/>
                    <corners radius="2dp"/>
                </shape>
            </item>
            <item>
                <shape>
                    <solid color="#20000000"/>
                    <corners radius="2dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
