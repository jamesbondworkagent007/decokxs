<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" color="?attr/colorControlHighlight">
    <item>
        <selector>
            <item state_enabled="false">
                <shape shape="0">
                    <solid color="@android:color/transparent"/>
                    <corners radius="10dp"/>
                </shape>
            </item>
            <item state_pressed="true">
                <shape shape="0">
                    <solid color="@color/debugbox_widget_background_color"/>
                    <corners radius="2dp"/>
                </shape>
            </item>
            <item>
                <shape shape="0">
                    <solid color="@android:color/transparent"/>
                    <corners radius="10dp"/>
                </shape>
            </item>
        </selector>
    </item>
</ripple>
