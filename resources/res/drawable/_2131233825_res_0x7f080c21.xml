<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" color="?attr/colorControlHighlight">
    <item id="@android:id/mask">
        <shape shape="0">
            <corners radius="60dp"/>
            <solid color="@android:color/black"/>
            <stroke
                width="0.5dp"
                color="@android:color/transparent"/>
        </shape>
    </item>
    <item>
        <selector>
            <item state_enabled="false">
                <shape shape="0">
                    <corners radius="60dp"/>
                    <solid color="@android:color/black"/>
                </shape>
            </item>
            <item>
                <shape shape="0">
                    <corners radius="60dp"/>
                    <solid color="@android:color/black"/>
                </shape>
            </item>
        </selector>
    </item>
</ripple>
