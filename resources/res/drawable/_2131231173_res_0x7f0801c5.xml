<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item state_pressed="false">
        <shape>
            <solid color="@color/grey_g900_blue_lv2"/>
            <corners radius="60dp"/>
        </shape>
    </item>
    <item state_enabled="false">
        <shape shape="0">
            <solid color="@color/grey_g100"/>
            <corners radius="60dp"/>
        </shape>
    </item>
    <item state_pressed="true">
        <shape shape="0">
            <solid color="@color/grey_g900_blue_b500"/>
            <corners radius="60dp"/>
        </shape>
    </item>
</selector>
