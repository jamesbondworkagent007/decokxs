<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item state_selected="false">
        <shape>
            <corners radius="8dp"/>
            <solid color="@color/transparent"/>
        </shape>
    </item>
    <item state_selected="true">
        <shape>
            <corners radius="8dp"/>
            <stroke
                width="2dp"
                color="@color/BorderSelected"/>
            <solid color="@android:color/transparent"/>
        </shape>
    </item>
</selector>
