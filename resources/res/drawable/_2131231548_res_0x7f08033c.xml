<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" color="?attr/colorControlHighlight">
    <item>
        <selector>
            <item state_enabled="false">
                <shape shape="0">
                    <padding
                        left="8dp"
                        top="4dp"
                        right="8dp"
                        bottom="4dp"/>
                    <solid color="@color/widget_disable_color"/>
                    <corners radius="@dimen/btn_small_round_radius"/>
                </shape>
            </item>
            <item state_pressed="true">
                <shape shape="0">
                    <padding
                        left="8dp"
                        top="4dp"
                        right="8dp"
                        bottom="4dp"/>
                    <solid color="@color/light_blue_color"/>
                    <corners radius="@dimen/btn_small_round_radius"/>
                </shape>
            </item>
            <item>
                <shape shape="0">
                    <padding
                        left="8dp"
                        top="4dp"
                        right="8dp"
                        bottom="4dp"/>
                    <solid color="@color/light_blue_color"/>
                    <corners radius="@dimen/btn_small_round_radius"/>
                </shape>
            </item>
        </selector>
    </item>
</ripple>
