<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item state_pressed="true">
        <shape>
            <solid color="@color/ContainerSecondary"/>
            <corners radius="8dp"/>
        </shape>
    </item>
    <item state_selected="true">
        <shape>
            <solid color="@color/ContainerSecondary"/>
            <corners radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid color="@color/ContainerPrimary"/>
            <corners radius="8dp"/>
        </shape>
    </item>
</selector>
