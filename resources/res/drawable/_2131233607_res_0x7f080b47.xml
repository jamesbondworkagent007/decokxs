<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" color="?attr/colorControlHighlight">
    <item id="@android:id/mask">
        <shape shape="0">
            <corners radius="@dimen/oktemp_btn_default_radius"/>
            <solid color="@android:color/black"/>
            <stroke
                width="@dimen/oktemp_widget_border_width"
                color="@android:color/transparent"/>
        </shape>
    </item>
    <item>
        <selector>
            <item state_enabled="false">
                <shape shape="0">
                    <corners radius="@dimen/oktemp_btn_default_radius"/>
                    <solid color="@android:color/transparent"/>
                    <stroke
                        width="@dimen/oktemp_widget_border_width"
                        color="@color/oktemp_widget_border_color"/>
                </shape>
            </item>
            <item state_pressed="true">
                <shape shape="0">
                    <corners radius="@dimen/oktemp_btn_default_radius"/>
                    <solid color="@android:color/transparent"/>
                    <stroke
                        width="@dimen/oktemp_widget_border_width"
                        color="@color/oktemp_widget_border_color"/>
                </shape>
            </item>
            <item>
                <shape shape="0">
                    <corners radius="@dimen/oktemp_btn_default_radius"/>
                    <solid color="@android:color/transparent"/>
                    <stroke
                        width="@dimen/oktemp_widget_border_width"
                        color="@color/oktemp_widget_border_color"/>
                </shape>
            </item>
        </selector>
    </item>
</ripple>
