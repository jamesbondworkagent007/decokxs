<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item state_enabled="false">
        <shape shape="0">
            <corners radius="6dp"/>
            <solid color="@color/SurfaceDisabled"/>
        </shape>
    </item>
    <item state_focused="true">
        <shape shape="0">
            <corners radius="6dp"/>
            <solid color="@color/SurfacePrimary"/>
            <stroke
                width="1dp"
                color="@color/ContentPrimary"/>
        </shape>
    </item>
    <item>
        <shape shape="0">
            <corners radius="6dp"/>
            <solid color="@color/SurfacePrimary"/>
        </shape>
    </item>
</selector>
